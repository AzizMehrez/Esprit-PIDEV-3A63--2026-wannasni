{% extends 'admin/base_admin.html.twig' %}

{% block title %}Commandes Marketplace - Admin WANNASNI{% endblock %}
{% block page_title %}Commandes Marketplace{% endblock %}

{% block header_actions %}
<a href="{{ path('admin_nutrition_marketplace') }}" class="btn btn-outline" style="margin-right: 0.75rem;">🛍️ Produits</a>
<a href="{{ path('admin_nutrition') }}" class="btn btn-outline">🥗 Régimes</a>
{% endblock %}

{% block content %}
{# Flash Messages #}
{% for type in ['success', 'error'] %}
    {% if app.flashes(type) %}
        <div class="alert alert-{{ type }}">
            {% for message in app.flashes(type) %}{{ message }}{% endfor %}
        </div>
    {% endif %}
{% endfor %}

{# Statistics Cards #}
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon" style="background: linear-gradient(135deg, #6366f1, #818cf8);">📋</div>
        <div class="stat-info">
            <div class="stat-value">{{ total_orders }}</div>
            <div class="stat-label">Total Commandes</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background: linear-gradient(135deg, #f59e0b, #fbbf24);">⏳</div>
        <div class="stat-info">
            <div class="stat-value">{{ pending_orders }}</div>
            <div class="stat-label">En attente</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background: linear-gradient(135deg, #3b82f6, #60a5fa);">✅</div>
        <div class="stat-info">
            <div class="stat-value">{{ confirmed_orders }}</div>
            <div class="stat-label">Confirmées</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background: linear-gradient(135deg, #10b981, #34d399);">💰</div>
        <div class="stat-info">
            <div class="stat-value">{{ total_revenue|number_format(2, '.', ' ') }} DH</div>
            <div class="stat-label">Chiffre d'affaires</div>
        </div>
    </div>
</div>

{# Filters #}
<div class="admin-toolbar">
    <div class="toolbar-search">
        <form method="get" action="{{ path('admin_nutrition_marketplace_orders') }}" style="display: flex; gap: 0.5rem;">
            <input type="text" name="q" placeholder="Rechercher (n° commande, nom, email)..." value="{{ current_search }}">
            <button type="submit" class="btn btn-secondary">🔍</button>
        </form>
    </div>
    <div class="toolbar-actions">
        <div class="filter-group">
            <a href="{{ path('admin_nutrition_marketplace_orders') }}" class="filter-btn {% if not current_status %}active{% endif %}">Toutes</a>
            <a href="{{ path('admin_nutrition_marketplace_orders', {status: 'pending'}) }}" class="filter-btn {% if current_status == 'pending' %}active{% endif %}">⏳ En attente</a>
            <a href="{{ path('admin_nutrition_marketplace_orders', {status: 'confirmed'}) }}" class="filter-btn {% if current_status == 'confirmed' %}active{% endif %}">✅ Confirmées</a>
            <a href="{{ path('admin_nutrition_marketplace_orders', {status: 'shipped'}) }}" class="filter-btn {% if current_status == 'shipped' %}active{% endif %}">📦 Expédiées</a>
            <a href="{{ path('admin_nutrition_marketplace_orders', {status: 'delivered'}) }}" class="filter-btn {% if current_status == 'delivered' %}active{% endif %}">🎉 Livrées</a>
            <a href="{{ path('admin_nutrition_marketplace_orders', {status: 'cancelled'}) }}" class="filter-btn {% if current_status == 'cancelled' %}active{% endif %}">❌ Annulées</a>
        </div>
    </div>
</div>

{# Orders Table #}
<div class="admin-card">
    <div class="card-header">
        <h2 class="card-title">📦 Liste des Commandes</h2>
        <span class="badge badge-info">{{ orders|length }} commande{{ orders|length > 1 ? 's' : '' }}</span>
    </div>
    <table class="admin-table">
        <thead>
            <tr>
                <th>N° Commande</th>
                <th>Client</th>
                <th>Articles</th>
                <th>Total</th>
                <th>Statut</th>
                <th>Date</th>
                <th style="width: 100px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for order in orders %}
            <tr>
                <td>
                    <strong style="color: var(--admin-primary-light);">{{ order.orderNumber ?? '#' ~ order.id }}</strong>
                </td>
                <td>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 36px; height: 36px; border-radius: 8px; background: linear-gradient(135deg, #6366f1, #818cf8); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 0.85rem; color: white;">
                            {{ order.user.firstName|first|upper }}{{ order.user.lastName|first|upper }}
                        </div>
                        <div>
                            <div style="font-weight: 600;">{{ order.user.firstName }} {{ order.user.lastName }}</div>
                            <div style="font-size: 0.8rem; color: var(--admin-text-muted);">{{ order.user.email }}</div>
                        </div>
                    </div>
                </td>
                <td>
                    <span class="badge badge-secondary">{{ order.itemCount }} article{{ order.itemCount > 1 ? 's' : '' }}</span>
                </td>
                <td>
                    <strong>{{ order.grandTotal }} DH</strong>
                    {% if order.shippingCost > 0 %}
                        <div style="font-size: 0.75rem; color: var(--admin-text-muted);">dont {{ order.shippingCost }} DH livraison</div>
                    {% endif %}
                </td>
                <td>
                    <span class="badge" style="background: {{ order.statusColor }}20; color: {{ order.statusColor }}; border: 1px solid {{ order.statusColor }}40;">
                        {{ order.statusLabel }}
                    </span>
                </td>
                <td>
                    <div>{{ order.createdAt|date('d/m/Y') }}</div>
                    <div style="font-size: 0.8rem; color: var(--admin-text-muted);">{{ order.createdAt|date('H:i') }}</div>
                </td>
                <td>
                    <a href="{{ path('admin_nutrition_marketplace_order_show', {id: order.id}) }}" class="action-btn" title="Voir détails">👁️</a>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="7" style="text-align: center; padding: 2rem; color: var(--admin-text-muted);">
                    Aucune commande trouvée.
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<style>
.filter-group { display: flex; gap: 0.5rem; flex-wrap: wrap; }
.filter-btn {
    padding: 0.4rem 0.8rem;
    background: var(--admin-card);
    border: 1px solid var(--admin-border);
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    color: var(--admin-text-muted);
    font-size: 0.85rem;
}
.filter-btn:hover { background: var(--admin-card-hover); color: var(--admin-text); }
.filter-btn.active { background: var(--admin-primary); color: white; border-color: var(--admin-primary); }
.alert {
    padding: 1rem 1.5rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    font-weight: 500;
}
.alert-success { background: rgba(34,197,94,0.15); color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
.alert-error { background: rgba(239,68,68,0.15); color: #f87171; border: 1px solid rgba(239,68,68,0.3); }
</style>
{% endblock %}
