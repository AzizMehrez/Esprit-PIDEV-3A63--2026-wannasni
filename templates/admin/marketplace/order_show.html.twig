{% extends 'admin/base_admin.html.twig' %}

{% block title %}Commande {{ order.orderNumber ?? '#' ~ order.id }} - Admin WANNASNI{% endblock %}
{% block page_title %}Détails Commande{% endblock %}

{% block header_actions %}
<a href="{{ path('admin_nutrition_marketplace_orders') }}" class="btn btn-outline">← Retour Commandes</a>
{% endblock %}

{% block content %}
{# Flash Messages #}
{% for type in ['success', 'error'] %}
    {% if app.flashes(type) %}
        <div class="alert alert-{{ type }}">
            {% for message in app.flashes(type) %}{{ message }}{% endfor %}
        </div>
    {% endif %}
{% endfor %}

<div class="order-detail-grid">
    {# Left Column: Order Info #}
    <div class="order-main">
        {# Order Header #}
        <div class="admin-card">
            <div class="card-header">
                <h2 class="card-title">📋 Commande {{ order.orderNumber ?? '#' ~ order.id }}</h2>
                <span class="badge" style="background: {{ order.statusColor }}20; color: {{ order.statusColor }}; border: 1px solid {{ order.statusColor }}40; font-size: 0.9rem; padding: 0.4rem 0.8rem;">
                    {{ order.statusLabel }}
                </span>
            </div>

            <div class="order-timeline" style="padding: 1rem 1.5rem;">
                <div class="timeline-step {% if order.createdAt %}done{% endif %}">
                    <div class="timeline-dot"></div>
                    <div class="timeline-label">Créée</div>
                    <div class="timeline-date">{{ order.createdAt|date('d/m/Y H:i') }}</div>
                </div>
                <div class="timeline-line {% if order.confirmedAt %}done{% endif %}"></div>
                <div class="timeline-step {% if order.confirmedAt %}done{% endif %}">
                    <div class="timeline-dot"></div>
                    <div class="timeline-label">Confirmée</div>
                    <div class="timeline-date">{{ order.confirmedAt ? order.confirmedAt|date('d/m/Y H:i') : '—' }}</div>
                </div>
                <div class="timeline-line {% if order.shippedAt %}done{% endif %}"></div>
                <div class="timeline-step {% if order.shippedAt %}done{% endif %}">
                    <div class="timeline-dot"></div>
                    <div class="timeline-label">Expédiée</div>
                    <div class="timeline-date">{{ order.shippedAt ? order.shippedAt|date('d/m/Y H:i') : '—' }}</div>
                </div>
                <div class="timeline-line {% if order.deliveredAt %}done{% endif %}"></div>
                <div class="timeline-step {% if order.deliveredAt %}done{% endif %}">
                    <div class="timeline-dot"></div>
                    <div class="timeline-label">Livrée</div>
                    <div class="timeline-date">{{ order.deliveredAt ? order.deliveredAt|date('d/m/Y H:i') : '—' }}</div>
                </div>
            </div>
        </div>

        {# Order Items #}
        <div class="admin-card" style="margin-top: 1.5rem;">
            <div class="card-header">
                <h2 class="card-title">🛒 Articles ({{ order.itemCount }})</h2>
            </div>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Produit</th>
                        <th>Prix unitaire</th>
                        <th>Quantité</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in order.items %}
                    <tr>
                        <td>
                            <div style="display: flex; align-items: center; gap: 0.75rem;">
                                <div style="width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, #6366f1, #818cf8); display: flex; align-items: center; justify-content: center; font-size: 1.2rem;">
                                    {{ item.product ? item.product.categoryEmoji : '🥤' }}
                                </div>
                                <div>
                                    <div style="font-weight: 600;">{{ item.product ? item.product.name : 'Produit supprimé' }}</div>
                                    {% if item.product and item.product.volume %}
                                        <div style="font-size: 0.8rem; color: var(--admin-text-muted);">{{ item.product.volume }}</div>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        <td>{{ item.unitPrice }} DH</td>
                        <td><span class="badge badge-info">× {{ item.quantity }}</span></td>
                        <td><strong>{{ item.lineTotal }} DH</strong></td>
                    </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" style="text-align: right; font-weight: 600;">Sous-total :</td>
                        <td><strong>{{ order.totalAmount }} DH</strong></td>
                    </tr>
                    {% if order.shippingCost > 0 %}
                    <tr>
                        <td colspan="3" style="text-align: right; color: var(--admin-text-muted);">Livraison :</td>
                        <td>{{ order.shippingCost }} DH</td>
                    </tr>
                    {% endif %}
                    <tr style="font-size: 1.1rem;">
                        <td colspan="3" style="text-align: right; font-weight: 700;">Total :</td>
                        <td><strong style="color: var(--admin-primary-light);">{{ order.grandTotal }} DH</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    {# Right Column: Client + Actions #}
    <div class="order-sidebar">
        {# Client Info #}
        <div class="admin-card">
            <div class="card-header">
                <h2 class="card-title">👤 Client</h2>
            </div>
            <div style="padding: 1.25rem;">
                <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.25rem;">
                    <div style="width: 50px; height: 50px; border-radius: 12px; background: linear-gradient(135deg, #6366f1, #818cf8); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.1rem; color: white;">
                        {{ order.user.firstName|first|upper }}{{ order.user.lastName|first|upper }}
                    </div>
                    <div>
                        <div style="font-weight: 700; font-size: 1.05rem;">{{ order.user.firstName }} {{ order.user.lastName }}</div>
                        <div style="color: var(--admin-text-muted); font-size: 0.85rem;">{{ order.user.email }}</div>
                    </div>
                </div>

                {% if order.phone %}
                <div class="info-row">
                    <span class="info-label">📞 Téléphone</span>
                    <span class="info-value">{{ order.phone }}</span>
                </div>
                {% endif %}

                {% if order.shippingAddress %}
                <div class="info-row">
                    <span class="info-label">📍 Adresse</span>
                    <span class="info-value">{{ order.shippingAddress }}</span>
                </div>
                {% endif %}

                {% if order.shippingCity %}
                <div class="info-row">
                    <span class="info-label">🏙️ Ville</span>
                    <span class="info-value">{{ order.shippingCity }} {{ order.shippingPostalCode }}</span>
                </div>
                {% endif %}

                {% if order.paymentMethod %}
                <div class="info-row">
                    <span class="info-label">💳 Paiement</span>
                    <span class="info-value">{{ order.paymentMethod }}</span>
                </div>
                {% endif %}

                {% if order.notes %}
                <div class="info-row">
                    <span class="info-label">📝 Notes</span>
                    <span class="info-value">{{ order.notes }}</span>
                </div>
                {% endif %}
            </div>
        </div>

        {# Change Status #}
        {% if order.status != 'cancelled' and order.status != 'delivered' %}
        <div class="admin-card" style="margin-top: 1.25rem;">
            <div class="card-header">
                <h2 class="card-title">🔄 Changer le statut</h2>
            </div>
            <div style="padding: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem;">
                {% set next_statuses = {
                    'pending': [
                        {'value': 'confirmed', 'label': '✅ Confirmer', 'color': '#3b82f6'},
                        {'value': 'cancelled', 'label': '❌ Annuler', 'color': '#ef4444'}
                    ],
                    'confirmed': [
                        {'value': 'shipped', 'label': '📦 Marquer Expédiée', 'color': '#8b5cf6'},
                        {'value': 'cancelled', 'label': '❌ Annuler', 'color': '#ef4444'}
                    ],
                    'shipped': [
                        {'value': 'delivered', 'label': '🎉 Marquer Livrée', 'color': '#10b981'}
                    ]
                } %}

                {% for action in next_statuses[order.status] ?? [] %}
                    <form method="post" action="{{ path('admin_nutrition_marketplace_order_status', {id: order.id}) }}" {% if action.value == 'cancelled' %}onsubmit="return confirm('Êtes-vous sûr de vouloir annuler cette commande ?')"{% endif %}>
                        <input type="hidden" name="status" value="{{ action.value }}">
                        <button type="submit" class="status-btn" style="background: {{ action.color }}; width: 100%;">
                            {{ action.label }}
                        </button>
                    </form>
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>
</div>

<style>
.order-detail-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 1.5rem;
    align-items: start;
}
@media (max-width: 1000px) {
    .order-detail-grid { grid-template-columns: 1fr; }
}

.order-timeline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem;
}
.timeline-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
}
.timeline-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--admin-border);
    border: 3px solid var(--admin-card);
    transition: all 0.3s;
}
.timeline-step.done .timeline-dot {
    background: var(--admin-primary);
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.2);
}
.timeline-label { font-weight: 600; font-size: 0.8rem; }
.timeline-date { font-size: 0.7rem; color: var(--admin-text-muted); }
.timeline-line {
    flex: 1;
    height: 3px;
    background: var(--admin-border);
    margin: 0 0.5rem;
    margin-bottom: 2.5rem;
}
.timeline-line.done { background: var(--admin-primary); }

.info-row {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--admin-border);
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 0.8rem; color: var(--admin-text-muted); }
.info-value { font-weight: 500; font-size: 0.9rem; }

.status-btn {
    display: block;
    padding: 0.7rem 1rem;
    border: none;
    border-radius: var(--admin-radius-sm);
    color: white;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
}
.status-btn:hover { opacity: 0.85; transform: translateY(-1px); }

.alert { padding: 1rem 1.5rem; border-radius: 8px; margin-bottom: 1.5rem; font-weight: 500; }
.alert-success { background: rgba(34,197,94,0.15); color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
</style>
{% endblock %}
