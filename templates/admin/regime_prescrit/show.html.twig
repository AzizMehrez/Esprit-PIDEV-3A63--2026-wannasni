{% extends 'admin/base_admin.html.twig' %}

{% block page_title %}Régime #{{ regime_prescrit.id }}{% endblock %}

{% block header_actions %}
    <a href="{{ path('admin_nutrition_edit', {'id': regime_prescrit.id}) }}" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 0.3rem;">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
        Modifier
    </a>
    <a href="{{ path('admin_nutrition') }}" class="btn btn-outline">
        ← Retour
    </a>
    <form method="post" action="{{ path('admin_nutrition_send_sms', {id: regime_prescrit.id}) }}" onsubmit="return confirm('Envoyer un SMS d\'alerte manuel au proche ?');" style="display: inline-block; margin-left: 0.5rem;">
        <button type="submit" class="btn btn-outline" style="color: #6366f1; border-color: #6366f1;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 0.3rem;">
                <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
                <line x1="12" y1="18" x2="12.01" y2="18"/>
            </svg>
            Alerte SMS
        </button>
    </form>
    <form method="post" action="{{ path('admin_nutrition_regime_delete', {id: regime_prescrit.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce régime ?');" style="display: inline-block; margin-left: 0.5rem;">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ regime_prescrit.id) }}">
        <button type="submit" class="btn btn-outline" style="color: var(--admin-danger); border-color: var(--admin-danger);">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 0.3rem;">
                <polyline points="3 6 5 6 21 6"/>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
            </svg>
            Supprimer
        </button>
    </form>
{% endblock %}

{% block content %}
    {# Informations générales #}
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
        <div class="admin-card">
            <div class="card-header">
                <div class="card-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 0.4rem;">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                    </svg>
                    Informations générales
                </div>
            </div>
            <div class="card-body">
                <table style="width: 100%; border-collapse: collapse;">
                    <tr style="border-bottom: 1px solid var(--admin-border);">
                        <td style="padding: 0.75rem 0; color: var(--admin-text-muted); font-size: 0.9rem;">Senior ID:</td>
                        <td style="padding: 0.75rem 0; font-weight: 600; text-align: right;">
                            <span style="display: inline-flex; align-items: center; gap: 0.5rem;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 0.3rem;">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                    <circle cx="12" cy="7" r="4"/>
                                </svg>
                                {{ regime_prescrit.seniorId }}
                            </span>
                        </td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--admin-border);">
                        <td style="padding: 0.75rem 0; color: var(--admin-text-muted); font-size: 0.9rem;">Type de régime:</td>
                        <td style="padding: 0.75rem 0; text-align: right;">
                            <span class="badge-info">{{ regime_prescrit.typeRegime }}</span>
                        </td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--admin-border);">
                        <td style="padding: 0.75rem 0; color: var(--admin-text-muted); font-size: 0.9rem;">Période:</td>
                        <td style="padding: 0.75rem 0; font-weight: 600; text-align: right; font-size: 0.9rem;">
                            {{ regime_prescrit.dateDebut|date('d/m/Y') }} → {{ regime_prescrit.dateFin|date('d/m/Y') }}
                        </td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--admin-border);">
                        <td style="padding: 0.75rem 0; color: var(--admin-text-muted); font-size: 0.9rem;">Calories journalières:</td>
                        <td style="padding: 0.75rem 0; font-weight: 600; text-align: right; color: var(--admin-success);">
                            {{ regime_prescrit.caloriesJournalieres }} kcal
                        </td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--admin-border);">
                        <td style="padding: 0.75rem 0; color: var(--admin-text-muted); font-size: 0.9rem;">Repas par jour:</td>
                        <td style="padding: 0.75rem 0; text-align: right;">
                            <span class="badge-success">{{ regime_prescrit.repasParJour }}</span>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 0.75rem 0; color: var(--admin-text-muted); font-size: 0.9rem;">Consommé aujourd'hui:</td>
                        <td style="padding: 0.75rem 0; font-weight: 800; text-align: right; font-size: 1.1rem;">
                            {% set isOver = consumed_today > regime_prescrit.caloriesJournalieres %}
                            {% set isCritical = consumed_today > regime_prescrit.caloriesJournalieres * 3 %}
                            <span style="color: {{ isCritical ? '#dc2626' : (isOver ? '#d97706' : '#10b981') }};">
                                {{ consumed_today }} kcal
                            </span>
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="admin-card">
            <div class="card-header">
                <div class="card-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 0.4rem;">
                        <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
                    </svg>
                    Autres informations
                </div>
            </div>
            <div class="card-body">
                <table style="width: 100%; border-collapse: collapse;">
                    <tr style="border-bottom: 1px solid var(--admin-border);">
                        <td style="padding: 0.75rem 0; color: var(--admin-text-muted); font-size: 0.9rem;">Hydratation:</td>
                        <td style="padding: 0.75rem 0; font-weight: 600; text-align: right; color: var(--admin-primary);">
                            {{ regime_prescrit.hydratationQuotidienne }} ml
                        </td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--admin-border);">
                        <td style="padding: 0.75rem 0; color: var(--admin-text-muted); font-size: 0.9rem;">Suivi requis:</td>
                        <td style="padding: 0.75rem 0; font-weight: 600; text-align: right;">
                            {{ regime_prescrit.suiviRequis }}
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 0.75rem 0; color: var(--admin-text-muted); font-size: 0.9rem;">Date prescription:</td>
                        <td style="padding: 0.75rem 0; font-weight: 600; text-align: right; font-size: 0.9rem;">
                            {{ regime_prescrit.datePrescription|date('d/m/Y H:i') }}
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    {# Aliments #}
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
        <div class="admin-card">
            <div class="card-header" style="background: rgba(34, 197, 94, 0.1); border-bottom: 2px solid var(--admin-success);">
                <div class="card-title" style="color: var(--admin-success);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 0.4rem;">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Aliments recommandés
                </div>
            </div>
            <div class="card-body">
                {% if regime_prescrit.alimentsRecommandes %}
                    {% if regime_prescrit.alimentsRecommandes is iterable %}
                        <ul style="list-style: none; padding: 0; margin: 0;">
                            {% for aliment in regime_prescrit.alimentsRecommandes %}
                                <li style="padding: 0.5rem 0; border-bottom: 1px solid var(--admin-border); display: flex; align-items: center; gap: 0.5rem;">
                                    <span style="color: var(--admin-success);">✓</span>
                                    <span>{{ aliment }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p>{{ regime_prescrit.alimentsRecommandes }}</p>
                    {% endif %}
                {% else %}
                    <p style="color: var(--admin-text-muted); text-align: center; padding: 2rem;">Aucun aliment recommandé</p>
                {% endif %}
            </div>
        </div>

        <div class="admin-card">
            <div class="card-header" style="background: rgba(239, 68, 68, 0.1); border-bottom: 2px solid var(--admin-danger);">
                <div class="card-title" style="color: var(--admin-danger);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 0.4rem;">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                    </svg>
                    Aliments interdits
                </div>
            </div>
            <div class="card-body">
                {% if regime_prescrit.alimentsInterdits %}
                    {% if regime_prescrit.alimentsInterdits is iterable %}
                        <ul style="list-style: none; padding: 0; margin: 0;">
                            {% for aliment in regime_prescrit.alimentsInterdits %}
                                <li style="padding: 0.5rem 0; border-bottom: 1px solid var(--admin-border); display: flex; align-items: center; gap: 0.5rem;">
                                    <span style="color: var(--admin-danger);">✗</span>
                                    <span>{{ aliment }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p>{{ regime_prescrit.alimentsInterdits }}</p>
                    {% endif %}
                {% else %}
                    <p style="color: var(--admin-text-muted); text-align: center; padding: 2rem;">Aucun aliment interdit</p>
                {% endif %}
            </div>
        </div>
    </div>

    {# Recommandations spéciales #}
    <div class="admin-card">
        <div class="card-header">
            <div class="card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 0.4rem;">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Recommandations spéciales
            </div>
        </div>
        <div class="card-body">
            {% if regime_prescrit.recommandationsSpeciales %}
                <div style="padding: 1rem; background: rgba(59, 130, 246, 0.05); border-left: 3px solid var(--admin-primary); border-radius: 8px;">
                    {{ regime_prescrit.recommandationsSpeciales|nl2br }}
                </div>
            {% else %}
                <p style="color: var(--admin-text-muted); text-align: center; padding: 2rem;">Aucune recommandation spéciale</p>
            {% endif %}
        </div>
    </div>

    {# Données biométriques #}
    {% if regime_prescrit.poidsActuel or regime_prescrit.taille or regime_prescrit.niveauActivite %}
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 1.5rem; margin-top: 1.5rem; margin-bottom: 1.5rem;">
        <div class="admin-card">
            <div class="card-header" style="background: rgba(99, 102, 241, 0.1); border-bottom: 2px solid #6366f1;">
                <div class="card-title" style="color: #6366f1;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 0.4rem;">
                        <path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/>
                    </svg>
                    Données biométriques
                </div>
            </div>
            <div class="card-body">
                <table style="width: 100%; border-collapse: collapse;">
                    {% if regime_prescrit.poidsActuel %}
                    <tr style="border-bottom: 1px solid var(--admin-border);">
                        <td style="padding: 0.75rem 0; color: var(--admin-text-muted); font-size: 0.9rem;">Poids actuel:</td>
                        <td style="padding: 0.75rem 0; font-weight: 600; text-align: right;">{{ regime_prescrit.poidsActuel }} kg</td>
                    </tr>
                    {% endif %}
                    {% if regime_prescrit.taille %}
                    <tr style="border-bottom: 1px solid var(--admin-border);">
                        <td style="padding: 0.75rem 0; color: var(--admin-text-muted); font-size: 0.9rem;">Taille:</td>
                        <td style="padding: 0.75rem 0; font-weight: 600; text-align: right;">{{ regime_prescrit.taille }} cm</td>
                    </tr>
                    {% endif %}
                    {% if regime_prescrit.imc %}
                    <tr style="border-bottom: 1px solid var(--admin-border);">
                        <td style="padding: 0.75rem 0; color: var(--admin-text-muted); font-size: 0.9rem;">IMC:</td>
                        <td style="padding: 0.75rem 0; font-weight: 600; text-align: right;">
                            <span style="color: {% if regime_prescrit.imc < 18.5 %}#f59e0b{% elseif regime_prescrit.imc < 25 %}#10b981{% elseif regime_prescrit.imc < 30 %}#f97316{% else %}#dc2626{% endif %};">
                                {{ regime_prescrit.imc }}
                                {% if regime_prescrit.imc < 18.5 %}(sous-poids){% elseif regime_prescrit.imc < 25 %}(normal){% elseif regime_prescrit.imc < 30 %}(surpoids){% else %}(obésité){% endif %}
                            </span>
                        </td>
                    </tr>
                    {% endif %}
                    {% if regime_prescrit.niveauActivite %}
                    <tr>
                        <td style="padding: 0.75rem 0; color: var(--admin-text-muted); font-size: 0.9rem;">Activité physique:</td>
                        <td style="padding: 0.75rem 0; font-weight: 600; text-align: right;">{{ regime_prescrit.niveauActivite|replace({'_': ' '})|capitalize }}</td>
                    </tr>
                    {% endif %}
                </table>
            </div>
        </div>
    </div>
    {% endif %}
{% endblock %}
