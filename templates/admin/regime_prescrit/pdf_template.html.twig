<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Plan Nutritionnel #{{ regime.id }}</title>
    <style>
        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            color: #333;
            line-height: 1.6;
            font-size: 12pt;
            margin: 0;
            padding: 40px;
        }
        @media print {
            .no-print { display: none !important; }
            body { padding: 0; }
            .header { margin-top: 0; }
        }
        .print-btn {
            position: fixed;
            top: 20px;
            right: 20px;
            background: #2c3e50;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
            font-weight: bold;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            z-index: 1000;
        }
        .print-btn:hover { background: #34495e; }
        .header {
            border-bottom: 2px solid #2c3e50;
            padding-bottom: 20px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }
        .logo-area {
            font-size: 24pt;
            font-weight: bold;
            color: #2c3e50;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        .document-info {
            text-align: right;
            font-size: 10pt;
            color: #7f8c8d;
        }
        .patient-box {
            background-color: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 4px;
            padding: 15px;
            margin-bottom: 30px;
        }
        .patient-box h2 {
            margin-top: 0;
            font-size: 14pt;
            color: #2c3e50;
            border-bottom: 1px solid #dee2e6;
            padding-bottom: 10px;
            margin-bottom: 10px;
        }
        .info-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
        }
        .section-title {
            color: #2c3e50;
            font-size: 16pt;
            font-weight: bold;
            margin-top: 30px;
            margin-bottom: 15px;
            border-left: 5px solid #3498db;
            padding-left: 10px;
        }
        .grid-2 {
            display: table;
            width: 100%;
            margin-bottom: 20px;
        }
        .col {
            display: table-cell;
            width: 50%;
            vertical-align: top;
            padding-right: 20px;
        }
        .stat-box {
            border: 1px solid #bdc3c7;
            padding: 10px;
            text-align: center;
            border-radius: 4px;
            margin-bottom: 10px;
        }
        .stat-label {
            font-size: 9pt;
            text-transform: uppercase;
            color: #7f8c8d;
            margin-bottom: 5px;
        }
        .stat-value {
            font-size: 14pt;
            font-weight: bold;
            color: #2c3e50;
        }
        .list-box {
            border: 1px solid #e9ecef;
            padding: 15px;
            border-radius: 4px;
            height: 100%;
        }
        .list-box.recommended {
            border-top: 3px solid #27ae60;
            background-color: #f0fff4;
        }
        .list-box.forbidden {
            border-top: 3px solid #c0392b;
            background-color: #fff5f5;
        }
        .list-title {
            font-weight: bold;
            text-transform: uppercase;
            font-size: 10pt;
            margin-bottom: 10px;
            display: block;
        }
        .footer {
            margin-top: 50px;
            border-top: 1px solid #dee2e6;
            padding-top: 20px;
            font-size: 9pt;
            color: #7f8c8d;
            text-align: center;
        }
        .signature-area {
            margin-top: 40px;
            text-align: right;
        }
        .signature-line {
            display: inline-block;
            width: 200px;
            border-top: 1px solid #333;
            margin-top: 40px;
            text-align: center;
            padding-top: 5px;
            font-size: 10pt;
        }
    </style>
</head>
<body>
    <button onclick="window.print()" class="no-print print-btn">
        🖨️ Imprimer / Sauvegarder en PDF
    </button>

    <div class="header">
        <div class="logo-area">
            Santé & Bien-être
        </div>
        <div class="document-info">
            <strong>Plan Nutritionnel #{{ regime.id }}</strong><br>
            Date: {{ "now"|date("d/m/Y") }}<br>
            Docteur Jean Nutrition
        </div>
    </div>

    <div class="patient-box">
        <h2>Informations du Patient</h2>
        <div class="info-row">
            <div>
                <strong>Identifiant:</strong> Senior #{{ demande.seniorId }}<br>
                <strong>Objectif:</strong> {{ demande.objectifPrincipal }}
            </div>
            <div style="text-align: right;">
                <strong>Type de Régime:</strong> {{ regime.typeRegime|default(demande.typeRegimeSouhaite)|title }}<br>
                <strong>Durée:</strong> {{ regime.dateDebut|date("d/m/Y") }} - {{ regime.dateFin|date("d/m/Y") }}
            </div>
        </div>
    </div>

    <div class="section-title">Paramètres Nutritionnels</div>
    
    <div class="grid-2">
        <div class="col">
            <div class="stat-box">
                <div class="stat-label">Calories Journalières</div>
                <div class="stat-value">{{ regime.caloriesJournalieres }} kcal</div>
            </div>
            <div class="stat-box">
                <div class="stat-label">Hydratation</div>
                <div class="stat-value">{{ regime.hydratationQuotidienne }} L/jour</div>
            </div>
        </div>
        <div class="col">
            <div class="stat-box">
                <div class="stat-label">Repas par jour</div>
                <div class="stat-value">{{ regime.repasParJour }} repas</div>
            </div>
            <div class="stat-box">
                <div class="stat-label">Suivi Requis</div>
                <div class="stat-value">{{ regime.suiviRequis }}</div>
            </div>
        </div>
    </div>

    <div class="section-title">Guide Alimentaire</div>

    <div class="grid-2">
        <div class="col">
            <div class="list-box recommended">
                <span class="list-title" style="color: #27ae60;">A PRIVILÉGIER</span>
                <div style="white-space: pre-wrap;">{{ regime.alimentsRecommandes|join(', ') }}</div>
            </div>
        </div>
        <div class="col">
            <div class="list-box forbidden">
                <span class="list-title" style="color: #c0392b;">A ÉVITER</span>
                <div style="white-space: pre-wrap;">{{ regime.alimentsInterdits|join(', ') }}</div>
            </div>
        </div>
    </div>

    {% if regime.recommandationsSpeciales %}
    <div class="section-title">Recommandations Spéciales</div>
    <div class="patient-box" style="background-color: #fdfdfe; border-left: 4px solid #8e44ad;">
        <div style="white-space: pre-wrap;">{{ regime.recommandationsSpeciales }}</div>
    </div>
    {% endif %}

    {% if regime.poidsActuel or regime.taille %}
    <div class="section-title">Données Biométriques</div>
    <div class="grid-2">
        <div class="col">
            {% if regime.poidsActuel %}
            <div class="stat-box">
                <div class="stat-label">Poids</div>
                <div class="stat-value">{{ regime.poidsActuel }} kg</div>
            </div>
            {% endif %}
            {% if regime.taille %}
            <div class="stat-box">
                <div class="stat-label">Taille</div>
                <div class="stat-value">{{ regime.taille }} cm</div>
            </div>
            {% endif %}
        </div>
        <div class="col">
            {% if regime.poidsActuel and regime.taille %}
            {% set imc = regime.imc %}
            <div class="stat-box" style="border-color: {% if imc < 18.5 %}#3498db{% elseif imc < 25 %}#27ae60{% elseif imc < 30 %}#f39c12{% else %}#e74c3c{% endif %};">
                <div class="stat-label">IMC</div>
                <div class="stat-value" style="color: {% if imc < 18.5 %}#3498db{% elseif imc < 25 %}#27ae60{% elseif imc < 30 %}#f39c12{% else %}#e74c3c{% endif %};">
                    {{ imc|number_format(1) }}
                    <span style="font-size: 9pt; font-weight: normal;">
                        {% if imc < 18.5 %}(Maigreur){% elseif imc < 25 %}(Normal){% elseif imc < 30 %}(Surpoids){% else %}(Obésité){% endif %}
                    </span>
                </div>
            </div>
            {% endif %}
            {% if regime.niveauActivite %}
            <div class="stat-box">
                <div class="stat-label">Niveau d'activité</div>
                <div class="stat-value" style="font-size: 12pt;">{{ regime.niveauActivite|replace({'_': ' '})|title }}</div>
            </div>
            {% endif %}
        </div>
    </div>

    {% endif %}

    <div class="signature-area">
        <div class="signature-line">
            Signature du Nutritionniste
        </div>
    </div>

    <div class="footer">
        Ce document est un plan nutritionnel personnalisé. Veuillez consulter votre médecin avant tout changement drastique.<br>
        Généré le {{ "now"|date("d/m/Y à H:i") }}
    </div>
</body>
</html>

