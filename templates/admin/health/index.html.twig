{% extends 'admin/base_admin.html.twig' %}

{% block title %}Dossiers Santé - Admin WANNASNI{% endblock %}
{% block page_title %}Dossiers de Santé{% endblock %}

{% block header_actions %}
<a href="{{ path('admin_health_new') }}" class="btn btn-primary">➕ Nouvelle Entrée</a>
{% endblock %}

{% block content %}
<div class="admin-card">
    <div class="card-header">
        <h2 class="card-title">❤️ Entrées de Santé</h2>
        <span class="badge badge-danger">{{ records|length }} entrées</span>
    </div>
    <table class="admin-table">
        <thead>
            <tr>
                <th>Patient</th>
                <th>Date</th>
                <th>Tension</th>
                <th>Pouls</th>
                <th>Poids</th>
                <th>Humeur</th>
                <th style="width: 80px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for record in records %}
            <tr>
                <td>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 36px; height: 36px; border-radius: 8px; background: linear-gradient(135deg, #ef4444, #f87171); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 0.85rem;">
                            {{ record.user|first }}
                        </div>
                        <span style="font-weight: 600;">{{ record.user }}</span>
                    </div>
                </td>
                <td>{{ record.date|date('d/m/Y') }}</td>
                <td><span style="font-weight: 600; color: #ef4444;">{{ record.bloodPressure }}</span></td>
                <td><span style="font-weight: 600; color: #3b82f6;">{{ record.heartRate }} bpm</span></td>
                <td>{{ record.weight }} kg</td>
                <td>
                    {% if record.mood == 'excellent' %}
                        <span class="badge badge-success">😊 Excellent</span>
                    {% elseif record.mood == 'good' %}
                        <span class="badge badge-info">🙂 Bien</span>
                    {% else %}
                        <span class="badge badge-warning">😐 Correct</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('admin_health_show', {id: record.id}) }}" class="action-btn" title="Voir">👁️</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
