{% extends 'admin/base_admin.html.twig' %}

{% block title %}Dossiers Santé - Admin WANNASNI{% endblock %}
{% block page_title %}Dossiers de Santé{% endblock %}

{% block header_actions %}
<a href="{{ path('admin_health_new') }}" class="btn btn-primary">➕ Nouvelle Entrée</a>
{% endblock %}

{% block content %}
{# Statistics Cards #}
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon red">❤️</div>
        <div class="stat-info">
            <div class="stat-value">{{ records|length }}</div>
            <div class="stat-label">Total Entrées</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">😊</div>
        <div class="stat-info">
            <div class="stat-value">{{ records|filter(r => r.humeur == 'excellent' or r.humeur == 'good')|length }}</div>
            <div class="stat-label">Bonne Humeur</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue">💓</div>
        <div class="stat-info">
            {# Compute average heart rate safely #}
            {% set totalHR = 0 %}
            {% set hrCount = 0 %}
            {% for r in records %}
                {% if r.frequenceCardiaque is not null %}
                    {% set totalHR = totalHR + r.frequenceCardiaque %}
                    {% set hrCount = hrCount + 1 %}
                {% endif %}
            {% endfor %}
            <div class="stat-value">{{ hrCount > 0 ? (totalHR / hrCount)|round : 'N/A' }}</div>
            <div class="stat-label">FC Moyenne</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple">🌡️</div>
        <div class="stat-info">
            {% set totalTemp = 0 %}
            {% set tempCount = 0 %}
            {% for r in records %}
                {% if r.temperature is not null %}
                    {% set totalTemp = totalTemp + r.temperature %}
                    {% set tempCount = tempCount + 1 %}
                {% endif %}
            {% endfor %}
            <div class="stat-value">{{ tempCount > 0 ? (totalTemp / tempCount)|round(1) : 'N/A' }} °C</div>
            <div class="stat-label">Température Moyenne</div>
        </div>
    </div>
</div>

{# Toolbar #}
<div class="admin-toolbar">
    <form method="get" action="{{ path('admin_health') }}" style="display:flex; gap:1rem; width:100%; align-items:center;">
        <input type="search" name="q" placeholder="Rechercher patient, notes, humeur..." value="{{ q|default('') }}" class="form-input" style="max-width:420px;">
        <select name="sort" class="form-input" style="width:180px;">
            <option value="desc" {% if sort is not defined or sort == 'desc' %}selected{% endif %}>Date: plus récentes</option>
            <option value="asc" {% if sort == 'asc' %}selected{% endif %}>Date: plus anciennes</option>
        </select>
        <button type="submit" class="btn btn-primary">🔎 Rechercher</button>
        <div style="margin-left:auto; display:flex; gap:0.5rem;">
            <a href="{{ path('admin_health_export', {'q': q|default(''), 'sort': sort|default('desc')}) }}" class="export-btn pdf">📄 Exporter PDF</a>
            <a href="#" class="export-btn excel" onclick="alert('Export Excel - À implémenter')">📊 Excel</a>
        </div>
    </form>
</div>

{# Table #}
<div class="admin-card">
    <div class="card-header">
        <h2 class="card-title">❤️ Entrées de Santé</h2>
        <span class="badge badge-danger">{{ records|length }} entrées</span>
    </div>
    <table class="admin-table" id="dataTable">
        <thead>
            <tr>
                <th class="sortable" onclick="sortTable(0)">Patient</th>
                <th class="sortable" onclick="sortTable(1)">Date</th>
                <th class="sortable" onclick="sortTable(2)">Tension</th>
                <th class="sortable" onclick="sortTable(3)">Pouls</th>
                <th class="sortable" onclick="sortTable(4)">Poids</th>
                <th class="sortable" onclick="sortTable(5)">Humeur</th>
                <th style="width: 80px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for record in records %}
            <tr>
                <td>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 36px; height: 36px; border-radius: 8px; background: linear-gradient(135deg, #ef4444, #f87171); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 0.85rem;">
                            {{ record.senior.getFullName()|first }}
                        </div>
                        <span style="font-weight: 600;">{{ record.senior ? record.senior.getFullName() : '—' }}</span>
                    </div>
                </td>
                <td>{{ record.date|date('d/m/Y') }}</td>
                <td><span style="font-weight: 600; color: #ef4444;">{{ record.tensionArterielle }}</span></td>
                <td><span style="font-weight: 600; color: #3b82f6;">{{ record.frequenceCardiaque }} bpm</span></td>
                <td>{{ record.temperature ? record.temperature ~ ' °C' : '—' }}</td>
                <td>
                    {% if record.humeur == 'excellent' %}
                        <span class="badge badge-success">😊 Excellent</span>
                    {% elseif record.humeur == 'good' %}
                        <span class="badge badge-info">🙂 Bien</span>
                    {% else %}
                        <span class="badge badge-warning">😐 {{ record.humeur ?: 'Indéfini' }}</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('admin_health_show', {id: record.id}) }}" class="action-btn" title="Voir">👁️</a>
                    <a href="{{ path('admin_health_edit', {id: record.id}) }}" class="action-btn" title="Éditer">✏️</a>
                    <form method="post" action="{{ path('admin_health_delete', {id: record.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cette entrée ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ record.id) }}">
                        <button class="action-btn" title="Supprimer">🗑️</button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<script>
let sortDirection = {};
function sortTable(columnIndex) {
    const table = document.getElementById('dataTable');
    const tbody = table.getElementsByTagName('tbody')[0];
    const rows = Array.from(tbody.getElementsByTagName('tr'));
    const headers = table.getElementsByTagName('th');
    
    sortDirection[columnIndex] = !sortDirection[columnIndex];
    const ascending = sortDirection[columnIndex];
    
    for (let i = 0; i < headers.length; i++) {
        headers[i].classList.remove('asc', 'desc');
    }
    headers[columnIndex].classList.add(ascending ? 'asc' : 'desc');
    
    rows.sort((a, b) => {
        const aText = a.cells[columnIndex].textContent.trim().toLowerCase();
        const bText = b.cells[columnIndex].textContent.trim().toLowerCase();
        return ascending ? aText.localeCompare(bText) : bText.localeCompare(aText);
    });
    
    rows.forEach(row => tbody.appendChild(row));
}
</script>
{% endblock %}
