{% extends 'admin/base_admin.html.twig' %}

{% block title %}Dossiers Santé - Admin WANNASNI{% endblock %}
{% block page_title %}Dossiers de Santé{% endblock %}

{% block header_actions %}
<a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">🏠 Accueil</a>
<a href="{{ path('admin_health_new') }}" class="btn btn-primary">➕ Nouvelle Entrée</a>
{% endblock %}

{% block content %}
{# Statistics Cards #}
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon red">❤️</div>
        <div class="stat-info">
            <div class="stat-value">{{ records|length }}</div>
            <div class="stat-label">Total Entrées</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">😊</div>
        <div class="stat-info">
            <div class="stat-value">{{ records|filter(r => r.humeur == 'excellent' or r.humeur == 'bon')|length }}</div>
            <div class="stat-label">Bonne Humeur</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue">💓</div>
        <div class="stat-info">
            <div class="stat-value">{{ records|length > 0 ? ((records|reduce((carry, r) => carry + (r.frequenceCardiaque ?? 0), 0) / records|length)|round) : 0 }}</div>
            <div class="stat-label">FC Moyenne</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple">🌡️</div>
        <div class="stat-info">
            <div class="stat-value">{{ records|length > 0 ? ((records|reduce((carry, r) => carry + (r.temperature ?? 0), 0) / records|length)|round(1)) : 0 }}</div>
            <div class="stat-label">Temp. Moyenne (°C)</div>
        </div>
    </div>
</div>

{# Toolbar #}
<div class="admin-toolbar">
    <div class="toolbar-search">
        <input type="text" id="searchInput" placeholder="Rechercher un patient..." onkeyup="filterTable()">
    </div>
    <div class="toolbar-actions">
        <button class="filter-btn">
            🔽 Filtrer
        </button>
        <a href="#" class="export-btn pdf" onclick="exportPDF(); return false;">
            📄 PDF
        </a>
        <a href="#" class="export-btn excel" onclick="exportExcel(); return false;">
            📊 Excel
        </a>
    </div>
</div>

{# Table #}
<div class="admin-card">
    <div class="card-header">
        <h2 class="card-title">❤️ Entrées de Santé</h2>
        <span class="badge badge-danger">{{ records|length }} entrées</span>
    </div>
    <table class="admin-table" id="dataTable">
        <thead>
            <tr>
                <th class="sortable" onclick="sortTable(0)">Patient</th>
                <th class="sortable" onclick="sortTable(1)">Date</th>
                <th class="sortable" onclick="sortTable(2)">Tension</th>
                <th class="sortable" onclick="sortTable(3)">Pouls</th>
                <th class="sortable" onclick="sortTable(4)">Température</th>
                <th class="sortable" onclick="sortTable(5)">Humeur</th>
                <th style="width: 80px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% if records|length == 0 %}
            <tr>
                <td colspan="7" style="text-align: center; padding: 2rem; color: #64748b;">
                    <div style="font-size: 3rem; margin-bottom: 1rem;">📋</div>
                    <p>Aucune entrée de santé trouvée.</p>
                    <a href="{{ path('admin_health_new') }}" class="btn btn-primary" style="margin-top: 1rem;">➕ Ajouter une entrée</a>
                </td>
            </tr>
            {% else %}
            {% for record in records %}
            <tr>
                <td>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 36px; height: 36px; border-radius: 8px; background: linear-gradient(135deg, #ef4444, #f87171); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 0.85rem; color: white;">
                            {{ record.senior ? (record.senior.firstName|first|upper) : '?' }}
                        </div>
                        <span style="font-weight: 600;">{{ record.senior ? (record.senior.firstName ~ ' ' ~ record.senior.lastName) : 'Inconnu' }}</span>
                    </div>
                </td>
                <td>{{ record.date|date('d/m/Y') }}</td>
                <td><span style="font-weight: 600; color: #ef4444;">{{ record.tensionArterielle ?? '-' }}</span></td>
                <td><span style="font-weight: 600; color: #3b82f6;">{{ record.frequenceCardiaque ? record.frequenceCardiaque ~ ' bpm' : '-' }}</span></td>
                <td>{{ record.temperature ? (record.temperature ~ ' °C') : '-' }}</td>
                <td>
                    {% if record.humeur == 'excellent' %}
                        <span class="badge badge-success">😊 Excellent</span>
                    {% elseif record.humeur == 'bon' or record.humeur == 'good' %}
                        <span class="badge badge-info">🙂 Bien</span>
                    {% elseif record.humeur == 'moyen' or record.humeur == 'average' %}
                        <span class="badge badge-warning">😐 Moyen</span>
                    {% else %}
                        <span class="badge badge-secondary">{{ record.humeur ?? '-' }}</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('admin_health_show', {id: record.id}) }}" class="action-btn" title="Voir">👁️</a>
                    <a href="{{ path('admin_health_edit', {id: record.id}) }}" class="action-btn" title="Modifier">✏️</a>
                    <form action="{{ path('admin_health_delete', {id: record.id}) }}" method="post" style="display: inline;" onsubmit="return confirm('Supprimer cette entrée ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ record.id) }}">
                        <button type="submit" class="action-btn" title="Supprimer" style="background: none; border: none; cursor: pointer; padding: 0.25rem;">🗑️</button>
                    </form>
                </td>
            </tr>
            {% endfor %}
            {% endif %}
        </tbody>
    </table>
</div>

<script>
/* ── Search ── */
function filterTable() {
    const filter = document.getElementById('searchInput').value.toLowerCase();
    const tbody  = document.querySelector('#dataTable tbody');
    const rows   = tbody.querySelectorAll('tr');
    rows.forEach(row => {
        const cells = row.querySelectorAll('td');
        let found = false;
        cells.forEach((cell, idx) => {
            if (idx < cells.length - 1 && cell.textContent.toLowerCase().includes(filter)) found = true;
        });
        row.style.display = found ? '' : 'none';
    });
}

/* ── Sort ── */
let sortDirection = {};
function sortTable(columnIndex) {
    const table   = document.getElementById('dataTable');
    const tbody   = table.querySelector('tbody');
    const rows    = Array.from(tbody.querySelectorAll('tr'));
    const headers = table.querySelectorAll('thead th');

    sortDirection[columnIndex] = !sortDirection[columnIndex];
    const ascending = sortDirection[columnIndex];
    headers.forEach(h => h.classList.remove('asc', 'desc'));
    headers[columnIndex].classList.add(ascending ? 'asc' : 'desc');

    // Numeric columns: Pouls (3), Poids (4) — Date column: 1
    const numericCols = [3, 4];
    rows.sort((a, b) => {
        let aText = a.cells[columnIndex].textContent.trim();
        let bText = b.cells[columnIndex].textContent.trim();
        if (columnIndex === 1) {
            const aDate = new Date(aText.split('/').reverse().join('-'));
            const bDate = new Date(bText.split('/').reverse().join('-'));
            return ascending ? aDate - bDate : bDate - aDate;
        }
        if (numericCols.includes(columnIndex)) {
            const aNum = parseFloat(aText) || 0;
            const bNum = parseFloat(bText) || 0;
            return ascending ? aNum - bNum : bNum - aNum;
        }
        return ascending
            ? aText.toLowerCase().localeCompare(bText.toLowerCase())
            : bText.toLowerCase().localeCompare(aText.toLowerCase());
    });
    rows.forEach(row => tbody.appendChild(row));
}

/* ── PDF Export ── */
function exportPDF() {
    const table = document.getElementById('dataTable');
    const rows  = table.querySelectorAll('tbody tr');
    const date  = new Date().toLocaleDateString('fr-FR');
    let tableHTML = '';
    rows.forEach(row => {
        if (row.style.display === 'none') return;
        const c = row.querySelectorAll('td');
        tableHTML += '<tr>';
        tableHTML += '<td>' + c[0].textContent.trim().replace(/\s+/g, ' ') + '</td>';
        tableHTML += '<td>' + c[1].textContent.trim() + '</td>';
        tableHTML += '<td>' + c[2].textContent.trim() + '</td>';
        tableHTML += '<td>' + c[3].textContent.trim() + '</td>';
        tableHTML += '<td>' + c[4].textContent.trim() + '</td>';
        tableHTML += '<td>' + c[5].textContent.trim() + '</td>';
        tableHTML += '</tr>';
    });
    const html = `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Dossiers Santé - WANNASNI</title>
<style>body{font-family:Arial,sans-serif;padding:30px;color:#1e293b}h1{text-align:center;margin-bottom:4px;color:#1e40af}.subtitle{text-align:center;color:#64748b;margin-bottom:24px;font-size:14px}table{width:100%;border-collapse:collapse;margin-top:10px}th{background:#1e40af;color:#fff;padding:10px 12px;text-align:left;font-size:13px}td{padding:9px 12px;border-bottom:1px solid #e2e8f0;font-size:13px}tr:nth-child(even){background:#f8fafc}.footer{text-align:center;margin-top:30px;font-size:11px;color:#94a3b8}</style></head><body>
<h1>❤️ Dossiers de Santé</h1><p class="subtitle">WANNASNI – Généré le ${date}</p>
<table><thead><tr><th>Patient</th><th>Date</th><th>Tension</th><th>Pouls</th><th>Poids</th><th>Humeur</th></tr></thead><tbody>${tableHTML}</tbody></table>
<p class="footer">WANNASNI – Système de Gestion – ${date}</p></body></html>`;
    const win = window.open('', '_blank');
    win.document.write(html); win.document.close(); win.focus();
    setTimeout(() => win.print(), 400);
}

/* ── Excel / CSV Export ── */
function exportExcel() {
    const table = document.getElementById('dataTable');
    const rows  = table.querySelectorAll('tbody tr');
    const BOM   = '\uFEFF';
    let csv     = BOM + 'Patient;Date;Tension;Pouls;Poids;Humeur\n';
    rows.forEach(row => {
        if (row.style.display === 'none') return;
        const c = row.querySelectorAll('td');
        csv += [
            c[0].textContent.trim().replace(/\s+/g, ' ').replace(/;/g, ','),
            c[1].textContent.trim(),
            c[2].textContent.trim(),
            c[3].textContent.trim(),
            c[4].textContent.trim(),
            c[5].textContent.trim()
        ].join(';') + '\n';
    });
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = 'sante_wannasni_' + new Date().toISOString().slice(0,10) + '.csv';
    a.click(); URL.revokeObjectURL(url);
}
</script>
{% endblock %}
