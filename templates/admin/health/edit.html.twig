{% extends 'admin/base_admin.html.twig' %}

{% block title %}Éditer Entrée Santé #{{ record.id }} - Admin WANNASNI{% endblock %}
{% block page_title %}Éditer Entrée Santé{% endblock %}

{% block header_actions %}
<a href="{{ path('admin_health') }}" class="btn btn-outline">← Retour</a>
{% endblock %}

{% block extra_styles %}
<style>
    .form-container { max-width: 700px; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-group { margin-bottom: 1.25rem; }
    .form-group.full { grid-column: span 2; }
    .form-label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--admin-text); margin-bottom: 0.5rem; }
    .form-input { width: 100%; padding: 0.85rem 1rem; font-size: 0.95rem; border: 1px solid var(--admin-border); border-radius: var(--admin-radius-sm); background: var(--admin-bg); color: var(--admin-text); transition: all 0.2s; }
    .form-input:focus { outline: none; border-color: var(--admin-primary); box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2); }
    .btn-group { display: flex; gap: 1rem; margin-top: 1.5rem; }
</style>
{% endblock %}

{% block content %}
<div class="form-container">
    <div class="admin-card">
        <div class="card-header">
            <h2 class="card-title">✏️ Éditer Entrée</h2>
        </div>
        <div class="card-body">
            {% if app.flashes('error') %}
                <div class="alert alert-error" style="margin-bottom: 1rem; padding: 1rem; background: #fed7d7; color: #c53030; border-radius: 8px;">
                    {% for message in app.flashes('error') %}
                        <p>{{ message }}</p>
                    {% endfor %}
                </div>
            {% endif %}

            {{ form_start(form) }}
                <div class="form-grid">
                    <div class="form-group full">
                        {{ form_row(form.senior, {'attr': {'class': 'form-input form-select'}}) }}
                    </div>
                    <div class="form-group">
                        {{ form_row(form.tensionArterielle, {'attr': {'class': 'form-input'}}) }}
                    </div>
                    <div class="form-group">
                        {{ form_row(form.frequenceCardiaque, {'attr': {'class': 'form-input'}}) }}
                    </div>
                    <div class="form-group">
                        {{ form_row(form.temperature, {'attr': {'class': 'form-input'}}) }}
                    </div>
                    <div class="form-group">
                        {{ form_row(form.humeur, {'attr': {'class': 'form-input'}}) }}
                    </div>
                    <div class="form-group full">
                        {{ form_row(form.notes, {'attr': {'class': 'form-input', 'rows': 3}}) }}
                    </div>
                </div>
                <div class="btn-group">
                    <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
                    <a href="{{ path('admin_health') }}" class="btn btn-outline">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
