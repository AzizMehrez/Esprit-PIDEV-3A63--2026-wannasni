{% extends 'base.html.twig' %}

{% block title %}Export - Journal de santé{% endblock %}

{% block body %}
    <h1>Journal de santé</h1>
    <p>Export filtré: <strong>{{ q|default('') }}</strong> — Tri: <strong>{{ sort|default('desc') }}</strong></p>

    <table style="width:100%; border-collapse:collapse;">
        <thead>
            <tr style="background:#f6f6f6; text-align:left;">
                <th style="padding:8px; border:1px solid #ddd;">Date</th>
                <th style="padding:8px; border:1px solid #ddd;">Patient</th>
                <th style="padding:8px; border:1px solid #ddd;">Humeur</th>
                <th style="padding:8px; border:1px solid #ddd;">Tension</th>
                <th style="padding:8px; border:1px solid #ddd;">Fréquence cardiaque</th>
                <th style="padding:8px; border:1px solid #ddd;">Température</th>
                <th style="padding:8px; border:1px solid #ddd;">Notes</th>
            </tr>
        </thead>
        <tbody>
            {% for entry in entries %}
                <tr>
                    <td style="padding:8px; border:1px solid #ddd;">{{ entry.date ? entry.date|date('Y-m-d') : '-' }}</td>
                    <td style="padding:8px; border:1px solid #ddd;">{{ entry.senior ? entry.senior.getFullName() : '-' }}</td>
                    <td style="padding:8px; border:1px solid #ddd;">{{ entry.humeur|default('-') }}</td>
                    <td style="padding:8px; border:1px solid #ddd;">{{ entry.tensionArterielle|default('-') }}</td>
                    <td style="padding:8px; border:1px solid #ddd;">{{ entry.frequenceCardiaque|default('-') }}</td>
                    <td style="padding:8px; border:1px solid #ddd;">{{ entry.temperature|default('-') }}</td>
                    <td style="padding:8px; border:1px solid #ddd;">{{ entry.notes|e }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" style="padding:12px; text-align:center;">Aucune entrée trouvée</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

{% endblock %}
