{% extends 'admin/base_admin.html.twig' %}

{% block title %}Health Record #{{ record.id }} - Admin WANNASNI{% endblock %}
{% block page_title %}Health Record Details{% endblock %}

{% block content %}
<div style="margin-bottom: 1rem;">
    <a href="{{ path('admin_health_list') }}" class="btn btn-secondary">← Back to Health Records</a>
</div>

<div class="grid-2">
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Record #{{ record.id }}</h2>
            <span style="color: var(--text-secondary);">{{ record.date|date('F d, Y') }}</span>
        </div>
        
        <div style="padding: 1rem; background: var(--bg-tertiary); border-radius: var(--radius-md); margin-bottom: 1.5rem;">
            <div style="font-weight: 600; font-size: 1.1rem;">{{ record.user }}</div>
        </div>
        
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
            <div style="padding: 1rem; background: rgba(239, 68, 68, 0.1); border-radius: var(--radius-md); text-align: center;">
                <div style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;">Blood Pressure</div>
                <div style="font-size: 1.5rem; font-weight: 700; color: var(--danger);">{{ record.bloodPressure }}</div>
                <div style="font-size: 0.75rem; color: var(--text-muted);">mmHg</div>
            </div>
            <div style="padding: 1rem; background: rgba(59, 130, 246, 0.1); border-radius: var(--radius-md); text-align: center;">
                <div style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;">Heart Rate</div>
                <div style="font-size: 1.5rem; font-weight: 700; color: var(--info);">{{ record.heartRate }}</div>
                <div style="font-size: 0.75rem; color: var(--text-muted);">bpm</div>
            </div>
            <div style="padding: 1rem; background: rgba(34, 197, 94, 0.1); border-radius: var(--radius-md); text-align: center;">
                <div style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;">Weight</div>
                <div style="font-size: 1.5rem; font-weight: 700; color: var(--success);">{{ record.weight }}</div>
                <div style="font-size: 0.75rem; color: var(--text-muted);">kg</div>
            </div>
            <div style="padding: 1rem; background: rgba(245, 158, 11, 0.1); border-radius: var(--radius-md); text-align: center;">
                <div style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;">Mood</div>
                <div style="font-size: 1.5rem; font-weight: 700; color: var(--warning);">
                    {% if record.mood == 'excellent' %}😊{% elseif record.mood == 'good' %}🙂{% else %}😐{% endif %}
                </div>
                <div style="font-size: 0.75rem; color: var(--text-muted);">{{ record.mood|capitalize }}</div>
            </div>
        </div>
    </div>
    
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Notes</h2>
        </div>
        <p style="color: var(--text-secondary); padding: 1rem; background: var(--bg-tertiary); border-radius: var(--radius-md);">
            {{ record.notes }}
        </p>
        
        <hr style="border: none; border-top: 1px solid var(--border-color); margin: 1.5rem 0;">
        
        <div class="card-header">
            <h2 class="card-title">Actions</h2>
        </div>
        <div style="display: grid; gap: 0.75rem;">
            <button class="btn btn-secondary" style="justify-content: flex-start;">
                <span>📊</span> View History
            </button>
            <button class="btn btn-secondary" style="justify-content: flex-start;">
                <span>📧</span> Send to Doctor
            </button>
            <button class="btn btn-secondary" style="justify-content: flex-start;">
                <span>🖨️</span> Print Report
            </button>
        </div>
    </div>
</div>
{% endblock %}
