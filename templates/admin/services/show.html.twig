{% extends 'admin/base_admin.html.twig' %}

{% block title %}Service Request #{{ service.id }} - Admin WANNASNI{% endblock %}
{% block page_title %}Service Request Details{% endblock %}

{% block content %}
<style>
    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 0.75rem 0;
        border-bottom: 1px solid #e5e7eb;
    }
    .info-row:last-child {
        border-bottom: none;
    }
    .info-label {
        color: #6b7280;
        font-size: 0.875rem;
        font-weight: 500;
    }
    .info-value {
        color: #111827;
        font-weight: 600;
        text-align: right;
    }
    .section-header {
        font-size: 0.875rem;
        font-weight: 600;
        color: #374151;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #e5e7eb;
    }
    .status-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        padding: 1.5rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        color: white;
    }
    .status-header h1 {
        margin: 0;
        font-size: 1.875rem;
        font-weight: 700;
    }
    .contact-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.875rem;
        background: #f9fafb;
        border-radius: 8px;
        margin-bottom: 0.75rem;
    }
    .contact-icon {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border-radius: 8px;
        font-size: 1.25rem;
    }
    .contact-details {
        flex: 1;
    }
    .contact-label {
        font-size: 0.75rem;
        color: #6b7280;
        margin-bottom: 0.25rem;
    }
    .contact-value {
        font-weight: 600;
        color: #111827;
    }
</style>

<div style="margin-bottom: 1.5rem;">
    <a href="{{ path('admin_services') }}" class="btn btn-secondary" style="gap: 0.5rem;">
        <span>←</span> Back to Services
    </a>
</div>

<!-- Status Header -->
<div class="status-header">
    <div>
        <h1>Request #{{ service.id }}</h1>
        <p style="margin: 0.5rem 0 0 0; opacity: 0.9;">{{ service.typeService }}</p>
    </div>
    <div>
        {% if service.statut == 'pending' %}
            <span class="badge badge-warning" style="font-size: 1rem; padding: 0.5rem 1rem;">⏳ Pending</span>
        {% elseif service.statut == 'assigned' %}
            <span class="badge badge-info" style="font-size: 1rem; padding: 0.5rem 1rem;">👤 Assigned</span>
        {% elseif service.statut == 'in_progress' %}
            <span class="badge badge-info" style="font-size: 1rem; padding: 0.5rem 1rem;">⚙️ In Progress</span>
        {% elseif service.statut == 'completed' %}
            <span class="badge badge-success" style="font-size: 1rem; padding: 0.5rem 1rem;">✅ Completed</span>
        {% else %}
            <span class="badge" style="font-size: 1rem; padding: 0.5rem 1rem; background: #6b7280;">❌ {{ service.statut|title }}</span>
        {% endif %}
    </div>
</div>

<div class="grid-2">
    <!-- Left Column -->
    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        
        <!-- Contact Information -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">📞 Contact Information</h2>
            </div>
            <div style="padding: 1rem;">
                <div class="contact-item">
                    <div class="contact-icon">📧</div>
                    <div class="contact-details">
                        <div class="contact-label">Email</div>
                        <div class="contact-value">{{ service.seniorEmail }}</div>
                    </div>
                </div>
                
                <div class="contact-item">
                    <div class="contact-icon">📱</div>
                    <div class="contact-details">
                        <div class="contact-label">Phone</div>
                        <div class="contact-value">{{ service.seniorTelephone }}</div>
                    </div>
                </div>

                {% if service.user %}
                <div class="contact-item">
                    <div class="contact-icon">👤</div>
                    <div class="contact-details">
                        <div class="contact-label">User Account</div>
                        <div class="contact-value">{{ service.user.firstName }} {{ service.user.lastName }}</div>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>

        <!-- Service Details -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">📋 Service Details</h2>
            </div>
            <div style="padding: 1rem;">
                <div class="info-row">
                    <span class="info-label">Service Type</span>
                    <span class="info-value">{{ service.typeService }}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Priority Level</span>
                    <span class="info-value">
                        {% if service.niveauUrgence == 'haute' or service.niveauUrgence == 'high' %}
                            <span class="badge badge-danger">High</span>
                        {% elseif service.niveauUrgence == 'moyenne' or service.niveauUrgence == 'medium' %}
                            <span class="badge badge-warning">Medium</span>
                        {% else %}
                            <span class="badge badge-success">Normal</span>
                        {% endif %}
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-label">Created At</span>
                    <span class="info-value">{{ service.createdAt|date('d/m/Y à H:i') }}</span>
                </div>
                {% if service.dateSouhaitee %}
                <div class="info-row">
                    <span class="info-label">Desired Date</span>
                    <span class="info-value">{{ service.dateSouhaitee|date('d/m/Y à H:i') }}</span>
                </div>
                {% endif %}
                <div class="info-row">
                    <span class="info-label">Notify Close Ones</span>
                    <span class="info-value">
                        {% if service.notifierProches %}
                            <span style="color: #10b981;">✓ Yes</span>
                        {% else %}
                            <span style="color: #6b7280;">✗ No</span>
                        {% endif %}
                    </span>
                </div>
            </div>
        </div>

        <!-- Location -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">📍 Location</h2>
            </div>
            <div style="padding: 1rem;">
                <div class="info-row">
                    <span class="info-label">Address</span>
                    <span class="info-value">{{ service.adresse ?: 'Not provided' }}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">City</span>
                    <span class="info-value">{{ service.ville ?: 'Not provided' }}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Postal Code</span>
                    <span class="info-value">{{ service.codePostal ?: 'Not provided' }}</span>
                </div>
            </div>
        </div>

        <!-- Budget -->
        {% if service.budgetMinimum or service.budgetMaximum %}
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">💰 Budget</h2>
            </div>
            <div style="padding: 1rem;">
                {% if service.budgetMinimum %}
                <div class="info-row">
                    <span class="info-label">Minimum Budget</span>
                    <span class="info-value">{{ service.budgetMinimum }} €</span>
                </div>
                {% endif %}
                {% if service.budgetMaximum %}
                <div class="info-row">
                    <span class="info-label">Maximum Budget</span>
                    <span class="info-value">{{ service.budgetMaximum }} €</span>
                </div>
                {% endif %}
            </div>
        </div>
        {% endif %}

    </div>

    <!-- Right Column -->
    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        
        <!-- Description -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">📝 Description</h2>
            </div>
            <div style="padding: 1rem;">
                <p style="margin: 0; line-height: 1.6; color: #374151;">{{ service.description }}</p>
            </div>
        </div>

        <!-- Technician Info -->
        {% if service.technicienNom %}
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">👨‍🔧 Assigned Technician</h2>
            </div>
            <div style="padding: 1rem;">
                <div class="info-row">
                    <span class="info-label">Name</span>
                    <span class="info-value">{{ service.technicienNom }}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Assigned On</span>
                    <span class="info-value">{{ service.dateAssignation|date('d/m/Y à H:i') }}</span>
                </div>
                {% if service.dateDebut %}
                <div class="info-row">
                    <span class="info-label">Start Date</span>
                    <span class="info-value">{{ service.dateDebut|date('d/m/Y à H:i') }}</span>
                </div>
                {% endif %}
                {% if service.dateFin %}
                <div class="info-row">
                    <span class="info-label">End Date</span>
                    <span class="info-value">{{ service.dateFin|date('d/m/Y à H:i') }}</span>
                </div>
                {% endif %}
            </div>
        </div>
        {% endif %}

        <!-- Admin Notes -->
        {% if service.notesAdmin %}
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">📌 Admin Notes</h2>
            </div>
            <div style="padding: 1rem;">
                <p style="margin: 0; line-height: 1.6; color: #374151; background: #fef3c7; padding: 1rem; border-radius: 8px; border-left: 4px solid #f59e0b;">
                    {{ service.notesAdmin }}
                </p>
            </div>
        </div>
        {% endif %}

        <!-- Quick Actions -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title">⚡ Quick Actions</h2>
            </div>
            <div style="padding: 1rem; display: grid; gap: 0.75rem;">
                {% if service.statut == 'pending' %}
                <a href="{{ path('admin_services_assign', {id: service.id}) }}" class="btn btn-primary" style="justify-content: center; gap: 0.5rem;">
                    <span>👤</span> Assign Technician
                </a>
                {% elseif service.technicienNom and intervention %}
                <a href="{{ path('admin_interventions_show', {id: intervention.id}) }}" class="btn btn-primary" style="justify-content: center; gap: 0.5rem;">
                    <span>🔍</span> View Intervention
                </a>
                {% endif %}
                
                <a href="mailto:{{ service.seniorEmail }}" class="btn btn-secondary" style="justify-content: center; gap: 0.5rem;">
                    <span>📧</span> Contact Requester
                </a>
                
                <a href="tel:{{ service.seniorTelephone }}" class="btn btn-secondary" style="justify-content: center; gap: 0.5rem;">
                    <span>📱</span> Call Requester
                </a>
                
                {% if service.statut != 'cancelled' and service.statut != 'completed' %}
                <button class="btn" style="justify-content: center; gap: 0.5rem; background: #ef4444; color: white;">
                    <span>❌</span> Cancel Request
                </button>
                {% endif %}
            </div>
        </div>

    </div>
</div>
{% endblock %}
