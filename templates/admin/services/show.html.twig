{% extends 'admin/base_admin.html.twig' %}

{% block title %}Service Request #{{ service.id }} - Admin WANNASNI{% endblock %}
{% block page_title %}Service Request Details{% endblock %}

{% block content %}
<div style="margin-bottom: 1rem;">
    <a href="{{ path('admin_services_list') }}" class="btn btn-secondary">← Back to Services</a>
</div>

<div class="grid-2">
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Request #{{ service.id }}</h2>
            {% if service.status == 'pending' %}
                <span class="badge badge-warning">Pending</span>
            {% elseif service.status == 'in_progress' %}
                <span class="badge badge-info">In Progress</span>
            {% elseif service.status == 'completed' %}
                <span class="badge badge-success">Completed</span>
            {% else %}
                <span class="badge badge-default">Cancelled</span>
            {% endif %}
        </div>
        
        <div style="display: grid; gap: 1rem;">
            <div style="padding: 1rem; background: var(--bg-tertiary); border-radius: var(--radius-md);">
                <div style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; margin-bottom: 0.5rem;">Requester</div>
                <div style="font-weight: 600; font-size: 1.1rem;">{{ service.requester }}</div>
            </div>
            
            <div style="display: grid; gap: 0.75rem;">
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: var(--text-secondary);">Service Type</span>
                    <span style="font-weight: 500;">{{ service.type }}</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: var(--text-secondary);">Priority</span>
                    {% if service.priority == 'high' %}
                        <span class="badge badge-danger">High</span>
                    {% elseif service.priority == 'medium' %}
                        <span class="badge badge-warning">Medium</span>
                    {% else %}
                        <span class="badge badge-default">Low</span>
                    {% endif %}
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: var(--text-secondary);">Requested At</span>
                    <span style="font-weight: 500;">{{ service.requestedAt|date('M d, Y H:i') }}</span>
                </div>
            </div>
            
            <div>
                <div style="font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Description</div>
                <p style="padding: 1rem; background: var(--bg-tertiary); border-radius: var(--radius-md);">{{ service.description }}</p>
            </div>
        </div>
    </div>
    
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Quick Actions</h2>
        </div>
        <div style="display: grid; gap: 0.75rem;">
            {% if service.status == 'pending' %}
            <button class="btn btn-primary" style="justify-content: flex-start;">
                <span>▶️</span> Start Processing
            </button>
            {% endif %}
            {% if service.status == 'in_progress' %}
            <button class="btn btn-primary" style="justify-content: flex-start;">
                <span>✅</span> Mark as Completed
            </button>
            {% endif %}
            <a href="{{ path('admin_services_edit', {id: service.id}) }}" class="btn btn-secondary" style="justify-content: flex-start;">
                <span>✏️</span> Edit Request
            </a>
            <button class="btn btn-secondary" style="justify-content: flex-start;">
                <span>📧</span> Contact Requester
            </button>
            {% if service.status != 'cancelled' and service.status != 'completed' %}
            <button class="btn btn-secondary" style="justify-content: flex-start; color: var(--danger);">
                <span>❌</span> Cancel Request
            </button>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
