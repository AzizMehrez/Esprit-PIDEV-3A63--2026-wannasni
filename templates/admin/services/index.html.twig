{% extends 'admin/base_admin.html.twig' %}

{% block title %}Services - Admin WANNASNI{% endblock %}
{% block page_title %}Gestion des Services{% endblock %}

{% block header_actions %}
<a href="{{ path('admin_services_new') }}" class="btn btn-primary">➕ Nouveau Service</a>
{% endblock %}

{% block content %}
{# Statistics Cards #}
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon orange">🛎️</div>
        <div class="stat-info">
            <div class="stat-value">{{ services|length }}</div>
            <div class="stat-label">Total Demandes</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue">⏳</div>
        <div class="stat-info">
            <div class="stat-value">{{ services|filter(s => s.status == 'pending')|length }}</div>
            <div class="stat-label">En Attente</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon cyan">🔄</div>
        <div class="stat-info">
            <div class="stat-value">{{ services|filter(s => s.status == 'in_progress')|length }}</div>
            <div class="stat-label">En Cours</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon red">🔴</div>
        <div class="stat-info">
            <div class="stat-value">{{ services|filter(s => s.priority == 'high')|length }}</div>
            <div class="stat-label">Priorité Haute</div>
        </div>
    </div>
</div>

{# Toolbar #}
<div class="admin-toolbar">
    <div class="toolbar-search">
        <input type="text" id="searchInput" placeholder="Rechercher un service..." onkeyup="filterTable()">
    </div>
    <div class="toolbar-actions">
        <button class="filter-btn">
            🔽 Filtrer
        </button>
        <a href="#" class="export-btn pdf" onclick="exportPDF(); return false;">
            📄 PDF
        </a>
        <a href="#" class="export-btn excel" onclick="exportExcel(); return false;">
            📊 Excel
        </a>
    </div>
</div>

{# Table #}
<div class="admin-card">
    <div class="card-header">
        <h2 class="card-title">🛎️ Demandes de Services</h2>
        <span class="badge badge-warning">{{ services|length }} demandes</span>
    </div>
    <table class="admin-table" id="dataTable">
        <thead>
            <tr>
                <th class="sortable" onclick="sortTable(0)">Service</th>
                <th class="sortable" onclick="sortTable(1)">Demandeur</th>
                <th class="sortable" onclick="sortTable(2)">Priorité</th>
                <th class="sortable" onclick="sortTable(3)">Statut</th>
                <th class="sortable" onclick="sortTable(4)">Demandé le</th>
                <th style="width: 120px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for service in services %}
            <tr>
                <td>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, #f59e0b, #fbbf24); display: flex; align-items: center; justify-content: center; font-size: 1.1rem;">
                            {% if 'Transport' in service.type %}🚗
                            {% elseif 'Home' in service.type %}🏠
                            {% else %}🛎️{% endif %}
                        </div>
                        <div>
                            <div style="font-weight: 600;">{{ service.type }}</div>
                            <div style="font-size: 0.8rem; color: var(--admin-text-muted);">{{ service.description|slice(0, 35) }}...</div>
                        </div>
                    </div>
                </td>
                <td>{{ service.requester }}</td>
                <td>
                    {% if service.priority == 'high' %}
                        <span class="badge badge-danger">🔴 Urgente</span>
                    {% elseif service.priority == 'medium' %}
                        <span class="badge badge-warning">🟡 Moyenne</span>
                    {% else %}
                        <span class="badge badge-success">🟢 Normale</span>
                    {% endif %}
                </td>
                <td>
                    {% if service.status == 'pending' %}
                        <span class="badge badge-warning">⏳ En attente</span>
                    {% elseif service.status == 'in_progress' %}
                        <span class="badge badge-info">🔄 En cours</span>
                    {% elseif service.status == 'completed' %}
                        <span class="badge badge-success">✅ Terminé</span>
                    {% else %}
                        <span class="badge badge-danger">❌ Annulé</span>
                    {% endif %}
                </td>
                <td>{{ service.requestedAt|date('d/m/Y') }}</td>
                <td>
                    <a href="{{ path('admin_services_show', {id: service.id}) }}" class="action-btn" title="Voir">👁️</a>
                    <a href="{{ path('admin_services_edit', {id: service.id}) }}" class="action-btn" title="Traiter">✏️</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<script>
/* ── Search ── */
function filterTable() {
    const filter = document.getElementById('searchInput').value.toLowerCase();
    const tbody  = document.querySelector('#dataTable tbody');
    const rows   = tbody.querySelectorAll('tr');
    rows.forEach(row => {
        const cells = row.querySelectorAll('td');
        let found = false;
        cells.forEach((cell, idx) => {
            if (idx < cells.length - 1 && cell.textContent.toLowerCase().includes(filter)) found = true;
        });
        row.style.display = found ? '' : 'none';
    });
}

/* ── Sort ── */
let sortDirection = {};
function sortTable(columnIndex) {
    const table   = document.getElementById('dataTable');
    const tbody   = table.querySelector('tbody');
    const rows    = Array.from(tbody.querySelectorAll('tr'));
    const headers = table.querySelectorAll('thead th');

    sortDirection[columnIndex] = !sortDirection[columnIndex];
    const ascending = sortDirection[columnIndex];
    headers.forEach(h => h.classList.remove('asc', 'desc'));
    headers[columnIndex].classList.add(ascending ? 'asc' : 'desc');

    // Date column index 4
    rows.sort((a, b) => {
        let aText = a.cells[columnIndex].textContent.trim();
        let bText = b.cells[columnIndex].textContent.trim();
        if (columnIndex === 4) {
            const aDate = new Date(aText.split('/').reverse().join('-'));
            const bDate = new Date(bText.split('/').reverse().join('-'));
            return ascending ? aDate - bDate : bDate - aDate;
        }
        return ascending
            ? aText.toLowerCase().localeCompare(bText.toLowerCase())
            : bText.toLowerCase().localeCompare(aText.toLowerCase());
    });
    rows.forEach(row => tbody.appendChild(row));
}

/* ── PDF Export ── */
function exportPDF() {
    const table = document.getElementById('dataTable');
    const rows  = table.querySelectorAll('tbody tr');
    const date  = new Date().toLocaleDateString('fr-FR');
    let tableHTML = '';
    rows.forEach(row => {
        if (row.style.display === 'none') return;
        const c = row.querySelectorAll('td');
        tableHTML += '<tr>';
        tableHTML += '<td>' + c[0].textContent.trim().replace(/\s+/g, ' ') + '</td>';
        tableHTML += '<td>' + c[1].textContent.trim() + '</td>';
        tableHTML += '<td>' + c[2].textContent.trim() + '</td>';
        tableHTML += '<td>' + c[3].textContent.trim() + '</td>';
        tableHTML += '<td>' + c[4].textContent.trim() + '</td>';
        tableHTML += '</tr>';
    });
    const html = `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Services - WANNASNI</title>
<style>body{font-family:Arial,sans-serif;padding:30px;color:#1e293b}h1{text-align:center;margin-bottom:4px;color:#1e40af}.subtitle{text-align:center;color:#64748b;margin-bottom:24px;font-size:14px}table{width:100%;border-collapse:collapse;margin-top:10px}th{background:#1e40af;color:#fff;padding:10px 12px;text-align:left;font-size:13px}td{padding:9px 12px;border-bottom:1px solid #e2e8f0;font-size:13px}tr:nth-child(even){background:#f8fafc}.footer{text-align:center;margin-top:30px;font-size:11px;color:#94a3b8}</style></head><body>
<h1>🛎️ Demandes de Services</h1><p class="subtitle">WANNASNI – Généré le ${date}</p>
<table><thead><tr><th>Service</th><th>Demandeur</th><th>Priorité</th><th>Statut</th><th>Demandé le</th></tr></thead><tbody>${tableHTML}</tbody></table>
<p class="footer">WANNASNI – Système de Gestion – ${date}</p></body></html>`;
    const win = window.open('', '_blank');
    win.document.write(html); win.document.close(); win.focus();
    setTimeout(() => win.print(), 400);
}

/* ── Excel / CSV Export ── */
function exportExcel() {
    const table = document.getElementById('dataTable');
    const rows  = table.querySelectorAll('tbody tr');
    const BOM   = '\uFEFF';
    let csv     = BOM + 'Service;Demandeur;Priorité;Statut;Demandé le\n';
    rows.forEach(row => {
        if (row.style.display === 'none') return;
        const c = row.querySelectorAll('td');
        csv += [
            c[0].textContent.trim().replace(/\s+/g, ' ').replace(/;/g, ','),
            c[1].textContent.trim(),
            c[2].textContent.trim(),
            c[3].textContent.trim(),
            c[4].textContent.trim()
        ].join(';') + '\n';
    });
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = 'services_wannasni_' + new Date().toISOString().slice(0,10) + '.csv';
    a.click(); URL.revokeObjectURL(url);
}
</script>
{% endblock %}
