{% extends 'admin/base_admin.html.twig' %}

{% block title %}Services - Admin WANNASNI{% endblock %}
{% block page_title %}Gestion des Services{% endblock %}


{% block content %}

{# Flash Messages #}
{% for message in app.flashes('success') %}
    <div class="alert alert-success">
        ✅ {{ message }}
    </div>
{% endfor %}

{% for message in app.flashes('error') %}
    <div class="alert alert-danger">
        ❌ {{ message }}
    </div>
{% endfor %}

{# Statistics Cards #}
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon orange">🛎️</div>
        <div class="stat-info">
            <div class="stat-value">{{ services|length }}</div>
            <div class="stat-label">Total Demandes</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue">⏳</div>
        <div class="stat-info">
            <div class="stat-value">{{ services|filter(s => s.statut == 'pending')|length }}</div>
            <div class="stat-label">En Attente</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon cyan">🔄</div>
        <div class="stat-info">
            <div class="stat-value">{{ services|filter(s => s.statut == 'in_progress')|length }}</div>
            <div class="stat-label">En Cours</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon red">🔴</div>
        <div class="stat-info">
            <div class="stat-value">{{ services|filter(s => s.niveauUrgence == 'urgent')|length }}</div>
            <div class="stat-label">Priorité Haute</div>
        </div>
    </div>
</div>

{# Navigation entre Services et Interventions #}
<div style="margin-bottom: 2rem; text-align: center;">
    <a href="{{ path('admin_interventions') }}" class="btn btn-info" style="margin: 0.5rem;">
        🔧 Voir les Interventions →
    </a>
</div>

{# Toolbar #}
<div class="admin-toolbar">
    <div class="toolbar-search">
        <form method="get" action="{{ path('admin_services') }}">
            <input type="text" name="q" value="{{ searchQuery }}" placeholder="Rechercher (type, email, desc)...">
            <button type="submit" style="display: none;">Search</button>
        </form>
    </div>
    <div class="toolbar-actions">
        {% if searchQuery %}
            <a href="{{ path('admin_services') }}" class="btn btn-secondary btn-sm" style="margin-right: 1rem;">
                ❌ Effacer la recherche
            </a>
        {% endif %}
        <button class="filter-btn">
            🔽 Filtrer
        </button>
        <a href="{{ path('admin_services_export_pdf', {'q': searchQuery}) }}" class="export-btn pdf">
            📄 PDF
        </a>
        <a href="#" class="export-btn excel" onclick="alert('Export Excel - Fonctionnalité à implémenter')">
            📊 Excel
        </a>
    </div>
</div>

{# Table #}
<div class="admin-card">
    <div class="card-header">
        <h2 class="card-title">🛎️ Demandes de Services</h2>
        <span class="badge badge-warning">{{ services|length }} demandes</span>
    </div>
    <table class="admin-table" id="dataTable">
        <thead>
            <tr>
                <th class="sortable" onclick="sortTable(0)">Service</th>
                <th class="sortable" onclick="sortTable(1)">Senior</th>
                <th class="sortable" onclick="sortTable(2)">Urgence</th>
                <th class="sortable" onclick="sortTable(3)">Statut</th>
                <th class="sortable" onclick="sortTable(4)">Date Souhaitée</th>
                <th class="sortable" onclick="sortTable(5)">Créé le</th>
                <th style="width: 220px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for service in services %}
            <tr>
                <td>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, #f59e0b, #fbbf24); display: flex; align-items: center; justify-content: center; font-size: 1.1rem;">
                            {% if 'transport' in service.typeService|lower %}🚗
                            {% elseif 'menage' in service.typeService|lower or 'ménage' in service.typeService|lower %}🏠
                            {% elseif 'course' in service.typeService|lower %}🛒
                            {% elseif 'accompagnement' in service.typeService|lower %}🤝
                            {% else %}🛎️{% endif %}
                        </div>
                        <div>
                            <div style="font-weight: 600;">{{ service.typeService }}</div>
                            <div style="font-size: 0.8rem; color: var(--admin-text-muted);">
                                {{ service.description|length > 35 ? service.description|slice(0, 35) ~ '...' : service.description }}
                            </div>
                        </div>
                    </div>
                </td>
                <td>
                    <div>
                        <div style="font-weight: 500;">{{ service.seniorEmail ?: 'Non renseigné' }}</div>
                        <div style="font-size: 0.8rem; color: var(--admin-text-muted);">{{ service.seniorTelephone ?: 'Pas de téléphone' }}</div>
                    </div>
                </td>
                <td>
                    {% if service.niveauUrgence == 'urgent' %}
                        <span class="badge badge-danger">🔴 Urgent</span>
                    {% elseif service.niveauUrgence == 'moyen' %}
                        <span class="badge badge-warning">🟡 Moyen</span>
                    {% else %}
                        <span class="badge badge-success">🟢 Normal</span>
                    {% endif %}
                </td>
                <td>
                    {% if service.statut == 'pending' %}
                        <span class="badge badge-warning">⏳ En attente</span>
                    {% elseif service.statut == 'in_progress' %}
                        <span class="badge badge-info">🔄 En cours</span>
                    {% elseif service.statut == 'completed' %}
                        <span class="badge badge-success">✅ Terminé</span>
                    {% elseif service.statut == 'assigned' %}
                        <span class="badge badge-info">👤 Assigné</span>
                    {% else %}
                        <span class="badge badge-danger">❌ Annulé</span>
                    {% endif %}
                </td>
                <td>{{ service.dateSouhaitee ? service.dateSouhaitee|date('d/m/Y') : 'Non précisé' }}</td>
                <td>{{ service.createdAt|date('d/m/Y H:i') }}</td>
                <td>
                    <div style="display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
                        {# Voir les détails #}
                        <a href="{{ path('admin_services_show', {id: service.id}) }}" 
                           class="action-btn action-btn-view" 
                           title="Voir les détails"
                           style="color: #2196f3;">
                            👁️
                        </a>

                        {# ACTION PRINCIPALE: Assigner ou Modifier selon si intervention existe #}
                        {% if service.interventions|length == 0 %}
                            {# Pas d'intervention -> Assigner/Créer #}
                            <a href="{{ path('admin_services_assign', {id: service.id}) }}" 
                               class="action-btn" 
                               title="Assigner un technicien"
                               style="background-color: #4caf50; color: white;">
                                ➕
                            </a>
                        {% else %}
                            {# Intervention existe -> Modifier #}
                            {% set lastIntervention = service.interventions|first %}
                            <a href="{{ path('admin_interventions_edit', {id: lastIntervention.id}) }}" 
                               class="action-btn" 
                               title="Modifier l'intervention"
                               style="background-color: #ff9800; color: white;">
                                ✏️
                            </a>
                            
                            {# Bouton suppression pour l'intervention #}
                            <form method="post" 
                                  action="{{ path('admin_interventions_delete', {id: lastIntervention.id}) }}" 
                                  style="display: inline;"
                                  onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette intervention ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ lastIntervention.id) }}">
                                <button type="submit" 
                                        class="action-btn" 
                                        title="Supprimer l'intervention"
                                        style="background-color: #f44336; color: white; border: none; cursor: pointer;">
                                    🗑️
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="7" style="text-align: center; padding: 2rem; color: var(--admin-text-muted);">
                    Aucune demande de service pour le moment
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{# Modal de confirmation de suppression #}
<div id="deleteModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>⚠️ Confirmer la suppression</h3>
        </div>
        <div class="modal-body">
            <p>Êtes-vous sûr de vouloir supprimer cette demande de service ?</p>
            <p><strong id="serviceToDelete"></strong></p>
            <p style="color: #dc3545; font-size: 0.9rem;">⚠️ Cette action est irréversible.</p>
        </div>
        <div class="modal-footer">
            <button onclick="closeDeleteModal()" class="btn btn-secondary">Annuler</button>
            <form id="deleteForm" method="post" style="display: inline;">
                <input type="hidden" name="_token" id="deleteToken">
                <button type="submit" class="btn btn-danger">🗑️ Supprimer</button>
            </form>
        </div>
    </div>
</div>

<style>
.alert {
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    border-radius: 8px;
    border-left: 4px solid;
}

.alert-success {
    background-color: #d4edda;
    border-color: #28a745;
    color: #155724;
}

.alert-danger {
    background-color: #f8d7da;
    border-color: #dc3545;
    color: #721c24;
}

.action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 1rem;
    transition: all 0.2s;
    text-decoration: none;
}

.action-btn-view {
    background: #e3f2fd;
}

.action-btn-view:hover {
    background: #2196f3;
    transform: scale(1.1);
}

.action-btn-assign {
    background: #e8f5e9;
}

.action-btn-assign:hover {
    background: #4caf50;
    transform: scale(1.1);
}

.action-btn-edit {
    background: #fff3e0;
}

.action-btn-edit:hover {
    background: #ff9800;
    transform: scale(1.1);
}

.action-btn-delete {
    background: #ffebee;
}

.action-btn-delete:hover {
    background: #f44336;
    transform: scale(1.1);
}

/* Modal Styles */
.modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    animation: fadeIn 0.3s;
}

.modal.active {
    display: flex;
    align-items: center;
    justify-content: center;
}

.modal-content {
    background-color: white;
    border-radius: 12px;
    max-width: 500px;
    width: 90%;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    animation: slideIn 0.3s;
}

.modal-header {
    padding: 1.5rem;
    border-bottom: 1px solid #e9ecef;
}

.modal-header h3 {
    margin: 0;
    color: #333;
}

.modal-body {
    padding: 1.5rem;
}

.modal-footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid #e9ecef;
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

@keyframes slideIn {
    from { transform: translateY(-50px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}
</style>

<script>
let sortDirection = {};
function sortTable(columnIndex) {
    const table = document.getElementById('dataTable');
    const tbody = table.getElementsByTagName('tbody')[0];
    const rows = Array.from(tbody.getElementsByTagName('tr'));
    const headers = table.getElementsByTagName('th');
    
    sortDirection[columnIndex] = !sortDirection[columnIndex];
    const ascending = sortDirection[columnIndex];
    
    for (let i = 0; i < headers.length; i++) {
        headers[i].classList.remove('asc', 'desc');
    }
    headers[columnIndex].classList.add(ascending ? 'asc' : 'desc');
    
    rows.sort((a, b) => {
        const aText = a.cells[columnIndex].textContent.trim().toLowerCase();
        const bText = b.cells[columnIndex].textContent.trim().toLowerCase();
        return ascending ? aText.localeCompare(bText) : bText.localeCompare(aText);
    });
    
    rows.forEach(row => tbody.appendChild(row));
}

function confirmDelete(button) {
    const serviceId = button.dataset.serviceId;
    const serviceName = button.dataset.serviceName;
    const csrfToken = button.dataset.csrfToken;
    
    const modal = document.getElementById('deleteModal');
    const serviceToDelete = document.getElementById('serviceToDelete');
    const deleteForm = document.getElementById('deleteForm');
    const deleteToken = document.getElementById('deleteToken');
    
    serviceToDelete.textContent = serviceName;
    deleteForm.action = `/admin/services/${serviceId}/delete`;
    deleteToken.value = csrfToken;
    
    modal.classList.add('active');
}

function closeDeleteModal() {
    const modal = document.getElementById('deleteModal');
    modal.classList.remove('active');
}

window.onclick = function(event) {
    const modal = document.getElementById('deleteModal');
    if (event.target == modal) {
        closeDeleteModal();
    }
}
</script>
{% endblock %}