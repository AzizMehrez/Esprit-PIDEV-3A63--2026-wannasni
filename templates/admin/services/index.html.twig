{% extends 'admin/base_admin.html.twig' %}

{% block title %}Services - Admin WANNASNI{% endblock %}
{% block page_title %}Gestion des Services{% endblock %}

{% block header_actions %}
<a href="{{ path('admin_services_new') }}" class="btn btn-primary">➕ Nouveau Service</a>
{% endblock %}

{% block content %}
{# Statistics Cards #}
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon orange">🛎️</div>
        <div class="stat-info">
            <div class="stat-value">{{ services|length }}</div>
            <div class="stat-label">Total Demandes</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue">⏳</div>
        <div class="stat-info">
            <div class="stat-value">{{ services|filter(s => s.status == 'pending')|length }}</div>
            <div class="stat-label">En Attente</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon cyan">🔄</div>
        <div class="stat-info">
            <div class="stat-value">{{ services|filter(s => s.status == 'in_progress')|length }}</div>
            <div class="stat-label">En Cours</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon red">🔴</div>
        <div class="stat-info">
            <div class="stat-value">{{ services|filter(s => s.priority == 'high')|length }}</div>
            <div class="stat-label">Priorité Haute</div>
        </div>
    </div>
</div>

{# Toolbar #}
<div class="admin-toolbar">
    <div class="toolbar-search">
        <input type="text" id="searchInput" placeholder="Rechercher un service..." onkeyup="filterTable()">
    </div>
    <div class="toolbar-actions">
        <button class="filter-btn">
            🔽 Filtrer
        </button>
        <a href="#" class="export-btn pdf" onclick="alert('Export PDF - Fonctionnalité à implémenter')">
            📄 PDF
        </a>
        <a href="#" class="export-btn excel" onclick="alert('Export Excel - Fonctionnalité à implémenter')">
            📊 Excel
        </a>
    </div>
</div>

{# Table #}
<div class="admin-card">
    <div class="card-header">
        <h2 class="card-title">🛎️ Demandes de Services</h2>
        <span class="badge badge-warning">{{ services|length }} demandes</span>
    </div>
    <table class="admin-table" id="dataTable">
        <thead>
            <tr>
                <th class="sortable" onclick="sortTable(0)">Service</th>
                <th class="sortable" onclick="sortTable(1)">Demandeur</th>
                <th class="sortable" onclick="sortTable(2)">Priorité</th>
                <th class="sortable" onclick="sortTable(3)">Statut</th>
                <th class="sortable" onclick="sortTable(4)">Demandé le</th>
                <th style="width: 120px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for service in services %}
            <tr>
                <td>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, #f59e0b, #fbbf24); display: flex; align-items: center; justify-content: center; font-size: 1.1rem;">
                            {% if 'Transport' in service.type %}🚗
                            {% elseif 'Home' in service.type %}🏠
                            {% else %}🛎️{% endif %}
                        </div>
                        <div>
                            <div style="font-weight: 600;">{{ service.type }}</div>
                            <div style="font-size: 0.8rem; color: var(--admin-text-muted);">{{ service.description|slice(0, 35) }}...</div>
                        </div>
                    </div>
                </td>
                <td>{{ service.requester }}</td>
                <td>
                    {% if service.priority == 'high' %}
                        <span class="badge badge-danger">🔴 Urgente</span>
                    {% elseif service.priority == 'medium' %}
                        <span class="badge badge-warning">🟡 Moyenne</span>
                    {% else %}
                        <span class="badge badge-success">🟢 Normale</span>
                    {% endif %}
                </td>
                <td>
                    {% if service.status == 'pending' %}
                        <span class="badge badge-warning">⏳ En attente</span>
                    {% elseif service.status == 'in_progress' %}
                        <span class="badge badge-info">🔄 En cours</span>
                    {% elseif service.status == 'completed' %}
                        <span class="badge badge-success">✅ Terminé</span>
                    {% else %}
                        <span class="badge badge-danger">❌ Annulé</span>
                    {% endif %}
                </td>
                <td>{{ service.requestedAt|date('d/m/Y') }}</td>
                <td>
                    <a href="{{ path('admin_services_show', {id: service.id}) }}" class="action-btn" title="Voir">👁️</a>
                    <a href="{{ path('admin_services_edit', {id: service.id}) }}" class="action-btn" title="Traiter">✏️</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<script>
function filterTable() {
    const input = document.getElementById('searchInput');
    const filter = input.value.toLowerCase();
    const table = document.getElementById('dataTable');
    const rows = table.getElementsByTagName('tr');

    for (let i = 1; i < rows.length; i++) {
        const cells = rows[i].getElementsByTagName('td');
        let found = false;
        for (let j = 0; j < cells.length - 1; j++) {
            if (cells[j].textContent.toLowerCase().includes(filter)) {
                found = true;
                break;
            }
        }
        rows[i].style.display = found ? '' : 'none';
    }
}

let sortDirection = {};
function sortTable(columnIndex) {
    const table = document.getElementById('dataTable');
    const tbody = table.getElementsByTagName('tbody')[0];
    const rows = Array.from(tbody.getElementsByTagName('tr'));
    const headers = table.getElementsByTagName('th');
    
    sortDirection[columnIndex] = !sortDirection[columnIndex];
    const ascending = sortDirection[columnIndex];
    
    for (let i = 0; i < headers.length; i++) {
        headers[i].classList.remove('asc', 'desc');
    }
    headers[columnIndex].classList.add(ascending ? 'asc' : 'desc');
    
    rows.sort((a, b) => {
        const aText = a.cells[columnIndex].textContent.trim().toLowerCase();
        const bText = b.cells[columnIndex].textContent.trim().toLowerCase();
        return ascending ? aText.localeCompare(bText) : bText.localeCompare(aText);
    });
    
    rows.forEach(row => tbody.appendChild(row));
}
</script>
{% endblock %}
