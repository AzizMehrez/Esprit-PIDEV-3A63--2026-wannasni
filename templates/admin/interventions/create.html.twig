{% extends 'admin/base_admin.html.twig' %}

{% block title %}Nouvelle Intervention - Admin WANNASNI{% endblock %}
{% block page_title %}Créer une Intervention{% endblock %}

{% block content %}

{% for message in app.flashes('success') %}
    <div class="alert alert-success">✅ {{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="alert alert-danger">❌ {{ message }}</div>
{% endfor %}

<div class="admin-toolbar" style="margin-bottom: 2rem;">
    <a href="{{ path('admin_interventions') }}" class="btn btn-secondary">← Retour à la liste</a>
</div>

<form method="post" novalidate>
    <div class="row">
        <div class="col-md-8">
            <div class="admin-card" style="margin-bottom: 1.5rem;">
                <div class="card-header"><h2 class="card-title">🛎️ Service Associé</h2></div>
                <div class="card-body">
                    <div class="form-group">
                        <label for="service_request_id">Demande de service (optionnel)</label>
                        <select id="service_request_id" name="service_request_id" class="form-control">
                            <option value="">-- Aucun service associé --</option>
                            {% for service in services %}
                            <option value="{{ service.id }}" 
                                    data-type="{{ service.typeService }}" 
                                    data-zone="{{ service.ville }}"
                                    data-email="{{ service.seniorEmail }}"
                                    data-user-email="{{ service.user ? service.user.email : '' }}">
                                #{{ service.id }} - {{ service.typeService }} {% if service.ville %}({{ service.ville }}){% endif %}
                            </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div id="emailInfo" style="display: none; margin-top: 1rem; padding: 1rem; background: #e0f2fe; border-radius: 8px; border-left: 4px solid #0284c7;">
                        <strong>📧 Email du devis</strong><br>
                        <small>Le devis sera automatiquement envoyé à : <span id="emailRecipients"></span></small>
                    </div>
                </div>
            </div>

            <div class="admin-card" style="margin-bottom: 1.5rem;">
                <div class="card-header"><h2 class="card-title">📋 Informations</h2></div>
                <div class="card-body">
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="competences">Compétences requises *</label>
                            <input type="text" id="competences" name="competences" class="form-control" placeholder="Ex: Transport, Ménage..." required>
                        </div>
                        <div class="form-group">
                            <label for="zone_intervention">Zone d'intervention *</label>
                            <input type="text" id="zone_intervention" name="zone_intervention" class="form-control" placeholder="Ex: Paris 15e" required>
                        </div>
                        <div class="form-group">
                            <label for="heures_travail">Heures de travail *</label>
                            <input type="number" id="heures_travail" name="heures_travail" class="form-control" value="2" min="1" required>
                        </div>
                        <div class="form-group">
                            <label for="tarif_horaire">Tarif horaire (€) *</label>
                            <input type="number" id="tarif_horaire" name="tarif_horaire" class="form-control" value="25.00" step="0.01" min="0" required>
                        </div>
                        <div class="form-group" style="grid-column: 1 / -1;">
                            <label>Coût total estimé</label>
                            <div style="font-size: 1.5rem; font-weight: 700; color: #f59e0b; padding: 1rem; background: #fef3c7; border-radius: 8px; text-align: center;">
                                <span id="coutTotal">50.00</span>€
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="admin-card" style="margin-bottom: 1.5rem;">
                <div class="card-header"><h2 class="card-title">👤 Technicien</h2></div>
                <div class="card-body">
                    <div class="form-group">
                        <label for="technicien_id">Technicien *</label>
                        <select id="technicien_id" name="technicien_id" class="form-control" required>
                            <option value="">-- Sélectionnez un technicien --</option>
                            {% for tech in techniciens %}
                            <option value="{{ tech.id }}" 
                                    data-email="{{ tech.email }}" 
                                    data-telephone="{{ tech.phone }}" 
                                    data-tarif="{{ tech.tarifHoraire ?: '25.00' }}" 
                                    data-specialite="{{ tech.specialite ?: 'Non spécifié' }}" 
                                    {% if not tech.disponible %}disabled{% endif %}>
                                {{ tech.fullName ?: tech.email }} 
                                {% if tech.specialite %}- {{ tech.specialite }}{% endif %}
                                {% if tech.tarifHoraire %} ({{ tech.tarifHoraire }}€/h){% endif %}
                                {% if not tech.disponible %} - ⚠️ Indisponible{% endif %}
                            </option>
                            {% else %}
                            <option value="" disabled>Aucun technicien disponible (créez des utilisateurs avec @gmail.com)</option>
                            {% endfor %}
                        </select>
                    </div>
                    {% if techniciens|length == 0 %}
                    <div style="margin-top: 1rem; padding: 1rem; background: #fef3c7; border-radius: 8px; border-left: 4px solid #f59e0b;">
                        <strong>⚠️ Aucun technicien trouvé</strong><br>
                        <small>Pour créer des techniciens, enregistrez des utilisateurs avec une adresse email @gmail.com. Vous pouvez définir leur spécialité et tarif horaire depuis leur profil.</small>
                    </div>
                    {% endif %}
                    <div id="techInfo" style="margin-top: 1rem; padding: 1rem; background: #f3f4f6; border-radius: 8px; display: none;">
                        <strong>Infos technicien :</strong><div id="techDetails"></div>
                    </div>
                </div>
            </div>

            <div class="admin-card">
                <div class="card-header"><h2 class="card-title">📝 Notes</h2></div>
                <div class="card-body">
                    <div class="form-group">
                        <label for="notes">Notes internes</label>
                        <textarea id="notes" name="notes" class="form-control" rows="4" placeholder="Notes..."></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="admin-card">
                <div class="card-header"><h2 class="card-title">📊 Statut Initial</h2></div>
                <div class="card-body">
                    <div class="form-group">
                        <label for="statut">Statut</label>
                        <select id="statut" name="statut" class="form-control">
                            <option value="en_attente">⏳ En attente</option>
                            <option value="assignee" selected>👤 Assignée</option>
                            <option value="en_cours">🔄 En cours</option>
                            <option value="terminee">✅ Terminée</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="form-actions" style="margin-top: 2rem; display: flex; gap: 1rem; justify-content: flex-end;">
        <a href="{{ path('admin_interventions') }}" class="btn btn-secondary">Annuler</a>
        <button type="submit" class="btn btn-success">✅ Créer l'intervention</button>
    </div>
</form>

<style>
.alert { padding: 1rem 1.5rem; margin-bottom: 1.5rem; border-radius: 8px; border-left: 4px solid; }
.alert-success { background-color: #d4edda; border-color: #28a745; color: #155724; }
.alert-danger { background-color: #f8d7da; border-color: #dc3545; color: #721c24; }
.row { display: flex; gap: 1.5rem; flex-wrap: wrap; }
.col-md-8 { flex: 0 0 calc(66.666% - 1rem); }
.col-md-4 { flex: 0 0 calc(33.333% - 0.5rem); }
@media (max-width: 768px) { .col-md-8, .col-md-4 { flex: 0 0 100%; } }
.form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; }
.form-group { display: flex; flex-direction: column; }
.form-group label { font-weight: 600; margin-bottom: 0.5rem; color: var(--admin-text); }
.form-control { padding: 0.75rem; border: 1px solid #d1d5db; border-radius: 8px; font-size: 1rem; }
.form-control:focus { outline: none; border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1); }
.btn { padding: 0.75rem 1.5rem; border-radius: 8px; border: none; font-weight: 600; cursor: pointer; transition: all 0.2s; text-decoration: none; display: inline-block; }
.btn-secondary { background: #6b7280; color: white; }
.btn-success { background: #10b981; color: white; }
</style>

<script>
function updateCoutTotal() {
    const heures = parseFloat(document.getElementById('heures_travail').value) || 0;
    const tarif = parseFloat(document.getElementById('tarif_horaire').value) || 0;
    document.getElementById('coutTotal').textContent = (heures * tarif).toFixed(2);
}
document.getElementById('heures_travail').addEventListener('input', updateCoutTotal);
document.getElementById('tarif_horaire').addEventListener('input', updateCoutTotal);

document.getElementById('technicien_id').addEventListener('change', function() {
    const opt = this.options[this.selectedIndex];
    const techInfo = document.getElementById('techInfo');
    if (opt.value) {
        const tarif = opt.dataset.tarif;
        if (tarif) { document.getElementById('tarif_horaire').value = tarif; updateCoutTotal(); }
        if (!document.getElementById('competences').value && opt.dataset.specialite) {
            document.getElementById('competences').value = opt.dataset.specialite;
        }
        document.getElementById('techDetails').innerHTML = `<small>📧 ${opt.dataset.email}<br>📞 ${opt.dataset.telephone}<br>🎯 ${opt.dataset.specialite}<br>💶 ${tarif}€/h</small>`;
        techInfo.style.display = 'block';
    } else { techInfo.style.display = 'none'; }
});

document.getElementById('service_request_id').addEventListener('change', function() {
    const opt = this.options[this.selectedIndex];
    const emailInfo = document.getElementById('emailInfo');
    const emailRecipients = document.getElementById('emailRecipients');
    
    if (opt.value) {
        // Auto-fill fields
        if (opt.dataset.type && !document.getElementById('competences').value) {
            document.getElementById('competences').value = opt.dataset.type;
        }
        if (opt.dataset.zone && !document.getElementById('zone_intervention').value) {
            document.getElementById('zone_intervention').value = opt.dataset.zone;
        }
        
        // Show email recipients
        const emails = [];
        if (opt.dataset.email) {
            emails.push(opt.dataset.email);
        }
        if (opt.dataset.userEmail && opt.dataset.userEmail !== opt.dataset.email) {
            emails.push(opt.dataset.userEmail);
        }
        
        if (emails.length > 0) {
            emailRecipients.textContent = emails.join(', ');
            emailInfo.style.display = 'block';
        } else {
            emailInfo.style.display = 'none';
        }
    } else {
        emailInfo.style.display = 'none';
    }
});
</script>

{% endblock %}
