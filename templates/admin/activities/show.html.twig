{% extends 'admin/base_admin.html.twig' %}

{% block title %}{{ activity.title }} - Admin WANNASNI{% endblock %}
{% block page_title %}Activity Details{% endblock %}

{% block content %}
<div style="margin-bottom: 1rem;">
    <a href="{{ path('admin_activities') }}" class="btn btn-secondary">← Back to Activities</a>
</div>

<div class="grid-2">
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">{{ activity.title }}</h2>
            <div style="display: flex; gap: 0.5rem;">
                <a href="{{ path('admin_activities_edit', {id: activity.id}) }}" class="btn btn-sm btn-primary">Edit</a>
                <form method="post" action="{{ path('admin_activities_delete', {id: activity.id}) }}" style="display:inline;" onsubmit="return confirm('Are you sure?');">
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </div>
        </div>
        
        <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">{{ activity.description }}</p>
        
        <div style="display: grid; gap: 0.75rem;">
            <div style="display: flex; justify-content: space-between;">
                <span style="color: var(--text-secondary);">Type</span>
                <span class="badge {% if activity.type == 'physical' %}badge-success{% elseif activity.type == 'cognitive' %}badge-info{% else %}badge-warning{% endif %}">
                    {{ activity.type|capitalize }}
                </span>
            </div>
            <div style="display: flex; justify-content: space-between;">
                <span style="color: var(--text-secondary);">Location</span>
                <span style="font-weight: 500;">{{ activity.location }}</span>
            </div>
            <div style="display: flex; justify-content: space-between;">
                <span style="color: var(--text-secondary);">Start Time</span>
                <span style="font-weight: 500;">{{ activity.startTime|date('Y-m-d H:i') }}</span>
            </div>
            <div style="display: flex; justify-content: space-between;">
                <span style="color: var(--text-secondary);">End Time</span>
                <span style="font-weight: 500;">{{ activity.endTime|date('Y-m-d H:i') }}</span>
            </div>
            <div style="display: flex; justify-content: space-between;">
                <span style="color: var(--text-secondary);">Max Participants</span>
                <span style="font-weight: 500;">{{ activity.maxParticipants ?? 'Unlimited' }}</span>
            </div>
            <div style="display: flex; justify-content: space-between;">
                <span style="color: var(--text-secondary);">Status</span>
                <span class="badge {% if activity.isActive %}badge-success{% else %}badge-default{% endif %}">
                    {{ activity.isActive ? 'Active' : 'Inactive' }}
                </span>
            </div>
        </div>
    </div>
    
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Participants ({{ activity.currentParticipants }})</h2>
        </div>
        <div style="text-align: center; padding: 2rem; color: var(--text-muted);">
            <span style="font-size: 3rem;">👥</span>
            <p style="margin-top: 1rem;">{{ activity.currentParticipants }} / {% if activity.maxParticipants %}{{ activity.maxParticipants }}{% else %}∞{% endif %} enrolled</p>
        </div>
    </div>
</div>
{% endblock %}
