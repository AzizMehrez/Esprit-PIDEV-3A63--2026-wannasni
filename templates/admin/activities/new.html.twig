{% extends 'admin/base_admin.html.twig' %}

{% block title %}New Activity - Admin WANNASNI{% endblock %}
{% block page_title %}Create New Activity{% endblock %}

{% block content %}
<div style="margin-bottom: 1rem;">
    <a href="{{ path('admin_activities') }}" class="btn btn-secondary">← Back to Activities</a>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-header">
        <h2 class="card-title">Create New Activity</h2>
    </div>
    
    <form method="post" action="{{ path('admin_activities_store') }}">
        <div class="form-group">
            <label class="form-label">Activity Title *</label>
            <input type="text" class="form-input" name="title" placeholder="e.g., Morning Walk" required>
        </div>
        
        <div class="form-group">
            <label class="form-label">Description</label>
            <textarea class="form-input" name="description" rows="3" placeholder="Describe the activity..."></textarea>
        </div>
        
        <div class="form-group">
            <label class="form-label">Type</label>
            <select class="form-input" name="type" required>
                <option value="social">Social</option>
                <option value="physical">Physical</option>
                <option value="cultural">Cultural</option>
                <option value="educational">Educational</option>
            </select>
        </div>
        
        <div class="form-group">
            <label class="form-label">Location</label>
            <input type="text" class="form-input" name="location" placeholder="e.g., Community Center">
        </div>
        
        <div class="form-group">
            <label class="form-label">Start Time *</label>
            <input type="datetime-local" class="form-input" name="start_time" required>
        </div>
        
        <div class="form-group">
            <label class="form-label">End Time</label>
            <input type="datetime-local" class="form-input" name="end_time">
        </div>
        
        <div class="form-group">
            <label class="form-label">Max Participants</label>
            <input type="number" class="form-input" name="max_participants" min="1" placeholder="Leave blank for unlimited">
        </div>
        
        <div class="form-group">
            <label class="form-label">
                <input type="hidden" name="is_active" value="0">
                <input type="checkbox" name="is_active" value="1" checked>
                Active
            </label>
        </div>
        
        <div style="display: flex; gap: 1rem; margin-top: 2rem;">
            <button type="submit" class="btn btn-primary">Create Activity</button>
            <a href="{{ path('admin_activities') }}" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
{% endblock %}
