{% extends 'admin/base_admin.html.twig' %}

{% block title %}Modifier Activité - Admin WANNASNI{% endblock %}
{% block page_title %}Modifier Activité{% endblock %}

{% block content %}
<div style="margin-bottom: 1rem;">
    <a href="{{ path('admin_activities') }}" class="btn btn-secondary">← Retour aux Activités</a>
</div>

<div class="card" style="max-width: 700px;">
    <div class="card-header">
        <h2 class="card-title">Modifier : {{ activity.name }}</h2>
    </div>
    
    <form method="post" action="{{ path('admin_activities_edit', {id: activity.id}) }}">
        <div class="form-group">
            <label class="form-label">Nom de l'activité *</label>
            <input type="text" class="form-input" name="name" value="{{ activity.name }}" required>
        </div>
        
        <div class="form-group">
            <label class="form-label">Description</label>
            <textarea class="form-input" name="description" rows="3">{{ activity.description }}</textarea>
        </div>
        
        <div class="form-group">
            <label class="form-label">Type</label>
            <select class="form-input" name="type">
                <option value="physical" {{ activity.type == 'physical' ? 'selected' : '' }}>Physique</option>
                <option value="cognitive" {{ activity.type == 'cognitive' ? 'selected' : '' }}>Cognitive</option>
                <option value="creative" {{ activity.type == 'creative' ? 'selected' : '' }}>Créative</option>
                <option value="social" {{ activity.type == 'social' ? 'selected' : '' }}>Sociale</option>
                <option value="cultural" {{ activity.type == 'cultural' ? 'selected' : '' }}>Culturelle</option>
                <option value="educational" {{ activity.type == 'educational' ? 'selected' : '' }}>Éducative</option>
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">Lieu</label>
            <input type="text" class="form-input" name="location" value="{{ activity.location }}" placeholder="ex: Salle de gym">
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
                <label class="form-label">Date/heure début</label>
                <input type="datetime-local" class="form-input" name="start_time" value="{{ activity.startTime }}">
            </div>
            <div class="form-group">
                <label class="form-label">Date/heure fin</label>
                <input type="datetime-local" class="form-input" name="end_time" value="{{ activity.endTime }}">
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Max participants</label>
            <input type="number" class="form-input" name="max_participants" value="{{ activity.maxParticipants }}" min="1" max="200">
        </div>
        
        <div class="form-group">
            <label class="form-label">Statut</label>
            <select class="form-input" name="status">
                <option value="active" {{ activity.status == 'active' ? 'selected' : '' }}>Active</option>
                <option value="inactive" {{ activity.status == 'inactive' ? 'selected' : '' }}>Inactive</option>
            </select>
        </div>
        
        <div style="display: flex; gap: 1rem; margin-top: 2rem;">
            <button type="submit" class="btn btn-primary">Sauvegarder</button>
            <a href="{{ path('admin_activities_show', {id: activity.id}) }}" class="btn btn-secondary">Annuler</a>
        </div>
    </form>
</div>
{% endblock %}
