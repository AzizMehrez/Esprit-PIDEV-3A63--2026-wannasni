{% extends 'admin/base_admin.html.twig' %}

{% block title %}Edit Activity - Admin WANNASNI{% endblock %}
{% block page_title %}Edit Activity{% endblock %}

{% block content %}
<div style="margin-bottom: 1rem;">
    <a href="{{ path('admin_activities_list') }}" class="btn btn-secondary">← Back to Activities</a>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-header">
        <h2 class="card-title">Edit: {{ activity.name }}</h2>
    </div>
    
    <form method="post">
        <div class="form-group">
            <label class="form-label">Activity Name</label>
            <input type="text" class="form-input" name="name" value="{{ activity.name }}" required>
        </div>
        
        <div class="form-group">
            <label class="form-label">Description</label>
            <textarea class="form-input" name="description" rows="3">{{ activity.description }}</textarea>
        </div>
        
        <div class="form-group">
            <label class="form-label">Type</label>
            <select class="form-input" name="type">
                <option value="physical" {{ activity.type == 'physical' ? 'selected' : '' }}>Physical</option>
                <option value="cognitive" {{ activity.type == 'cognitive' ? 'selected' : '' }}>Cognitive</option>
                <option value="creative" {{ activity.type == 'creative' ? 'selected' : '' }}>Creative</option>
                <option value="social" {{ activity.type == 'social' ? 'selected' : '' }}>Social</option>
            </select>
        </div>
        
        <div class="form-group">
            <label class="form-label">Duration (minutes)</label>
            <input type="number" class="form-input" name="duration" value="{{ activity.duration }}" min="5" max="180">
        </div>
        
        <div class="form-group">
            <label class="form-label">Schedule</label>
            <input type="text" class="form-input" name="schedule" value="{{ activity.schedule }}" placeholder="e.g., Daily 8:00 AM">
        </div>
        
        <div class="form-group">
            <label class="form-label">Status</label>
            <select class="form-input" name="status">
                <option value="active" {{ activity.status == 'active' ? 'selected' : '' }}>Active</option>
                <option value="inactive" {{ activity.status == 'inactive' ? 'selected' : '' }}>Inactive</option>
            </select>
        </div>
        
        <div style="display: flex; gap: 1rem; margin-top: 2rem;">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="{{ path('admin_activities_show', {id: activity.id}) }}" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
{% endblock %}
