{% extends 'admin/base_admin.html.twig' %}

{% block title %}Activités - Admin WANNASNI{% endblock %}
{% block page_title %}Gestion des Activités{% endblock %}

{% block header_actions %}
<a href="{{ path('admin_activities_new') }}" class="btn btn-primary">➕ Nouvelle Activité</a>
{% endblock %}

{% block content %}
<div class="admin-card">
    <div class="card-header">
        <h2 class="card-title">🎯 Liste des Activités</h2>
        <span class="badge badge-success">{{ activities|length }} activités</span>
    </div>
    <table class="admin-table">
        <thead>
            <tr>
                <th>Activité</th>
                <th>Type</th>
                <th>Horaire</th>
                <th>Participants</th>
                <th>Statut</th>
                <th style="width: 120px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for activity in activities %}
            <tr>
                <td>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, #22c55e, #4ade80); display: flex; align-items: center; justify-content: center; font-size: 1.1rem;">
                            {% if activity.type == 'physical' %}🏃
                            {% elseif activity.type == 'cognitive' %}🧠
                            {% elseif activity.type == 'creative' %}🎨
                            {% else %}👥{% endif %}
                        </div>
                        <div>
                            <div style="font-weight: 600;">{{ activity.name }}</div>
                            <div style="font-size: 0.8rem; color: var(--admin-text-muted);">{{ activity.description|slice(0, 40) }}...</div>
                        </div>
                    </div>
                </td>
                <td>
                    <span class="badge badge-info">{{ activity.type|capitalize }}</span>
                </td>
                <td>{{ activity.schedule }}</td>
                <td>
                    <span style="font-weight: 600;">{{ activity.participants }}</span>
                </td>
                <td>
                    {% if activity.status == 'active' %}
                        <span class="badge badge-success">✓ Active</span>
                    {% else %}
                        <span class="badge badge-warning">⏸ Inactive</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('admin_activities_show', {id: activity.id}) }}" class="action-btn" title="Voir">👁️</a>
                    <a href="{{ path('admin_activities_edit', {id: activity.id}) }}" class="action-btn" title="Modifier">✏️</a>
                    <button class="action-btn danger" title="Supprimer">🗑️</button>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
