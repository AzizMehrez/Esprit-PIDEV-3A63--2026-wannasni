{% extends 'admin/base_admin.html.twig' %}

{% block title %}Activités - Admin WANNASNI{% endblock %}
{% block page_title %}Gestion des Activités{% endblock %}

{% block header_actions %}
<a href="{{ path('admin_activities_new') }}" class="btn btn-primary">➕ Nouvelle Activité</a>
{% endblock %}

{% block content %}
{# Statistics Cards #}
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon green">🎯</div>
        <div class="stat-info">
            <div class="stat-value">{{ activities|length }}</div>
            <div class="stat-label">Total Activités</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue">✓</div>
        <div class="stat-info">
            <div class="stat-value">{{ activities|filter(a => a.status == 'active')|length }}</div>
            <div class="stat-label">Actives</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple">👥</div>
        <div class="stat-info">
            <div class="stat-value">{{ activities|reduce((carry, a) => carry + a.participants, 0) }}</div>
            <div class="stat-label">Participants</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon orange">⏱️</div>
        <div class="stat-info">
            <div class="stat-value">{{ (activities|reduce((carry, a) => carry + a.duration, 0) / activities|length)|round }}min</div>
            <div class="stat-label">Durée Moyenne</div>
        </div>
    </div>
</div>

{# Toolbar #}
<div class="admin-toolbar">
    <div class="toolbar-search">
        <input type="text" id="searchInput" placeholder="Rechercher une activité..." onkeyup="filterTable()">
    </div>
    <div class="toolbar-actions">
        <button class="filter-btn">
            🔽 Filtrer
        </button>
        <a href="#" class="export-btn pdf" onclick="alert('Export PDF - Fonctionnalité à implémenter')">
            📄 PDF
        </a>
        <a href="#" class="export-btn excel" onclick="alert('Export Excel - Fonctionnalité à implémenter')">
            📊 Excel
        </a>
    </div>
</div>

{# Table #}
<div class="admin-card">
    <div class="card-header">
        <h2 class="card-title">🎯 Liste des Activités</h2>
        <span class="badge badge-success">{{ activities|length }} activités</span>
    </div>
    <table class="admin-table" id="dataTable">
        <thead>
            <tr>
                <th class="sortable" onclick="sortTable(0)">Activité</th>
                <th class="sortable" onclick="sortTable(1)">Type</th>
                <th class="sortable" onclick="sortTable(2)">Horaire</th>
                <th class="sortable" onclick="sortTable(3)">Participants</th>
                <th class="sortable" onclick="sortTable(4)">Statut</th>
                <th style="width: 120px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for activity in activities %}
            <tr>
                <td>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, #22c55e, #4ade80); display: flex; align-items: center; justify-content: center; font-size: 1.1rem;">
                            {% if activity.type == 'physical' %}🏃
                            {% elseif activity.type == 'cognitive' %}🧠
                            {% elseif activity.type == 'creative' %}🎨
                            {% else %}👥{% endif %}
                        </div>
                        <div>
                            <div style="font-weight: 600;">{{ activity.name }}</div>
                            <div style="font-size: 0.8rem; color: var(--admin-text-muted);">{{ activity.description|slice(0, 40) }}...</div>
                        </div>
                    </div>
                </td>
                <td>
                    <span class="badge badge-info">{{ activity.type|capitalize }}</span>
                </td>
                <td>{{ activity.schedule }}</td>
                <td>
                    <span style="font-weight: 600;">{{ activity.participants }}</span>
                </td>
                <td>
                    {% if activity.status == 'active' %}
                        <span class="badge badge-success">✓ Active</span>
                    {% else %}
                        <span class="badge badge-warning">⏸ Inactive</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('admin_activities_show', {id: activity.id}) }}" class="action-btn" title="Voir">👁️</a>
                    <a href="{{ path('admin_activities_edit', {id: activity.id}) }}" class="action-btn" title="Modifier">✏️</a>
                    <button class="action-btn danger" title="Supprimer">🗑️</button>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<script>
function filterTable() {
    const input = document.getElementById('searchInput');
    const filter = input.value.toLowerCase();
    const table = document.getElementById('dataTable');
    const rows = table.getElementsByTagName('tr');

    for (let i = 1; i < rows.length; i++) {
        const cells = rows[i].getElementsByTagName('td');
        let found = false;
        for (let j = 0; j < cells.length - 1; j++) {
            if (cells[j].textContent.toLowerCase().includes(filter)) {
                found = true;
                break;
            }
        }
        rows[i].style.display = found ? '' : 'none';
    }
}

let sortDirection = {};
function sortTable(columnIndex) {
    const table = document.getElementById('dataTable');
    const tbody = table.getElementsByTagName('tbody')[0];
    const rows = Array.from(tbody.getElementsByTagName('tr'));
    const headers = table.getElementsByTagName('th');
    
    sortDirection[columnIndex] = !sortDirection[columnIndex];
    const ascending = sortDirection[columnIndex];
    
    for (let i = 0; i < headers.length; i++) {
        headers[i].classList.remove('asc', 'desc');
    }
    headers[columnIndex].classList.add(ascending ? 'asc' : 'desc');
    
    rows.sort((a, b) => {
        const aText = a.cells[columnIndex].textContent.trim().toLowerCase();
        const bText = b.cells[columnIndex].textContent.trim().toLowerCase();
        return ascending ? aText.localeCompare(bText) : bText.localeCompare(aText);
    });
    
    rows.forEach(row => tbody.appendChild(row));
}
</script>
{% endblock %}
