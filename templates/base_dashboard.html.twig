<!DOCTYPE html>
{% set current_locale = app.request.locale|default('fr') %}
{% set text_direction = current_locale == 'ar' ? 'rtl' : 'ltr' %}
<html lang="{{ current_locale }}" dir="{{ text_direction }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="{{ 'meta.description'|trans }}">
        <meta name="theme-color" content="#2E7D32">
        <title>{% block title %}{{ 'site.name'|trans }}{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🌿</text></svg>">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&family=Noto+Sans+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
        {% block stylesheets %}
        <style>
            /* Dashboard Navigation Styles */
            .dash-header {
                background: white;
                box-shadow: 0 2px 12px rgba(0,0,0,0.08);
                position: sticky;
                top: 0;
                z-index: 100;
            }

            .dash-header-inner {
                max-width: 1280px;
                margin: 0 auto;
                padding: 1rem 1.5rem;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
            }

            .dash-logo {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                text-decoration: none;
            }

            .dash-logo img {
                height: 44px;
                width: auto;
            }

            .dash-logo-text {
                font-family: 'Playfair Display', serif;
                font-size: 1.5rem;
                font-weight: 700;
                color: #2E7D32;
            }

            .dash-nav {
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

            .dash-nav-link {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.75rem 1.25rem;
                color: #64748b;
                text-decoration: none;
                font-weight: 600;
                font-size: 1rem;
                border-radius: 50px;
                transition: all 0.2s;
            }

            .dash-nav-link:hover {
                background: #f0fdf4;
                color: #2E7D32;
            }

            .dash-nav-link.active {
                background: linear-gradient(135deg, #2E7D32, #4CAF50);
                color: white;
            }

            .dash-nav-icon {
                font-size: 1.25rem;
            }

            .dash-user-menu {
                display: flex;
                align-items: center;
                gap: 1rem;
            }

            .dash-user-avatar {
                width: 44px;
                height: 44px;
                border-radius: 50%;
                background: linear-gradient(135deg, #2E7D32, #4CAF50);
                color: white;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 700;
                font-size: 1.1rem;
            }

            .dash-logout {
                padding: 0.6rem 1.25rem;
                background: #f1f5f9;
                color: #64748b;
                text-decoration: none;
                font-weight: 600;
                font-size: 0.9rem;
                border-radius: 50px;
                transition: all 0.2s;
            }

            .dash-logout:hover {
                background: #fef2f2;
                color: #dc2626;
            }

            /* Mobile Nav */
            @media (max-width: 768px) {
                .dash-nav {
                    position: fixed;
                    bottom: 0;
                    left: 0;
                    right: 0;
                    background: white;
                    padding: 0.75rem;
                    box-shadow: 0 -4px 20px rgba(0,0,0,0.1);
                    justify-content: center;
                    z-index: 100;
                }

                .dash-nav-link {
                    flex-direction: column;
                    gap: 0.25rem;
                    padding: 0.5rem 1rem;
                    font-size: 0.75rem;
                }

                .dash-nav-icon {
                    font-size: 1.5rem;
                }

                .dash-nav-text {
                    display: block;
                }

                .dash-header-inner {
                    padding-bottom: 0.75rem;
                }

                .dash-logout {
                    padding: 0.5rem 0.85rem;
                    font-size: 0.8rem;
                }
            }
        </style>
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {# Dashboard Header with User Navigation #}
        <header class="dash-header" role="banner">
            <div class="dash-header-inner">
                <a href="{{ path('app_dashboard', {'_locale': current_locale}) }}" class="dash-logo" aria-label="WANNASNI Dashboard">
                    <img src="/images/logo.png" alt="" aria-hidden="true">
                    <span class="dash-logo-text">WANNASNI</span>
                </a>
                
                <nav class="dash-nav" role="navigation" aria-label="User navigation">
                    <a href="{{ path('app_dashboard', {'_locale': current_locale}) }}" class="dash-nav-link {% if app.request.get('_route') == 'app_dashboard' %}active{% endif %}">
                        <span class="dash-nav-icon">🏠</span>
                        <span class="dash-nav-text">Accueil</span>
                    </a>
                    <a href="{{ path('app_my_services', {'_locale': current_locale}) }}" class="dash-nav-link {% if 'service' in app.request.get('_route') %}active{% endif %}">
                        <span class="dash-nav-icon">🛎️</span>
                        <span class="dash-nav-text">Services</span>
                    </a>
                    <a href="{{ path('app_my_activities', {'_locale': current_locale}) }}" class="dash-nav-link {% if 'activities' in app.request.get('_route') %}active{% endif %}">
                        <span class="dash-nav-icon">🎯</span>
                        <span class="dash-nav-text">Activités</span>
                    </a>
                    <a href="{{ path('app_my_health', {'_locale': current_locale}) }}" class="dash-nav-link {% if 'health' in app.request.get('_route') %}active{% endif %}">
                        <span class="dash-nav-icon">❤️</span>
                        <span class="dash-nav-text">Santé</span>
                    </a>
                    <a href="{{ path('app_my_nutrition', {'_locale': current_locale}) }}" class="dash-nav-link {% if 'nutrition' in app.request.get('_route') %}active{% endif %}">
                        <span class="dash-nav-icon">🥗</span>
                        <span class="dash-nav-text">Nutrition</span>
                    </a>
                    <a href="{{ path('app_subscription', {'_locale': current_locale}) }}" class="dash-nav-link {% if 'subscription' in app.request.get('_route') %}active{% endif %}">
                        <span class="dash-nav-icon">💎</span>
                        <span class="dash-nav-text">Abonnement</span>
                    </a>
                    <a href="{{ path('app_loyalty', {'_locale': current_locale}) }}" class="dash-nav-link {% if 'loyalty' in app.request.get('_route') %}active{% endif %}">
                        <span class="dash-nav-icon">🏆</span>
                        <span class="dash-nav-text">Fidélité</span>
                    </a>
                </nav>

                <div class="dash-user-menu">
                    <a href="{{ path('app_profile', {'_locale': current_locale}) }}" class="dash-user-avatar" title="Mon Profil">
                        M
                    </a>
                    <a href="{{ path('app_logout', {'_locale': current_locale}) }}" class="dash-logout">
                        Déconnexion
                    </a>
                </div>
            </div>
        </header>

        {# Main Content #}
        <main role="main" id="main-content">
            {% block body %}{% endblock %}
        </main>

        {# Floating Help Button #}
        <div class="floating-help" id="floatingHelp">
            <button class="help-trigger" onclick="document.getElementById('helpModal').classList.add('active')" aria-label="Get Help">
                <span class="help-icon">🆘</span>
                <span class="help-text">Aide</span>
            </button>
        </div>
        
        {# Help Modal #}
        <div class="help-modal" id="helpModal" role="dialog" aria-modal="true" aria-labelledby="helpTitle">
            <div class="help-modal-content">
                <button class="help-close" onclick="document.getElementById('helpModal').classList.remove('active')" aria-label="Close">&times;</button>
                <h2 id="helpTitle" style="font-size: 1.75rem; margin-bottom: 1.5rem; color: #2E7D32;">🤝 Comment puis-je vous aider ?</h2>
                <div class="help-options">
                    <a href="tel:+2161223445" class="help-option urgent">
                        <span class="help-option-icon">📞</span>
                        <span class="help-option-text">
                            <strong>Appeler maintenant</strong>
                            <small>Assistance immédiate</small>
                        </span>
                    </a>
                    <a href="mailto:wannasni@gmail.com" class="help-option">
                        <span class="help-option-icon">✉️</span>
                        <span class="help-option-text">
                            <strong>Envoyer un email</strong>
                            <small>Réponse sous 24h</small>
                        </span>
                    </a>
                    <a href="{{ path('app_services_request', {'_locale': current_locale}) }}" class="help-option">
                        <span class="help-option-icon">🛎️</span>
                        <span class="help-option-text">
                            <strong>Demander un service</strong>
                            <small>Transport, aide, courses...</small>
                        </span>
                    </a>
                </div>
            </div>
        </div>
        
        <style>
            /* Floating Help Button */
            .floating-help {
                position: fixed;
                bottom: 2rem;
                right: 2rem;
                z-index: 9999;
            }
            
            .help-trigger {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                padding: 1rem 1.5rem;
                background: linear-gradient(135deg, #dc2626, #ef4444);
                color: white;
                border: none;
                border-radius: 50px;
                font-size: 1.1rem;
                font-weight: 600;
                cursor: pointer;
                box-shadow: 0 8px 32px rgba(220, 38, 38, 0.4);
                transition: all 0.3s ease;
                animation: pulse-help 2s infinite;
            }
            
            .help-trigger:hover {
                transform: scale(1.08);
                box-shadow: 0 12px 40px rgba(220, 38, 38, 0.5);
            }
            
            .help-icon { font-size: 1.5rem; }
            
            @keyframes pulse-help {
                0%, 100% { box-shadow: 0 8px 32px rgba(220, 38, 38, 0.4); }
                50% { box-shadow: 0 8px 32px rgba(220, 38, 38, 0.6), 0 0 20px rgba(220, 38, 38, 0.3); }
            }
            
            /* Help Modal */
            .help-modal {
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.6);
                backdrop-filter: blur(8px);
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 10000;
                opacity: 0;
                visibility: hidden;
                transition: all 0.3s ease;
            }
            
            .help-modal.active {
                opacity: 1;
                visibility: visible;
            }
            
            .help-modal-content {
                background: white;
                border-radius: 24px;
                padding: 2.5rem;
                max-width: 450px;
                width: 90%;
                position: relative;
                transform: scale(0.9) translateY(20px);
                transition: all 0.3s ease;
            }
            
            .help-modal.active .help-modal-content {
                transform: scale(1) translateY(0);
            }
            
            .help-close {
                position: absolute;
                top: 1rem;
                right: 1rem;
                width: 40px;
                height: 40px;
                border: none;
                background: #f1f5f9;
                border-radius: 50%;
                font-size: 1.5rem;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: all 0.2s;
            }
            
            .help-close:hover { background: #e2e8f0; }
            
            .help-options {
                display: flex;
                flex-direction: column;
                gap: 1rem;
            }
            
            .help-option {
                display: flex;
                align-items: center;
                gap: 1rem;
                padding: 1.25rem;
                background: #f8fafc;
                border-radius: 16px;
                text-decoration: none;
                border: 2px solid transparent;
                transition: all 0.2s;
            }
            
            .help-option:hover {
                border-color: #2E7D32;
                background: #f0fdf4;
            }
            
            .help-option.urgent {
                background: linear-gradient(135deg, #fef2f2, #fee2e2);
                border-color: #fca5a5;
            }
            
            .help-option.urgent:hover {
                border-color: #dc2626;
                background: #fee2e2;
            }
            
            .help-option-icon {
                font-size: 2rem;
                width: 56px;
                height: 56px;
                display: flex;
                align-items: center;
                justify-content: center;
                background: white;
                border-radius: 12px;
                box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            }
            
            .help-option-text {
                display: flex;
                flex-direction: column;
            }
            
            .help-option-text strong {
                font-size: 1.1rem;
                color: #1a1a2e;
            }
            
            .help-option-text small {
                font-size: 0.85rem;
                color: #64748b;
            }
            
            @media (max-width: 768px) {
                .floating-help { bottom: 5rem; right: 1rem; }
                .help-text { display: none; }
                .help-trigger { padding: 1rem; border-radius: 50%; }
            }
        </style>
    </body>
</html>
