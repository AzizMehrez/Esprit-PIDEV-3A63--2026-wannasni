{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'auth.forgot_password.title'|trans|default('Mot de passe oublié') }} — {{ 'site.name'|trans }}{% endblock %}

{% block body %}
<div class="auth-page">
    {# Left Side - Image & Quote #}
    <div class="auth-image-side">
        <div class="auth-image-overlay"></div>
        <img src="/images/hero.png" alt="" class="auth-bg-image" aria-hidden="true">
        <div class="auth-image-content">
            <div class="auth-logo">
                <img src="/images/logo.png" alt="WANNASNI" class="auth-logo-img">
            </div>
            <blockquote class="auth-quote">
                <p>"{{ 'auth.quote.forgot'|trans|default('Ne vous inquiétez pas, nous allons vous aider à récupérer votre compte.') }}"</p>
                <cite>— WANNASNI</cite>
            </blockquote>
        </div>
    </div>
    
    {# Right Side - Forgot Password Form #}
    <div class="auth-form-side">
        <div class="auth-form-container">
            {# Mobile Logo (shown on small screens only) #}
            <div class="auth-mobile-header">
                <a href="{{ path('app_login', {_locale: app.request.locale}) }}" class="auth-back-link">
                    ← {{ 'nav.back_to_login'|trans|default('Retour à la connexion') }}
                </a>
                <img src="/images/logo.png" alt="WANNASNI" class="auth-mobile-logo">
            </div>
            
            <div class="auth-form-header">
                <h1 class="auth-title">{{ 'auth.forgot_password.title'|trans|default('Mot de passe oublié ?') }}</h1>
                <p class="auth-subtitle">{{ 'auth.forgot_password.subtitle'|trans|default('Entrez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.') }}</p>
            </div>
            
            {% for message in app.flashes('error') %}
                {% if loop.first %}
                <div class="alert alert-error" style="padding: 1rem; background: #fed7d7; color: #c53030; border: 1px solid #fc8181; border-radius: 8px; margin-bottom: 1rem;">
                {% endif %}
                    <p style="margin: 0;">⚠️ {{ message }}</p>
                {% if loop.last %}
                </div>
                {% endif %}
            {% endfor %}
            
            {% for message in app.flashes('success') %}
                {% if loop.first %}
                <div class="alert alert-success" style="padding: 1rem; background: #c6f6d5; color: #276749; border: 1px solid #9ae6b4; border-radius: 8px; margin-bottom: 1rem;">
                {% endif %}
                    <p style="margin: 0;">✓ {{ message }}</p>
                {% if loop.last %}
                </div>
                {% endif %}
            {% endfor %}
            
            {% for message in app.flashes('info') %}
                {% if loop.first %}
                <div class="alert alert-info" style="padding: 1rem; background: #bee3f8; color: #2b6cb0; border: 1px solid #90cdf4; border-radius: 8px; margin-bottom: 1rem;">
                {% endif %}
                    <p style="margin: 0;">ℹ️ {{ message }}</p>
                {% if loop.last %}
                </div>
                {% endif %}
            {% endfor %}
            
            <form method="post" action="{{ path('app_forgot_password', {_locale: app.request.locale}) }}" class="auth-form">
                <div class="form-group">
                    <label for="inputEmail" class="form-label">{{ 'auth.email'|trans|default('Adresse email') }}</label>
                    <input type="email" 
                           id="inputEmail" 
                           name="email" 
                           class="form-input" 
                           placeholder="exemple@email.com"
                           autocomplete="email"
                           required 
                           autofocus>
                </div>
                
                <button type="submit" class="btn btn-primary btn-large btn-full">
                    {{ 'auth.send_reset_link'|trans|default('Envoyer le lien de réinitialisation') }}
                </button>
            </form>
            
            <div class="auth-footer" style="margin-top: 1.5rem; text-align: center;">
                <p>{{ 'auth.remember_password'|trans|default('Vous vous souvenez de votre mot de passe ?') }} 
                   <a href="{{ path('app_login', {_locale: app.request.locale}) }}" class="auth-link-strong">{{ 'cta.login'|trans|default('Se connecter') }}</a>
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
