{% extends 'base_dashboard.html.twig' %}

{% block title %}Mes Activités - WANNASNI{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ============================================
       ACTIVITIES PAGE - Senior-Friendly Design
       Large fonts, simple layout, clear actions
       ============================================ */
    
    :root {
        --act-primary: #2E7D32;
        --act-primary-light: #4CAF50;
        --act-bg: #f0fdf4;
        --act-card: #ffffff;
        --act-text: #1a1a2e;
        --act-text-muted: #64748b;
        --act-border: #dcfce7;
    }

    /* Chat styles handled by chat/style.css */

    .activities-wrapper {
        min-height: 100vh;
        padding: 2rem 1.5rem 4rem;
        background: linear-gradient(180deg, var(--act-bg) 0%, #f8fafc 30%);
    }

    .activities-container {
        max-width: 900px;
        margin: 0 auto;
    }

    /* Back Link */
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--act-primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 1.1rem;
        margin-bottom: 1.5rem;
        padding: 0.75rem 1.25rem;
        border-radius: 50px;
        background: white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: all 0.2s;
    }

    .back-link:hover {
        background: var(--act-bg);
        transform: translateX(-4px);
    }

    /* Header */
    .activities-header {
        background: linear-gradient(135deg, var(--act-primary), var(--act-primary-light));
        border-radius: 24px;
        padding: 2.5rem;
        margin-bottom: 2rem;
        color: white;
        text-align: center;
        box-shadow: 0 8px 32px rgba(46, 125, 50, 0.3);
    }

    .activities-header-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .activities-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .activities-subtitle {
        font-size: 1.25rem;
        opacity: 0.9;
    }

    /* Section */
    .section {
        margin-bottom: 2rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
        padding: 1rem 1.5rem;
        background: white;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .section-icon {
        font-size: 2rem;
        width: 56px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--act-primary), var(--act-primary-light));
        border-radius: 14px;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--act-text);
    }

    .section-count {
        margin-left: auto;
        background: var(--act-bg);
        color: var(--act-primary);
        padding: 0.5rem 1.25rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1rem;
    }

    /* Activity Cards */
    .activity-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .activity-list {
        display: grid;
        gap: 1.25rem;
    }

    .activity-card {
        cursor: pointer;
        background: var(--act-card);
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        border: 2px solid var(--act-border);
        transition: all 0.3s;
    }

    .activity-card:hover {
        border-color: var(--act-primary);
        transform: translateY(-4px);
        box-shadow: 0 8px 32px rgba(46, 125, 50, 0.15);
    }

    .activity-top {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        margin-bottom: 1rem;
    }

    .activity-icon {
        width: 72px;
        height: 72px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        flex-shrink: 0;
    }

    .activity-icon.physical { background: linear-gradient(135deg, #dcfce7, #bbf7d0); }
    .activity-icon.cognitive { background: linear-gradient(135deg, #dbeafe, #bfdbfe); }
    .activity-icon.creative { background: linear-gradient(135deg, #f3e8ff, #e9d5ff); }
    .activity-icon.social { background: linear-gradient(135deg, #fef3c7, #fde68a); }

    .activity-name {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--act-text);
    }

    .activity-details {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        align-items: center;
    }

    .activity-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.1rem;
        color: var(--act-text-muted);
    }

    .activity-badge {
        padding: 0.75rem 1.5rem;
        border-radius: 50px;
        font-size: 1.1rem;
        font-weight: 700;
        background: linear-gradient(135deg, #dcfce7, #bbf7d0);
        color: #166534;
    }

    .btn-join {
        padding: 1rem 2rem;
        background: linear-gradient(135deg, var(--act-primary), var(--act-primary-light));
        color: white;
        border: none;
        border-radius: 50px;
        font-size: 1.15rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(46, 125, 50, 0.3);
        transition: all 0.3s;
    }

    .btn-join:hover {
        transform: scale(1.05);
        box-shadow: 0 6px 20px rgba(46, 125, 50, 0.4);
    }

    .btn-join:disabled {
        background: #ccc;
        color: #666;
        cursor: not-allowed;
        opacity: 0.6;
        box-shadow: none;
    }

    .btn-join:disabled:hover {
        transform: none;
        box-shadow: none;
    }

    .btn-cancel {
        padding: 1rem 2rem;
        background: linear-gradient(135deg, #dc2626, #ef4444);
        color: white;
        border: none;
        border-radius: 50px;
        font-size: 1.15rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(220, 38, 38, 0.3);
        transition: all 0.3s;
        margin-left: 1rem;
    }

    .btn-cancel:hover {
        transform: scale(1.05);
        box-shadow: 0 6px 20px rgba(220, 38, 38, 0.4);
    }

    .btn-cancel:disabled {
        background: #ccc;
        color: #666;
        cursor: not-allowed;
        opacity: 0.6;
        box-shadow: none;
    }

    .btn-cancel:disabled:hover {
        transform: none;
        box-shadow: none;
    }

    /* Flash messages */
    .flash-messages {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 1000;
        max-width: 400px;
    }

    .alert {
        padding: 1.25rem;
        border-radius: 12px;
        margin-bottom: 1rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        animation: slideIn 0.3s ease-out;
    }

    .alert-success {
        background: #dcfce7;
        color: #166534;
        border-left: 5px solid #22c55e;
    }

    .alert-error {
        background: #fee2e2;
        color: #991b1b;
        border-left: 5px solid #ef4444;
    }

    @keyframes slideIn {
        from {
            transform: translateX(400px);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @media (max-width: 640px) {
        .activities-title { font-size: 2rem; }
        .activity-top { flex-direction: column; text-align: center; }
        .activity-details { justify-content: center; }
    }
</style>
{% endblock %}

{% block body %}
<div class="activities-wrapper">
    <!-- Flash Messages -->
    {% if app.flashes %}
    <div class="flash-messages">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
            <div class="alert alert-{{ type }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}
    </div>
    {% endif %}

    <div class="activities-container">
        
        <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1.5rem;">
            <a href="{{ path('app_dashboard', {'_locale': app.request.locale}) }}" class="back-link">
                ← Retour au tableau de bord
            </a>
            <a href="{{ path('app_participation_history', {'_locale': app.request.locale}) }}" style="display: inline-flex; align-items: center; gap: 0.5rem; color: #8b5cf6; text-decoration: none; font-weight: 600; font-size: 1.1rem; padding: 0.75rem 1.25rem; border-radius: 50px; background: white; box-shadow: 0 2px 8px rgba(0,0,0,0.08); transition: all 0.2s;">
                📊 Mon Historique
            </a>
        </div>
        
        <!-- Header -->
        <div class="activities-header">
            <div class="activities-header-icon">🎯</div>
            <h1 class="activities-title">Mes Activités</h1>
            <p class="activities-subtitle">Restez actif et connecté avec nos activités</p>
        </div>

        <!-- My Enrollments -->
        <div class="section">
            <div class="section-header">
                <span class="section-icon">✅</span>
                <span class="section-title">Mes Inscriptions</span>
                <span class="section-count">{{ enrolled_activities|length }}</span>
            </div>
            <div class="activity-list">
                {% if enrolled_activities|length > 0 %}
                    {% for participation in enrolled_activities %}
                    <a href="{{ path('app_activity_show', {'_locale': app.request.locale, 'id': participation.id}) }}" class="activity-card-link">
                    <div class="activity-card">
                        <div class="activity-top">
                            <div class="activity-icon {{ participation.type }}">
                                {% if participation.type == 'physical' %}🏃
                                {% elseif participation.type == 'cognitive' %}🧠
                                {% elseif participation.type == 'creative' %}🎨
                                {% elseif participation.type == 'social' %}👥
                                {% else %}📋{% endif %}
                            </div>
                            <div>
                                <div class="activity-name">{{ participation.name }}</div>
                                <div style="color: var(--act-text-muted); font-size: 0.95rem;">{{ participation.schedule }}</div>
                            </div>
                        </div>
                        <div class="activity-details">
                            <span class="activity-info">📅 {{ participation.nextSession|date('d/m/Y H:i') }}</span>
                            <span class="activity-badge">✓ Inscrit</span>
                            <form method="POST" action="{{ path('app_my_activities_cancel', {'_locale': app.request.locale, 'id': participation.id}) }}" style="display: inline;" onclick="event.stopPropagation();">
                                <input type="hidden" name="_token" value="{{ csrf_token('cancel_activity_' ~ participation.id) }}">
                                <button type="submit" class="btn-cancel" onclick="event.stopPropagation(); return confirm('Êtes-vous sûr de vouloir annuler votre inscription ?');">
                                    Annuler
                                </button>
                            </form>
                        </div>
                    </div>
                    </a>
                    {% endfor %}
                {% else %}
                    <div style="text-align: center; padding: 3rem 2rem; color: var(--act-text-muted);">
                        <p style="font-size: 1.2rem; margin-bottom: 0.5rem;">Vous n'êtes inscrit à aucune activité</p>
                        <p>Explorez les activités disponibles ci-dessous!</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Available Activities -->
        <div class="section">
            <div class="section-header">
                <span class="section-icon">🌟</span>
                <span class="section-title">Activités Disponibles</span>
                <span class="section-count">{{ available_activities|length }}</span>
            </div>
            <div class="activity-list">
                {% if available_activities|length > 0 %}
                    {% for activity in available_activities %}
                    <a href="{{ path('app_activity_show', {'_locale': app.request.locale, 'id': activity.id}) }}" class="activity-card-link">
                    <div class="activity-card">
                        <div class="activity-top">
                            <div class="activity-icon {{ activity.type }}">
                                {% if activity.type == 'physical' %}🏃
                                {% elseif activity.type == 'cognitive' %}🧠
                                {% elseif activity.type == 'creative' %}🎨
                                {% elseif activity.type == 'social' %}👥
                                {% else %}📋{% endif %}
                            </div>
                            <div>
                                <div class="activity-name">{{ activity.name }}</div>
                                <div style="color: var(--act-text-muted); font-size: 0.95rem;">{{ activity.schedule }}</div>
                            </div>
                        </div>
                        <div class="activity-details">
                            <span class="activity-info">👥 {{ activity.participants }} participants</span>
                            <form method="POST" action="{{ path('app_my_activities_enroll', {'_locale': app.request.locale, 'id': activity.id}) }}" style="display: inline;" onclick="event.stopPropagation();">
                                <input type="hidden" name="_token" value="{{ csrf_token('enroll_activity_' ~ activity.id) }}">
                                <button type="submit" class="btn-join" onclick="event.stopPropagation();">S'inscrire</button>
                            </form>
                        </div>
                    </div>
                    </a>
                    {% endfor %}
                {% else %}
                    <div style="text-align: center; padding: 3rem 2rem; color: var(--act-text-muted);">
                        <p style="font-size: 1.5rem; margin-bottom: 1rem;">Aucune activité disponible</p>
                        <p>Revenez vérifier plus tard!</p>
                    </div>
                {% endif %}
            </div>
        </div>

    </div>
</div>

<!-- Unified Chat & Voice Launcher -->
<button class="chat-toggle-btn unified-launcher" id="chat-toggle" aria-label="Chat & Voice Assistant" title="Chat & Voice Assistant">
    <svg class="icon-chat" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    <span class="mic-indicator" title="Voice Assistant available">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z"/>
            <path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"/>
        </svg>
    </span>
    <span class="notification-badge" style="display: none;">1</span>
</button>

<!-- Smart Chat Container -->
<div id="smart-chat-container">
    <div class="chat-window" id="chat-window">
        <div class="chat-header">
            <div class="header-info">
                <div class="avatar-ring">
                    <img src="https://ui-avatars.com/api/?name=Activity&background=2E7D32&color=fff" alt="Activity Agent">
                    <span class="status-dot"></span>
                </div>
                <div class="agent-details">
                    <span class="agent-name">Assistant Activités</span>
                    <span class="agent-status" id="agent-status">Prêt à bouger</span>
                </div>
            </div>
            <select id="persona-select" class="persona-select" title="AI Persona">
                <option value="activity">🏃 Activités</option>
                <option value="default">🤖 Assistant</option>
            </select>
            <div class="header-actions">
                <button class="header-icon-btn" id="export-chat" title="Exporter">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="7 10 12 15 17 10"></polyline>
                        <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                </button>
                <button class="header-icon-btn" id="clear-chat" title="Nouveau">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 20h9"></path>
                        <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                    </svg>
                </button>
                <button class="close-btn" id="close-chat" aria-label="Fermer">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 6L6 18M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>
        <div class="drop-zone" id="drop-zone">
            <div class="drop-zone-content">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="17 8 12 3 7 8"></polyline>
                    <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                <span>Déposez un fichier ici</span>
            </div>
        </div>
        <div class="chat-messages" id="chat-messages">
            <div class="message bot-message welcome">
                <p>Salut! Je suis votre <strong>Assistant Activités</strong> 🏃<br>
                   Prêt pour des activités physiques et cognitives adaptées!</p>
                <span class="timestamp">Maintenant</span>
            </div>
        </div>
        <div class="usage-stats" id="usage-stats">
            <span>💬 <span id="msg-count">0</span> msgs</span>
            <span>📈 <span id="token-count">0</span> tokens</span>
        </div>
        <div class="suggested-prompts" id="suggested-prompts">
            <button class="prompt-chip" data-prompt="Quelles activités physiques me recommandez-vous?">🏃 Physique</button>
            <button class="prompt-chip" data-prompt="Activités cognitives pour seniors">🧠 Cognitive</button>
            <button class="prompt-chip" data-prompt="Comment m'inscrire à une activité?">✅ Inscription</button>
            <button class="prompt-chip" data-prompt="Horaires des activités">⏰ Horaires</button>
        </div>
        <div class="chat-input-area">
            <div class="typing-indicator" id="typing-indicator">
                <span></span><span></span><span></span>
            </div>
            <div id="image-preview-container" class="image-preview hidden">
                <img id="image-preview" src="" alt="Preview">
                <button id="remove-image" class="remove-btn">×</button>
            </div>
            <div class="input-wrapper">
                <input type="file" id="image-upload" accept="image/*" style="display: none;">
                <input type="file" id="file-upload" accept=".pdf,.txt" style="display: none;">
                <button id="upload-btn" title="Télécharger Image">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
                    </svg>
                </button>
                <button id="mic-input-btn" title="Entrée vocale" class="mic-input-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
                        <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
                        <line x1="12" y1="19" x2="12" y2="23"></line>
                        <line x1="8" y1="23" x2="16" y2="23"></line>
                    </svg>
                </button>
                <button id="voice-call-btn" title="Appel vocal IA" class="voice-call-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                    </svg>
                </button>
                <input type="text" id="user-input" placeholder="Posez vos questions sur les activités..." autocomplete="off">
                <button id="send-btn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Voice Call Overlay -->
<div class="voice-call-overlay" id="voice-call-overlay">
    <div class="voice-call-container">
        <div class="voice-orb-wrapper">
            <div class="voice-orb" id="voice-orb">
                <div class="orb-inner"></div>
            </div>
            <div class="voice-orb-ring ring-1"></div>
            <div class="voice-orb-ring ring-2"></div>
            <div class="voice-orb-ring ring-3"></div>
        </div>
        <div class="voice-call-status" id="voice-call-status">Connecting...</div>
        <div class="voice-transcript" id="voice-transcript"></div>
        <div class="voice-ai-text" id="voice-ai-text"></div>
        <div class="voice-call-controls">
            <button class="voice-control-btn mute-btn" id="voice-mute-btn" title="Mute/Unmute">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
                    <line x1="12" y1="19" x2="12" y2="23"></line>
                    <line x1="8" y1="23" x2="16" y2="23"></line>
                </svg>
            </button>
            <button class="voice-control-btn end-call-btn" id="voice-end-call" title="End Call">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M22 10.5c-1.6-1.6-3.7-2.5-5.9-2.5-1.4 0-2.7.3-3.9.8l1.5 1.5c.7-.2 1.5-.3 2.3-.3 1.6 0 3.1.6 4.2 1.8l1.8-1.8zM7 12.5c-.8 0-1.6.1-2.3.3L3.2 11.3C4.3 10.8 5.6 10.5 7 10.5c2.2 0 4.3.9 5.9 2.5l-1.8 1.8c-1.1-1.2-2.6-1.8-4.1-1.8zm5 3.5h5v5h-5v-5zm-10 0h5v5H2v-5z"/>
                </svg>
            </button>
            <button class="voice-control-btn speaker-btn" id="voice-speaker-btn" title="Speaker On/Off">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                    <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                    <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
                </svg>
            </button>
        </div>
