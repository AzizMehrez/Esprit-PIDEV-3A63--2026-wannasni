{% extends 'base_dashboard.html.twig' %}

{% block title %}Mes Activités - WANNASNI{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ============================================
       ACTIVITIES PAGE - Senior-Friendly Design
       Large fonts, simple layout, clear actions
       ============================================ */
    
    :root {
        --act-primary: #2E7D32;
        --act-primary-light: #4CAF50;
        --act-bg: #f0fdf4;
        --act-card: #ffffff;
        --act-text: #1a1a2e;
        --act-text-muted: #64748b;
        --act-border: #dcfce7;
    }

    .activities-wrapper {
        min-height: 100vh;
        padding: 2rem 1.5rem 4rem;
        background: linear-gradient(180deg, var(--act-bg) 0%, #f8fafc 30%);
    }

    .activities-container {
        max-width: 900px;
        margin: 0 auto;
    }

    /* Back Link */
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--act-primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 1.1rem;
        margin-bottom: 1.5rem;
        padding: 0.75rem 1.25rem;
        border-radius: 50px;
        background: white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: all 0.2s;
    }

    .back-link:hover {
        background: var(--act-bg);
        transform: translateX(-4px);
    }

    /* Header */
    .activities-header {
        background: linear-gradient(135deg, var(--act-primary), var(--act-primary-light));
        border-radius: 24px;
        padding: 2.5rem;
        margin-bottom: 2rem;
        color: white;
        text-align: center;
        box-shadow: 0 8px 32px rgba(46, 125, 50, 0.3);
    }

    .activities-header-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .activities-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .activities-subtitle {
        font-size: 1.25rem;
        opacity: 0.9;
    }

    /* Section */
    .section {
        margin-bottom: 2rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
        padding: 1rem 1.5rem;
        background: white;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .section-icon {
        font-size: 2rem;
        width: 56px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--act-primary), var(--act-primary-light));
        border-radius: 14px;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--act-text);
    }

    .section-count {
        margin-left: auto;
        background: var(--act-bg);
        color: var(--act-primary);
        padding: 0.5rem 1.25rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1rem;
    }

    /* Activity Cards */
    .activity-list {
        display: grid;
        gap: 1.25rem;
    }

    .activity-card {
        background: var(--act-card);
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        border: 2px solid var(--act-border);
        transition: all 0.3s;
    }

    .activity-card:hover {
        border-color: var(--act-primary);
        transform: translateY(-4px);
        box-shadow: 0 8px 32px rgba(46, 125, 50, 0.15);
    }

    .activity-top {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        margin-bottom: 1rem;
    }

    .activity-icon {
        width: 72px;
        height: 72px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        flex-shrink: 0;
    }

    .activity-icon.physical { background: linear-gradient(135deg, #dcfce7, #bbf7d0); }
    .activity-icon.cognitive { background: linear-gradient(135deg, #dbeafe, #bfdbfe); }
    .activity-icon.creative { background: linear-gradient(135deg, #f3e8ff, #e9d5ff); }
    .activity-icon.social { background: linear-gradient(135deg, #fef3c7, #fde68a); }

    .activity-name {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--act-text);
    }

    .activity-details {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        align-items: center;
    }

    .activity-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.1rem;
        color: var(--act-text-muted);
    }

    .activity-badge {
        padding: 0.75rem 1.5rem;
        border-radius: 50px;
        font-size: 1.1rem;
        font-weight: 700;
        background: linear-gradient(135deg, #dcfce7, #bbf7d0);
        color: #166534;
    }

    .btn-join {
        padding: 1rem 2rem;
        background: linear-gradient(135deg, var(--act-primary), var(--act-primary-light));
        color: white;
        border: none;
        border-radius: 50px;
        font-size: 1.15rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(46, 125, 50, 0.3);
        transition: all 0.3s;
    }

    .btn-join:hover {
        transform: scale(1.05);
        box-shadow: 0 6px 20px rgba(46, 125, 50, 0.4);
    }

    @media (max-width: 640px) {
        .activities-title { font-size: 2rem; }
        .activity-top { flex-direction: column; text-align: center; }
        .activity-details { justify-content: center; }
    }
</style>
{% endblock %}

{% block body %}
<div class="activities-wrapper">
    <div class="activities-container">
        
        <a href="{{ path('app_dashboard', {'_locale': app.request.locale}) }}" class="back-link">
            ← Retour au tableau de bord
        </a>
        
        <!-- Header -->
        <div class="activities-header">
            <div class="activities-header-icon">🎯</div>
            <h1 class="activities-title">Mes Activités</h1>
            <p class="activities-subtitle">Restez actif et connecté avec nos activités</p>
        </div>

        <!-- My Enrollments -->
        <div class="section">
            <div class="section-header">
                <span class="section-icon">✅</span>
                <span class="section-title">Mes Inscriptions</span>
                <span class="section-count">{{ enrolled_activities|length }} activités</span>
            </div>
            <div class="activity-list">
                {% for activity in enrolled_activities %}
                <div class="activity-card">
                    <div class="activity-top">
                        <div class="activity-icon {{ activity.type }}">
                            {% if activity.type == 'physical' %}🏃
                            {% elseif activity.type == 'cognitive' %}🧠
                            {% elseif activity.type == 'creative' %}🎨
                            {% else %}👥{% endif %}
                        </div>
                        <div class="activity-name">{{ activity.name }}</div>
                    </div>
                    <div class="activity-details">
                        <span class="activity-info">📅 {{ activity.schedule }}</span>
                        <span class="activity-info">🕐 Prochaine: {{ activity.nextSession|date('d/m/Y') }}</span>
                        <span class="activity-badge">✓ Inscrit</span>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

        <!-- Available Activities -->
        <div class="section">
            <div class="section-header">
                <span class="section-icon">🌟</span>
                <span class="section-title">Activités Disponibles</span>
            </div>
            <div class="activity-list">
                {% for activity in available_activities %}
                <div class="activity-card">
                    <div class="activity-top">
                        <div class="activity-icon {{ activity.type }}">
                            {% if activity.type == 'physical' %}🏃
                            {% elseif activity.type == 'cognitive' %}🧠
                            {% elseif activity.type == 'creative' %}🎨
                            {% else %}👥{% endif %}
                        </div>
                        <div class="activity-name">{{ activity.name }}</div>
                    </div>
                    <div class="activity-details">
                        <span class="activity-info">📅 {{ activity.schedule }}</span>
                        <span class="activity-info">👥 {{ activity.participants }} participants</span>
                        <button class="btn-join">S'inscrire</button>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

    </div>
</div>
{% endblock %}
