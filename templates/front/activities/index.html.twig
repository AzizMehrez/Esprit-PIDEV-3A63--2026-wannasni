{% extends 'base_dashboard.html.twig' %}

{% block title %}Mes Activités - WANNASNI{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ============================================
       ACTIVITIES PAGE - Senior-Friendly Design
       Large fonts, simple layout, clear actions
       ============================================ */
    
    :root {
        --act-primary: #2E7D32;
        --act-primary-light: #4CAF50;
        --act-bg: #f0fdf4;
        --act-card: #ffffff;
        --act-text: #1a1a2e;
        --act-text-muted: #64748b;
        --act-border: #dcfce7;
    }

    .activities-wrapper {
        min-height: 100vh;
        padding: 2rem 1.5rem 4rem;
        background: linear-gradient(180deg, var(--act-bg) 0%, #f8fafc 30%);
    }

    .activities-container {
        max-width: 900px;
        margin: 0 auto;
    }

    /* Back Link */
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--act-primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 1.1rem;
        margin-bottom: 1.5rem;
        padding: 0.75rem 1.25rem;
        border-radius: 50px;
        background: white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: all 0.2s;
    }

    .back-link:hover {
        background: var(--act-bg);
        transform: translateX(-4px);
    }

    /* Header */
    .activities-header {
        background: linear-gradient(135deg, var(--act-primary), var(--act-primary-light));
        border-radius: 24px;
        padding: 2.5rem;
        margin-bottom: 2rem;
        color: white;
        text-align: center;
        box-shadow: 0 8px 32px rgba(46, 125, 50, 0.3);
    }

    .activities-header-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .activities-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .activities-subtitle {
        font-size: 1.25rem;
        opacity: 0.9;
    }

    /* Section */
    .section {
        margin-bottom: 2rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
        padding: 1rem 1.5rem;
        background: white;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .section-icon {
        font-size: 2rem;
        width: 56px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--act-primary), var(--act-primary-light));
        border-radius: 14px;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--act-text);
    }

    .section-count {
        margin-left: auto;
        background: var(--act-bg);
        color: var(--act-primary);
        padding: 0.5rem 1.25rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1rem;
    }

    /* Activity Cards */
    .activity-list {
        display: grid;
        gap: 1.25rem;
    }

    .activity-card {
        background: var(--act-card);
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        border: 2px solid var(--act-border);
        transition: all 0.3s;
    }

    .activity-card:hover {
        border-color: var(--act-primary);
        transform: translateY(-4px);
        box-shadow: 0 8px 32px rgba(46, 125, 50, 0.15);
    }

    .activity-top {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        margin-bottom: 1rem;
    }

    .activity-icon {
        width: 72px;
        height: 72px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        flex-shrink: 0;
    }

    .activity-icon.physical { background: linear-gradient(135deg, #dcfce7, #bbf7d0); }
    .activity-icon.cognitive { background: linear-gradient(135deg, #dbeafe, #bfdbfe); }
    .activity-icon.creative { background: linear-gradient(135deg, #f3e8ff, #e9d5ff); }
    .activity-icon.social { background: linear-gradient(135deg, #fef3c7, #fde68a); }

    .activity-name {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--act-text);
    }

    .activity-details {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        align-items: center;
    }

    .activity-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.1rem;
        color: var(--act-text-muted);
    }

    .activity-badge {
        padding: 0.75rem 1.5rem;
        border-radius: 50px;
        font-size: 1.1rem;
        font-weight: 700;
        background: linear-gradient(135deg, #dcfce7, #bbf7d0);
        color: #166534;
    }

    .btn-join {
        padding: 1rem 2rem;
        background: linear-gradient(135deg, var(--act-primary), var(--act-primary-light));
        color: white;
        border: none;
        border-radius: 50px;
        font-size: 1.15rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(46, 125, 50, 0.3);
        transition: all 0.3s;
    }

    .btn-join:hover {
        transform: scale(1.05);
        box-shadow: 0 6px 20px rgba(46, 125, 50, 0.4);
    }

    .btn-join:disabled {
        background: #ccc;
        color: #666;
        cursor: not-allowed;
        opacity: 0.6;
        box-shadow: none;
    }

    .btn-join:disabled:hover {
        transform: none;
        box-shadow: none;
    }

    .btn-cancel {
        padding: 1rem 2rem;
        background: linear-gradient(135deg, #dc2626, #ef4444);
        color: white;
        border: none;
        border-radius: 50px;
        font-size: 1.15rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(220, 38, 38, 0.3);
        transition: all 0.3s;
        margin-left: 1rem;
    }

    .btn-cancel:hover {
        transform: scale(1.05);
        box-shadow: 0 6px 20px rgba(220, 38, 38, 0.4);
    }

    .btn-cancel:disabled {
        background: #ccc;
        color: #666;
        cursor: not-allowed;
        opacity: 0.6;
        box-shadow: none;
    }

    .btn-cancel:disabled:hover {
        transform: none;
        box-shadow: none;
    }

    /* Flash messages */
    .flash-messages {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 1000;
        max-width: 400px;
    }

    .alert {
        padding: 1.25rem;
        border-radius: 12px;
        margin-bottom: 1rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        animation: slideIn 0.3s ease-out;
    }

    .alert-success {
        background: #dcfce7;
        color: #166534;
        border-left: 5px solid #22c55e;
    }

    .alert-error {
        background: #fee2e2;
        color: #991b1b;
        border-left: 5px solid #ef4444;
    }

    @keyframes slideIn {
        from {
            transform: translateX(400px);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @media (max-width: 640px) {
        .activities-title { font-size: 2rem; }
        .activity-top { flex-direction: column; text-align: center; }
        .activity-details { justify-content: center; }
    }
</style>
{% endblock %}

{% block body %}
<div class="activities-wrapper">
    <!-- Flash Messages -->
    {% if app.flashes %}
    <div class="flash-messages">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
            <div class="alert alert-{{ type }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}
    </div>
    {% endif %}

    <div class="activities-container">
        
        <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1.5rem;">
            <a href="{{ path('app_dashboard', {'_locale': app.request.locale}) }}" class="back-link">
                ← Retour au tableau de bord
            </a>
            <a href="{{ path('app_participation_history', {'_locale': app.request.locale}) }}" style="display: inline-flex; align-items: center; gap: 0.5rem; color: #8b5cf6; text-decoration: none; font-weight: 600; font-size: 1.1rem; padding: 0.75rem 1.25rem; border-radius: 50px; background: white; box-shadow: 0 2px 8px rgba(0,0,0,0.08); transition: all 0.2s;">
                📊 Mon Historique
            </a>
        </div>
        
        <!-- Header -->
        <div class="activities-header">
            <div class="activities-header-icon">🎯</div>
            <h1 class="activities-title">Mes Activités</h1>
            <p class="activities-subtitle">Restez actif et connecté avec nos activités</p>
        </div>

        <!-- My Enrollments -->
        <div class="section">
            <div class="section-header">
                <span class="section-icon">✅</span>
                <span class="section-title">Mes Inscriptions</span>
                <span class="section-count">{{ enrolled_activities|length }}</span>
            </div>
            <div class="activity-list">
                {% if enrolled_activities|length > 0 %}
                    {% for activity in enrolled_activities %}
                    <div class="activity-card">
                        <div class="activity-top">
                            <div class="activity-icon {{ activity.type }}">
                                {% if activity.type == 'physical' %}🏃
                                {% elseif activity.type == 'cultural' %}🎭
                                {% elseif activity.type == 'educational' %}📚
                                {% else %}👥{% endif %}
                            </div>
                            <div>
                                <div class="activity-name">{{ activity.name }}</div>
                                <div style="color: var(--act-text-muted); font-size: 0.95rem;">{{ activity.location ?? 'Location TBA' }}</div>
                            </div>
                        </div>
                        <div class="activity-details">
                            <span class="activity-info">📅 {{ activity.schedule }}</span>
                            <span class="activity-badge">✓ Inscrit</span>
                            <form method="POST" action="{{ path('app_cancel_activity', {id: activity.id}) }}" style="display: inline;">
                                <button type="submit" class="btn-cancel" onclick="return confirm('Are you sure you want to cancel your enrollment?');">
                                    Annuler
                                </button>
                            </form>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <div style="text-align: center; padding: 3rem 2rem; color: var(--act-text-muted);">
                        <p style="font-size: 1.2rem; margin-bottom: 0.5rem;">Vous n'êtes inscrit à aucune activité</p>
                        <p>Explorez les activités disponibles ci-dessous!</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Available Activities -->
        <div class="section">
            <div class="section-header">
                <span class="section-icon">🌟</span>
                <span class="section-title">Activités Disponibles</span>
                <span class="section-count">{{ available_activities|length }}</span>
            </div>
            <div class="activity-list">
                {% if available_activities|length > 0 %}
                    {% for activity in available_activities %}
                    <div class="activity-card">
                        <div class="activity-top">
                            <div class="activity-icon {{ activity.type }}">
                                {% if activity.type == 'physical' %}🏃
                                {% elseif activity.type == 'cultural' %}🎭
                                {% elseif activity.type == 'educational' %}📚
                                {% else %}👥{% endif %}
                            </div>
                            <div>
                                <div class="activity-name">{{ activity.name }}</div>
                                <div style="color: var(--act-text-muted); font-size: 0.95rem;">{{ activity.location ?? 'Location TBA' }}</div>
                            </div>
                        </div>
                        <p style="color: var(--act-text-muted); margin: 0.75rem 0; font-size: 0.95rem;">{{ activity.description }}</p>
                        <div class="activity-details">
                            <span class="activity-info">📅 {{ activity.schedule }}</span>
                            <span class="activity-info">👥 {{ activity.participants }}{% if activity.maxParticipants %}/{{ activity.maxParticipants }}{% endif %}</span>
                            <form method="POST" action="{{ path('app_enroll_activity', {id: activity.id}) }}" style="display: inline;">
                                <button type="submit" class="btn-join" {% if activity.maxParticipants and activity.participants >= activity.maxParticipants %}disabled{% endif %}>
                                    {% if activity.maxParticipants and activity.participants >= activity.maxParticipants %}
                                        Complet
                                    {% else %}
                                        S'inscrire
                                    {% endif %}
                                </button>
                            </form>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <div style="text-align: center; padding: 3rem 2rem; color: var(--act-text-muted);">
                        <p style="font-size: 1.5rem; margin-bottom: 1rem;">Aucune activité disponible</p>
                        <p>Revenez vérifier plus tard!</p>
                    </div>
                {% endif %}
            </div>
        </div>

    </div>
</div>
{% endblock %}
