<form method="post" action="{{ path('app_health_journal_delete', {'id': health_journal.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ health_journal.id) }}">
    <button class="btn btn-danger mt-3">Supprimer</button>
</form>
