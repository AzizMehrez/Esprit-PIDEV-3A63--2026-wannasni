{% extends 'base_dashboard.html.twig' %}

{% block title %}Nouvelle Entrée Journal de Santé - WANNASNI{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    :root {
        --dash-primary: #dc2626;  /* Red for Health */
        --dash-primary-light: #ef4444;
        --dash-primary-soft: rgba(220, 38, 38, 0.08);
        --dash-bg: #fef2f2;
        --dash-card: #ffffff;
        --dash-text: #1a1a2e;
        --dash-text-muted: #64748b;
        --dash-border: #fecaca;
        --dash-shadow: 0 4px 24px rgba(220, 38, 38, 0.06);
        --dash-radius: 20px;
        --dash-radius-sm: 12px;
    }

    body { background: var(--dash-bg); }

    .page-wrapper {
        min-height: 100vh;
        padding: 2rem 1.5rem 4rem;
        background: linear-gradient(180deg, #fef2f2 0%, var(--dash-bg) 30%);
    }

    .page-container {
        max-width: 700px;
        margin: 0 auto;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--dash-primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        transition: all 0.2s;
    }

    .back-link:hover {
        background: var(--dash-primary-soft);
    }

    .form-card {
        background: var(--dash-card);
        border-radius: var(--dash-radius);
        box-shadow: var(--dash-shadow);
        border: 1px solid var(--dash-border);
        overflow: hidden;
    }

    .form-header {
        padding: 1.5rem 2rem;
        border-bottom: 1px solid var(--dash-border);
        background: linear-gradient(to right, var(--dash-primary-soft), transparent);
    }

    .form-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--dash-text);
    }

    .form-title-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--dash-primary), var(--dash-primary-light));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.25rem;
    }

    .form-body {
        padding: 2rem;
    }

    .form-section {
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 2px solid var(--dash-border);
    }

    .form-section:last-of-type {
        border-bottom: none;
    }

    .section-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--dash-text);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .form-label {
        display: block;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--dash-text);
        margin-bottom: 0.75rem;
    }

    .form-input {
        width: 100%;
        padding: 1rem 1.25rem;
        font-size: 1rem;
        border: 2px solid var(--dash-border);
        border-radius: var(--dash-radius-sm);
        background: white;
        transition: all 0.2s;
        font-family: inherit;
    }

    .form-input:focus {
        outline: none;
        border-color: var(--dash-primary);
        box-shadow: 0 0 0 4px var(--dash-primary-soft);
    }

    /* Custom Input Group Styling for Units */
    .input-group {
        position: relative;
        display: flex;
        align-items: center;
    }
    
    .input-group .form-input {
        padding-right: 3.5rem; /* Make room for the unit text */
    }

    .input-group-text {
        position: absolute;
        right: 1rem;
        color: var(--dash-text-muted);
        font-weight: 600;
        font-size: 0.9rem;
        pointer-events: none;
        background: transparent;
        border: none;
    }

    .btn-group {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn {
        padding: 1rem 2rem;
        font-size: 1rem;
        font-weight: 600;
        border-radius: var(--dash-radius-sm);
        cursor: pointer;
        text-decoration: none;
        text-align: center;
        transition: all 0.2s;
        border: none;
        flex: 1;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--dash-primary), var(--dash-primary-light));
        color: white;
        box-shadow: 0 4px 16px rgba(220, 38, 38, 0.25);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(220, 38, 38, 0.35);
    }

    .btn-secondary {
        background: white;
        color: var(--dash-text-muted);
        border: 2px solid var(--dash-border);
    }

    .btn-secondary:hover {
        border-color: var(--dash-primary);
        color: var(--dash-primary);
    }

    .alert {
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        border-radius: 12px;
        font-size: 1rem;
    }

    .alert-success { background: #fee2e2; color: #991b1b; border-left: 4px solid #ef4444; }

    @media (max-width: 480px) {
        .form-row { grid-template-columns: 1fr; }
    }
</style>
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-container">
        <a href="{{ path('app_health_journal_index', {'_locale': app.request.locale}) }}" class="back-link">
            ← Retour au journal
        </a>

        <div class="form-card">
            <div class="form-header">
                <h1 class="form-title">
                    <span class="form-title-icon">❤️</span>
                    Nouvelle Entrée Santé
                </h1>
            </div>
            <div class="form-body">
                {{ form_start(form, {'action': path('app_health_journal_new', {'_locale': app.request.locale}), 'attr': {'novalidate': 'novalidate'}}) }}
                    
                    {% if not form.vars.valid %}
                    <div class="alert alert-danger">
                        {{ form_errors(form) }}
                        <ul>
                            {% for child in form.children %}
                                {% for error in child.vars.errors %}
                                    <li>{{ child.vars.label }}: {{ error.message }}</li>
                                {% endfor %}
                            {% endfor %}
                        </ul>
                    </div>
                    {% endif %}

                    <!-- Section 1: Date & Temps -->
                    <div class="form-section">
                        <h2 class="section-title">📅 Date & Heure</h2>
                        <div class="form-group">
                            {{ form_label(form.date, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.date, {'attr': {'class': 'form-input'}}) }}
                            {{ form_errors(form.date) }}
                        </div>
                    </div>

                    <!-- Section 2: Signes Vitaux -->
                    <div class="form-section">
                        <h2 class="section-title">🩺 Signes Vitaux</h2>
                        
                        <!-- Blood Pressure Row -->
                        <div class="form-row">
                            <div class="form-group">
                                {{ form_label(form.bloodPressureSystolic, null, {'label_attr': {'class': 'form-label'}}) }}
                                <div class="input-group">
                                    {{ form_widget(form.bloodPressureSystolic, {'attr': {'class': 'form-input', 'placeholder': '120'}}) }}
                                    <span class="input-group-text">mmHg</span>
                                </div>
                                {{ form_errors(form.bloodPressureSystolic) }}
                            </div>
                            <div class="form-group">
                                {{ form_label(form.bloodPressureDiastolic, null, {'label_attr': {'class': 'form-label'}}) }}
                                <div class="input-group">
                                    {{ form_widget(form.bloodPressureDiastolic, {'attr': {'class': 'form-input', 'placeholder': '80'}}) }}
                                    <span class="input-group-text">mmHg</span>
                                </div>
                                {{ form_errors(form.bloodPressureDiastolic) }}
                            </div>
                        </div>

                        <!-- Heart Rate & Temp Row -->
                        <div class="form-row">
                            <div class="form-group">
                                {{ form_label(form.heartRate, null, {'label_attr': {'class': 'form-label'}}) }}
                                <div class="input-group">
                                    {{ form_widget(form.heartRate, {'attr': {'class': 'form-input', 'placeholder': '72'}}) }}
                                    <span class="input-group-text">bpm</span>
                                </div>
                                {{ form_errors(form.heartRate) }}
                            </div>
                            <div class="form-group">
                                {{ form_label(form.temperature, null, {'label_attr': {'class': 'form-label'}}) }}
                                <div class="input-group">
                                    {{ form_widget(form.temperature, {'attr': {'class': 'form-input', 'placeholder': '37.0'}}) }}
                                    <span class="input-group-text">°C</span>
                                </div>
                                {{ form_errors(form.temperature) }}
                            </div>
                        </div>
                    </div>

                    <!-- Section 3: Métabolisme -->
                    <div class="form-section">
                        <h2 class="section-title">⚖️ Métabolisme</h2>
                        <div class="form-row">
                            <div class="form-group">
                                {{ form_label(form.weight, null, {'label_attr': {'class': 'form-label'}}) }}
                                <div class="input-group">
                                    {{ form_widget(form.weight, {'attr': {'class': 'form-input', 'placeholder': '70.5'}}) }}
                                    <span class="input-group-text">kg</span>
                                </div>
                                {{ form_errors(form.weight) }}
                            </div>
                            <div class="form-group">
                                {{ form_label(form.bloodSugar, null, {'label_attr': {'class': 'form-label'}}) }}
                                <div class="input-group">
                                    {{ form_widget(form.bloodSugar, {'attr': {'class': 'form-input', 'placeholder': '100'}}) }}
                                    <span class="input-group-text">mg/dL</span>
                                </div>
                                {{ form_errors(form.bloodSugar) }}
                            </div>
                        </div>
                    </div>

                    <!-- Section 4: Notes -->
                    <div class="form-section">
                        <h2 class="section-title">📝 Notes & Observations</h2>
                        <div class="form-group">
                            {{ form_label(form.notes, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.notes, {'attr': {'class': 'form-input', 'rows': '4'}}) }}
                            {{ form_errors(form.notes) }}
                        </div>
                    </div>

                    <div class="btn-group">
                        <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
                        <a href="{{ path('app_health_journal_index', {'_locale': app.request.locale}) }}" class="btn btn-secondary">Annuler</a>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
