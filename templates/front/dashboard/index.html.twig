{% extends 'base_dashboard.html.twig' %}

{% block title %}Mon Tableau de Bord - WANNASNI{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ============================================
       DASHBOARD REDESIGN - Premium Senior-Friendly
       ============================================ */
    
    :root {
        --dash-primary: #2E7D32;
        --dash-primary-light: #4CAF50;
        --dash-primary-soft: rgba(46, 125, 50, 0.08);
        --dash-accent: #FF6B35;
        --dash-bg: #f8faf8;
        --dash-card: #ffffff;
        --dash-text: #1a1a2e;
        --dash-text-muted: #64748b;
        --dash-border: #e2e8f0;
        --dash-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
        --dash-shadow-hover: 0 8px 32px rgba(46, 125, 50, 0.12);
        --dash-radius: 20px;
        --dash-radius-sm: 12px;
    }

    body {
        background: var(--dash-bg);
    }

    /* Chat Toggle Button Styles */
    .chat-toggle-btn {
        position: fixed;
        bottom: 24px;
        right: 24px;
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border: none;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 0 8px 32px rgba(99, 102, 241, 0.3);
        transition: all 0.3s ease;
        z-index: 1000;
    }

    .chat-toggle-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 40px rgba(99, 102, 241, 0.4);
    }

    .chat-toggle-btn .icon-chat {
        color: white;
        width: 24px;
        height: 24px;
    }

    .notification-badge {
        position: absolute;
        top: -8px;
        right: -8px;
        background: #ef4444;
        color: white;
        border-radius: 50%;
        width: 20px;
        height: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: bold;
    }

    /* Help Button Styles */
    .help-trigger {
        position: fixed;
        bottom: 24px;
        left: 24px;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.85rem 1.5rem;
        background: linear-gradient(135deg, #dc2626, #ef4444);
        color: white;
        border: none;
        border-radius: 50px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 8px 32px rgba(220, 38, 38, 0.35);
        transition: all 0.3s ease;
        z-index: 1000;
        animation: pulse-help 2s infinite;
    }

    .help-trigger:hover {
        transform: translateY(-2px) scale(1.05);
        box-shadow: 0 12px 40px rgba(220, 38, 38, 0.45);
    }

    .help-icon {
        font-size: 1.3rem;
    }

    .help-text {
        color: white;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.025em;
    }
    
    @keyframes pulse-help {
        0%, 100% { box-shadow: 0 8px 32px rgba(220, 38, 38, 0.35); }
        50% { box-shadow: 0 8px 32px rgba(220, 38, 38, 0.55), 0 0 16px rgba(220, 38, 38, 0.25); }
    }

    /* Dashboard Layout */
    .dashboard-wrapper {
        min-height: 100vh;
        padding: 2rem 1.5rem 4rem;
        background: linear-gradient(180deg, #f0f7f0 0%, var(--dash-bg) 30%);
    }

    .dashboard-container {
        max-width: 1280px;
        margin: 0 auto;
    }

    /* Hero Welcome Section */
    .welcome-hero {
        position: relative;
        background: linear-gradient(135deg, var(--dash-primary) 0%, #1b5e20 100%);
        border-radius: var(--dash-radius);
        padding: 2.5rem;
        margin-bottom: 2rem;
        overflow: hidden;
        box-shadow: 0 8px 40px rgba(46, 125, 50, 0.25);
    }

    .welcome-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
        border-radius: 50%;
    }

    .welcome-hero::after {
        content: '🌿';
        position: absolute;
        right: 2rem;
        bottom: 1rem;
        font-size: 6rem;
        opacity: 0.15;
        transform: rotate(-15deg);
    }

    .welcome-content {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1.5rem;
    }

    .welcome-text {
        color: white;
    }

    .welcome-greeting {
        font-size: 1rem;
        opacity: 0.9;
        margin-bottom: 0.25rem;
        letter-spacing: 0.02em;
    }

    .welcome-name {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        font-weight: 700;
        margin-bottom: 0.5rem;
        text-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .welcome-subtitle {
        font-size: 1rem;
        opacity: 0.85;
    }

    .welcome-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .welcome-date {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
        padding: 0.75rem 1.25rem;
        border-radius: 50px;
        color: white;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .btn-admin-dashboard {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background: rgba(255, 255, 255, 0.95);
        color: var(--dash-primary);
        text-decoration: none;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        border: 2px solid rgba(255, 255, 255, 0.3);
        backdrop-filter: blur(10px);
    }

    .btn-admin-dashboard:hover {
        background: white;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        border-color: white;
    }

    .btn-admin-dashboard span {
        font-size: 1.1rem;
    }

    /* Stats Bar */
    .stats-bar {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: var(--dash-card);
        border-radius: var(--dash-radius-sm);
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: var(--dash-shadow);
        border: 1px solid var(--dash-border);
        transition: all 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--dash-shadow-hover);
    }

    .stat-icon {
        width: 56px;
        height: 56px;
        border-radius: var(--dash-radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .stat-icon.health { background: linear-gradient(135deg, #fee2e2, #fecaca); }
    .stat-icon.activity { background: linear-gradient(135deg, #dcfce7, #bbf7d0); }
    .stat-icon.services { background: linear-gradient(135deg, #dbeafe, #bfdbfe); }
    .stat-icon.mood { background: linear-gradient(135deg, #fef3c7, #fde68a); }

    .stat-info {
        flex: 1;
    }

    .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--dash-text);
        line-height: 1.2;
    }

    .stat-label {
        font-size: 0.8rem;
        color: var(--dash-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    /* Main Grid */
    .dashboard-main {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @media (min-width: 768px) {
        .dashboard-main {
            grid-template-columns: 2fr 1fr;
        }
    }

    /* Cards */
    .dash-card {
        background: var(--dash-card);
        border-radius: var(--dash-radius);
        box-shadow: var(--dash-shadow);
        border: 1px solid var(--dash-border);
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .dash-card:hover {
        box-shadow: var(--dash-shadow-hover);
    }

    .dash-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--dash-border);
        background: linear-gradient(to right, var(--dash-primary-soft), transparent);
    }

    .dash-card-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--dash-text);
    }

    .dash-card-title-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: linear-gradient(135deg, var(--dash-primary), var(--dash-primary-light));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1rem;
    }

    .dash-card-link {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        color: var(--dash-primary);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 600;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        transition: all 0.2s;
    }

    .dash-card-link:hover {
        background: var(--dash-primary-soft);
    }

    .dash-card-body {
        padding: 1.5rem;
    }

    /* Activity Items */
    .activity-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .activity-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        background: linear-gradient(to right, #f8faf8, white);
        border-radius: var(--dash-radius-sm);
        border: 1px solid var(--dash-border);
        transition: all 0.25s ease;
        cursor: pointer;
    }

    .activity-item:hover {
        transform: translateX(8px);
        border-color: var(--dash-primary);
        box-shadow: 0 4px 16px rgba(46, 125, 50, 0.1);
    }

    .activity-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        flex-shrink: 0;
    }

    .activity-icon.physical { 
        background: linear-gradient(135deg, #dcfce7, #bbf7d0);
    }
    .activity-icon.cognitive { 
        background: linear-gradient(135deg, #dbeafe, #bfdbfe);
    }
    .activity-icon.social { 
        background: linear-gradient(135deg, #fef3c7, #fde68a);
    }

    .activity-info {
        flex: 1;
        min-width: 0;
    }

    .activity-name {
        font-weight: 600;
        font-size: 1rem;
        color: var(--dash-text);
        margin-bottom: 0.25rem;
    }

    .activity-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.85rem;
        color: var(--dash-text-muted);
    }

    .activity-time {
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .activity-badge {
        padding: 0.25rem 0.75rem;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .badge-tomorrow { background: #dcfce7; color: #166534; }
    .badge-upcoming { background: #dbeafe; color: #1e40af; }

    /* Health Widget */
    .health-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }

    .health-metric {
        text-align: center;
        padding: 1.25rem;
        background: linear-gradient(135deg, #f8faf8, white);
        border-radius: var(--dash-radius-sm);
        border: 1px solid var(--dash-border);
        transition: all 0.25s ease;
    }

    .health-metric:hover {
        border-color: var(--dash-primary);
        transform: scale(1.02);
    }

    .health-metric-icon {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
    }

    .health-metric-value {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--dash-primary);
        line-height: 1.2;
    }

    .health-metric-label {
        font-size: 0.75rem;
        color: var(--dash-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-top: 0.25rem;
    }

    .health-mood {
        grid-column: span 2;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        padding: 1rem;
        background: linear-gradient(135deg, #fef3c7, #fef9c3);
        border-radius: var(--dash-radius-sm);
        border: 1px solid #fde68a;
    }

    .health-mood-icon {
        font-size: 2.5rem;
    }

    .health-mood-text {
        font-weight: 600;
        color: #92400e;
    }

    /* Services List */
    .service-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.25rem;
        background: linear-gradient(to right, #f8faf8, white);
        border-radius: var(--dash-radius-sm);
        border: 1px solid var(--dash-border);
        margin-bottom: 0.75rem;
        transition: all 0.25s ease;
    }

    .service-item:hover {
        border-color: var(--dash-primary);
        box-shadow: 0 4px 16px rgba(46, 125, 50, 0.1);
    }

    .service-item:last-child {
        margin-bottom: 0;
    }

    .service-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .service-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: var(--dash-primary-soft);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    .service-name {
        font-weight: 600;
        color: var(--dash-text);
    }

    .service-badge {
        padding: 0.35rem 0.85rem;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .badge-pending { background: #fef3c7; color: #92400e; }
    .badge-progress { background: #dbeafe; color: #1e40af; }
    .badge-completed { background: #dcfce7; color: #166534; }

    /* Quick Actions */
    .quick-actions {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }

    .quick-action-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        padding: 1.5rem 1rem;
        background: linear-gradient(135deg, #f8faf8, white);
        border-radius: var(--dash-radius-sm);
        border: 2px solid var(--dash-border);
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .quick-action-btn:hover {
        border-color: var(--dash-primary);
        background: linear-gradient(135deg, #dcfce7, white);
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(46, 125, 50, 0.15);
    }

    .quick-action-icon {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--dash-primary), var(--dash-primary-light));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        box-shadow: 0 4px 16px rgba(46, 125, 50, 0.25);
    }

    .quick-action-label {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--dash-text);
        text-align: center;
    }

    /* Primary Action Button */
    .btn-primary-action {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        padding: 1rem;
        background: linear-gradient(135deg, var(--dash-primary), var(--dash-primary-light));
        color: white;
        border: none;
        border-radius: var(--dash-radius-sm);
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 16px rgba(46, 125, 50, 0.25);
        margin-top: 1rem;
    }

    .btn-primary-action:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(46, 125, 50, 0.35);
    }

    /* Sidebar Cards */
    .sidebar-stack {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Emergency Card */
    .emergency-card {
        background: linear-gradient(135deg, #fee2e2, #fecaca);
        border: 2px solid #f87171;
        border-radius: var(--dash-radius);
        padding: 1.5rem;
        text-align: center;
    }

    .emergency-icon {
        font-size: 2.5rem;
        margin-bottom: 0.75rem;
    }

    .emergency-title {
        font-weight: 700;
        font-size: 1.1rem;
        color: #b91c1c;
        margin-bottom: 0.5rem;
    }

    .emergency-text {
        font-size: 0.875rem;
        color: #991b1b;
        margin-bottom: 1rem;
    }

    .emergency-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background: #dc2626;
        color: white;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }

    .emergency-btn:hover {
        background: #b91c1c;
        transform: scale(1.05);
    }

    /* Responsive */
    @media (max-width: 767px) {
        .dashboard-wrapper {
            padding: 1rem;
            padding-bottom: 5rem;
        }

        .welcome-hero {
            padding: 1.5rem;
        }

        .welcome-content {
            flex-direction: column;
            align-items: flex-start;
        }

        .stats-bar {
            grid-template-columns: repeat(2, 1fr);
        }

        .quick-actions {
            grid-template-columns: 1fr;
        }

        .health-grid {
            grid-template-columns: 1fr;
        }

        .health-mood {
            grid-column: span 1;
        }

        .service-type-grid {
            grid-template-columns: 1fr;
        }
        
        /* Move floating buttons above mobile nav */
        .chat-toggle-btn {
            bottom: 5.5rem;
        }
        
        .help-trigger {
            bottom: 5.5rem;
        }

        .help-text {
            display: none;
        }
    }

    /* ===== Service Type Cards ===== */
    .service-type-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .service-type-card {
        display: block;
        text-decoration: none;
        padding: 1.25rem;
        border-radius: 16px;
        border: 2px solid transparent;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .service-type-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    }

    .service-type-card.transport {
        background: linear-gradient(135deg, #dbeafe, #eff6ff);
    }
    .service-type-card.transport:hover { border-color: #3b82f6; }

    .service-type-card.home {
        background: linear-gradient(135deg, #dcfce7, #f0fdf4);
    }
    .service-type-card.home:hover { border-color: #22c55e; }

    .service-type-card.grocery {
        background: linear-gradient(135deg, #fef3c7, #fefce8);
    }
    .service-type-card.grocery:hover { border-color: #f59e0b; }

    .service-type-card.companion {
        background: linear-gradient(135deg, #f3e8ff, #faf5ff);
    }
    .service-type-card.companion:hover { border-color: #a855f7; }

    .service-type-emoji {
        font-size: 2.5rem;
        margin-bottom: 0.75rem;
    }

    .service-type-name {
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 0.25rem;
    }

    .service-type-card.transport .service-type-name { color: #1e40af; }
    .service-type-card.home .service-type-name { color: #166534; }
    .service-type-card.grocery .service-type-name { color: #92400e; }
    .service-type-card.companion .service-type-name { color: #7c3aed; }

    .service-type-desc {
        font-size: 0.8rem;
        opacity: 0.8;
    }

    .service-type-card.transport .service-type-desc { color: #3b82f6; }
    .service-type-card.home .service-type-desc { color: #22c55e; }
    .service-type-card.grocery .service-type-desc { color: #f59e0b; }
    .service-type-card.companion .service-type-desc { color: #a855f7; }

    /* ===== Recent Services List ===== */
    .recent-services-wrapper {
        background: #f8fafc;
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .recent-services-title {
        font-weight: 600;
        color: #64748b;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.75rem;
    }

    .recent-service-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem;
        background: white;
        border-radius: 10px;
        margin-bottom: 0.5rem;
        border: 1px solid #e2e8f0;
        transition: all 0.2s ease;
    }

    .recent-service-item:last-child {
        margin-bottom: 0;
    }

    .recent-service-item:hover {
        border-color: var(--dash-primary);
    }

    .recent-service-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .recent-service-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: linear-gradient(135deg, #dbeafe, #bfdbfe);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
    }

    .recent-service-name {
        font-weight: 600;
        font-size: 0.9rem;
        color: #1a1a2e;
    }

    .recent-service-date {
        font-size: 0.75rem;
        color: #64748b;
    }

    .service-status-badge {
        padding: 0.35rem 0.85rem;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .service-status-badge.pending { background: #fef3c7; color: #92400e; }
    .service-status-badge.in-progress { background: #dbeafe; color: #1e40af; }
    .service-status-badge.completed { background: #dcfce7; color: #166534; }

    /* ===== New Service Button ===== */
    .btn-new-service {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        padding: 1rem;
        background: linear-gradient(135deg, #2563eb, #3b82f6);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 16px rgba(37, 99, 235, 0.25);
    }

    .btn-new-service:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(37, 99, 235, 0.35);
        color: white;
    }

    /* ===== Nutrition Cards ===== */
    .nutrition-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .nutrition-stat {
        text-align: center;
        padding: 1rem;
        border-radius: 12px;
    }

    .nutrition-stat.water { background: linear-gradient(135deg, #dbeafe, #eff6ff); }
    .nutrition-stat.calories { background: linear-gradient(135deg, #fef3c7, #fefce8); }

    .nutrition-stat-icon {
        font-size: 1.5rem;
        margin-bottom: 0.25rem;
    }

    .nutrition-stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .nutrition-stat.water .nutrition-stat-value { color: #3b82f6; }
    .nutrition-stat.calories .nutrition-stat-value { color: #f59e0b; }

    .nutrition-stat-label {
        font-size: 0.75rem;
        color: #64748b;
        text-transform: uppercase;
    }

    .nutrition-next-meal {
        background: #f0fdf4;
        padding: 0.85rem 1rem;
        border-radius: 10px;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .nutrition-next-meal-icon {
        font-size: 1.25rem;
    }

    .nutrition-next-meal-text {
        font-size: 0.9rem;
        color: #166534;
        font-weight: 500;
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard-wrapper">
    <div class="dashboard-container">
        
        {% if profile_incomplete %}
        <!-- Profile Completion Modal -->
        <div id="profileModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; align-items: center; justify-content: center; animation: fadeIn 0.3s;">
            <div style="background: white; border-radius: 20px; padding: 2.5rem; max-width: 500px; width: 90%; box-shadow: 0 20px 60px rgba(0,0,0,0.3); animation: slideUp 0.4s;">
                <div style="text-align: center;">
                    <div style="width: 80px; height: 80px; background: linear-gradient(135deg, #2E7D32, #4CAF50); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; font-size: 2.5rem; overflow: hidden; color: white; font-weight: 700;">
                        {% if user.imageProfil %}
                            <img src="{{ user.imageProfil }}" alt="{{ user.firstName }}" style="width: 100%; height: 100%; object-fit: cover; display: block;">
                        {% else %}
                            <span>{{ user.firstName|first }}{{ user.lastName|first }}</span>
                        {% endif %}
                    </div>
                    <h2 style="font-family: 'Playfair Display', serif; font-size: 1.75rem; color: #1a1a2e; margin-bottom: 1rem;">
                        Complétez votre profil
                    </h2>
                    <p style="color: #64748b; font-size: 1.1rem; line-height: 1.6; margin-bottom: 2rem;">
                        Nous avons remarqué que certaines informations de votre profil sont manquantes. Souhaitez-vous les compléter maintenant pour une meilleure expérience ?
                    </p>
                    <div style="display: flex; gap: 1rem; justify-content: center;">
                        <a href="{{ path('app_profile', {'_locale': app.request.locale}) }}" style="flex: 1; padding: 1rem 1.5rem; background: linear-gradient(135deg, #2E7D32, #4CAF50); color: white; text-decoration: none; border-radius: 12px; font-weight: 600; text-align: center; transition: all 0.2s; box-shadow: 0 4px 12px rgba(46, 125, 50, 0.3);">
                            ✅ Oui, compléter
                        </a>
                        <button onclick="document.getElementById('profileModal').style.display='none'" style="flex: 1; padding: 1rem 1.5rem; background: #f1f5f9; color: #64748b; border: none; border-radius: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s;">
                            ⏭️ Plus tard
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <style>
            @keyframes fadeIn {
                from { opacity: 0; }
                to { opacity: 1; }
            }
            @keyframes slideUp {
                from { transform: translateY(50px); opacity: 0; }
                to { transform: translateY(0); opacity: 1; }
            }
        </style>
        {% endif %}
        
        <!-- Welcome Hero -->
        <section class="welcome-hero">
            <div class="welcome-content">
                <div class="welcome-text">
                    <p class="welcome-greeting">Bonjour et bienvenue 👋</p>
                    <h1 class="welcome-name">{{ user.firstName }} {{ user.lastName }}</h1>
                    <p class="welcome-subtitle">Voici votre espace personnel WANNASNI</p>
                </div>
                <div class="welcome-actions">
                    <div class="welcome-date">
                        📅 {{ "now"|date("l d F Y") }}
                    </div>
                    {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin_dashboard') }}" class="btn-admin-dashboard">
                        <span>⚙️</span> Panneau Admin
                    </a>
                    {% endif %}
                </div>
            </div>
        </section>

        <!-- Stats Bar -->
        <section class="stats-bar">
            <div class="stat-card">
                <div class="stat-icon health">❤️</div>
                <div class="stat-info">
                    <div class="stat-value">{{ recent_health.bloodPressure }}</div>
                    <div class="stat-label">Tension Artérielle</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon activity">🎯</div>
                <div class="stat-info">
                    <div class="stat-value">{{ upcoming_activities|length }}</div>
                    <div class="stat-label">Activités à venir</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon services">🛎️</div>
                <div class="stat-info">
                    <div class="stat-value">{{ services|length }}</div>
                    <div class="stat-label">Services actifs</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon mood">
                    {% if recent_health.mood == 'excellent' %}😊{% elseif recent_health.mood == 'good' %}🙂{% else %}😐{% endif %}
                </div>
                <div class="stat-info">
                    <div class="stat-value">{% if recent_health.mood == 'excellent' %}Excellent{% elseif recent_health.mood == 'good' %}Bon{% else %}Correct{% endif %}</div>
                    <div class="stat-label">Humeur du jour</div>
                </div>
            </div>
        </section>

        <!-- Main Dashboard Grid -->
        <div class="dashboard-main">
            <!-- Left Column - Main Content -->
            <div class="main-content">
                
                <!-- Activities Card -->
                <div class="dash-card" style="margin-bottom: 1.5rem;">
                    <div class="dash-card-header">
                        <div class="dash-card-title">
                            <span class="dash-card-title-icon">🎯</span>
                            Prochaines Activités
                        </div>
                        <a href="{{ path('app_my_activities', {'_locale': app.request.locale}) }}" class="dash-card-link">
                            Voir tout →
                        </a>
                    </div>
                    <div class="dash-card-body">
                        <div class="activity-list">
                            {% for activity in upcoming_activities %}
                            <div class="activity-item">
                                <div class="activity-icon {{ activity.type }}">
                                    {% if activity.type == 'physical' %}🏃
                                    {% elseif activity.type == 'cognitive' %}🧠
                                    {% else %}👥{% endif %}
                                </div>
                                <div class="activity-info">
                                    <div class="activity-name">{{ activity.name }}</div>
                                    <div class="activity-meta">
                                        <span class="activity-time">🕐 {{ activity.time }}</span>
                                        <span class="activity-badge {% if loop.first %}badge-tomorrow{% else %}badge-upcoming{% endif %}">
                                            {{ activity.date }}
                                        </span>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <!-- Services Dashboard Card -->
                <div class="dash-card">
                    <div class="dash-card-header" style="background: linear-gradient(to right, rgba(37, 99, 235, 0.08), transparent);">
                        <div class="dash-card-title">
                            <span class="dash-card-title-icon" style="background: linear-gradient(135deg, #2563eb, #3b82f6);">🛎️</span>
                            Mes Services
                        </div>
                        <a href="{{ path('app_my_services', {'_locale': app.request.locale}) }}" class="dash-card-link" style="color: #2563eb;">
                            Voir tout →
                        </a>
                    </div>
                    <div class="dash-card-body">
                        <!-- Service Type Cards -->
                        <div class="service-type-grid">
                            <a href="{{ path('app_services_request', {'_locale': app.request.locale}) }}?type=transport" class="service-type-card transport">
                                <div class="service-type-emoji">🚗</div>
                                <div class="service-type-name">Transport</div>
                                <div class="service-type-desc">Médical & Personnel</div>
                            </a>
                            <a href="{{ path('app_services_request', {'_locale': app.request.locale}) }}?type=home" class="service-type-card home">
                                <div class="service-type-emoji">🏠</div>
                                <div class="service-type-name">Aide à Domicile</div>
                                <div class="service-type-desc">Ménage & Cuisine</div>
                            </a>
                            <a href="{{ path('app_services_request', {'_locale': app.request.locale}) }}?type=grocery" class="service-type-card grocery">
                                <div class="service-type-emoji">🛒</div>
                                <div class="service-type-name">Courses</div>
                                <div class="service-type-desc">Alimentation & Produits</div>
                            </a>
                            <a href="{{ path('app_services_request', {'_locale': app.request.locale}) }}?type=companion" class="service-type-card companion">
                                <div class="service-type-emoji">👥</div>
                                <div class="service-type-name">Compagnie</div>
                                <div class="service-type-desc">Visites & Accompagnement</div>
                            </a>
                        </div>
                        
                        <!-- Recent Services -->
                        {% if services|length > 0 %}
                        <div class="recent-services-wrapper">
                            <div class="recent-services-title">📋 Mes demandes récentes</div>
                            {% for service in services|slice(0, 3) %}
                            <div class="recent-service-item">
                                <div class="recent-service-info">
                                    <div class="recent-service-icon">
                                        {% if 'Transport' in service.type %}🚗
                                        {% elseif 'Home' in service.type %}🏠
                                        {% elseif 'Grocery' in service.type %}🛒
                                        {% else %}👥{% endif %}
                                    </div>
                                    <div>
                                        <div class="recent-service-name">{{ service.type }}</div>
                                        <div class="recent-service-date">{{ service.requestedAt|date('d/m/Y') }}</div>
                                    </div>
                                </div>
                                <span class="service-status-badge {% if service.status == 'pending' %}pending{% elseif service.status == 'in_progress' %}in-progress{% else %}completed{% endif %}">
                                    {% if service.status == 'pending' %}⏳ En attente{% elseif service.status == 'in_progress' %}🔄 En cours{% else %}✅ Terminé{% endif %}
                                </span>
                            </div>
                            {% endfor %}
                        </div>
                        {% endif %}
                        
                        <a href="{{ path('app_services_request', {'_locale': app.request.locale}) }}" class="btn-new-service">
                            ➕ Demander un nouveau service
                        </a>
                    </div>
                </div>
            </div>

            <!-- Right Column - Sidebar -->
            <div class="sidebar-stack">
                
                <!-- Health Widget -->
                <div class="dash-card">
                    <div class="dash-card-header">
                        <div class="dash-card-title">
                            <span class="dash-card-title-icon">❤️</span>
                            Ma Santé
                        </div>
                        <a href="{{ path('app_my_health', {'_locale': app.request.locale}) }}" class="dash-card-link">
                            Détails →
                        </a>
                    </div>
                    <div class="dash-card-body">
                        <div class="health-grid">
                            <div class="health-metric">
                                <div class="health-metric-icon">💓</div>
                                <div class="health-metric-value">{{ recent_health.heartRate }}</div>
                                <div class="health-metric-label">BPM</div>
                            </div>
                            <div class="health-metric">
                                <div class="health-metric-icon">🩺</div>
                                <div class="health-metric-value">{{ recent_health.bloodPressure }}</div>
                                <div class="health-metric-label">Tension</div>
                            </div>
                            <div class="health-mood">
                                <span class="health-mood-icon">
                                    {% if recent_health.mood == 'excellent' %}😊
                                    {% elseif recent_health.mood == 'good' %}🙂
                                    {% else %}😐{% endif %}
                                </span>
                                <span class="health-mood-text">
                                    Humeur: {% if recent_health.mood == 'excellent' %}Excellente{% elseif recent_health.mood == 'good' %}Bonne{% else %}Correcte{% endif %}
                                </span>
                            </div>
                        </div>
                        <a href="{{ path('app_my_health_add', {'_locale': app.request.locale}) }}" class="btn-primary-action">
                            ➕ Nouvelle entrée santé
                        </a>
                    </div>
                </div>

                <!-- Nutrition Widget -->
                <div class="dash-card">
                    <div class="dash-card-header" style="background: linear-gradient(to right, rgba(34, 197, 94, 0.08), transparent);">
                        <div class="dash-card-title">
                            <span class="dash-card-title-icon" style="background: linear-gradient(135deg, #22c55e, #4ade80);">🥗</span>
                            Ma Nutrition
                        </div>
                        <a href="{{ path('app_my_nutrition', {'_locale': app.request.locale}) }}" class="dash-card-link" style="color: #22c55e;">
                            Voir tout →
                        </a>
                    </div>
                    <div class="dash-card-body">
                        <div class="nutrition-grid">
                            <div class="nutrition-stat water">
                                <div class="nutrition-stat-icon">💧</div>
                                <div class="nutrition-stat-value">{{ nutrition.water_intake }}/{{ nutrition.water_goal }}</div>
                                <div class="nutrition-stat-label">Verres d'eau</div>
                            </div>
                            <div class="nutrition-stat calories">
                                <div class="nutrition-stat-icon">🔥</div>
                                <div class="nutrition-stat-value">{{ nutrition.calories_today }}</div>
                                <div class="nutrition-stat-label">Calories</div>
                            </div>
                        </div>
                        <div class="nutrition-next-meal">
                            <span class="nutrition-next-meal-icon">⏰</span>
                            <span class="nutrition-next-meal-text">{{ nutrition.next_meal }}</span>
                        </div>
                        <a href="{{ path('app_nutrition_request', {'_locale': app.request.locale}) }}" class="btn-primary-action" style="background: linear-gradient(135deg, #22c55e, #4ade80);">
                            ➕ Nouvelle demande de régime
                        </a>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="dash-card">
                    <div class="dash-card-header">
                        <div class="dash-card-title">
                            <span class="dash-card-title-icon">⚡</span>
                            Accès Rapide
                        </div>
                    </div>
                    <div class="dash-card-body">
                        <div class="quick-actions">
                            <a href="{{ path('app_profile', {'_locale': app.request.locale}) }}" class="quick-action-btn">
                                <span class="quick-action-icon">👤</span>
                                <span class="quick-action-label">Mon Profil</span>
                            </a>
                            <a href="{{ path('app_my_activities', {'_locale': app.request.locale}) }}" class="quick-action-btn">
                                <span class="quick-action-icon">🎯</span>
                                <span class="quick-action-label">Activités</span>
                            </a>
                            <a href="{{ path('app_my_nutrition', {'_locale': app.request.locale}) }}" class="quick-action-btn">
                                <span class="quick-action-icon">🥗</span>
                                <span class="quick-action-label">Nutrition</span>
                            </a>
                            <a href="{{ path('app_my_services', {'_locale': app.request.locale}) }}" class="quick-action-btn">
                                <span class="quick-action-icon">🛎️</span>
                                <span class="quick-action-label">Services</span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Emergency Card -->
                <div class="emergency-card">
                    <div class="emergency-icon">🆘</div>
                    <div class="emergency-title">Besoin d'aide urgente?</div>
                    <p class="emergency-text">Notre équipe est disponible 24h/24</p>
                    <a href="tel:+33123456789" class="emergency-btn">
                        📞 Appeler maintenant
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Help Button -->
<button class="help-trigger" onclick="document.getElementById('helpModal').classList.add('active')" aria-label="Get Help">
    <span class="help-icon">🆘</span>
    <span class="help-text">Aide</span>
</button>

<!-- Chat Toggle Button -->
<button class="chat-toggle-btn" id="chat-toggle" aria-label="Open Chat">
    <svg class="icon-chat" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    <span class="notification-badge" style="display: none;">1</span>
</button>

<!-- Smart Chat Container -->
<div id="smart-chat-container">
    <!-- Chat Window -->
    <div class="chat-window" id="chat-window">
        <div class="chat-header">
            <div class="header-info">
                <div class="avatar-ring">
                    <img src="https://ui-avatars.com/api/?name=AI&background=6366f1&color=fff" alt="AI Agent">
                    <span class="status-dot"></span>
                </div>
                <div class="agent-details">
                    <span class="agent-name">Assistant WANNASNI</span>
                    <span class="agent-status" id="agent-status">Online & Ready</span>
                </div>
            </div>
            <!-- Persona Selector -->
            <select id="persona-select" class="persona-select" title="AI Persona">
                <option value="default">🤖 Assistant</option>
                <option value="health">🎩 Santé</option>
                <option value="nutrition">🥗 Nutrition</option>
                <option value="activity">🏃 Activités</option>
                <option value="service">🛠️ Services</option>
            </select>
            <div class="header-actions">
                <!-- Export Chat -->
                <button class="header-icon-btn" id="export-chat" title="Exporter Chat">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="7 10 12 15 17 10"></polyline>
                        <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                </button>
                <!-- Clear Chat -->
                <button class="header-icon-btn" id="clear-chat" title="Nouveau Chat">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 20h9"></path>
                        <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                    </svg>
                </button>
                <!-- Close -->
                <button class="close-btn" id="close-chat" aria-label="Fermer Chat">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 6L6 18M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Drag & Drop Zone -->
        <div class="drop-zone" id="drop-zone">
            <div class="drop-zone-content">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="17 8 12 3 7 8"></polyline>
                    <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                <span>Déposez un fichier ou une image ici</span>
            </div>
        </div>

        <div class="chat-messages" id="chat-messages">
            <div class="message bot-message welcome">
                <p>Bonjour! Je suis votre <strong>Assistant WANNASNI</strong> 🤖<br>
                   Vos fonctionnalités: 🔍 Recherche · 📋 Données Santé · 🏃 Activités · 🍽️ Nutrition</p>
                <span class="timestamp">Maintenant</span>
            </div>
        </div>

        <!-- Usage Stats -->
        <div class="usage-stats" id="usage-stats">
            <span>💬 <span id="msg-count">0</span> msgs</span>
            <span>📈 <span id="token-count">0</span> tokens</span>
        </div>

        <!-- Suggested Prompts -->
        <div class="suggested-prompts" id="suggested-prompts">
            <button class="prompt-chip" data-prompt="Comment puis-je améliorer ma santé?">📊 Santé</button>
            <button class="prompt-chip" data-prompt="Quelles activités me recommandez-vous?">🏃 Activités</button>
            <button class="prompt-chip" data-prompt="Aide-moi avec mon régime alimentaire">🥗 Nutrition</button>
            <button class="prompt-chip" data-prompt="Quels services puis-je demander?">🛠️ Services</button>
        </div>

        <div class="chat-input-area">
            <div class="typing-indicator" id="typing-indicator">
                <span></span><span></span><span></span>
            </div>
            <div id="image-preview-container" class="image-preview hidden">
                <img id="image-preview" src="" alt="Preview">
                <button id="remove-image" class="remove-btn">×</button>
            </div>

            <div class="input-wrapper">
                <input type="file" id="image-upload" accept="image/*" style="display: none;">
                <input type="file" id="file-upload" accept=".pdf,.csv,.txt,.json,.xml,.html,.md,.js,.py,.php,.css" style="display: none;">
                <button id="upload-btn" title="Télécharger Image">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
                    </svg>
                </button>
                <button id="file-upload-btn" title="Télécharger Fichier">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="12" y1="18" x2="12" y2="12"></line>
                        <line x1="9" y1="15" x2="15" y2="15"></line>
                    </svg>
                </button>
                <button id="voice-btn" title="Entrée Vocale">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
