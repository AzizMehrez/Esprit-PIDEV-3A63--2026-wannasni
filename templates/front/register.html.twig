{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'cta.signup'|trans|default("S'inscrire") }} — {{ 'site.name'|trans }}{% endblock %}

{% block body %}
<div class="auth-page">
    {# Left Side - Image & Quote #}
    <div class="auth-image-side">
        <div class="auth-image-overlay"></div>
        <img src="/images/hero.png" alt="" class="auth-bg-image" aria-hidden="true">
        <div class="auth-image-content">
            <div class="auth-logo">
                <img src="/images/logo.png" alt="WANNASNI" class="auth-logo-img">
            </div>
            <blockquote class="auth-quote">
                <p>"{{ 'auth.quote.register'|trans|default('Rejoignez des milliers de familles qui ont trouvé la sérénité.') }}"</p>
                <cite>— WANNASNI</cite>
            </blockquote>
        </div>
    </div>
    
    {# Right Side - Register Form #}
    <div class="auth-form-side">
        <div class="auth-form-container auth-form-container--register">
            {# Mobile Logo (shown on small screens only) #}
            <div class="auth-mobile-header">
                <a href="{{ path('app_home') }}" class="auth-back-link">
                    ← {{ 'nav.back'|trans|default('Retour') }}
                </a>
                <img src="/images/logo.png" alt="WANNASNI" class="auth-mobile-logo">
            </div>
            
            <div class="auth-form-header">
                <h1 class="auth-title">{{ 'register'|trans|default('Créez votre compte') }}</h1>
                <p class="auth-subtitle">{{ 'register'|trans|default('Rejoignez la famille WANNASNI en quelques étapes.') }}</p>
            </div>
            
            {% for message in app.flashes('error') %}
                {% if loop.first %}
                <div class="alert alert-error" style="padding: 1rem; background: #fed7d7; color: #c53030; border: 1px solid #fc8181; border-radius: 8px; margin-bottom: 1rem;">
                {% endif %}
                    <p style="margin: 0;">⚠️ {{ message }}</p>
                {% if loop.last %}
                </div>
                {% endif %}
            {% endfor %}
            
            {% for message in app.flashes('success') %}
                {% if loop.first %}
                <div class="alert alert-success" style="padding: 1rem; background: #c6f6d5; color: #276749; border: 1px solid #9ae6b4; border-radius: 8px; margin-bottom: 1rem;">
                {% endif %}
                    <p style="margin: 0;">✓ {{ message }}</p>
                {% if loop.last %}
                </div>
                {% endif %}
            {% endfor %}
            
            {% for message in app.flashes('info') %}
                {% if loop.first %}
                <div class="alert alert-info" style="padding: 1rem; background: #bee3f8; color: #2b6cb0; border: 1px solid #90cdf4; border-radius: 8px; margin-bottom: 1rem;">
                {% endif %}
                    <p style="margin: 0;">ℹ️ {{ message }}</p>
                {% if loop.last %}
                </div>
                {% endif %}
            {% endfor %}
            
            <form method="post" action="{{ path('app_register', {_locale: app.request.locale}) }}" class="auth-form">
                {# Role Selection - Big Icon Cards #}
                <div class="role-selection">
                    <p class="role-label">{{ 'select_role'|trans|default('Je suis...') }}</p>
                    <div class="role-cards">
                        <label class="role-card-option">
                            <input type="radio" name="role" value="senior" checked>
                            <div class="role-card-content">
                                <span class="role-emoji">👴</span>
                                <span class="role-name">{{ 'role.senior'|trans|default('Senior') }}</span>
                            </div>
                        </label>
                        <label class="role-card-option">
                            <input type="radio" name="role" value="family">
                            <div class="role-card-content">
                                <span class="role-emoji">👨‍👩‍👧</span>
                                <span class="role-name">{{ 'role.family'|trans|default('Famille') }}</span>
                            </div>
                        </label>
                        <label class="role-card-option">
                            <input type="radio" name="role" value="doctor">
                            <div class="role-card-content">
                                <span class="role-emoji">👨‍⚕️</span>
                                <span class="role-name">{{ 'role.doctor'|trans|default('Médecin') }}</span>
                            </div>
                        </label>
                        <label class="role-card-option">
                            <input type="radio" name="role" value="coach">
                            <div class="role-card-content">
                                <span class="role-emoji">🏋️</span>
                                <span class="role-name">{{ 'role.coach'|trans|default('Coach') }}</span>
                            </div>
                        </label>
                    </div>
                </div>
                
                <div class="form-row-2col">
                    <div class="form-group">
                        <label for="inputFirstName" class="form-label">{{ 'auth.first_name'|trans|default('Prénom') }}</label>
                        <input type="text" 
                               id="inputFirstName" 
                               name="firstName" 
                               class="form-input" 
                               placeholder="Jean"
                               autocomplete="given-name"
                               required>
                        <span class="error-message" id="firstNameError" style="display: none; color: #c53030; font-size: 0.875rem; margin-top: 0.25rem;"></span>
                    </div>
                    <div class="form-group">
                        <label for="inputLastName" class="form-label">{{ 'auth.last_name'|trans|default('Nom') }}</label>
                        <input type="text" 
                               id="inputLastName" 
                               name="lastName" 
                               class="form-input" 
                               placeholder="Dupont"
                               autocomplete="family-name"
                               required>
                        <span class="error-message" id="lastNameError" style="display: none; color: #c53030; font-size: 0.875rem; margin-top: 0.25rem;"></span>
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="inputEmail" class="form-label">{{ 'auth.email'|trans|default('Adresse email') }}</label>
                    <input type="email" 
                           id="inputEmail" 
                           name="email" 
                           class="form-input" 
                           placeholder="exemple@email.com"
                           autocomplete="email"
                           required>
                    <span class="error-message" id="emailError" style="display: none; color: #c53030; font-size: 0.875rem; margin-top: 0.25rem;"></span>
                </div>
                
                <div class="form-group">
                    <label for="inputPhone" class="form-label">{{ 'auth.phone'|trans|default('Numéro de téléphone') }}</label>
                    <input type="tel" 
                           id="inputPhone" 
                           name="phone" 
                           class="form-input" 
                           placeholder="+216 XX XXX XXX"
                           autocomplete="tel">
                    <span class="error-message" id="phoneError" style="display: none; color: #c53030; font-size: 0.875rem; margin-top: 0.25rem;"></span>
                </div>
                
                <div class="form-group">
                    <label for="inputPassword" class="form-label">{{ 'auth.password'|trans|default('Mot de passe') }}</label>
                    <input type="password" 
                           id="inputPassword" 
                           name="password" 
                           class="form-input" 
                           placeholder="••••••••"
                           autocomplete="new-password"
                           required>
                </div>
                
                <div class="form-group">
                    <label for="inputPasswordConfirm" class="form-label">{{ 'auth.password_confirm'|trans|default('Confirmer le mot de passe') }}</label>
                    <input type="password" 
                           id="inputPasswordConfirm" 
                           name="passwordConfirm" 
                           class="form-input" 
                           placeholder="••••••••"
                           autocomplete="new-password"
                           required>
                </div>
                
                <label class="form-checkbox terms-checkbox">
                    <input type="checkbox" name="agreeTerms">
                    <span class="checkbox-label">
                        {{ 'auth.agree_terms'|trans|default("J'accepte les") }} 
                        <a href="#terms" class="auth-link">{{ 'auth.terms'|trans|default("conditions d'utilisation") }}</a>
                    </span>
                </label>
                
                <button type="submit" class="btn btn-primary btn-large btn-full">
                    {{ 'auth.create_account'|trans|default('Créer mon compte') }}
                </button>
            </form>
            
            {# Social Authentication Buttons #}
            <div class="auth-divider">
                <span class="auth-divider-text">{{ 'auth.or_continue_with'|trans|default('Ou continuer avec') }}</span>
            </div>
            
            <div class="social-auth-buttons">
                <button type="button" class="btn-social btn-google" disabled>
                    <span class="btn-social-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="20" height="20">
                            <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/>
                            <path fill="#FF3D00" d="m6.306 14.691 6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/>
                            <path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/>
                            <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/>
                        </svg>
                    </span>
                    <span>{{ 'auth.continue_google'|trans|default('Continuer avec Google') }}</span>
                </button>
                <button type="button" class="btn-social btn-x" disabled>
                    <span class="btn-social-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18">
                            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                        </svg>
                    </span>
                    <span>{{ 'auth.continue_x'|trans|default('Continuer avec X') }}</span>
                </button>
                <button type="button" class="btn-social btn-facebook" disabled>
                    <span class="btn-social-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20">
                            <path fill="#1877F2" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                    </span>
                    <span>{{ 'auth.continue_facebook'|trans|default('Continuer avec Facebook') }}</span>
                </button>
            </div>
            
            <div class="auth-footer">
                <p>{{ 'auth.have_account'|trans|default('Vous avez déjà un compte ?') }} 
                   <a href="{{ path('app_login') }}" class="auth-link-strong">{{ 'cta.login'|trans|default('Se connecter') }}</a>
                </p>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const firstNameInput = document.getElementById('inputFirstName');
    const lastNameInput = document.getElementById('inputLastName');
    const emailInput = document.getElementById('inputEmail');
    const phoneInput = document.getElementById('inputPhone');

    const firstNameError = document.getElementById('firstNameError');
    const lastNameError = document.getElementById('lastNameError');
    const emailError = document.getElementById('emailError');
    const phoneError = document.getElementById('phoneError');

    // Validate first name - only letters
    function validateFirstName() {
        const value = firstNameInput.value.trim();
        const letterPattern = /^[a-zA-ZÀ-ÿ\s\-']+$/;
        
        if (value && !letterPattern.test(value)) {
            firstNameError.textContent = '⚠️ Le prénom ne doit contenir que des lettres.';
            firstNameError.style.display = 'block';
            firstNameInput.style.borderColor = '#c53030';
            return false;
        } else {
            firstNameError.style.display = 'none';
            firstNameInput.style.borderColor = '';
            return true;
        }
    }

    // Validate last name - only letters
    function validateLastName() {
        const value = lastNameInput.value.trim();
        const letterPattern = /^[a-zA-ZÀ-ÿ\s\-']+$/;
        
        if (value && !letterPattern.test(value)) {
            lastNameError.textContent = '⚠️ Le nom ne doit contenir que des lettres.';
            lastNameError.style.display = 'block';
            lastNameInput.style.borderColor = '#c53030';
            return false;
        } else {
            lastNameError.style.display = 'none';
            lastNameInput.style.borderColor = '';
            return true;
        }
    }

    // Validate email
    function validateEmail() {
        const value = emailInput.value.trim();
        const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        
        if (value && !emailPattern.test(value)) {
            emailError.textContent = '⚠️ Veuillez entrer une adresse email valide (exemple: nom@gmail.com).';
            emailError.style.display = 'block';
            emailInput.style.borderColor = '#c53030';
            return false;
        } else {
            emailError.style.display = 'none';
            emailInput.style.borderColor = '';
            return true;
        }
    }

    // Validate phone - only numbers and at least 8 digits
    function validatePhone() {
        const value = phoneInput.value.trim();
        if (!value) {
            phoneError.style.display = 'none';
            phoneInput.style.borderColor = '';
            return true;
        }

        const phonePattern = /^[0-9\s\-\+\(\)]+$/;
        const digitsOnly = value.replace(/\D/g, '');
        
        if (!phonePattern.test(value)) {
            phoneError.textContent = '⚠️ Le numéro de téléphone ne doit contenir que des chiffres.';
            phoneError.style.display = 'block';
            phoneInput.style.borderColor = '#c53030';
            return false;
        } else if (digitsOnly.length < 8) {
            phoneError.textContent = '⚠️ Le numéro de téléphone doit contenir au moins 8 chiffres.';
            phoneError.style.display = 'block';
            phoneInput.style.borderColor = '#c53030';
            return false;
        } else {
            phoneError.style.display = 'none';
            phoneInput.style.borderColor = '';
            return true;
        }
    }

    // Add event listeners for real-time validation
    firstNameInput.addEventListener('input', validateFirstName);
    firstNameInput.addEventListener('blur', validateFirstName);
    
    lastNameInput.addEventListener('input', validateLastName);
    lastNameInput.addEventListener('blur', validateLastName);
    
    emailInput.addEventListener('input', validateEmail);
    emailInput.addEventListener('blur', validateEmail);
    
    phoneInput.addEventListener('input', validatePhone);
    phoneInput.addEventListener('blur', validatePhone);
});
</script>
{% endblock %}
