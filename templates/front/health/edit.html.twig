                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
                <div class="form-group">
                    {{ form_label(form.hydratation) }}
                    {{ form_widget(form.hydratation) }}
                    {% if form.hydratation.vars.errors|length > 0 %}
                        <div class="form-error-container">
                            {% for error in form.hydratation.vars.errors %}
                                <div class="form-error-message">
                                    <span>⚠️</span>
