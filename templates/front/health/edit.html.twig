                                <span>{{ error.message }}</span>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="form-group">
                {{ form_label(form.medicamentsPris) }}
                {{ form_widget(form.medicamentsPris) }}
                {% if form.medicamentsPris.vars.errors|length > 0 %}
