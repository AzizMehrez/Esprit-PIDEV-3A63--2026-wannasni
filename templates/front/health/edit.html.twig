                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
            
            <div style="margin-top:1rem; display:flex; gap:0.5rem;">
                <button class="btn btn-primary">Enregistrer</button>
                <a href="{{ path('app_my_health', {'_locale': app.request.locale}) }}" class="btn btn-outline">Annuler</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
