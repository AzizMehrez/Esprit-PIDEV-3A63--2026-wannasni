                    {% endif %}
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div class="form-group">
                    {{ form_label(form.appetit) }}
                    {{ form_widget(form.appetit) }}
                    {% if form.appetit.vars.errors|length > 0 %}
