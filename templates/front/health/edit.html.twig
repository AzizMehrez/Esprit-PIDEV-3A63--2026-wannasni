                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.symptomes) }}
                {{ form_widget(form.symptomes) }}
                {% if form.symptomes.vars.errors|length > 0 %}
