                {% endif %}
            </div>

            <div class="form-group">
                {{ form_label(form.activitePhysique) }}
                {{ form_widget(form.activitePhysique) }}
                {% if form.activitePhysique.vars.errors|length > 0 %}
                    <div class="form-error-container">
                        {% for error in form.activitePhysique.vars.errors %}
