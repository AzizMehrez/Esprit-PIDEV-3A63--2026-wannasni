<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        body { font-family: DejaVu Sans, Arial, sans-serif; font-size: 12px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 1rem; }
        th, td { border: 1px solid #ddd; padding: 8px; }
        th { background: #f4f4f4; text-align: left; }
        h2 { text-align: center; }
    </style>
</head>
<body>
    <h2>Mon Journal de Santé</h2>
    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Tension</th>
                <th>Pouls</th>
                <th>Température</th>
                <th>Humeur</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
            {% for r in records %}
            <tr>
                <td>{{ r.date ? r.date|date('Y-m-d H:i') : '' }}</td>
                <td>{{ r.tensionArterielle }}</td>
                <td>{{ r.frequenceCardiaque }}</td>
                <td>{{ r.temperature }}</td>
                <td>{{ r.humeur }}</td>
                <td>{{ r.notes }}</td>
            </tr>
            {% else %}
            <tr><td colspan="6">Aucun enregistrement</td></tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>