{% extends 'base.html.twig' %}

{% block title %}Nouvelle Entrée Santé - WANNASNI{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    :root {
        --dash-primary: #dc2626;
        --dash-primary-light: #ef4444;
        --dash-bg: #f8faf8;
        --dash-card: #ffffff;
        --dash-text: #1a1a2e;
        --dash-text-muted: #64748b;
        --dash-border: #e2e8f0;
        --dash-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
        --dash-radius: 20px;
        --dash-radius-sm: 12px;
    }

    body { background: var(--dash-bg); }

    .page-wrapper {
        min-height: 100vh;
        padding: 2rem 1.5rem 4rem;
        background: linear-gradient(180deg, #fef2f2 0%, var(--dash-bg) 30%);
    }

    .page-container {
        max-width: 700px;
        margin: 0 auto;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #dc2626;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        transition: all 0.2s;
    }

    .back-link:hover {
        background: rgba(220, 38, 38, 0.08);
    }

    .form-card {
        background: var(--dash-card);
        border-radius: var(--dash-radius);
        box-shadow: var(--dash-shadow);
        border: 1px solid var(--dash-border);
        overflow: hidden;
    }

    .form-header {
        padding: 1.5rem 2rem;
        border-bottom: 1px solid var(--dash-border);
        background: linear-gradient(to right, rgba(220, 38, 38, 0.08), transparent);
    }

    .form-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--dash-text);
    }

    .form-title-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg, #dc2626, #b91c1c);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.25rem;
    }

    .form-body {
        padding: 2rem;
    }

    .form-section {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--dash-border);
    }

    .form-section:last-child {
        border-bottom: none;
        margin-bottom: 0;
    }

    .section-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--dash-text);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-group label {
        display: block;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--dash-text);
        margin-bottom: 0.5rem;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
        width: 100%;
        padding: 0.875rem 1rem;
        font-size: 1rem;
        border: 2px solid var(--dash-border);
        border-radius: var(--dash-radius-sm);
        background: white;
        transition: all 0.2s;
        font-family: inherit;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: #dc2626;
        box-shadow: 0 0 0 4px rgba(220, 38, 38, 0.1);
    }

    .btn-group {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn {
        padding: 1rem 2rem;
        font-size: 1rem;
        font-weight: 600;
        border-radius: var(--dash-radius-sm);
        cursor: pointer;
        text-decoration: none;
        text-align: center;
        transition: all 0.2s;
        border: none;
    }

    .btn-primary {
        flex: 1;
        background: linear-gradient(135deg, #dc2626, #b91c1c);
        color: white;
        box-shadow: 0 4px 16px rgba(220, 38, 38, 0.25);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(220, 38, 38, 0.35);
    }

    .btn-secondary {
        background: white;
        color: var(--dash-text-muted);
        border: 2px solid var(--dash-border);
    }

    .btn-secondary:hover {
        border-color: #dc2626;
        color: #dc2626;
    }

    @media (max-width: 600px) {
        .form-row {
            grid-template-columns: 1fr;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-container">
        <a href="{{ path('app_my_health', {'_locale': app.request.locale}) }}" class="back-link">
            ← Retour au journal
        </a>

        <div class="form-card">
            <div class="form-header">
                <h1 class="form-title">
                    <span class="form-title-icon">❤️</span>
                    Nouvelle Entrée Santé
                </h1>
            </div>
            <div class="form-body">
                {{ form_start(form) }}
                
                {# Date Section #}
                <div class="form-section">
                    <h3 class="section-title">📅 Date de l'entrée</h3>
                    <div class="form-group">
                        {{ form_label(form.date) }}
                        {{ form_widget(form.date, {'attr': {'class': 'form-input'}}) }}
                        {{ form_errors(form.date) }}
                    </div>
                </div>
                
                {# Vital Signs Section #}
                <div class="form-section">
                    <h3 class="section-title">🩺 Signes Vitaux</h3>
                    <div class="form-row">
                        <div class="form-group">
                            {{ form_label(form.tensionArterielle) }}
                            {{ form_widget(form.tensionArterielle, {'attr': {'class': 'form-input', 'placeholder': '120/80'}}) }}
                            {{ form_errors(form.tensionArterielle) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(form.frequenceCardiaque) }}
                            {{ form_widget(form.frequenceCardiaque, {'attr': {'class': 'form-input', 'placeholder': '72'}}) }}
                            {{ form_errors(form.frequenceCardiaque) }}
                        </div>
                    </div>
                    <div class="form-group">
                        {{ form_label(form.temperature) }}
                        {{ form_widget(form.temperature, {'attr': {'class': 'form-input', 'placeholder': '36.5'}}) }}
                        {{ form_errors(form.temperature) }}
                    </div>
                </div>
                
                {# Mood & Sleep Section #}
                <div class="form-section">
                    <h3 class="section-title">😊 Humeur & Bien-être</h3>
                    <div class="form-row">
                        <div class="form-group">
                            {{ form_label(form.humeur) }}
                            {{ form_widget(form.humeur, {'attr': {'class': 'form-input'}}) }}
                            {{ form_errors(form.humeur) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(form.qualiteSommeil) }}
                            {{ form_widget(form.qualiteSommeil, {'attr': {'class': 'form-input'}}) }}
                            {{ form_errors(form.qualiteSommeil) }}
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            {{ form_label(form.appetit) }}
                            {{ form_widget(form.appetit, {'attr': {'class': 'form-input'}}) }}
                            {{ form_errors(form.appetit) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(form.niveauDouleur) }}
                            {{ form_widget(form.niveauDouleur, {'attr': {'class': 'form-input', 'placeholder': '0-10'}}) }}
                            {{ form_errors(form.niveauDouleur) }}
                        </div>
                    </div>
                </div>
                
                {# Activity & Hydration Section #}
                <div class="form-section">
                    <h3 class="section-title">🏃 Activité & Hydratation</h3>
                    <div class="form-row">
                        <div class="form-group">
                            {{ form_label(form.activitePhysique) }}
                            {{ form_widget(form.activitePhysique, {'attr': {'class': 'form-input', 'placeholder': 'Marche 30 min'}}) }}
                            {{ form_errors(form.activitePhysique) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(form.hydratation) }}
                            {{ form_widget(form.hydratation, {'attr': {'class': 'form-input'}}) }}
                            {{ form_errors(form.hydratation) }}
                        </div>
                    </div>
                </div>
                
                {# Medications & Symptoms Section #}
                <div class="form-section">
                    <h3 class="section-title">💊 Médicaments & Symptômes</h3>
                    <div class="form-group">
                        {{ form_label(form.medicamentsPris) }}
                        {{ form_widget(form.medicamentsPris, {'attr': {'class': 'form-input', 'rows': 2}}) }}
                        {{ form_errors(form.medicamentsPris) }}
                    </div>
                    <div class="form-group">
                        {{ form_label(form.symptomes) }}
                        {{ form_widget(form.symptomes, {'attr': {'class': 'form-input', 'rows': 2}}) }}
                        {{ form_errors(form.symptomes) }}
                    </div>
                </div>
                
                {# Notes Section #}
                <div class="form-section">
                    <h3 class="section-title">📝 Notes Additionnelles</h3>
                    <div class="form-group">
                        {{ form_widget(form.notes, {'attr': {'class': 'form-input', 'rows': 3, 'placeholder': 'Observations, remarques...'}}) }}
                        {{ form_errors(form.notes) }}
                    </div>
                </div>

                {# Hide senior field for regular users - auto-set in controller #}
                {{ form_widget(form.senior, {'attr': {'style': 'display:none'}}) }}
                
                <div class="btn-group">
                    <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
                    <a href="{{ path('app_my_health', {'_locale': app.request.locale}) }}" class="btn btn-secondary">Annuler</a>
                </div>
                
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
