{% extends 'base_dashboard.html.twig' %}

{% block title %}Nouvelle Entrée Santé - WANNASNI{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    :root {
        --dash-primary: #2E7D32;
        --dash-primary-light: #4CAF50;
        --dash-primary-soft: rgba(46, 125, 50, 0.08);
        --dash-bg: #f8faf8;
        --dash-card: #ffffff;
        --dash-text: #1a1a2e;
        --dash-text-muted: #64748b;
        --dash-border: #e2e8f0;
        --dash-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
        --dash-radius: 20px;
        --dash-radius-sm: 12px;
    }

    body { background: var(--dash-bg); }

    .page-wrapper {
        min-height: 100vh;
        padding: 2rem 1.5rem 4rem;
        background: linear-gradient(180deg, #fef2f2 0%, var(--dash-bg) 30%);
    }

    .page-container {
        max-width: 600px;
        margin: 0 auto;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #dc2626;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        transition: all 0.2s;
    }

    .back-link:hover {
        background: rgba(220, 38, 38, 0.08);
    }

    .form-card {
        background: var(--dash-card);
        border-radius: var(--dash-radius);
        box-shadow: var(--dash-shadow);
        border: 1px solid var(--dash-border);
        overflow: hidden;
    }

    .form-header {
        padding: 1.5rem 2rem;
        border-bottom: 1px solid var(--dash-border);
        background: linear-gradient(to right, rgba(220, 38, 38, 0.08), transparent);
    }

    .form-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--dash-text);
    }

    .form-title-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg, #dc2626, #b91c1c);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.25rem;
    }

    .form-body {
        padding: 2rem;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        display: block;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--dash-text);
        margin-bottom: 0.5rem;
    }

    .form-input {
        width: 100%;
        padding: 1rem 1.25rem;
        font-size: 1.1rem;
        border: 2px solid var(--dash-border);
        border-radius: var(--dash-radius-sm);
        background: white;
        transition: all 0.2s;
        font-family: inherit;
    }

    .form-input:focus {
        outline: none;
        border-color: #dc2626;
        box-shadow: 0 0 0 4px rgba(220, 38, 38, 0.1);
    }

    .mood-selector {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
    }

    .mood-option {
        text-align: center;
        padding: 1.25rem;
        border: 2px solid var(--dash-border);
        border-radius: var(--dash-radius-sm);
        cursor: pointer;
        transition: all 0.2s;
    }

    .mood-option:hover {
        border-color: #dc2626;
    }

    .mood-option.selected {
        border-color: #dc2626;
        background: rgba(220, 38, 38, 0.05);
    }

    .mood-option input {
        display: none;
    }

    .mood-emoji {
        font-size: 2.5rem;
        display: block;
        margin-bottom: 0.5rem;
    }

    .mood-text {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--dash-text);
    }

    .btn-group {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn {
        padding: 1rem 2rem;
        font-size: 1rem;
        font-weight: 600;
        border-radius: var(--dash-radius-sm);
        cursor: pointer;
        text-decoration: none;
        text-align: center;
        transition: all 0.2s;
        border: none;
    }

    .btn-primary {
        flex: 1;
        background: linear-gradient(135deg, #dc2626, #b91c1c);
        color: white;
        box-shadow: 0 4px 16px rgba(220, 38, 38, 0.25);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(220, 38, 38, 0.35);
    }

    .btn-secondary {
        background: white;
        color: var(--dash-text-muted);
        border: 2px solid var(--dash-border);
    }

    .btn-secondary:hover {
        border-color: #dc2626;
        color: #dc2626;
    }

    /* Error messages */
    .form-error {
        background: #fee2e2;
        border: 1px solid #fca5a5;
        color: #991b1b;
        padding: 0.75rem;
        border-radius: 8px;
        margin-top: 0.5rem;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .form-error-container {
        background: #fee2e2;
        border: 1px solid #fca5a5;
        border-radius: 8px;
        padding: 0.75rem;
        margin-top: 0.5rem;
        list-style: none;
    }

    .form-error-message {
        color: #991b1b;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0.25rem 0;
    }

    .error-icon {
        font-size: 1rem;
    }

    .form-input.error {
        border-color: #dc2626 !important;
        background: #fef2f2;
    }

    .form-input:invalid {
        border-color: #dc2626;
    }

    .form-input.is-invalid {
        border-color: #dc2626 !important;
        background: #fef2f2;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 500;
        color: var(--dash-text);
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
        width: 100%;
        padding: 0.75rem;
        border: 2px solid var(--dash-border);
        border-radius: 8px;
        font-size: 0.95rem;
        font-family: inherit;
        transition: border-color 0.2s, background-color 0.2s;
    }

    .form-group input.is-invalid,
    .form-group select.is-invalid,
    .form-group textarea.is-invalid {
        border-color: #dc2626 !important;
        background-color: #fef2f2 !important;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: #dc2626;
        box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
    }

    .form-error-container {
        background: #fee2e2;
        border: 1px solid #fca5a5;
        border-radius: 8px;
        padding: 0.75rem;
        margin-top: 0.3rem;
    }

    .form-error-message {
        color: #991b1b;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .error-icon {
        font-size: 1rem;
    }

    @media (max-width: 480px) {
        .form-row {
            grid-template-columns: 1fr;
        }

        .mood-selector {
            grid-template-columns: 1fr;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-container">
        <a href="{{ path('app_my_health', {'_locale': app.request.locale}) }}" class="back-link">
            ← Retour au journal
        </a>

        <div class="form-card">
            <div class="form-header">
                <h1 class="form-title">
                    <span class="form-title-icon">❤️</span>
                    Nouvelle Entrée Santé
                </h1>
            </div>
            <div class="form-body">
                {% if form is defined %}
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    
                    {# Display global form errors #}
                    {% if form.vars.errors|length > 0 %}
                        <div style="background: #fee2e2; border: 1px solid #fca5a5; color: #991b1b; padding: 0.75rem; border-radius: 8px; margin-bottom: 1rem;">
                            <strong>⚠️ Erreurs dans le formulaire:</strong>
                            {% for error in form.vars.errors %}
                                <div>• {{ error.message }}</div>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {# Date field (required) #}
                    {{ form_row(form.date, {'label': 'Date et Heure *'}) }}

                    <div class="form-row">
                        {{ form_row(form.tensionArterielle, {'label': 'Tension Artérielle'}) }}
                        {{ form_row(form.frequenceCardiaque, {'label': 'FC (bpm)'}) }}
                    </div>

                    <div class="form-row">
                        {{ form_row(form.temperature, {'label': 'Température (°C)'}) }}
                        {{ form_row(form.niveauDouleur, {'label': 'Niveau de Douleur (0-10)'}) }}
                    </div>

                    <div class="form-row">
                        {{ form_row(form.humeur, {'label': 'Humeur'}) }}
                        {{ form_row(form.qualiteSommeil, {'label': 'Qualité du Sommeil'}) }}
                    </div>

                    <div class="form-row">
                        {{ form_row(form.appetit, {'label': 'Appétit'}) }}
                        {{ form_row(form.hydratation, {'label': 'Hydratation'}) }}
                    </div>

                    {{ form_row(form.symptomes, {'label': 'Symptômes'}) }}
                    {{ form_row(form.medicamentsPris, {'label': 'Médicaments Pris'}) }}
                    {{ form_row(form.activitePhysique, {'label': 'Activité Physique'}) }}
                    {{ form_row(form.notes, {'label': 'Notes Additionnelles'}) }}

                    <div class="btn-group">
                        <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
                        <a href="{{ path('app_my_health', {'_locale': app.request.locale}) }}" class="btn btn-secondary">Annuler</a>
                    </div>
                    {{ form_end(form) }}
                {% else %}
                    <p>Formulaire non disponible.</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<script>
document.querySelectorAll('.mood-option').forEach(option => {
    option.addEventListener('click', () => {
        document.querySelectorAll('.mood-option').forEach(o => o.classList.remove('selected'));
        option.classList.add('selected');
    });
});
</script>
{% endblock %}
