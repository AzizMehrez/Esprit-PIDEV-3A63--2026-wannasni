{% extends 'base_auth.html.twig' %}

{% block title %}{{ 'auth.reset_password_title'|trans|default('Réinitialiser le mot de passe') }} — {{ 'site.name'|trans }}{% endblock %}

{% block body %}
<div class="auth-page">
    {# Left Side - Image & Quote #}
    <div class="auth-image-side">
        <div class="auth-image-overlay"></div>
        <img src="/images/hero.png" alt="" class="auth-bg-image" aria-hidden="true">
        <div class="auth-image-content">
            <div class="auth-logo">
                <img src="/images/logo.png" alt="WANNASNI" class="auth-logo-img">
            </div>
            <blockquote class="auth-quote">
                <p>"{{ 'auth.quote.reset'|trans|default('Créez un nouveau mot de passe sécurisé pour votre compte.') }}"</p>
                <cite>— WANNASNI</cite>
            </blockquote>
        </div>
    </div>
    
    {# Right Side - Reset Password Form #}
    <div class="auth-form-side">
        <div class="auth-form-container">
            {# Mobile Logo (shown on small screens only) #}
            <div class="auth-mobile-header">
                <a href="{{ path('app_login', {_locale: app.request.locale}) }}" class="auth-back-link">
                    ← {{ 'nav.back_to_login'|trans|default('Retour à la connexion') }}
                </a>
                <img src="/images/logo.png" alt="WANNASNI" class="auth-mobile-logo">
            </div>
            
            <div class="auth-form-header">
                <h1 class="auth-title">{{ 'auth.reset_password_title'|trans|default('Réinitialiser le mot de passe') }}</h1>
                <p class="auth-subtitle">
                    {{ 'auth.reset_password.subtitle'|trans|default('Entrez votre nouveau mot de passe ci-dessous.') }}
                    {% if email is defined and email %}
                        <br><strong>{{ email }}</strong>
                    {% endif %}
                </p>
            </div>
            
            {% for message in app.flashes('error') %}
                {% if loop.first %}
                <div class="alert alert-error" style="padding: 1rem; background: #fed7d7; color: #c53030; border: 1px solid #fc8181; border-radius: 8px; margin-bottom: 1rem;">
                {% endif %}
                    <p style="margin: 0;">⚠️ {{ message }}</p>
                {% if loop.last %}
                </div>
                {% endif %}
            {% endfor %}
            
            {% for message in app.flashes('success') %}
                {% if loop.first %}
                <div class="alert alert-success" style="padding: 1rem; background: #c6f6d5; color: #276749; border: 1px solid #9ae6b4; border-radius: 8px; margin-bottom: 1rem;">
                {% endif %}
                    <p style="margin: 0;">✓ {{ message }}</p>
                {% if loop.last %}
                </div>
                {% endif %}
            {% endfor %}
            
            <form method="post" action="{{ path('app_reset_password', {_locale: app.request.locale, token: token}) }}" class="auth-form">
                <div class="form-group">
                    <label for="inputPassword" class="form-label">{{ 'auth.new_password'|trans|default('Nouveau mot de passe') }}</label>
                    <input type="password" 
                           id="inputPassword" 
                           name="password" 
                           class="form-input" 
                           placeholder="••••••••"
                           autocomplete="new-password"
                           minlength="6"
                           required 
                           autofocus>
                    <small style="display: block; margin-top: 0.25rem; color: #6b7280; font-size: 0.875rem;">
                        {{ 'auth.password_requirements'|trans|default('Minimum 6 caractères') }}
                    </small>
                </div>
                
                <div class="form-group">
                    <label for="inputPasswordConfirm" class="form-label">{{ 'auth.confirm_password'|trans|default('Confirmer le mot de passe') }}</label>
                    <input type="password" 
                           id="inputPasswordConfirm" 
                           name="passwordConfirm" 
                           class="form-input" 
                           placeholder="••••••••"
                           autocomplete="new-password"
                           minlength="6"
                           required>
                </div>
                
                <button type="submit" class="btn btn-primary btn-large btn-full">
                    {{ 'auth.reset_password_button'|trans|default('Réinitialiser le mot de passe') }}
                </button>
            </form>
            
            <div class="auth-footer" style="margin-top: 1.5rem; text-align: center;">
                <p>{{ 'auth.remember_password'|trans|default('Vous vous souvenez de votre mot de passe ?') }} 
                   <a href="{{ path('app_login', {_locale: app.request.locale}) }}" class="auth-link-strong">{{ 'cta.login'|trans|default('Se connecter') }}</a>
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
