{% extends 'base.html.twig' %}

{% block title %}{{ 'site.name'|trans }} — {{ 'hero.tagline'|trans }}{% endblock %}

{% block body %}

{# ==================== HERO SECTION ==================== #}
<section class="hero hero-centered" id="hero">
    {# Decorative Background Elements #}
    <div class="hero-bg-pattern" aria-hidden="true"></div>
    
    {# Video Background #}
    <div class="hero-bg-video" aria-hidden="true">
        <video autoplay muted loop playsinline>
            <source src="/images/Video_for_Elderly_Care_Website.mp4" type="video/mp4">
        </video>
        <div class="hero-video-overlay"></div>
    </div>
    
    <div class="container">
        <div class="hero-layout">
            {# Main Content - Centered #}
            <div class="hero-text-content animate-fade-in">
                <h1 class="hero-title">{{ 'hero.title'|trans }}</h1>
                <p class="hero-subtitle">{{ 'hero.subtitle'|trans }}</p>
                
                <div class="hero-cta">
                    {% if app.user %}
                        <a href="{{ path('app_dashboard', {_locale: app.request.locale|default('fr')}) }}" class="btn btn-primary btn-large" id="ctaLogin">
                            <span class="btn-icon" aria-hidden="true">🏠</span>
                            {{ 'nav.dashboard'|trans|default('Mon espace') }}
                        </a>
                    {% else %}
                        <a href="{{ path('app_login', {_locale: app.request.locale|default('fr')}) }}" class="btn btn-primary btn-large" id="ctaLogin">
                            <span class="btn-icon" aria-hidden="true"><img src="/images/lock.png" alt="" style="width: 1.2em; height: 1.2em; vertical-align: middle;"></span>
                            {{ 'cta.login'|trans|default('Connexion') }}
                        </a>
                        <a href="{{ path('app_register', {_locale: app.request.locale|default('fr')}) }}" class="btn btn-outline btn-large" id="ctaSignup">
                            <span class="btn-icon" aria-hidden="true"><img src="/images/sign.png" alt="" style="width: 1.2em; height: 1.2em; vertical-align: middle;"></span>
                            {{ 'cta.signup'|trans|default("S'inscrire") }}
                        </a>
                    {% endif %}
                </div>
            </div>
            
            {# Image Card with Greeting #}
            <div class="hero-image-card animate-fade-in" style="animation-delay: 300ms;">
                <div class="hero-image-wrapper">
                    <img src="/images/hero.png" alt="Famille heureuse avec WANNASNI" loading="eager">
                </div>
                <div class="hero-image-caption">
                    <span class="greeting-badge" id="heroGreeting">
                        {% set hour = "now"|date("H") %}
                        {% if hour < 12 %}
                            {{ 'greeting.morning'|trans|default('Good morning') }} 🌅
                        {% elseif hour < 18 %}
                            {{ 'greeting.afternoon'|trans|default('Good afternoon') }} ☀️
                        {% else %}
                            {{ 'greeting.evening'|trans|default('Good evening') }} 🌙
                        {% endif %}
                    </span>
                    <p class="hero-description">
                        {{ 'hero.description'|trans|default('We are here when you need us.') }}
                    </p>
                </div>
            </div>
        </div>
    </div>
    
    {# Scroll Indicator #}
    <div class="scroll-indicator" aria-hidden="true">
        <span class="scroll-arrow">↓</span>
    </div>
</section>

{# ==================== STATS SECTION ==================== #}
<section class="stats-section" id="stats">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-item animate-on-scroll">
                <span class="stat-number" data-target="2847">0</span>
                <span class="stat-label">{{ 'stats.families'|trans|default('Familles accompagnées') }}</span>
            </div>
            <div class="stat-item animate-on-scroll" style="animation-delay: 100ms;">
                <span class="stat-number" data-target="24">0</span>
                <span class="stat-suffix">/7</span>
                <span class="stat-label">{{ 'stats.support'|trans|default('Support disponible') }}</span>
            </div>
            <div class="stat-item animate-on-scroll" style="animation-delay: 200ms;">
                <span class="stat-number" data-target="98">0</span>
                <span class="stat-suffix">%</span>
                <span class="stat-label">{{ 'stats.satisfaction'|trans|default('Taux de satisfaction') }}</span>
            </div>
            <div class="stat-item animate-on-scroll" style="animation-delay: 300ms;">
                <span class="stat-number" data-target="15">0</span>
                <span class="stat-suffix">+</span>
                <span class="stat-label">{{ 'stats.experience'|trans|default("Années d'expérience") }}</span>
            </div>
        </div>
    </div>
</section>

