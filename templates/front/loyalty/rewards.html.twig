{% extends 'base_dashboard.html.twig' %}

{% block title %}Mes Récompenses - WANNASNI{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    :root {
        --dash-primary: #2E7D32;
        --dash-primary-light: #4CAF50;
        --dash-bg: #f8faf8;
        --dash-card: #ffffff;
        --dash-text: #1a1a2e;
        --dash-text-muted: #64748b;
        --dash-border: #e2e8f0;
        --dash-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
        --dash-radius: 20px;
        --dash-radius-sm: 12px;
        --gold: #F59E0B;
        --gold-light: #FEF3C7;
    }
    body { background: var(--dash-bg); }

    .rewards-wrapper {
        min-height: 100vh;
        padding: 2rem 1.5rem 4rem;
        background: linear-gradient(180deg, #f0f7f0 0%, var(--dash-bg) 30%);
    }
    .rewards-container { max-width: 1100px; margin: 0 auto; }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--dash-primary);
        text-decoration: none;
        font-weight: 600;
        margin-bottom: 1.5rem;
    }
    .back-link:hover { text-decoration: underline; }

    .rewards-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }
    .rewards-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 1.8rem;
        color: var(--dash-text);
    }
    .balance-badge {
        background: linear-gradient(135deg, var(--dash-primary), var(--dash-primary-light));
        color: white;
        padding: 0.6rem 1.5rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .flash-msg {
        padding: 1rem 1.5rem;
        border-radius: var(--dash-radius-sm);
        margin-bottom: 1rem;
        font-weight: 600;
    }
    .flash-msg.success { background: #DCFCE7; color: #166534; }
    .flash-msg.error { background: #FEE2E2; color: #991B1B; }

    .section-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.4rem;
        color: var(--dash-text);
        margin-bottom: 1.25rem;
    }

    .rewards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.25rem;
        margin-bottom: 3rem;
    }

    .reward-card {
        background: white;
        border-radius: var(--dash-radius);
        padding: 1.75rem;
        box-shadow: var(--dash-shadow);
        border: 2px solid transparent;
        transition: all 0.3s;
        position: relative;
    }
    .reward-card:hover {
        border-color: var(--dash-primary);
        transform: translateY(-4px);
        box-shadow: 0 8px 32px rgba(46, 125, 50, 0.15);
    }
    .reward-card.discount { border-left: 4px solid #3B82F6; }
    .reward-card.free_maintenance { border-left: 4px solid #22C55E; }
    .reward-card.plan_upgrade { border-left: 4px solid var(--gold); }
    .reward-card.redeemed {
        opacity: 0.7;
        border-left-color: #94a3b8;
    }
    .reward-card.redeemed::after {
        content: '✅ Échangé';
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: #DCFCE7;
        color: #166534;
        padding: 0.25rem 0.75rem;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .reward-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
    .reward-type-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
    }
    .reward-type-badge.discount { background: #DBEAFE; color: #1D4ED8; }
    .reward-type-badge.free_maintenance { background: #DCFCE7; color: #166534; }
    .reward-type-badge.plan_upgrade { background: var(--gold-light); color: #92400E; }

    .reward-ml-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        background: #F0FDF4;
        color: #166534;
        padding: 0.2rem 0.6rem;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 600;
        margin-left: 0.5rem;
    }

    .reward-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--dash-text);
        margin-bottom: 0.5rem;
    }
    .reward-desc {
        font-size: 0.9rem;
        color: var(--dash-text-muted);
        line-height: 1.5;
        margin-bottom: 1rem;
    }
    .reward-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .reward-cost {
        font-weight: 700;
        color: var(--dash-primary);
    }
    .reward-expires {
        font-size: 0.8rem;
        color: var(--dash-text-muted);
    }

    .btn-redeem {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.65rem 1.5rem;
        background: linear-gradient(135deg, var(--dash-primary), var(--dash-primary-light));
        color: white;
        border: none;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s;
    }
    .btn-redeem:hover {
        transform: scale(1.05);
        box-shadow: 0 4px 20px rgba(46, 125, 50, 0.3);
    }
    .btn-redeem:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }

    @media (max-width: 768px) {
        .rewards-grid { grid-template-columns: 1fr; }
        .rewards-header { flex-direction: column; gap: 1rem; text-align: center; }
    }
</style>
{% endblock %}

{% block body %}
<div class="rewards-wrapper">
    <div class="rewards-container">
        <a href="{{ path('app_loyalty', {'_locale': app.request.locale}) }}" class="back-link">← Retour au Programme Fidélité</a>

        {# Flash Messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash-msg {{ type }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="rewards-header">
            <h1>🎁 Mes Récompenses</h1>
            <span class="balance-badge">⭐ {{ totalPoints|number_format(0, '.', ' ') }} points disponibles</span>
        </div>

        {# ─── Available Rewards ───────────────────────────────────────── #}
        <h2 class="section-title">🎯 Récompenses Disponibles</h2>
        {% if availableRewards|length > 0 %}
        <div class="rewards-grid">
            {% for reward in availableRewards %}
            <div class="reward-card {{ reward.type }}">
                <div class="reward-icon">{{ reward.typeIcon }}</div>
                <span class="reward-type-badge {{ reward.type }}">{{ reward.typeLabel }}</span>
                {% if reward.mlConfidence %}
                <span class="reward-ml-badge">🤖 IA {{ (reward.mlConfidence * 100)|round }}%</span>
                {% endif %}
                <div class="reward-title">{{ reward.title }}</div>
                <div class="reward-desc">{{ reward.description }}</div>
                <div style="margin-bottom: 0.75rem;">
                    <div class="reward-cost">⭐ {{ reward.pointsCost }} points</div>
                    {% if reward.expiresAt %}
                    <div class="reward-expires">Expire le {{ reward.expiresAt|date('d/m/Y') }}</div>
                    {% endif %}
                </div>
                <div class="reward-meta">
                    {% if totalPoints >= reward.pointsCost %}
                    <form method="post" action="{{ path('app_loyalty_redeem', {'_locale': app.request.locale, 'id': reward.id}) }}">
                        <button type="submit" class="btn-redeem" onclick="return confirm('Échanger {{ reward.pointsCost }} points pour cette récompense ?')">
                            🎉 Échanger maintenant
                        </button>
                    </form>
                    {% else %}
                    <button class="btn-redeem" disabled>
                        🔒 Il vous manque {{ reward.pointsCost - totalPoints }} pts
                    </button>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <div style="text-align: center; padding: 3rem 2rem; background: white; border-radius: var(--dash-radius); box-shadow: var(--dash-shadow); margin-bottom: 3rem;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">🎯</div>
            <p style="font-size: 1.1rem; color: var(--dash-text-muted);">Aucune récompense disponible pour le moment.</p>
            <p style="font-size: 0.9rem; color: var(--dash-text-muted); margin-top: 0.5rem;">Continuez à gagner des points pour débloquer des récompenses personnalisées !</p>
        </div>
        {% endif %}

        {# ─── Redeemed Rewards ────────────────────────────────────────── #}
        {% if redeemedRewards|length > 0 %}
        <h2 class="section-title">✅ Récompenses Échangées</h2>
        <div class="rewards-grid">
            {% for reward in redeemedRewards %}
            <div class="reward-card {{ reward.type }} redeemed">
                <div class="reward-icon">{{ reward.typeIcon }}</div>
                <span class="reward-type-badge {{ reward.type }}">{{ reward.typeLabel }}</span>
                <div class="reward-title">{{ reward.title }}</div>
                <div class="reward-desc">{{ reward.description }}</div>
                <div class="reward-meta">
                    <div class="reward-cost" style="color: var(--dash-text-muted);">{{ reward.pointsCost }} points utilisés</div>
                    {% if reward.redeemedAt %}
                    <div class="reward-expires">Échangé le {{ reward.redeemedAt|date('d/m/Y') }}</div>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
