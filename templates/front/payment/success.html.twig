{% extends 'base_auth.html.twig' %}

{% block title %}Paiement Réussi - WANNASNI{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    <div class="text-center">
        <div class="mb-4">
            <i class="fas fa-check-circle text-success fa-5x"></i>
        </div>
        <h1 class="display-4 text-success">Paiement Réussi !</h1>
        <p class="lead">Votre paiement pour l'intervention #{{ intervention.id }} a bien été enregistré.</p>

        <div class="card shadow-sm mx-auto mt-4 mb-4" style="max-width: 420px; text-align: left;">
            <div class="card-body">
                <h5 class="card-title">Récapitulatif du paiement</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Service</span>
                        <strong>{{ intervention.serviceRequest.typeService|default('Intervention') }}</strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Durée</span>
                        <span>{{ intervention.heuresTravail }}h × {{ intervention.tarifHoraire|number_format(2, '.', ' ') }} DT</span>
                    </li>
                    {% if discountInfo and discountInfo.hasSubscription and discountInfo.discountPercent > 0 %}
                    <li class="list-group-item d-flex justify-content-between text-muted">
                        <span>Montant brut</span>
                        <span class="text-decoration-line-through">{{ total|number_format(2, '.', ' ') }} DT</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between text-success">
                        <span>🎉 Réduction {{ discountInfo.planName }} ({{ discountInfo.discountPercent }}%)</span>
                        <span>-{{ discountInfo.discount|number_format(2, '.', ' ') }} DT</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between fw-bold fs-5">
                        <span>Montant payé</span>
                        <span class="text-success">{{ amountPaid|number_format(2, '.', ' ') }} DT</span>
                    </li>
                    {% else %}
                    <li class="list-group-item d-flex justify-content-between fw-bold fs-5">
                        <span>Montant payé</span>
                        <span class="text-success">{{ total|number_format(2, '.', ' ') }} DT</span>
                    </li>
                    {% endif %}
                </ul>
            </div>
        </div>
        <div class="mt-3">
            <a href="{{ path('app_home', {'_locale': app.request.locale|default('fr')}) }}" class="btn btn-primary">Retour à l'accueil</a>
            <a href="{{ path('payment_invoice', {'id': intervention.id}) }}" class="btn btn-outline-dark" id="btn-invoice">
                <i class="fas fa-file-pdf me-2"></i> Télécharger la facture
            </a>
        </div>
    </div>
</div>

<script>
    document.getElementById('btn-invoice').addEventListener('click', function() {
        // Change button state to loading
        const originalContent = this.innerHTML;
        this.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Préparation du PDF...';
        
        // Revert after 5 seconds just in case
        setTimeout(() => {
            this.innerHTML = originalContent;
        }, 5000);
    });
</script>
{% endblock %}
