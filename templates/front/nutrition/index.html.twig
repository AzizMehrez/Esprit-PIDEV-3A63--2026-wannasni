{% extends 'base_dashboard.html.twig' %}

{% block title %}Mes Demandes de Régime - WANNASNI{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    :root {
        --nutri-primary: #10b981;
        --nutri-primary-dark: #059669;
        --nutri-bg: #f8fafc;
        --nutri-card: #ffffff;
        --nutri-text: #1f2937;
        --nutri-border: #e2e8f0;
    }

    /* Chat Toggle Button Styles */
    .chat-toggle-btn {
        position: fixed;
        bottom: 24px;
        right: 24px;
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border: none;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 0 8px 32px rgba(99, 102, 241, 0.3);
        transition: all 0.3s ease;
        z-index: 1000;
    }

    .chat-toggle-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 40px rgba(99, 102, 241, 0.4);
    }

    .chat-toggle-btn .icon-chat {
        color: white;
        width: 24px;
        height: 24px;
    }

    .notification-badge {
        position: absolute;
        top: -8px;
        right: -8px;
        background: #ef4444;
        color: white;
        border-radius: 50%;
        width: 20px;
        height: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: bold;
    }

    /* Help Button Styles */
    .help-trigger {
        position: fixed;
        bottom: 24px;
        left: 24px;
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #10b981, #059669);
        border: none;
        border-radius: 50%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 0 8px 32px rgba(16, 185, 129, 0.3);
        transition: all 0.3s ease;
        z-index: 1000;
    }

    .help-trigger:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 40px rgba(16, 185, 129, 0.4);
    }

    .help-icon {
        font-size: 20px;
        margin-bottom: 2px;
    }

    .help-text {
        color: white;
        font-size: 10px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Chat Window Styles */
    .chat-window {
        position: fixed;
        bottom: 100px;
        right: 24px;
        width: 350px;
        height: 500px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
        display: flex;
        flex-direction: column;
        z-index: 1001;
        font-family: system-ui, -apple-system, sans-serif;
        overflow: hidden;
    }

    .chat-header {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white;
        padding: 15px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .chat-title {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .agent-avatar {
        font-size: 20px;
    }

    .agent-name {
        font-weight: 600;
        font-size: 14px;
    }

    .close-chat-btn {
        background: none;
        border: none;
        color: white;
        font-size: 18px;
        cursor: pointer;
        padding: 5px;
        border-radius: 50%;
        transition: background 0.2s;
    }

    .close-chat-btn:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    .chat-messages {
        flex: 1;
        padding: 20px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .message {
        display: flex;
        flex-direction: column;
    }

    .message-content {
        padding: 12px 16px;
        border-radius: 15px;
        max-width: 85%;
        word-wrap: break-word;
        font-size: 14px;
        line-height: 1.4;
    }

    .bot-message {
        align-items: flex-start;
    }

    .bot-message .message-content {
        background: #f3f4f6;
        color: #374151;
    }

    .user-message {
        align-items: flex-end;
    }

    .user-message .message-content {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white;
    }

    .chat-input-container {
        padding: 20px;
        border-top: 1px solid #e5e7eb;
        display: flex;
        gap: 10px;
    }

    .chat-input {
        flex: 1;
        padding: 12px 16px;
        border: 1px solid #d1d5db;
        border-radius: 25px;
        font-size: 14px;
        outline: none;
        transition: border-color 0.2s;
    }

    .chat-input:focus {
        border-color: #6366f1;
    }

    .send-btn {
        padding: 12px 20px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white;
        border: none;
        border-radius: 25px;
        cursor: pointer;
        font-weight: 500;
        transition: transform 0.2s;
    }

    .send-btn:hover {
        transform: translateY(-1px);
    }

    .nutrition-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem 1rem 4rem;
    }

    /* Header Section */
    .nutri-header {
        background: linear-gradient(135deg, var(--nutri-primary), var(--nutri-primary-dark));
        border-radius: 24px;
        padding: 3rem 2rem;
        margin-bottom: 2.5rem;
        color: white;
        text-align: center;
        box-shadow: 0 10px 40px rgba(16, 185, 129, 0.2);
    }

    .header-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
        display: block;
    }

    .nutri-title {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

    .nutri-subtitle {
        font-size: 1.1rem;
        opacity: 0.9;
    }

    /* Create Button */
    .btn-create-floating {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        background: white;
        color: var(--nutri-primary-dark);
        padding: 1.25rem 2.5rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1.2rem;
        text-decoration: none;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        margin-top: 1.5rem;
        transition: all 0.3s;
    }

    .btn-create-floating:hover {
        transform: scale(1.05);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    }

    /* Demandes Grid */
    .demandes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(450px, 1fr));
        gap: 1.5rem;
    }

    .demande-premium-card {
        background: white;
        border-radius: 20px;
        padding: 2rem;
        border: 2px solid var(--nutri-border);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }

    .demande-premium-card:hover {
        border-color: var(--nutri-primary);
        transform: translateY(-5px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.06);
    }

    .card-id {
        position: absolute;
        top: -10px;
        right: -10px;
        background: var(--nutri-bg);
        color: var(--nutri-text);
        padding: 1rem;
        border-radius: 20px;
        font-weight: 800;
        font-size: 0.8rem;
        opacity: 0.5;
    }

    .card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.5rem;
    }

    .statut-badge-p {
        padding: 0.5rem 1.25rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-traite { background: #dcfce7; color: #065f46; }
    .status-attente { background: #fef3c7; color: #92400e; }

    .card-content h3 {
        font-size: 1.4rem;
        margin-bottom: 1rem;
        color: var(--nutri-text);
    }

    .meta-info {
        display: flex;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .meta-box {
        display: flex;
        flex-direction: column;
    }

    .meta-box label {
        font-size: 0.75rem;
        color: #94a3b8;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 0.25rem;
    }

    .meta-box span {
        font-weight: 700;
        color: #334155;
    }

    .card-actions-p {
        display: flex;
        gap: 1rem;
        padding-top: 1.5rem;
        border-top: 1px dashed var(--nutri-border);
    }

    .btn-nutri-view {
        flex: 2;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.85rem;
        background: var(--nutri-primary);
        color: white;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
        transition: all 0.2s;
    }

    .btn-nutri-view:hover {
        background: var(--nutri-primary-dark);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    .btn-nutri-delete {
        flex: 0.5;
        background: #fee2e2;
        color: #991b1b;
        border: none;
        border-radius: 14px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-nutri-delete:hover { background: #fecaca; }

    .empty-nutri {
        text-align: center;
        padding: 5rem 2rem;
        background: white;
        border-radius: 24px;
        border: 3px dashed var(--nutri-border);
    }

    @media (max-width: 600px) {
        .demandes-grid { grid-template-columns: 1fr; }
        .meta-info { flex-direction: column; gap: 0.5rem; }
    }
</style>
{% endblock %}

{% block body %}
<div class="nutrition-container">
    
    <!-- Header Hero -->
    <div class="nutri-header">
        <span class="header-icon">🍎</span>
        <h1 class="nutri-title">Mon Service Nutrition</h1>
        <p class="nutri-subtitle">Gérez vos demandes et consultez vos programmes alimentaires</p>
        
        <div class="d-flex justify-content-center gap-3">
            <a href="{{ path('app_nutrition_request') }}" class="btn-create-floating">
                ➕ Nouvelle demande
            </a>
            <a href="{{ path('app_nutrition_scan') }}" class="btn-create-floating" style="background: #212529; color: white;">
                🔍 Scanner un produit
            </a>
        </div>
    </div>

    <!-- Stats summary (facultatif si disponible) -->
    
    {% if demande_regimes is not empty %}
        <div class="demandes-grid">
            {% for demande in demande_regimes %}
                {% set isTraitee = (demande.statut == 'traité') %}
                <div class="demande-premium-card">
                    <span class="card-id">ID #{{ demande.id }}</span>
                    
                    <div class="card-top">
                        <div class="date-tag">
                            <span style="display:block; font-size: 0.75rem; color: #94a3b8; font-weight: 700;">DATE</span>
                            <span style="font-weight: 700; color: #334155;">{{ demande.dateDemande|date('d/m/Y') }}</span>
                        </div>
                        <span class="statut-badge-p {{ isTraitee ? 'status-traite' : 'status-attente' }}">
                            {{ isTraitee ? '✅ Traitée' : '🕒 En attente' }}
                        </span>
                    </div>

                    <div class="card-content">
                        <h3>{{ demande.typeRegimeSouhaite }}</h3>
                        
                        <div class="meta-info">
                            <div class="meta-box">
                                <label>Objectif</label>
                                <span>{{ demande.objectifPrincipal|length > 30 ? demande.objectifPrincipal|slice(0, 30) ~ '...' : demande.objectifPrincipal }}</span>
                            </div>
                            <div class="meta-box">
                                <label>Budget</label>
                                <span>{{ demande.budgetMensuel ?: '0' }} DH</span>
                            </div>
                        </div>
                    </div>

                    <div class="card-actions-p">
                        <a href="{{ path('app_nutrition_show', {'id': demande.id}) }}" class="btn-nutri-view">
                            {{ isTraitee ? '👁️ Voir mon régime' : '👁️ Détails demande' }}
                        </a>
                        
                        <form method="post" action="{{ path('app_nutrition_delete', {'id': demande.id}) }}" 
                              onsubmit="return confirm('Supprimer définitivement ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ demande.id) }}">
                            <button type="submit" class="btn-nutri-delete">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="empty-nutri">
            <div style="font-size: 5rem; margin-bottom: 2rem;">🍽️</div>
            <h2>Prêt pour une vie plus saine ?</h2>
            <p style="color: #64748b; margin-bottom: 2rem;">Créez votre première demande de régime pour recevoir un programme personnalisé de nos experts.</p>
            <a href="{{ path('app_nutrition_request') }}" class="btn-nutri-view" style="display:inline-flex; width: auto; padding: 1.25rem 3rem;">
                Commencer maintenant
            </a>
        </div>
    {% endif %}

</div>

<!-- Help Button -->
<button class="help-trigger" onclick="document.getElementById('helpModal').classList.add('active')" aria-label="Get Help">
    <span class="help-icon">🆘</span>
    <span class="help-text">Aide</span>
</button>

<!-- Chat Toggle Button -->
<button class="chat-toggle-btn" id="chat-toggle">
    <svg class="icon-chat" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    <span class="notification-badge" style="display: none;">1</span>
</button>

<!-- Smart Chat Container -->
<div id="smart-chat-container">
    <div class="chat-window" id="chat-window">
        <div class="chat-header">
            <div class="header-info">
                <div class="avatar-ring">
                    <img src="https://ui-avatars.com/api/?name=Nutrition&background=F57C00&color=fff" alt="Nutrition Agent">
                    <span class="status-dot"></span>
                </div>
                <div class="agent-details">
                    <span class="agent-name">Assistant Nutrition</span>
                    <span class="agent-status" id="agent-status">Votre santé nutritionnelle</span>
                </div>
            </div>
            <select id="persona-select" class="persona-select" title="AI Persona">
                <option value="nutrition">🥗 Nutrition</option>
                <option value="default">🤖 Assistant</option>
            </select>
            <div class="header-actions">
                <button class="header-icon-btn" id="export-chat" title="Exporter">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="7 10 12 15 17 10"></polyline>
                        <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                </button>
                <button class="header-icon-btn" id="clear-chat" title="Nouveau">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 20h9"></path>
                        <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                    </svg>
                </button>
                <button class="close-btn" id="close-chat" aria-label="Fermer">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 6L6 18M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>
        <div class="drop-zone" id="drop-zone">
            <div class="drop-zone-content">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="17 8 12 3 7 8"></polyline>
                    <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                <span>Déposez un fichier ici</span>
            </div>
        </div>
        <div class="chat-messages" id="chat-messages">
            <div class="message bot-message welcome">
                <p>Bonjour! Je suis votre <strong>Assistant Nutrition</strong> 🥗<br>
                   Prêt à vous accompagner vers une alimentation équilibrée!</p>
                <span class="timestamp">Maintenant</span>
            </div>
        </div>
        <div class="usage-stats" id="usage-stats">
            <span>💬 <span id="msg-count">0</span> msgs</span>
            <span>📈 <span id="token-count">0</span> tokens</span>
        </div>
        <div class="suggested-prompts" id="suggested-prompts">
            <button class="prompt-chip" data-prompt="Plan nutritionnel pour seniors">🍎 Plan Senior</button>
            <button class="prompt-chip" data-prompt="Recettes équilibrées faciles">👨‍🍳 Recettes</button>
            <button class="prompt-chip" data-prompt="Gérer mon diabète par l'alimentation">🩺 Diabète</button>
            <button class="prompt-chip" data-prompt="Vitamines essentielles 60+">💊 Vitamines</button>
        </div>
        <div class="chat-input-area">
            <div class="typing-indicator" id="typing-indicator">
                <span></span><span></span><span></span>
            </div>
            <div id="image-preview-container" class="image-preview hidden">
                <img id="image-preview" src="" alt="Preview">
                <button id="remove-image" class="remove-btn">×</button>
            </div>
            <div class="input-wrapper">
                <input type="file" id="image-upload" accept="image/*" style="display: none;">
                <input type="file" id="file-upload" accept=".pdf,.txt" style="display: none;">
                <button id="upload-btn" title="Télécharger Image">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
                    </svg>
                </button>
                <button id="voice-btn" title="Entrée Vocale">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
                        <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
                        <line x1="12" y1="19" x2="12" y2="23"></line>
                        <line x1="8" y1="23" x2="16" y2="23"></line>
                    </svg>
                </button>
                <input type="text" id="user-input" placeholder="Posez vos questions sur la nutrition..." autocomplete="off">
                <button id="send-btn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Voice Call Overlay -->
<div class="voice-call-overlay" id="voice-call-overlay">
    <div class="voice-call-container">
        <div class="voice-orb-wrapper">
            <div class="voice-orb" id="voice-orb">
                <div class="orb-inner"></div>
            </div>
            <div class="voice-orb-ring ring-1"></div>
            <div class="voice-orb-ring ring-2"></div>
            <div class="voice-orb-ring ring-3"></div>
        </div>
        <div class="voice-call-status" id="voice-call-status">Connecting...</div>
        <div class="voice-transcript" id="voice-transcript"></div>
        <div class="voice-ai-text" id="voice-ai-text"></div>
        <div class="voice-call-controls">
            <button class="voice-control-btn mute-btn" id="voice-mute-btn" title="Mute/Unmute">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
                    <line x1="12" y1="19" x2="12" y2="23"></line>
                    <line x1="8" y1="23" x2="16" y2="23"></line>
                </svg>
            </button>
            <button class="voice-control-btn end-call-btn" id="voice-end-call" title="End Call">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M22 10.5c-1.6-1.6-3.7-2.5-5.9-2.5-1.4 0-2.7.3-3.9.8l1.5 1.5c.7-.2 1.5-.3 2.3-.3 1.6 0 3.1.6 4.2 1.8l1.8-1.8zM7 12.5c-.8 0-1.6.1-2.3.3L3.2 11.3C4.3 10.8 5.6 10.5 7 10.5c2.2 0 4.3.9 5.9 2.5l-1.8 1.8c-1.1-1.2-2.6-1.8-4.1-1.8zm5 3.5h5v5h-5v-5zm-10 0h5v5H2v-5z"/>
                </svg>
            </button>
            <button class="voice-control-btn speaker-btn" id="voice-speaker-btn" title="Speaker On/Off">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                    <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                    <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
                </svg>
            </button>
        </div>
        <div class="voice-call-timer" id="voice-call-timer">00:00</div>
    </div>
</div>

<link rel="stylesheet" href="{{ asset('chat/style.css') }}?v=2">
<script src="{{ asset('chat/api.js') }}"></script>
<script src="{{ asset('chat/script.js') }}"></script>

<script>
// Legacy chat functionality removed - using new AI chat system
{% endblock %}
