{% extends 'base_dashboard.html.twig' %}

{% block title %}Mes Commandes - WANNASNI{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    :root {
        --ord-primary: #6366f1;
        --ord-primary-dark: #4f46e5;
        --ord-accent: #10b981;
        --ord-text: #1f2937;
        --ord-border: #e2e8f0;
    }

    .orders-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 1.5rem 1rem 4rem;
    }

    .ord-header {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border-radius: 24px;
        padding: 2.5rem 2rem;
        margin-bottom: 2rem;
        color: white;
        text-align: center;
        box-shadow: 0 10px 40px rgba(99,102,241,0.25);
    }
    .ord-header h1 { font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .ord-header p { opacity: 0.9; font-size: 1rem; }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--ord-primary);
        text-decoration: none;
        font-weight: 600;
        margin-bottom: 1.5rem;
        transition: all 0.2s;
    }
    .back-link:hover { color: var(--ord-primary-dark); transform: translateX(-3px); }

    .order-card {
        background: white;
        border-radius: 16px;
        border: 2px solid var(--ord-border);
        margin-bottom: 1.25rem;
        overflow: hidden;
        transition: all 0.3s;
    }
    .order-card:hover { box-shadow: 0 8px 25px rgba(0,0,0,0.06); }

    .order-card-header {
        padding: 1.25rem 1.5rem;
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        background: #f8fafc;
        border-bottom: 1px solid var(--ord-border);
    }
    .order-number { font-weight: 800; font-size: 1rem; color: var(--ord-text); }
    .order-date { font-size: 0.85rem; color: #94a3b8; }

    .order-status {
        padding: 0.3rem 0.85rem;
        border-radius: 10px;
        font-size: 0.8rem;
        font-weight: 700;
    }
    .status-pending { background: #fef3c7; color: #d97706; }
    .status-confirmed { background: #dbeafe; color: #2563eb; }
    .status-shipped { background: #e0e7ff; color: #4f46e5; }
    .status-delivered { background: #d1fae5; color: #059669; }
    .status-cancelled { background: #fee2e2; color: #dc2626; }

    .order-card-body { padding: 1.25rem 1.5rem; }

    .order-items { display: flex; flex-direction: column; gap: 0.75rem; }
    .order-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.75rem;
        background: #f8fafc;
        border-radius: 12px;
    }
    .order-item-emoji { font-size: 1.8rem; flex-shrink: 0; }
    .order-item-info { flex: 1; }
    .order-item-name { font-weight: 700; font-size: 0.9rem; }
    .order-item-details { font-size: 0.8rem; color: #94a3b8; }
    .order-item-price { font-weight: 800; color: var(--ord-primary); white-space: nowrap; }

    .order-card-footer {
        padding: 1rem 1.5rem;
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        border-top: 1px solid var(--ord-border);
        background: #fafafe;
    }
    .order-shipping-info { font-size: 0.85rem; color: #64748b; }
    .order-shipping-info i { margin-right: 0.3rem; }
    .order-total { font-weight: 800; font-size: 1.2rem; color: var(--ord-primary); }

    .empty-orders {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 20px;
        border: 2px solid var(--ord-border);
    }
    .empty-orders-emoji { font-size: 4rem; margin-bottom: 1rem; }
    .empty-orders h3 { font-weight: 800; margin-bottom: 0.5rem; }
    .empty-orders p { color: #94a3b8; margin-bottom: 1.5rem; }

    .btn-shop {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.85rem 2rem;
        background: var(--ord-primary);
        color: white;
        border-radius: 14px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-shop:hover { background: var(--ord-primary-dark); color: white; transform: translateY(-1px); }

    .order-progress {
        display: flex;
        align-items: center;
        gap: 0;
        margin: 1rem 0 0.5rem;
    }
    .progress-step {
        flex: 1;
        text-align: center;
        position: relative;
    }
    .progress-step::before {
        content: '';
        position: absolute;
        top: 14px;
        left: 0;
        right: 0;
        height: 3px;
        background: #e2e8f0;
        z-index: 0;
    }
    .progress-step:first-child::before { left: 50%; }
    .progress-step:last-child::before { right: 50%; }
    .progress-dot {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: #e2e8f0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        position: relative;
        z-index: 1;
        color: #94a3b8;
    }
    .progress-step.active .progress-dot { background: var(--ord-primary); color: white; }
    .progress-step.done .progress-dot { background: var(--ord-accent); color: white; }
    .progress-step.done::before { background: var(--ord-accent); }
    .progress-step.active::before { background: var(--ord-primary); }
    .progress-label { display: block; font-size: 0.7rem; color: #94a3b8; margin-top: 0.3rem; font-weight: 600; }
    .progress-step.active .progress-label { color: var(--ord-primary); }
    .progress-step.done .progress-label { color: var(--ord-accent); }

    @media (max-width: 640px) {
        .order-card-header { flex-direction: column; align-items: flex-start; }
        .order-card-footer { flex-direction: column; align-items: flex-start; }
    }
</style>
{% endblock %}

{% block sidebar %}
    <span class="sidebar-nav-title">Navigation Nutrition</span>
    <nav>
        <a href="{{ path('app_my_nutrition') }}" class="sidebar-link">
            <i class="fas fa-utensils"></i> Tableau de bord
        </a>
        <a href="{{ path('app_nutrition_sommelier') }}" class="sidebar-link" data-turbo="false">
            <i class="fas fa-wine-glass-alt"></i> Sommelier
        </a>
        <a href="{{ path('app_nutrition_sommelier_marketplace') }}" class="sidebar-link" data-turbo="false">
            <i class="fas fa-store"></i> Boutique
        </a>
        <a href="{{ path('app_nutrition_sommelier_orders') }}" class="sidebar-link active" data-turbo="false">
            <i class="fas fa-box"></i> Mes commandes
        </a>
        <a href="{{ path('app_nutrition_sommelier_history') }}" class="sidebar-link" data-turbo="false">
            <i class="fas fa-history"></i> Historique boissons
        </a>
    </nav>
{% endblock %}

{% block body %}
<div class="orders-container">

    <a href="{{ path('app_nutrition_sommelier_marketplace') }}" class="back-link">
        <i class="fas fa-arrow-left"></i> Retour à la boutique
    </a>

    <div class="ord-header">
        <h1>📦 Mes Commandes</h1>
        <p>Suivez vos commandes de boissons et nutriments santé</p>
    </div>

    {% if orders is empty %}
    <div class="empty-orders">
        <div class="empty-orders-emoji">📦</div>
        <h3>Aucune commande pour le moment</h3>
        <p>Parcourez notre boutique pour découvrir des boissons healthy adaptées à votre régime</p>
        <a href="{{ path('app_nutrition_sommelier_marketplace') }}" class="btn-shop">
            <i class="fas fa-store"></i> Découvrir la boutique
        </a>
    </div>
    {% else %}

    {% for order in orders %}
    <div class="order-card">
        <div class="order-card-header">
            <div>
                <div class="order-number">Commande {{ order.orderNumber }}</div>
                <div class="order-date">
                    <i class="fas fa-calendar-alt"></i>
                    {{ order.createdAt|date('d/m/Y à H:i') }}
                </div>
            </div>
            <span class="order-status status-{{ order.status }}">
                {{ order.statusLabel }}
            </span>
        </div>

        <div class="order-card-body">
            {# Progress tracker #}
            {% set statusSteps = ['pending', 'confirmed', 'shipped', 'delivered'] %}
            {% set statusIcons = {'pending': '🕐', 'confirmed': '✅', 'shipped': '🚚', 'delivered': '📦'} %}
            {% set statusLabels = {'pending': 'En attente', 'confirmed': 'Confirmée', 'shipped': 'Expédiée', 'delivered': 'Livrée'} %}

            {% if order.status != 'cancelled' %}
            <div class="order-progress">
                {% set currentIdx = -1 %}
                {% for step in statusSteps %}
                    {% if step == order.status %}{% set currentIdx = loop.index0 %}{% endif %}
                {% endfor %}

                {% for step in statusSteps %}
                <div class="progress-step {% if loop.index0 < currentIdx %}done{% elseif loop.index0 == currentIdx %}active{% endif %}">
                    <span class="progress-dot">{{ statusIcons[step] }}</span>
                    <span class="progress-label">{{ statusLabels[step] }}</span>
                </div>
                {% endfor %}
            </div>
            {% endif %}

            <div class="order-items" style="margin-top:1rem;">
                {% for item in order.items %}
                <div class="order-item">
                    <span class="order-item-emoji">{{ item.product ? item.product.categoryEmoji : '🥤' }}</span>
                    <div class="order-item-info">
                        <div class="order-item-name">{{ item.product ? item.product.name : 'Produit' }}</div>
                        <div class="order-item-details">
                            {{ item.quantity }} × {{ item.unitPrice|number_format(2) }} DH
                            {% if item.product and item.product.volume %} · {{ item.product.volume }}{% endif %}
                        </div>
                    </div>
                    <div class="order-item-price">{{ item.lineTotal|number_format(2) }} DH</div>
                </div>
                {% endfor %}
            </div>
        </div>

        <div class="order-card-footer">
            <div class="order-shipping-info">
                <div><i class="fas fa-map-marker-alt"></i> {{ order.shippingAddress }}, {{ order.shippingCity }}{% if order.shippingPostalCode %} {{ order.shippingPostalCode }}{% endif %}</div>
                <div><i class="fas fa-phone"></i> {{ order.phone }}</div>
                <div><i class="fas fa-credit-card"></i> {{ order.paymentMethod == 'cash_on_delivery' ? 'Paiement à la livraison' : 'Virement bancaire' }}</div>
                {% if order.shippingCost == 0 %}
                <div style="color:#059669;font-weight:600;"><i class="fas fa-truck"></i> Livraison gratuite !</div>
                {% else %}
                <div><i class="fas fa-truck"></i> Livraison : {{ order.shippingCost|number_format(2) }} DH</div>
                {% endif %}
            </div>
            <div class="order-total">
                Total : {{ order.grandTotal|number_format(2) }} DH
            </div>
        </div>
    </div>
    {% endfor %}

    {% endif %}
</div>
{% endblock %}
