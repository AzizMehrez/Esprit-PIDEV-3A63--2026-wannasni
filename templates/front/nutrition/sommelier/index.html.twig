            <span style="font-weight:700;color:#4f46e5;">🛒 <span id="catalogCartCount">0</span> article(s) dans votre panier</span>
            <button onclick="openCart()" style="display:inline-block;margin-left:1rem;padding:0.5rem 1.25rem;background:linear-gradient(135deg,#6366f1,#7c3aed);color:white;border-radius:10px;font-weight:700;border:none;font-size:0.85rem;cursor:pointer;">
