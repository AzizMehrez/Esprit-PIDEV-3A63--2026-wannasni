{% block javascripts %}
{{ parent() }}
<script>
// Create namespace to avoid global conflicts and allow Turbo.js compatibility
window.sommelier = window.sommelier || {
    csrfToken: '{{ csrf_token("app") }}',
    currentPhotoFile: null,
    currentPhotoAnalysis: null,
    isSpeaking: false,
    catalogCartTotal: {{ cart_count }}
};

// Update with fresh values on each page load
Object.assign(window.sommelier, {
    csrfToken: '{{ csrf_token("app") }}'
});

// Helper function to make authenticated AJAX requests with CSRF protection
function apiRequest(url, options = {}) {
    const defaultOptions = {
        method: 'POST',
        credentials: 'include',
        headers: {
            'X-CSRF-Token': window.sommelier.csrfToken,
            'X-Requested-With': 'XMLHttpRequest',
            ...options.headers
        }
    };
    return fetch(url, { ...defaultOptions, ...options });
}

// Handle beverage photo upload
function handleBeveragePhoto(input) {
    if (input.files && input.files[0]) {
        window.sommelier.currentPhotoFile = input.files[0];
        const reader = new FileReader();
        reader.onload = function(e) {
            const photoPreviewImg = document.getElementById('photoPreviewImg');
            if (photoPreviewImg) photoPreviewImg.src = e.target.result;
            const photoPreview = document.getElementById('photoPreview');
            if (photoPreview) photoPreview.style.display = 'block';
            const photoPlaceholder = document.getElementById('photoPlaceholder');
            if (photoPlaceholder) photoPlaceholder.style.display = 'none';
            const photoAnalyzeBtn = document.getElementById('photoAnalyzeBtn');
            if (photoAnalyzeBtn) photoAnalyzeBtn.style.display = 'block';
            const photoAnalysisResult = document.getElementById('photoAnalysisResult');
            if (photoAnalysisResult) photoAnalysisResult.style.display = 'none';
            const photoUploadArea = document.getElementById('photoUploadArea');
            if (photoUploadArea) {
                photoUploadArea.style.borderColor = '#10b981';
                photoUploadArea.style.background = '#f0fdf4';
            }
        };
        reader.readAsDataURL(input.files[0]);
    }
}
    
// Defer initialization until DOM is ready
document.addEventListener('DOMContentLoaded', function() {
    loadSuggestions('petit-déjeuner', document.querySelector('.meal-tab.active'));
    loadTasting('thé', document.querySelector('.tasting-type-btn.active'));

    // ── Auto-select moment based on hour ──
    const hour = new Date().getHours();
    const momentSelect = document.getElementById('customMoment');
    if (momentSelect) {
        if (hour < 10) momentSelect.value = 'matin';
        else if (hour < 14) momentSelect.value = 'déjeuner';
        else if (hour < 17) momentSelect.value = 'après-midi';
        else if (hour < 21) momentSelect.value = 'dîner';
        else momentSelect.value = 'soirée';
    }
});

// ══════════════════════════════
// QUICK LOG
// ══════════════════════════════
function quickLog(category, name, ml) {
    const formData = new FormData();
    formData.append('custom_name', name);
    formData.append('category', category);
    formData.append('quantity_ml', ml);

    const hour = new Date().getHours();
    let moment = 'après-midi';
    if (hour < 10) moment = 'matin';
    else if (hour < 14) moment = 'déjeuner';
    else if (hour < 17) moment = 'après-midi';
    else if (hour < 21) moment = 'dîner';
    else moment = 'soirée';
    formData.append('moment', moment);

    apiRequest('{{ path("app_nutrition_sommelier_log") }}', {
        body: formData
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'success') {
            showSuccessToast(`✅ ${name} (${ml}ml) enregistré !`);
            refreshHydration();
        }
    })
    .catch(err => {
        console.error('Log error:', err);
        showSuccessToast('❌ Erreur lors de l\'enregistrement');
    });
}

function toggleCustomForm() {
    const form = document.getElementById('customDrinkForm');
    form.classList.toggle('open');
}

function submitCustomDrink() {
    const name = document.getElementById('customName').value;
    const category = document.getElementById('customCategory').value;
    const ml = document.getElementById('customMl').value;
    const moment = document.getElementById('customMoment').value;

    if (!name) { alert('Veuillez entrer le nom de la boisson'); return; }

    const formData = new FormData();
    formData.append('custom_name', name);
    formData.append('category', category);
    formData.append('quantity_ml', ml);
    formData.append('moment', moment);

    apiRequest('{{ path("app_nutrition_sommelier_log") }}', {
        body: formData
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'success') {
            showSuccessToast(`✅ ${name} (${ml}ml) enregistré !`);
            document.getElementById('customName').value = '';
            document.getElementById('customDrinkForm').classList.remove('open');
            refreshHydration();
        }
    });
}

// ══════════════════════════════
// REFRESH HYDRATION
// ══════════════════════════════
function refreshHydration() {
    apiRequest('{{ path("app_nutrition_sommelier_hydration") }}')
    .then(r => r.json())
    .then(data => {
        if (data.status === 'success') {
            document.getElementById('hydrationPercent').textContent = data.progress + '%';
            document.getElementById('todayMl').textContent = data.today_ml + ' ml';

            // Update circle
            const circle = document.querySelector('.hydration-circle .progress');
            if (circle) {
                const circumference = 2 * Math.PI * 70;
                const offset = circumference - (data.progress / 100) * circumference;
                circle.setAttribute('stroke-dashoffset', offset);
            }
        }
    });
}

// ══════════════════════════════
// MEAL PAIRING SUGGESTIONS
// ══════════════════════════════
function loadSuggestions(mealType, btn) {
    // Update active tab
    document.querySelectorAll('.meal-tab').forEach(t => t.classList.remove('active'));
    if (btn) btn.classList.add('active');

    const grid = document.getElementById('suggestionsGrid');
    if (!grid) return; // Element not on this page, silently skip
    
    grid.innerHTML = '<div class="text-center py-3" style="grid-column:1/-1"><div class="loading-spinner-sm"></div><p class="text-muted mt-2 small">Recherche des boissons adaptées...</p></div>';

    const formData = new FormData();
    formData.append('meal_type', mealType);

    apiRequest('{{ path("app_nutrition_sommelier_suggest") }}', {
        body: formData
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'success' && data.suggestions.length > 0) {
            lastSuggestionsData = data.suggestions;
            grid.innerHTML = data.suggestions.map(s => `
                <div class="suggestion-card">
                    <div class="suggestion-card-top">
                        <span class="suggestion-card-emoji">${s.emoji || '🥤'}</span>
                        <div class="suggestion-card-name">${s.name}</div>
                        ${s.origin ? `<div class="suggestion-card-origin">📍 ${s.origin}</div>` : ''}
                    </div>
                    <div class="suggestion-card-body">
                        ${s.description ? `<p>${s.description.substring(0, 150)}</p>` : ''}
                        <div class="suggestion-tags">
                            ${s.hydration_score ? `<span class="suggestion-tag tag-hydration">💧 ${s.hydration_score}%</span>` : ''}
                            ${s.calories !== undefined ? `<span class="suggestion-tag tag-benefit">🔥 ${s.calories} kcal/100ml</span>` : ''}
                            ${s.sugar_free ? '<span class="suggestion-tag tag-sugar-free">0 sucre</span>' : ''}
                            ${s.caffeine_free ? '<span class="suggestion-tag tag-caffeine-free">Sans caféine</span>' : ''}
                        </div>
                        ${s.benefits && s.benefits.length ? `<div style="margin-bottom:0.5rem;">${s.benefits.slice(0, 3).map(b => `<span style="font-size:0.8rem;color:#059669;">✓ ${b}</span>`).join(' &nbsp; ')}</div>` : ''}
                        <div class="suggestion-card-actions">
                            <button class="btn-log-drink" onclick="logSuggested('${s.id || ''}', '${s.name.replace(/'/g, "\\'")}', '${s.category || 'autre'}', 250)">
                                <i class="fas fa-plus me-1"></i> Boire
                            </button>
                            <button class="btn-detail-drink" onclick="showDetail(${JSON.stringify(s).replace(/"/g, '&quot;')})">
                                <i class="fas fa-info-circle"></i>
                            </button>
                        </div>
                    </div>
                </div>
            `).join('');
            document.getElementById('suggestionsVoiceBar').style.display = 'block';
            resetVoiceBtn('suggestions');
        } else {
            lastSuggestionsData = null;
            document.getElementById('suggestionsVoiceBar').style.display = 'none';
            grid.innerHTML = '<div class="text-center py-3 text-muted" style="grid-column:1/-1">Aucune suggestion trouvée pour ce repas.</div>';
        }
    })
    .catch(err => {
        grid.innerHTML = '<div class="text-center py-3 text-muted" style="grid-column:1/-1">Erreur lors du chargement des suggestions.</div>';
    });
}

function logSuggested(id, name, category, ml) {
    const formData = new FormData();
    if (id) formData.append('beverage_id', id);
    formData.append('custom_name', name);
    formData.append('category', category);
    formData.append('quantity_ml', ml);

    apiRequest('{{ path("app_nutrition_sommelier_log") }}', {
        body: formData
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'success') {
            showSuccessToast(`✅ ${name} enregistré !`);
            refreshHydration();
        }
    });
}

// ══════════════════════════════
// VIRTUAL TASTING
// ══════════════════════════════
function loadTasting(type, btn) {
    document.querySelectorAll('.tasting-type-btn').forEach(b => b.classList.remove('active'));
    if (btn) btn.classList.add('active');

    const content = document.getElementById('tastingContent');
    if (!content) return; // Element not on this page, silently skip
    
    content.innerHTML = '<div class="text-center py-3"><div class="loading-spinner-sm"></div><p class="text-muted mt-2 small">Préparation de la dégustation...</p></div>';

    const formData = new FormData();
    formData.append('type', type);

    apiRequest('{{ path("app_nutrition_sommelier_tasting") }}', {
        body: formData
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'success' && data.tasting) {
            lastTastingData = data.tasting;
            const t = data.tasting;
            let html = '';

            // ── Introduction with voice ──
            const introText = (t.titre || 'Dégustation') + '. ' + (t.introduction || '');
            html += `<div style="position:relative;">
                <h3 style="font-size:1.3rem;font-weight:800;margin-bottom:0.5rem;display:inline;">${t.titre || 'Dégustation'}</h3>
                <button onclick="speakSection(this, \`${introText.replace(/`/g,'\\`').replace(/"/g,'&quot;')}\`)" class="tasting-voice-btn" title="Écouter l'introduction">
                    <i class="fas fa-volume-up"></i>
                </button>
                <p style="color:#64748b;margin-bottom:1.5rem;">${t.introduction || ''}</p>
            </div>`;

            // ── Steps with individual voice buttons ──
            if (t.etapes && t.etapes.length) {
                html += '<h4 style="font-size:1rem;font-weight:700;margin-bottom:0.75rem;"><i class="fas fa-list-ol me-1"></i> Étapes de la dégustation</h4>';
                t.etapes.forEach(step => {
                    let stepText = `Étape ${step.numero}, ${step.nom || ''}. ${step.description || ''}`;
                    if (step.conseil) stepText += ` Conseil : ${step.conseil}.`;
                    if (step.duree_minutes) stepText += ` Durée : ${step.duree_minutes} minutes.`;
                    html += `<div class="tasting-step" style="position:relative;">
                        <div class="tasting-step-num">${step.numero || step.numero}</div>
                        <div class="tasting-step-content">
                            <div class="tasting-step-title">${step.nom || ''}
                                <button onclick="speakSection(this, \`${stepText.replace(/`/g,'\\`').replace(/"/g,'&quot;')}\`)" class="tasting-voice-btn" title="Écouter cette étape">
                                    <i class="fas fa-volume-up"></i>
                                </button>
                            </div>
                            <div class="tasting-step-desc">${step.description || ''}</div>
                            ${step.conseil ? `<div class="tasting-step-tip">💡 ${step.conseil}</div>` : ''}
                            ${step.duree_minutes ? `<div class="tasting-step-duration">⏱️ ${step.duree_minutes} min</div>` : ''}
                        </div>
                    </div>`;
                });
            }

            // ── Recommended drinks with individual voice buttons ──
            if (t.boissons_recommandees && t.boissons_recommandees.length) {
                html += '<h4 style="font-size:1rem;font-weight:700;margin:1.5rem 0 0.75rem;"><i class="fas fa-star me-1"></i> Boissons recommandées</h4>';
                html += '<div class="tasting-recs">';
                t.boissons_recommandees.forEach(b => {
                    let bText = `${b.nom || 'Boisson'}, origine ${b.origine || 'inconnue'}. Notes de dégustation : ${b.notes_degustation || ''}. Température idéale : ${b.temperature_ideale || ''}.`;
                    if (b.bienfaits && b.bienfaits.length) bText += ` Bienfaits : ${b.bienfaits.join(', ')}.`;
                    html += `<div class="tasting-rec-card" style="position:relative;">
                        <button onclick="speakSection(this, \`${bText.replace(/`/g,'\\`').replace(/"/g,'&quot;')}\`)" class="tasting-voice-btn" style="position:absolute;top:0.5rem;right:0.5rem;" title="Écouter cette boisson">
                            <i class="fas fa-volume-up"></i>
                        </button>
                        <div class="tasting-rec-name">${b.nom || ''}</div>
                        <div class="tasting-rec-origin">📍 ${b.origine || ''}</div>
                        <div class="tasting-rec-notes">"${b.notes_degustation || ''}"</div>
                        <div class="tasting-rec-temp">🌡️ ${b.temperature_ideale || ''}</div>
                        ${b.bienfaits ? `<div style="margin-top:0.5rem;">${b.bienfaits.map(bf => `<span style="font-size:0.75rem;background:#f0fdf4;color:#059669;padding:0.15rem 0.5rem;border-radius:6px;margin-right:0.25rem;">✓ ${bf}</span>`).join('')}</div>` : ''}
                    </div>`;
                });
                html += '</div>';
            }

            // ── Food pairings with voice ──
            if (t.accords_mets && t.accords_mets.length) {
                const accordsText = `Accords mets : ${t.accords_mets.join(', ')}.`;
                html += `<div style="margin-top:1.5rem;padding:1rem;background:#fffbeb;border-radius:12px;border:1px solid #fde68a;position:relative;">
                    <button onclick="speakSection(this, \`${accordsText.replace(/`/g,'\\`').replace(/"/g,'&quot;')}\`)" class="tasting-voice-btn" style="position:absolute;top:0.5rem;right:0.5rem;" title="Écouter les accords">
                        <i class="fas fa-volume-up"></i>
                    </button>
                    <strong>🍽️ Accords mets :</strong> ${t.accords_mets.join(' • ')}
                </div>`;
            }

            // ── Final advice with voice ──
            if (t.conseil_final) {
                const conseilText = `Conseil du sommelier : ${t.conseil_final}`;
                html += `<div style="margin-top:1rem;padding:1rem;background:#eef2ff;border-radius:12px;border:1px solid #c7d2fe;position:relative;">
                    <button onclick="speakSection(this, \`${conseilText.replace(/`/g,'\\`').replace(/"/g,'&quot;')}\`)" class="tasting-voice-btn" style="position:absolute;top:0.5rem;right:0.5rem;" title="Écouter le conseil">
                        <i class="fas fa-volume-up"></i>
                    </button>
                    <strong>🎓 Conseil du sommelier :</strong> ${t.conseil_final}
                </div>`;
            }

            // ── "Écouter tout" global button ──
            html += `<div style="text-align:center;margin-top:1.5rem;">
                <button id="tastingReadAllBtn" onclick="readTastingAloud()" class="btn-submit-drink" style="background:linear-gradient(135deg,#6366f1,#7c3aed);padding:0.6rem 1.5rem;font-size:0.9rem;">
                    <i class="fas fa-headphones me-1"></i> <span id="tastingReadAllLabel">🔊 Écouter tout</span>
                </button>
            </div>`;

            content.innerHTML = html;
            document.getElementById('tastingVoiceBar').style.display = 'none';
            resetVoiceBtn('tasting');
        } else {
            lastTastingData = null;
            document.getElementById('tastingVoiceBar').style.display = 'none';
            content.innerHTML = '<p class="text-muted text-center">Impossible de charger la dégustation.</p>';
        }
    })
    .catch(err => {
        content.innerHTML = '<p class="text-muted text-center">Erreur lors du chargement de la dégustation.</p>';
    });
}

// ══════════════════════════════
// STATS
// ══════════════════════════════
function loadStats() {
    const cont = document.getElementById('statsContent');
    cont.innerHTML = '<div class="text-center py-3"><div class="loading-spinner-sm"></div><p class="text-muted mt-2 small">Chargement desstatistiques...</p></div>';

    apiRequest('{{ path("app_nutrition_sommelier_stats") }}')
    .then(r => r.json())
    .then(data => {
        if (data.status === 'success') {
            let html = '';

            // Daily stats bars
            if (data.daily_stats && data.daily_stats.length) {
                html += '<h4 style="font-size:1rem;font-weight:700;margin-bottom:0.75rem;"><i class="fas fa-chart-bar me-1"></i> Hydratation quotidienne (7 jours)</h4>';
                html += '<div style="display:flex;align-items:flex-end;gap:0.75rem;height:200px;padding:1rem;background:#f8fafc;border-radius:14px;border:1px solid #e2e8f0;margin-bottom:1.5rem;">';
                const maxMl = Math.max(...data.daily_stats.map(d => d.totalMl), 1);
                data.daily_stats.forEach(day => {
                    const height = Math.max(10, (day.totalMl / maxMl) * 160);
                    const date = new Date(day.date);
                    const dayName = date.toLocaleDateString('fr-FR', { weekday: 'short' });
                    const color = day.totalMl >= {{ hydration.target_ml }} ? '#10b981' : '#3b82f6';
                    html += `<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:0.25rem;">
                        <span style="font-size:0.75rem;font-weight:700;">${day.totalMl}ml</span>
                        <div style="width:100%;height:${height}px;background:${color};border-radius:8px;transition:height 0.5s;"></div>
                        <span style="font-size:0.7rem;color:#94a3b8;">${dayName}</span>
                        <span style="font-size:0.65rem;color:#94a3b8;">${day.count} 🥤</span>
                    </div>`;
                });
                html += '</div>';
            } else {
                html += '<p class="text-muted text-center">Aucune donnée disponible. Commencez à enregistrer vos boissons !</p>';
            }

            // Favorites
            if (data.favorites && data.favorites.length) {
                html += '<h4 style="font-size:1rem;font-weight:700;margin-bottom:0.5rem;"><i class="fas fa-heart me-1"></i> Boissons favorites</h4>';
                html += '<div class="list-group">';
                data.favorites.forEach((f, i) => {
                    const emoji = {'thé':'🍵','café':'☕','infusion':'🌿','eau':'💧','jus':'🧃','smoothie':'🥤','sirop_sans_sucre':'🍯','mocktail':'🍹'}[f.category] || '🥤';
                    html += `<div class="list-group-item d-flex justify-content-between align-items-center" style="border:none;border-bottom:1px solid #f1f5f9;">
                        <span>${emoji} <strong>${f.customBeverageName || 'Inconnu'}</strong></span>
                        <span><span class="badge bg-primary rounded-pill">${f.consumeCount}x</span> <span class="badge bg-info rounded-pill">${f.totalMl}ml</span></span>
                    </div>`;
                });
                html += '</div>';
            }

            cont.innerHTML = html || '<p class="text-muted text-center">Pas encore de données.</p>';
        }
    })
    .catch(err => {
        cont.innerHTML = '<div class="alert alert-warning" style="border-radius:12px;">Impossible de charger les statistiques.</div>';
    });
}

// ══════════════════════════════
// DETAIL MODAL
// ══════════════════════════════
function showDetail(item) {
    const modal = document.getElementById('detailModal');
    const content = document.getElementById('detailModalContent');

    let html = `<div style="text-align:center;margin-bottom:1.5rem;">
        <span style="font-size:4rem;">${item.emoji || '🥤'}</span>
        <h3 style="font-size:1.4rem;font-weight:800;margin-top:0.5rem;">${item.name || ''}</h3>
        ${item.origin ? `<p style="color:#94a3b8;">📍 ${item.origin}</p>` : ''}
    </div>`;

    if (item.description) {
        html += `<p style="color:#64748b;line-height:1.6;margin-bottom:1rem;">${item.description}</p>`;
    }

    // Tags
    html += '<div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-bottom:1rem;">';
    if (item.hydration_score) html += `<span class="suggestion-tag tag-hydration">💧 Hydratation ${item.hydration_score}%</span>`;
    if (item.calories !== undefined) html += `<span class="suggestion-tag tag-benefit">🔥 ${item.calories} kcal/100ml</span>`;
    if (item.sugar_free) html += `<span class="suggestion-tag tag-sugar-free">Sans sucre</span>`;
    if (item.caffeine_free) html += `<span class="suggestion-tag tag-caffeine-free">Sans caféine</span>`;
    html += '</div>';

    // Benefits
    if (item.benefits && item.benefits.length) {
        html += '<h4 style="font-size:0.9rem;font-weight:700;margin-bottom:0.5rem;">🌿 Bienfaits</h4>';
        html += '<ul style="padding-left:1.2rem;margin-bottom:1rem;">';
        item.benefits.forEach(b => html += `<li style="font-size:0.85rem;color:#334155;margin-bottom:0.25rem;">${b}</li>`);
        html += '</ul>';
    }

    // Preparation
    if (item.preparation) {
        html += `<div style="padding:1rem;background:#faf5ff;border-radius:12px;margin-bottom:1rem;">
            <strong>📝 Préparation :</strong><br>
            <span style="font-size:0.85rem;color:#64748b;">${item.preparation}</span>
        </div>`;
    }

    // Temperature
    if (item.temp_min && item.temp_max) {
        html += `<div style="padding:0.75rem 1rem;background:#eff6ff;border-radius:12px;margin-bottom:1rem;">
            <strong>🌡️ Température :</strong> ${item.temp_min}°C - ${item.temp_max}°C
        </div>`;
    }

    // Pairing
    if (item.pairing && item.pairing.length) {
        html += `<div style="padding:0.75rem 1rem;background:#fffbeb;border-radius:12px;margin-bottom:1rem;">
            <strong>🍽️ Accords :</strong> ${item.pairing.join(', ')}
        </div>`;
    }

    // Log button
    html += `<button class="btn-submit-drink" style="width:100%;margin-top:1rem;" onclick="logSuggested('${item.id || ''}', '${(item.name || '').replace(/'/g, "\\'")}', '${item.category || 'autre'}', 250); closeModal();">
        <i class="fas fa-plus me-1"></i> Enregistrer cette boisson (250ml)
    </button>`;

    content.innerHTML = html;
    modal.classList.add('open');
}

function closeModal() {
    document.getElementById('detailModal').classList.remove('open');
}

// ══════════════════════════════
// CATALOG FILTER
// ══════════════════════════════
function filterCatalog(category, btn) {
    document.querySelectorAll('.catalog-tab').forEach(t => t.classList.remove('active'));
    if (btn) btn.classList.add('active');

    document.querySelectorAll('.catalog-item').forEach(item => {
        if (category === 'all' || item.dataset.category === category) {
            item.style.display = '';
        } else {
            item.style.display = 'none';
        }
    });
}

// Expose to window for HTML onclick handlers
window.filterCatalog = filterCatalog;

// ══════════════════════════════
// ADD TO CART FROM CATALOG
// ══════════════════════════════
// catalogCartTotal now stored in window.sommelier.catalogCartTotal

function addCatalogToCart(productId, btn) {
    if (btn.disabled) return;

    const originalHTML = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

    const formData = new FormData();
    formData.append('product_id', productId);
    formData.append('quantity', 1);

    apiRequest('{{ path("app_nutrition_sommelier_add_to_cart") }}', {
        body: formData
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'success') {
            window.sommelier.catalogCartTotal++;
            btn.innerHTML = '<i class="fas fa-check"></i> Ajouté !';
            btn.classList.add('added');
            showSuccessToast('✅ ' + (data.message || 'Produit ajouté au panier !'));

            // Update cart bar + badge
            updateCartBadge(data.cart_count || window.sommelier.catalogCartTotal);

            setTimeout(() => {
                btn.innerHTML = originalHTML;
                btn.classList.remove('added');
                btn.disabled = false;
            }, 2000);
        } else {
            btn.innerHTML = originalHTML;
            btn.disabled = false;
            showSuccessToast('❌ ' + (data.message || 'Erreur lors de l\'ajout'));
        }
    })
    .catch(err => {
        btn.innerHTML = originalHTML;
        btn.disabled = false;
        showSuccessToast('❌ Erreur de connexion');
    });
}

// Expose addCatalogToCart to window for HTML onclick handlers
window.addCatalogToCart = addCatalogToCart;

// Show cart bar on load if items exist
(function() {
    if (window.sommelier.catalogCartTotal > 0) {
        const bar = document.getElementById('catalogCartBar');
        const count = document.getElementById('catalogCartCount');
        if (bar) bar.style.display = 'block';
        if (count) count.textContent = window.sommelier.catalogCartTotal;
    }
})();

// ══════════════════════════════
// TOAST
// ══════════════════════════════
function showSuccessToast(message) {
    const toast = document.createElement('div');
    toast.style.cssText = 'position:fixed;top:20px;right:20px;z-index:20000;background:#f0fdf4;color:#065f46;padding:1rem 1.5rem;border-radius:14px;font-weight:600;box-shadow:0 8px 30px rgba(0,0,0,0.15);border:1px solid #bbf7d0;animation:slideIn 0.3s ease;max-width:400px;';
    if (message.includes('❌')) {
        toast.style.background = '#fef2f2';
        toast.style.color = '#991b1b';
        toast.style.borderColor = '#fecaca';
    }
    toast.innerHTML = message;
    document.body.appendChild(toast);
    setTimeout(() => { toast.style.animation = 'toastOut 0.3s forwards'; setTimeout(() => toast.remove(), 300); }, 3000);
}

// ══════════════════════════════
// CART SIDEBAR FUNCTIONS
// ══════════════════════════════
function openCart() {
    const overlay = document.getElementById('cartOverlay');
    if (!overlay) return;
    overlay.classList.add('open');
    loadCartData();
}

function closeCart(event) {
    if (event && event.target !== document.getElementById('cartOverlay')) return;
    const overlay = document.getElementById('cartOverlay');
    if (overlay) overlay.classList.remove('open');
    const checkoutForm = document.getElementById('checkoutForm');
    if (checkoutForm) checkoutForm.classList.remove('open');
}

function updateCartBadge(count) {
    window.sommelier.catalogCartTotal = count;
    const badge = document.getElementById('cartBadge');
    if (badge) {
        badge.textContent = count;
        badge.style.display = count > 0 ? 'flex' : 'none';
    }
    const countEl = document.getElementById('catalogCartCount');
    if (countEl) countEl.textContent = count;
    const bar = document.getElementById('catalogCartBar');
    if (bar) bar.style.display = count > 0 ? 'block' : 'none';
}

function loadCartData() {
    fetch('{{ path("app_nutrition_sommelier_cart_data") }}', {
        method: 'POST',
        credentials: 'include',
        headers: {
            'X-CSRF-Token': window.sommelier.csrfToken,
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'success') {
            renderCart(data);
        }
    })
    .catch(err => {
        console.error('Load cart error:', err);
        showSuccessToast('❌ Erreur lors du chargement du panier');
    });
}

function renderCart(data) {
    const container = document.getElementById('cartItems');
    const footer = document.getElementById('cartFooter');

    if (!container || !footer) return;

    if (!data.items || data.items.length === 0) {
        container.innerHTML = '<div style="text-align:center;padding:3rem 1rem;"><div style="font-size:4rem;margin-bottom:1rem;">🛒</div><p style="color:#94a3b8;">Votre panier est vide</p></div>';
        footer.style.display = 'none';
        return;
    }

    let html = '';
    data.items.forEach(item => {
        html += `<div class="cart-item">
            <span class="cart-item-emoji">${item.emoji}</span>
            <div class="cart-item-info">
                <div class="cart-item-name">${item.name}</div>
                <div class="cart-item-details">${item.brand || ''} · ${item.volume || ''}</div>
                <div class="cart-item-details">${item.unit_price} DH/unité</div>
                <div class="cart-item-qty">
                    <button class="cart-qty-btn" onclick="updateCartQty(${item.item_id}, ${item.quantity - 1})">−</button>
                    <span style="font-weight:700;">${item.quantity}</span>
                    <button class="cart-qty-btn" onclick="updateCartQty(${item.item_id}, ${item.quantity + 1})">+</button>
                </div>
                <button class="cart-item-remove" onclick="removeCartItem(${item.item_id})"><i class="fas fa-trash-alt me-1"></i> Supprimer</button>
            </div>
            <div class="cart-item-total">${item.line_total} DH</div>
        </div>`;
    });
    container.innerHTML = html;
    footer.style.display = 'block';

    const subtotalEl = document.getElementById('cartSubtotal');
    if (subtotalEl) subtotalEl.textContent = data.total + ' DH';
    const shippingEl = document.getElementById('cartShipping');
    if (shippingEl) shippingEl.textContent = data.shipping_cost === '0.00' ? 'Gratuit 🎉' : data.shipping_cost + ' DH';
    const totalEl = document.getElementById('cartGrandTotal');
    if (totalEl) totalEl.textContent = data.grand_total + ' DH';
    updateCartBadge(data.cart_count);

    // Shipping progress
    const total = parseFloat(data.total);
    const threshold = data.free_shipping_at;
    let bannerHTML = '';
    if (total >= threshold) {
        bannerHTML = '<div class="free-shipping-banner">🚚 Livraison gratuite !</div>';
    } else {
        const remaining = (threshold - total).toFixed(2);
        const pct = Math.min(100, (total / threshold) * 100);
        bannerHTML = `<div class="free-shipping-banner">
            🚚 Plus que ${remaining} DH pour la livraison gratuite !
            <div class="shipping-progress-bar"><div class="shipping-progress-fill" style="width:${pct}%"></div></div>
        </div>`;
    }
    const bannerArea = document.getElementById('shippingBannerArea');
    if (bannerArea) bannerArea.innerHTML = bannerHTML;
}

function updateCartQty(itemId, qty) {
    const formData = new FormData();
    formData.append('item_id', itemId);
    formData.append('quantity', qty);

    fetch('{{ path("app_nutrition_sommelier_update_cart") }}', {
        method: 'POST',
        body: formData,
        credentials: 'include',
        headers: {
            'X-CSRF-Token': window.sommelier.csrfToken,
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'success') {
            loadCartData();
        } else {
            showSuccessToast('❌ ' + data.message);
        }
    })
    .catch(err => {
        console.error('Update cart error:', err);
        showSuccessToast('❌ Erreur lors de la mise à jour du panier');
    });
}

function removeCartItem(itemId) {
    const formData = new FormData();
    formData.append('item_id', itemId);

    fetch('{{ path("app_nutrition_sommelier_remove_from_cart") }}', {
        method: 'POST',
        body: formData,
        credentials: 'include',
        headers: {
            'X-CSRF-Token': window.sommelier.csrfToken,
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'success') {
            loadCartData();
            updateCartBadge(data.cart_count);
        }
    })
    .catch(err => {
        console.error('Remove error:', err);
        showSuccessToast('❌ Erreur lors de la suppression');
    });
}

// ══════════════════════════════
// CHECKOUT
// ══════════════════════════════
function showCheckoutForm() {
    const btnArea = document.getElementById('checkoutBtnArea');
    if (btnArea) btnArea.style.display = 'none';
    const form = document.getElementById('checkoutForm');
    if (form) form.classList.add('open');
}

function submitCheckout() {
    const address = document.getElementById('ckAddress').value;
    const city = document.getElementById('ckCity').value;
    const phone = document.getElementById('ckPhone').value;

    if (!address || !city || !phone) {
        showSuccessToast('❌ Veuillez remplir adresse, ville et téléphone.');
        return;
    }

    const formData = new FormData();
    formData.append('address', address);
    formData.append('city', city);
    formData.append('postal_code', document.getElementById('ckPostalCode').value);
    formData.append('phone', phone);
    formData.append('payment_method', document.getElementById('ckPaymentMethod').value);
    formData.append('notes', document.getElementById('ckNotes').value);

    fetch('{{ path("app_nutrition_sommelier_checkout") }}', {
        method: 'POST',
        body: formData,
        credentials: 'include',
        headers: {
            'X-CSRF-Token': window.sommelier.csrfToken,
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(r => {
        if (!r.ok) throw new Error('Erreur serveur: ' + r.status);
        return r.json();
    })
    .then(data => {
        if (data.status === 'success') {
            const cartItems = document.getElementById('cartItems');
            if (cartItems) {
                cartItems.innerHTML = `
                    <div style="text-align:center;padding:3rem 1rem;">
                        <div style="font-size:4rem;margin-bottom:1rem;">🎉</div>
                        <h3 style="font-weight:800;margin-bottom:0.5rem;">Commande confirmée !</h3>
                        <p style="color:#64748b;">N° ${data.order_number}</p>
                        <p style="font-weight:700;font-size:1.3rem;color:#10b981;margin:1rem 0;">Total : ${data.grand_total} DH</p>
                        ${data.shipping_cost == 0 ? '<p style="color:#059669;font-weight:600;">🚚 Livraison gratuite !</p>' : ''}
                        <a href="{{ path('app_nutrition_sommelier_orders') }}" data-turbo="false" style="display:inline-block;margin-top:1.5rem;padding:0.75rem 2rem;background:#6366f1;color:white;border-radius:12px;text-decoration:none;font-weight:700;">
                            <i class="fas fa-box me-1"></i> Voir mes commandes
                        </a>
                    </div>`;
            }
            const cartFooter = document.getElementById('cartFooter');
            if (cartFooter) cartFooter.style.display = 'none';
            updateCartBadge(0);
            showSuccessToast('✅ Commande confirmée !');
        } else {
            showSuccessToast('❌ ' + (data.message || 'Erreur lors de la commande'));
        }
    })
    .catch(err => {
        console.error('Checkout error:', err);
        showSuccessToast('❌ Erreur réseau lors du checkout. Vérifiez votre connexion et réessayez.');
    });
}

// ══════════════════════════════
// BEVERAGE PHOTO ANALYSIS
// ══════════════════════════════
let lastSuggestionsData = null;
let lastTastingData = null;
let voiceSpeakingSection = null;

// ── Generic TTS helper ──
let currentSpeakingBtn = null;

function speakSection(btn, text) {
    if (!window.speechSynthesis) return;

    // If this button is already speaking, stop
    if (currentSpeakingBtn === btn) {
        window.speechSynthesis.cancel();
        currentSpeakingBtn = null;
        btn.innerHTML = '<i class="fas fa-volume-up"></i>';
        btn.classList.remove('tasting-voice-btn-active');
        return;
    }

    // Stop any ongoing speech
    window.speechSynthesis.cancel();
    if (currentSpeakingBtn) {
        currentSpeakingBtn.innerHTML = '<i class="fas fa-volume-up"></i>';
        currentSpeakingBtn.classList.remove('tasting-voice-btn-active');
    }
    currentSpeakingBtn = btn;

    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'fr-FR';
    utterance.rate = 0.95;
    utterance.pitch = 1;

    const voices = window.speechSynthesis.getVoices();
    const frVoice = voices.find(v => v.lang.startsWith('fr'));
    if (frVoice) utterance.voice = frVoice;

    utterance.onstart = function() {
        btn.innerHTML = '<i class="fas fa-stop"></i>';
        btn.classList.add('tasting-voice-btn-active');
    };
    utterance.onend = function() {
        currentSpeakingBtn = null;
        btn.innerHTML = '<i class="fas fa-volume-up"></i>';
        btn.classList.remove('tasting-voice-btn-active');
    };
    utterance.onerror = function() {
        currentSpeakingBtn = null;
        btn.innerHTML = '<i class="fas fa-volume-up"></i>';
        btn.classList.remove('tasting-voice-btn-active');
    };

    window.speechSynthesis.speak(utterance);
}

function speakFrench(text, sectionKey) {
    if (!window.speechSynthesis) return;

    // If same section is already speaking, stop
    if (voiceSpeakingSection === sectionKey) {
        window.speechSynthesis.cancel();
        voiceSpeakingSection = null;
        resetVoiceBtn(sectionKey);
        return;
    }

    // Stop any ongoing speech first
    window.speechSynthesis.cancel();
    voiceSpeakingSection = sectionKey;

    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'fr-FR';
    utterance.rate = 0.95;
    utterance.pitch = 1;

    const voices = window.speechSynthesis.getVoices();
    const frVoice = voices.find(v => v.lang.startsWith('fr'));
    if (frVoice) utterance.voice = frVoice;

    const btnLabel = document.getElementById(sectionKey + 'VoiceLabel');
    const btnIcon = document.getElementById(sectionKey + 'VoiceBtn');

    utterance.onstart = function() {
        if (btnLabel) btnLabel.textContent = '⏹️ Arrêter la lecture';
        if (btnIcon) btnIcon.querySelector('i').className = 'fas fa-stop me-1';
    };
    utterance.onend = function() {
        voiceSpeakingSection = null;
        resetVoiceBtn(sectionKey);
    };
    utterance.onerror = function() {
        voiceSpeakingSection = null;
        resetVoiceBtn(sectionKey);
    };

    window.speechSynthesis.speak(utterance);
}

function resetVoiceBtn(sectionKey) {
    const labels = {
        'suggestions': '🔊 Écouter les suggestions',
        'tasting': '🔊 Écouter la dégustation'
    };
    const btnLabel = document.getElementById(sectionKey + 'VoiceLabel');
    const btnIcon = document.getElementById(sectionKey + 'VoiceBtn');
    if (btnLabel) btnLabel.textContent = labels[sectionKey] || '🔊 Écouter';
    if (btnIcon) btnIcon.querySelector('i').className = 'fas fa-volume-up me-1';
}

// ── Read Suggestions Aloud ──
function readSuggestionsAloud() {
    if (!lastSuggestionsData || !lastSuggestionsData.length) return;
    let text = 'Voici les boissons suggérées pour ce repas. ';
    lastSuggestionsData.forEach((s, i) => {
        text += `Suggestion ${i + 1} : ${s.name || 'Boisson'}. `;
        if (s.origin) text += `Origine : ${s.origin}. `;
        if (s.description) text += s.description.substring(0, 200) + '. ';
        if (s.hydration_score) text += `Score d'hydratation : ${s.hydration_score} pourcent. `;
        if (s.calories !== undefined) text += `${s.calories} kilocalories pour 100 millilitres. `;
        if (s.benefits && s.benefits.length) text += 'Bienfaits : ' + s.benefits.slice(0, 3).join(', ') + '. ';
    });
    speakFrench(text, 'suggestions');
}

// ── Read Tasting Aloud (all at once) ──
function readTastingAloud() {
    if (!lastTastingData) return;

    const allBtn = document.getElementById('tastingReadAllBtn');
    const allLabel = document.getElementById('tastingReadAllLabel');

    // Toggle off if already speaking
    if (voiceSpeakingSection === 'tastingAll') {
        window.speechSynthesis.cancel();
        voiceSpeakingSection = null;
        if (allLabel) allLabel.textContent = '🔊 Écouter tout';
        if (allBtn) allBtn.querySelector('i').className = 'fas fa-headphones me-1';
        return;
    }

    // Stop any ongoing speech
    window.speechSynthesis.cancel();
    if (currentSpeakingBtn) {
        currentSpeakingBtn.innerHTML = '<i class="fas fa-volume-up"></i>';
        currentSpeakingBtn.classList.remove('tasting-voice-btn-active');
        currentSpeakingBtn = null;
    }
    voiceSpeakingSection = 'tastingAll';

    const t = lastTastingData;
    let text = '';
    text += (t.titre || 'Dégustation') + '. ';
    if (t.introduction) text += t.introduction + ' ';

    if (t.etapes && t.etapes.length) {
        text += 'Étapes de la dégustation. ';
        t.etapes.forEach(step => {
            text += `Étape ${step.numero} : ${step.nom || ''}. `;
            if (step.description) text += step.description + ' ';
            if (step.conseil) text += 'Conseil : ' + step.conseil + '. ';
            if (step.duree_minutes) text += `Durée : ${step.duree_minutes} minutes. `;
        });
    }

    if (t.boissons_recommandees && t.boissons_recommandees.length) {
        text += 'Boissons recommandées. ';
        t.boissons_recommandees.forEach(b => {
            text += `${b.nom || ''}, origine ${b.origine || 'inconnue'}. `;
            if (b.notes_degustation) text += `Notes de dégustation : ${b.notes_degustation}. `;
            if (b.temperature_ideale) text += `Température idéale : ${b.temperature_ideale}. `;
            if (b.bienfaits && b.bienfaits.length) text += 'Bienfaits : ' + b.bienfaits.join(', ') + '. ';
        });
    }

    if (t.accords_mets && t.accords_mets.length) {
        text += 'Accords mets : ' + t.accords_mets.join(', ') + '. ';
    }

    if (t.conseil_final) {
        text += 'Conseil du sommelier : ' + t.conseil_final;
    }

    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'fr-FR';
    utterance.rate = 0.95;
    utterance.pitch = 1;
    const voices = window.speechSynthesis.getVoices();
    const frVoice = voices.find(v => v.lang.startsWith('fr'));
    if (frVoice) utterance.voice = frVoice;

    utterance.onstart = function() {
        if (allLabel) allLabel.textContent = '⏹️ Arrêter la lecture';
        if (allBtn) allBtn.querySelector('i').className = 'fas fa-stop me-1';
    };
    utterance.onend = function() {
        voiceSpeakingSection = null;
        if (allLabel) allLabel.textContent = '🔊 Écouter tout';
        if (allBtn) allBtn.querySelector('i').className = 'fas fa-headphones me-1';
    };
    utterance.onerror = function() {
        voiceSpeakingSection = null;
        if (allLabel) allLabel.textContent = '🔊 Écouter tout';
        if (allBtn) allBtn.querySelector('i').className = 'fas fa-headphones me-1';
    };

    window.speechSynthesis.speak(utterance);
}

function analyzeBeveragePhoto() {
    if (!window.sommelier.currentPhotoFile) return;

    document.getElementById('photoAnalyzeBtn').style.display = 'none';
    document.getElementById('photoAnalysisLoading').style.display = 'block';
    document.getElementById('photoAnalysisResult').style.display = 'none';

    const formData = new FormData();
    formData.append('photo', window.sommelier.currentPhotoFile);

    apiRequest('{{ path("app_nutrition_sommelier_photo_analyze") }}', {
        body: formData
    })
    .then(r => {
        if (!r.ok) {
            throw new Error('Erreur HTTP: ' + r.status);
        }
        return r.json();
    })
    .then(data => {
        document.getElementById('photoAnalysisLoading').style.display = 'none';
        if (data.status === 'success') {
            window.sommelier.currentPhotoAnalysis = data.analysis;
            displayPhotoAnalysis(data.analysis);
        } else {
            showSuccessToast('❌ ' + (data.message || 'Erreur lors de l\'analyse'));
            document.getElementById('photoAnalyzeBtn').style.display = 'block';
        }
    })
    .catch(err => {
        document.getElementById('photoAnalysisLoading').style.display = 'none';
        document.getElementById('photoAnalyzeBtn').style.display = 'block';
        console.error('Analysis error:', err);
        showSuccessToast('❌ Erreur de connexion lors de l\'analyse. Vérifiez votre connexion Internet.');
    });
}

function displayPhotoAnalysis(analysis) {
    const catEmojis = {'thé':'🍵','café':'☕','infusion':'🌿','eau':'💧','jus':'🧃','smoothie':'🥤','sirop_sans_sucre':'🍯','mocktail':'🍹'};
    document.getElementById('photoResultName').textContent = (analysis.name || 'Boisson inconnue');
    document.getElementById('photoResultCategory').textContent = (catEmojis[analysis.category] || '🥤') + ' ' + (analysis.category || '');
    document.getElementById('photoResultVolume').textContent = (analysis.estimated_volume_ml || '?') + ' ml';
    document.getElementById('photoResultCalories').textContent = (analysis.calories_estimated || '?') + ' kcal';
    document.getElementById('photoResultHydration').textContent = (analysis.hydration_score || '?') + '/10';
    document.getElementById('photoResultHealthy').textContent = analysis.is_healthy ? '✅ Sain' : '⚠️ Attention';

    document.getElementById('photoResultDescription').textContent = analysis.description || '';

    // Benefits
    let benefitsHTML = '';
    if (analysis.health_benefits && analysis.health_benefits.length) {
        benefitsHTML = '<div style="margin-bottom:0.5rem;font-weight:700;font-size:0.85rem;">✅ Bienfaits :</div>';
        analysis.health_benefits.forEach(b => { benefitsHTML += '<span style="display:inline-block;padding:0.2rem 0.6rem;background:#ecfdf5;color:#059669;border-radius:8px;font-size:0.8rem;font-weight:600;margin:0.15rem;">' + b + '</span>'; });
    }
    document.getElementById('photoResultBenefits').innerHTML = benefitsHTML;

    // Warnings
    let warningsHTML = '';
    if (analysis.health_warnings && analysis.health_warnings.length) {
        warningsHTML = '<div style="margin-bottom:0.5rem;font-weight:700;font-size:0.85rem;">⚠️ Avertissements :</div>';
        analysis.health_warnings.forEach(w => { warningsHTML += '<span style="display:inline-block;padding:0.2rem 0.6rem;background:#fef2f2;color:#dc2626;border-radius:8px;font-size:0.8rem;font-weight:600;margin:0.15rem;">' + w + '</span>'; });
    }
    document.getElementById('photoResultWarnings').innerHTML = warningsHTML;

    // Alternatives
    let altHTML = '';
    if (analysis.alternatives_healthier && analysis.alternatives_healthier.length) {
        altHTML = '<div style="margin-bottom:0.5rem;font-weight:700;font-size:0.85rem;">💡 Alternatives plus saines :</div>';
        analysis.alternatives_healthier.forEach(a => { altHTML += '<span style="display:inline-block;padding:0.2rem 0.6rem;background:#eff6ff;color:#2563eb;border-radius:8px;font-size:0.8rem;font-weight:600;margin:0.15rem;">' + a + '</span>'; });
    }
    document.getElementById('photoResultAlternatives').innerHTML = altHTML;

    document.getElementById('photoAnalysisResult').style.display = 'block';
}

function savePhotoAnalysis() {
    if (!window.sommelier.currentPhotoAnalysis) return;

    const moment = prompt('À quel moment consommez-vous cette boisson? (petit-déjeuner, déjeuner, goûter, dîner, autre)', 'autre');
    if (!moment) return;

    const formData = new FormData();
    formData.append('name', window.sommelier.currentPhotoAnalysis.name || 'Boisson analysée');
    formData.append('category', window.sommelier.currentPhotoAnalysis.category || 'autre');
    formData.append('quantity_ml', window.sommelier.currentPhotoAnalysis.estimated_volume_ml || 250);
    formData.append('calories', window.sommelier.currentPhotoAnalysis.calories_estimated || 0);
    formData.append('moment', moment);

    apiRequest('{{ path("app_nutrition_sommelier_photo_log") }}', {
        body: formData
    })
    .then(r => r.json())
    .then(data => {
        if (data.status === 'success') {
            showSuccessToast('✅ Boisson enregistrée avec succès !');
            resetPhotoUpload();
            // Refresh after short delay
            setTimeout(() => location.reload(), 1500);
        } else {
            showSuccessToast('❌ ' + data.message);
        }
    })
    .catch(err => {
        console.error('Save error:', err);
        showSuccessToast('❌ Erreur de connexion lors de l\'enregistrement');
    });
}

// ── Text-to-Speech: read analysis results aloud ──
function readAnalysisAloud() {
    if (!window.sommelier.currentPhotoAnalysis) return;

    // If already speaking, stop
    if (window.sommelier.isSpeaking) {
        window.speechSynthesis.cancel();
        window.sommelier.isSpeaking = false;
        document.getElementById('voiceReadLabel').textContent = 'Écouter';
        document.getElementById('voiceReadBtn').querySelector('i').className = 'fas fa-volume-up me-1';
        return;
    }

    const a = window.sommelier.currentPhotoAnalysis;
    let text = '';
    text += 'Boisson identifiée : ' + (a.name || 'Inconnue') + '. ';
    text += 'Catégorie : ' + (a.category || 'non définie') + '. ';
    text += 'Volume estimé : ' + (a.estimated_volume_ml || 'inconnu') + ' millilitres. ';
    text += 'Calories estimées : ' + (a.calories_estimated || 0) + ' kilocalories. ';
    text += 'Score d\'hydratation : ' + (a.hydration_score || 'inconnu') + ' sur 10. ';
    text += a.is_healthy ? 'Cette boisson est considérée comme saine. ' : 'Attention, cette boisson nécessite de la prudence. ';

    if (a.description) {
        text += a.description + ' ';
    }

    if (a.health_benefits && a.health_benefits.length) {
        text += 'Bienfaits : ' + a.health_benefits.join(', ') + '. ';
    }

    if (a.health_warnings && a.health_warnings.length) {
        text += 'Avertissements : ' + a.health_warnings.join(', ') + '. ';
    }

    if (a.alternatives_healthier && a.alternatives_healthier.length) {
        text += 'Alternatives plus saines : ' + a.alternatives_healthier.join(', ') + '. ';
    }

    if (a.recommendation) {
        text += 'Conseil : ' + a.recommendation;
    }

    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'fr-FR';
    utterance.rate = 0.95;
    utterance.pitch = 1;

    // Try to pick a French voice
    const voices = window.speechSynthesis.getVoices();
    const frVoice = voices.find(v => v.lang.startsWith('fr'));
    if (frVoice) utterance.voice = frVoice;

    utterance.onstart = function() {
        window.sommelier.isSpeaking = true;
        document.getElementById('voiceReadLabel').textContent = 'Arrêter';
        document.getElementById('voiceReadBtn').querySelector('i').className = 'fas fa-stop me-1';
    };
    utterance.onend = function() {
        window.sommelier.isSpeaking = false;
        document.getElementById('voiceReadLabel').textContent = 'Écouter';
        document.getElementById('voiceReadBtn').querySelector('i').className = 'fas fa-volume-up me-1';
    };
    utterance.onerror = function() {
        window.sommelier.isSpeaking = false;
        document.getElementById('voiceReadLabel').textContent = 'Écouter';
        document.getElementById('voiceReadBtn').querySelector('i').className = 'fas fa-volume-up me-1';
    };

    window.speechSynthesis.cancel();
    window.speechSynthesis.speak(utterance);
}

// Pre-load voices (some browsers need this)
if (window.speechSynthesis) {
    window.speechSynthesis.onvoiceschanged = function() { window.speechSynthesis.getVoices(); };
}

function resetPhotoUpload() {
    // Stop any ongoing speech
    if (window.speechSynthesis) window.speechSynthesis.cancel();
    window.sommelier.isSpeaking = false;
    window.sommelier.currentPhotoFile = null;
    window.sommelier.currentPhotoAnalysis = null;
    document.getElementById('photoPreview').style.display = 'none';
    document.getElementById('photoPlaceholder').style.display = 'block';
    document.getElementById('photoAnalyzeBtn').style.display = 'none';
    document.getElementById('photoAnalysisLoading').style.display = 'none';
    document.getElementById('photoAnalysisResult').style.display = 'none';
    document.getElementById('photoUploadArea').style.borderColor = '#c7d2fe';
    document.getElementById('photoUploadArea').style.background = '#fafafe';
    document.getElementById('beveragePhotoInput').value = '';
}

