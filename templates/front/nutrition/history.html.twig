{% extends 'base_dashboard.html.twig' %}

{% block title %}Mon Historique - WANNASNI{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h1 class="h2 mb-0">📅 Mon Historique de Repas</h1>
        <a href="{{ path('app_nutrition_track') }}" class="btn btn-success rounded-pill px-4">
            <i class="fas fa-camera me-2"></i> Nouvelle analyse
        </a>
    </div>

    {% if history is empty %}
        <div class="text-center py-5 bg-white rounded-4 shadow-sm border">
            <div style="font-size: 4rem;">🍽️</div>
            <h3 class="mt-3">Aucun repas analysé</h3>
            <p class="text-muted">Commencez par prendre une photo de votre repas pour voir votre historique.</p>
        </div>
    {% else %}
        <div class="timeline">
            {% for item in history %}
                <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                    <div class="row g-0">
                        <div class="col-md-3">
                            <img src="{{ item.photoUrl ? asset('uploads/meals/' ~ item.photoUrl) : 'https://placehold.co/400x300?text=No+Photo' }}" 
                                 class="img-fluid h-100 object-fit-cover" 
                                 style="min-height: 200px; object-fit: cover; width: 100%;">
                        </div>
                        <div class="col-md-9">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <h3 class="h5 mb-1">{{ item.dateRepas|date('d/m/Y H:i') }}</h3>
                                        <span class="badge {% if item.estConforme %}bg-success{% else %}bg-danger{% endif %} rounded-pill">
                                            {% if item.estConforme %}✓ Conforme{% else %}✗ Non Conforme{% endif %}
                                        </span>
                                    </div>
                                    <div class="text-end">
                                        <div class="h4 mb-0 text-success">{{ item.caloriesCalculees }} <small class="h6">kcal</small></div>
                                    </div>
                                </div>
                                <p class="card-text">
                                    <strong>Aliments :</strong>
                                    {% for aliment in item.alimentsIdentifies %}
                                        <span class="badge bg-light text-dark border me-1">{{ aliment.nom|replace({'_': ' '}) }}</span>
                                    {% endfor %}
                                </p>
                                <p class="card-text text-muted small mt-2">
                                    <i class="fas fa-comment-dots me-1"></i> {{ item.commentairesIA|length > 100 ? item.commentairesIA|slice(0, 100) ~ '...' : item.commentairesIA }}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
