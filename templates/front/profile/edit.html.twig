{% extends 'base_dashboard.html.twig' %}

{% block title %}Modifier Mon Profil - WANNASNI{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    :root {
        --dash-primary: #2E7D32;
        --dash-primary-light: #4CAF50;
        --dash-primary-soft: rgba(46, 125, 50, 0.08);
        --dash-bg: #f8faf8;
        --dash-card: #ffffff;
        --dash-text: #1a1a2e;
        --dash-text-muted: #64748b;
        --dash-border: #e2e8f0;
        --dash-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
        --dash-radius: 20px;
        --dash-radius-sm: 12px;
    }

    body { background: var(--dash-bg); }

    .page-wrapper {
        min-height: 100vh;
        padding: 2rem 1.5rem 4rem;
        background: linear-gradient(180deg, #f0f7f0 0%, var(--dash-bg) 30%);
    }

    .page-container {
        max-width: 600px;
        margin: 0 auto;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--dash-primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        transition: all 0.2s;
    }

    .back-link:hover {
        background: var(--dash-primary-soft);
    }

    .form-card {
        background: var(--dash-card);
        border-radius: var(--dash-radius);
        box-shadow: var(--dash-shadow);
        border: 1px solid var(--dash-border);
        overflow: hidden;
    }

    .form-header {
        padding: 1.5rem 2rem;
        border-bottom: 1px solid var(--dash-border);
        background: linear-gradient(to right, var(--dash-primary-soft), transparent);
    }

    .form-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--dash-text);
    }

    .form-title-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--dash-primary), var(--dash-primary-light));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.25rem;
    }

    .form-body {
        padding: 2rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        display: block;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--dash-text);
        margin-bottom: 0.5rem;
    }

    .form-input {
        width: 100%;
        padding: 1rem 1.25rem;
        font-size: 1rem;
        border: 2px solid var(--dash-border);
        border-radius: var(--dash-radius-sm);
        background: white;
        transition: all 0.2s;
        font-family: inherit;
    }

    .form-input:focus {
        outline: none;
        border-color: var(--dash-primary);
        box-shadow: 0 0 0 4px var(--dash-primary-soft);
    }

    .btn-group {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn {
        padding: 1rem 2rem;
        font-size: 1rem;
        font-weight: 600;
        border-radius: var(--dash-radius-sm);
        cursor: pointer;
        text-decoration: none;
        text-align: center;
        transition: all 0.2s;
        border: none;
    }

    .btn-primary {
        flex: 1;
        background: linear-gradient(135deg, var(--dash-primary), var(--dash-primary-light));
        color: white;
        box-shadow: 0 4px 16px rgba(46, 125, 50, 0.25);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(46, 125, 50, 0.35);
    }

    .btn-secondary {
        background: white;
        color: var(--dash-text-muted);
        border: 2px solid var(--dash-border);
    }

    .btn-secondary:hover {
        border-color: var(--dash-primary);
        color: var(--dash-primary);
    }
</style>
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-container">
        <a href="{{ path('app_profile', {'_locale': app.request.locale}) }}" class="back-link">
            ← Retour au profil
        </a>

        <div class="form-card">
            <div class="form-header">
                <h1 class="form-title">
                    <span class="form-title-icon">✏️</span>
                    Modifier Mon Profil
                </h1>
            </div>
            <div class="form-body">
                <form method="post" enctype="multipart/form-data">
                    <div class="form-group">
                        <label class="form-label">Prénom</label>
                        <input type="text" class="form-input" name="firstName" value="{{ user.firstName }}" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Nom</label>
                        <input type="text" class="form-input" name="lastName" value="{{ user.lastName }}" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-input" name="email" value="{{ user.email }}" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Téléphone</label>
                        <input type="tel" class="form-input" name="phone" value="{{ user.phone }}">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Image de Profil</label>
                        {% if user.imageProfil %}
                            <div style="margin-bottom: 1rem;">
                                <img src="{{ user.imageProfil }}" alt="Profile" style="width: 100px; height: 100px; object-fit: cover; border-radius: 50%; border: 2px solid #e2e8f0;">
                            </div>
                        {% endif %}
                        <input type="file" class="form-input" name="imageProfil" accept="image/*" style="padding: 0.75rem;">
                        <small style="color: #64748b; display: block; margin-top: 0.5rem;">Formats acceptés: JPG, PNG, GIF (Max 2MB)</small>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Date de Naissance</label>
                        <input type="date" class="form-input" name="dateNaissance" value="{{ user.dateNaissance ? user.dateNaissance|date('Y-m-d') : '' }}">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Adresse</label>
                        <input type="text" class="form-input" name="adresse" value="{{ user.adresse }}" placeholder="123 Rue Example">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Ville</label>
                        <input type="text" class="form-input" name="ville" value="{{ user.ville }}" placeholder="Paris">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Code Postal</label>
                        <input type="text" class="form-input" name="codePostal" value="{{ user.codePostal }}" placeholder="75001">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Pays</label>
                        <input type="text" class="form-input" name="pays" value="{{ user.pays }}" placeholder="France">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Location</label>
                        <input type="text" class="form-input" name="location" value="{{ user.location }}" placeholder="Paris, France">
                    </div>

                    <div class="btn-group">
                        <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
                        <a href="{{ path('app_profile', {'_locale': app.request.locale}) }}" class="btn btn-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
