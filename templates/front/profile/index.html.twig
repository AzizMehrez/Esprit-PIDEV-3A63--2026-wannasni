{% extends 'base_dashboard.html.twig' %}

{% block title %}Mon Profil - WANNASNI{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    :root {
        --dash-primary: #2E7D32;
        --dash-primary-light: #4CAF50;
        --dash-primary-soft: rgba(46, 125, 50, 0.08);
        --dash-bg: #f8faf8;
        --dash-card: #ffffff;
        --dash-text: #1a1a2e;
        --dash-text-muted: #64748b;
        --dash-border: #e2e8f0;
        --dash-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
        --dash-shadow-hover: 0 8px 32px rgba(46, 125, 50, 0.12);
        --dash-radius: 20px;
        --dash-radius-sm: 12px;
    }

    body { background: var(--dash-bg); }

    .page-wrapper {
        min-height: 100vh;
        padding: 2rem 1.5rem 4rem;
        background: linear-gradient(180deg, #f0f7f0 0%, var(--dash-bg) 30%);
    }

    .page-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--dash-primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        transition: all 0.2s;
    }

    .back-link:hover {
        background: var(--dash-primary-soft);
    }

    .profile-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
        padding: 2rem;
        background: linear-gradient(135deg, var(--dash-primary) 0%, #1b5e20 100%);
        border-radius: var(--dash-radius);
        box-shadow: 0 8px 40px rgba(46, 125, 50, 0.25);
    }

    .profile-avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        font-weight: 700;
        color: white;
        border: 3px solid rgba(255,255,255,0.3);
        flex-shrink: 0;
    }

    .profile-info {
        color: white;
    }

    .profile-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.25rem;
    }

    .profile-email {
        opacity: 0.9;
        font-size: 1rem;
    }

    .profile-card {
        background: var(--dash-card);
        border-radius: var(--dash-radius);
        box-shadow: var(--dash-shadow);
        border: 1px solid var(--dash-border);
        overflow: hidden;
        margin-bottom: 1.5rem;
    }

    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--dash-border);
        background: linear-gradient(to right, var(--dash-primary-soft), transparent);
    }

    .card-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--dash-text);
    }

    .card-title-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: linear-gradient(135deg, var(--dash-primary), var(--dash-primary-light));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1rem;
    }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: linear-gradient(135deg, var(--dash-primary), var(--dash-primary-light));
        color: white;
        text-decoration: none;
        border-radius: 50px;
        font-size: 0.875rem;
        font-weight: 600;
        transition: all 0.2s;
        box-shadow: 0 4px 12px rgba(46, 125, 50, 0.25);
    }

    .btn-edit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(46, 125, 50, 0.35);
    }

    .card-body {
        padding: 1.5rem;
    }

    .info-grid {
        display: grid;
        gap: 0;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 0;
        border-bottom: 1px solid var(--dash-border);
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        color: var(--dash-text-muted);
        font-size: 0.9rem;
        font-weight: 500;
    }

    .info-value {
        font-weight: 600;
        color: var(--dash-text);
        font-size: 0.95rem;
        text-align: right;
    }

    @media (max-width: 640px) {
        .profile-header {
            flex-direction: column;
            text-align: center;
        }

        .info-row {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.25rem;
        }

        .info-value {
            text-align: left;
        }
    }
    
    /* Chat styles handled by chat/style.css */
</style>
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-container">
        <a href="{{ path('app_dashboard', {'_locale': app.request.locale}) }}" class="back-link">
            ← Retour au tableau de bord
        </a>

        <a href="{{ path('app_networking', {'_locale': app.request.locale}) }}" class="back-link" style="margin-left: 1rem; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; padding: 0.6rem 1.5rem;">
            🌐 Mon Réseau Social
        </a>

        {% if app.flashes('success') %}
            <div style="padding: 1rem 1.5rem; background: linear-gradient(135deg, #d4f4dd 0%, #c6f6d5 100%); color: #276749; border: 2px solid #48bb78; border-radius: 12px; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem; animation: slideIn 0.4s ease-out;">
                <span style="font-size: 1.5rem;">✅</span>
                {% for message in app.flashes('success') %}
                    <span style="font-weight: 500;">{{ message }}</span>
                {% endfor %}
            </div>
        {% endif %}

        <div class="profile-header">
            <div class="profile-avatar">
                {% if user.imageProfil %}
                    <img src="{{ user.imageProfil }}" alt="{{ user.firstName }} {{ user.lastName }}" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;">
                {% else %}
                    {{ user.firstName|first }}{{ user.lastName|first }}
                {% endif %}
            </div>
            <div class="profile-info">
                <h1 class="profile-name">{{ user.firstName }} {{ user.lastName }}</h1>
                <p class="profile-email">{{ user.email }}</p>
            </div>
        </div>
       
        <div class="profile-card">
            <div class="card-header">
                <div class="card-title">
                    <span class="card-title-icon">👤</span>
                    Informations Personnelles
                </div>
                <a href="{{ path('app_profile_edit', {'_locale': app.request.locale}) }}" class="btn-edit">
                    ✏️ Modifier
                </a>
            </div>
            <div class="card-body">
                <div class="info-grid">
                    <div class="info-row">
                        <span class="info-label">Prénom</span>
                        <span class="info-value">{{ user.firstName|default('Non renseigné') }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Nom</span>
                        <span class="info-value">{{ user.lastName|default('Non renseigné') }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Email</span>
                        <span class="info-value">{{ user.email }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Téléphone</span>
                        <span class="info-value">{{ user.phone|default('Non renseigné') }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Date de Naissance</span>
                        <span class="info-value">{{ user.dateNaissance ? user.dateNaissance|date('d/m/Y') : 'Non renseigné' }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Adresse</span>
                        <span class="info-value">{{ user.adresse|default('Non renseigné') }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Ville</span>
                        <span class="info-value">{{ user.ville|default('Non renseigné') }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Code Postal</span>
                        <span class="info-value">{{ user.codePostal|default('Non renseigné') }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Pays</span>
                        <span class="info-value">{{ user.pays|default('Non renseigné') }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Location</span>
                        <span class="info-value">{{ user.location|default('Non renseigné') }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Statut du compte</span>
                        <span class="info-value">{{ user.status|capitalize }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Membre depuis</span>
                        <span class="info-value">{{ user.createdAt|date('d/m/Y') }}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Unified Chat & Voice Launcher -->
<button class="chat-toggle-btn unified-launcher" id="chat-toggle" aria-label="Chat & Voice Assistant" title="Chat & Voice Assistant">
    <svg class="icon-chat" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    <span class="mic-indicator" title="Voice Assistant available">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z"/>
            <path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"/>
        </svg>
    </span>
    <span class="notification-badge" style="display: none;">1</span>
</button>

<!-- Smart Chat Container -->
<div id="smart-chat-container">
    <!-- Chat Window -->
    <div class="chat-window" id="chat-window">
        <div class="chat-header">
            <div class="header-info">
                <div class="avatar-ring">
                    <img src="https://ui-avatars.com/api/?name=AI&background=6366f1&color=fff" alt="AI Agent">
                    <span class="status-dot"></span>
                </div>
                <div class="agent-details">
                    <span class="agent-name">Assistant WANNASNI</span>
                    <span class="agent-status" id="agent-status">Online & Ready</span>
                </div>
            </div>
            <!-- Persona Selector -->
            <select id="persona-select" class="persona-select" title="AI Persona">
                <option value="default">🤖 Assistant</option>
                <option value="health">🎩 Santé</option>
                <option value="nutrition">🥗 Nutrition</option>
                <option value="activity">🏃 Activités</option>
                <option value="service">🛠️ Services</option>
            </select>
            <div class="header-actions">
                <!-- Export Chat -->
                <button class="header-icon-btn" id="export-chat" title="Exporter Chat">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="7 10 12 15 17 10"></polyline>
                        <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                </button>
                <!-- Clear Chat -->
                <button class="header-icon-btn" id="clear-chat" title="Nouveau Chat">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 20h9"></path>
                        <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                    </svg>
                </button>
                <!-- Close -->
                <button class="close-btn" id="close-chat" aria-label="Fermer Chat">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 6L6 18M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Drag & Drop Zone -->
        <div class="drop-zone" id="drop-zone">
            <div class="drop-zone-content">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="17 8 12 3 7 8"></polyline>
                    <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                <span>Déposez un fichier ou une image ici</span>
            </div>
        </div>

        <div class="chat-messages" id="chat-messages">
            <div class="message bot-message welcome">
                <p>Bonjour! Je suis votre <strong>Assistant WANNASNI</strong> 🤖<br>
                   Vos fonctionnalités: 🔍 Recherche · 📋 Données Santé · 🏃 Activités · 🍽️ Nutrition</p>
                <span class="timestamp">Maintenant</span>
            </div>
        </div>

        <!-- Usage Stats -->
        <div class="usage-stats" id="usage-stats">
            <span>💬 <span id="msg-count">0</span> msgs</span>
            <span>📈 <span id="token-count">0</span> tokens</span>
        </div>

        <!-- Suggested Prompts -->
        <div class="suggested-prompts" id="suggested-prompts">
            <button class="prompt-chip" data-prompt="Comment puis-je améliorer ma santé?">📊 Santé</button>
            <button class="prompt-chip" data-prompt="Quelles activités me recommandez-vous?">🏃 Activités</button>
            <button class="prompt-chip" data-prompt="Aide-moi avec mon régime alimentaire">🥗 Nutrition</button>
            <button class="prompt-chip" data-prompt="Quels services puis-je demander?">🛠️ Services</button>
        </div>

        <div class="chat-input-area">
            <div class="typing-indicator" id="typing-indicator">
                <span></span><span></span><span></span>
            </div>
            <div id="image-preview-container" class="image-preview hidden">
                <img id="image-preview" src="" alt="Preview">
                <button id="remove-image" class="remove-btn">×</button>
            </div>

            <div class="input-wrapper">
                <input type="file" id="image-upload" accept="image/*" style="display: none;">
                <input type="file" id="file-upload" accept=".pdf,.csv,.txt,.json,.xml,.html,.md,.js,.py,.php,.css" style="display: none;">
                <button id="upload-btn" title="Télécharger Image">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
                    </svg>
                </button>
                <button id="file-upload-btn" title="Télécharger Fichier">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="12" y1="18" x2="12" y2="12"></line>
                        <line x1="9" y1="15" x2="15" y2="15"></line>
                    </svg>
                </button>
                <button id="mic-input-btn" title="Entrée vocale" class="mic-input-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
                        <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
                        <line x1="12" y1="19" x2="12" y2="23"></line>
                        <line x1="8" y1="23" x2="16" y2="23"></line>
                    </svg>
                </button>
                <button id="voice-call-btn" title="Appel vocal IA" class="voice-call-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                    </svg>
                </button>
                <input type="text" id="user-input" placeholder="Tapez votre message..." autocomplete="off">
                <button id="send-btn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Voice Call Overlay -->
<div class="voice-call-overlay" id="voice-call-overlay">
    <div class="voice-call-container">
        <!-- Animated Orb -->
        <div class="voice-orb-wrapper">
            <div class="voice-orb" id="voice-orb">
                <div class="orb-inner"></div>
            </div>
            <div class="voice-orb-ring ring-1"></div>
            <div class="voice-orb-ring ring-2"></div>
            <div class="voice-orb-ring ring-3"></div>
        </div>

        <!-- Status -->
        <div class="voice-call-status" id="voice-call-status">Connecting...</div>

        <!-- User Transcript -->
        <div class="voice-transcript" id="voice-transcript"></div>

        <!-- AI Response Text -->
        <div class="voice-ai-text" id="voice-ai-text"></div>

        <!-- Call Controls -->
        <div class="voice-call-controls">
            <button class="voice-control-btn mute-btn" id="voice-mute-btn" title="Mute/Unmute">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
                    <line x1="12" y1="19" x2="12" y2="23"></line>
                    <line x1="8" y1="23" x2="16" y2="23"></line>
                </svg>
            </button>

            <button class="voice-control-btn end-call-btn" id="voice-end-call" title="End Call">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M22 10.5c-1.6-1.6-3.7-2.5-5.9-2.5-1.4 0-2.7.3-3.9.8l1.5 1.5c.7-.2 1.5-.3 2.3-.3 1.6 0 3.1.6 4.2 1.8l1.8-1.8zM7 12.5c-.8 0-1.6.1-2.3.3L3.2 11.3C4.3 10.8 5.6 10.5 7 10.5c2.2 0 4.3.9 5.9 2.5l-1.8 1.8c-1.1-1.2-2.6-1.8-4.1-1.8zm5 3.5h5v5h-5v-5zm-10 0h5v5H2v-5z"/>
                </svg>
            </button>

            <button class="voice-control-btn speaker-btn" id="voice-speaker-btn" title="Speaker On/Off">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                    <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                    <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
                </svg>
            </button>
        </div>

        <!-- Permanent text input (always visible, like Siri/Google Assistant) -->
        <div class="voice-text-bar" id="voice-text-bar">
            <input type="text" id="voice-text-field" placeholder="Type or speak..." autocomplete="off">
            <button id="voice-text-send" title="Send">➤</button>
        </div>

        <!-- Call Timer -->
        <div class="voice-call-timer" id="voice-call-timer">00:00</div>
    </div>
</div>

<!-- Include Chat Styles and Scripts -->
<link rel="stylesheet" href="{{ asset('chat/style.css') }}?v=8">
<script src="{{ asset('chat/api.js') }}?v=8"></script>
<script src="{{ asset('chat/script.js') }}?v=8"></script>

{% endblock %}
