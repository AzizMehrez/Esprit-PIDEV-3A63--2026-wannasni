<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        body { font-family: DejaVu Sans, Arial, sans-serif; font-size: 12px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 1rem; }
        th, td { border: 1px solid #ddd; padding: 8px; }
        th { background: #f4f4f4; text-align: left; }
        h2 { text-align: center; }
    </style>
</head>
<body>
    <h2>Mes Traitements</h2>
    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Patient</th>
                <th>Médecin</th>
                <th>Médicaments</th>
                <th>Posologie</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            {% for r in records %}
            <tr>
                <td>{{ r.datePrescription ? r.datePrescription|date('Y-m-d') : '' }}</td>
                <td>{{ r.senior ? r.senior.getFullName() : '' }}</td>
                <td>{{ r.docteur ? r.docteur.getFullName() : '' }}</td>
                <td>{{ r.medicaments }}</td>
                <td>{{ r.posologie }}</td>
                <td>{{ r.statut }}</td>
            </tr>
            {% else %}
            <tr><td colspan="6">Aucun enregistrement</td></tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>