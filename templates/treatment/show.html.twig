{% extends 'base.html.twig' %}

{% block title %}Treatment{% endblock %}

{% block body %}
    <h1>Treatment</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ treatment.id }}</td>
            </tr>
            <tr>
                <th>SeniorId</th>
                <td>{{ treatment.seniorId }}</td>
            </tr>
            <tr>
                <th>DocteurId</th>
                <td>{{ treatment.docteurId }}</td>
            </tr>
            <tr>
                <th>DatePrescription</th>
                <td>{{ treatment.datePrescription ? treatment.datePrescription|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Medicaments</th>
                <td>{{ treatment.medicaments }}</td>
            </tr>
            <tr>
                <th>Posologie</th>
                <td>{{ treatment.posologie }}</td>
            </tr>
            <tr>
                <th>Frequence</th>
                <td>{{ treatment.frequence }}</td>
            </tr>
            <tr>
                <th>DateDebut</th>
                <td>{{ treatment.dateDebut ? treatment.dateDebut|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>DateFin</th>
                <td>{{ treatment.dateFin ? treatment.dateFin|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Instructions</th>
                <td>{{ treatment.instructions }}</td>
            </tr>
            <tr>
                <th>Renouvellements</th>
                <td>{{ treatment.renouvellements }}</td>
            </tr>
            <tr>
                <th>Statut</th>
                <td>{{ treatment.statut }}</td>
            </tr>
            <tr>
                <th>EffetsSecondaires</th>
                <td>{{ treatment.effetsSecondaires }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_treatment_index') }}">back to list</a>

    <a href="{{ path('app_treatment_edit', {'id': treatment.id}) }}">edit</a>

    {{ include('treatment/_delete_form.html.twig') }}
{% endblock %}
