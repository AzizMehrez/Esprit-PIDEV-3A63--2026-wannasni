{% extends 'base_back.html.twig' %}

{% block title %}Rapports Hebdomadaires{% endblock %}

{% block body %}
<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Rapports Nutritionnels Hebdomadaires</h1>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Liste des rapports récents</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Senior</th>
                            <th>Période</th>
                            <th>Conformité</th>
                            <th>Date Génération</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for report in reports %}
                            <tr>
                                <td>#{{ report.id }}</td>
                                <td>{{ report.senior.firstName }} {{ report.senior.lastName }}</td>
                                <td>
                                    {{ report.periodeDebut|date('d/m') }} - {{ report.periodeFin|date('d/m/Y') }}
                                </td>
                                <td>
                                    {% if report.tauxConformite >= 80 %}
                                        <span class="badge badge-success">{{ report.tauxConformite|round }}%</span>
                                    {% elseif report.tauxConformite >= 50 %}
                                        <span class="badge badge-warning">{{ report.tauxConformite|round }}%</span>
                                    {% else %}
                                        <span class="badge badge-danger">{{ report.tauxConformite|round }}%</span>
                                    {% endif %}
                                </td>
                                <td>{{ report.dateGeneration|date('d/m/Y H:i') }}</td>
                                <td>
                                    {% if report.estLu %}
                                        <span class="badge badge-secondary">Lu</span>
                                    {% else %}
                                        <span class="badge badge-primary">Nouveau</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <a href="{{ path('app_nutritionist_report_show', {'id': report.id}) }}" class="btn btn-info btn-sm">
                                        <i class="fas fa-eye"></i> Voir
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-center">Aucun rapport disponible.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
