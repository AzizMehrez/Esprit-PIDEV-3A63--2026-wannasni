{% extends 'base.html.twig' %}

{% block title %}Configuration Alertes – AssistIQ Admin{% endblock %}

{% block body %}
{% include 'back/_nav.html.twig' %}

<div class="bo-shell">
    <div class="bo-header">
        <div>
            <h1 class="bo-title">⚙️ Configuration des Alertes</h1>
            <p class="bo-subtitle">Paramétrer les règles et canaux de notification</p>
        </div>
        <div class="bo-actions">
            <a href="{{ path('app_admin_alerts') }}" class="bo-btn bo-btnSecondary">← Retour</a>
            <button class="bo-btn bo-btnSuccess">💾 Enregistrer</button>
        </div>
    </div>

    <div class="bo-grid cols-2">
        <!-- Canaux de Notification -->
        <div class="bo-card">
            <div class="bo-cardHeader">
                <div class="bo-cardTitle">📧 Canaux de Notification</div>
            </div>

            <form class="bo-form">
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px; background: rgba(16,185,129,.08); border-radius: 10px; margin-bottom: 12px;">
                    <div>
                        <div style="font-weight: 700;">📧 Email</div>
                        <div style="font-size: 13px; color: var(--bo-muted);">Envoyer les alertes par email</div>
                    </div>
                    <span class="bo-pill success">Activé</span>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px; background: rgba(16,185,129,.08); border-radius: 10px; margin-bottom: 12px;">
                    <div>
                        <div style="font-weight: 700;">📱 SMS</div>
                        <div style="font-size: 13px; color: var(--bo-muted);">Alertes critiques par SMS</div>
                    </div>
                    <span class="bo-pill success">Activé</span>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px; background: rgba(15,23,42,.05); border-radius: 10px; margin-bottom: 12px;">
                    <div>
                        <div style="font-weight: 700;">🔔 Push</div>
                        <div style="font-size: 13px; color: var(--bo-muted);">Notifications push navigateur</div>
                    </div>
                    <span class="bo-pill">Désactivé</span>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px; background: rgba(16,185,129,.08); border-radius: 10px;">
                    <div>
                        <div style="font-weight: 700;">👨‍👩‍👧 Transfert Famille</div>
                        <div style="font-size: 13px; color: var(--bo-muted);">Notifier automatiquement les proches</div>
                    </div>
                    <span class="bo-pill success">Activé</span>
                </div>
            </form>
        </div>

        <!-- Règles d'Escalade -->
        <div class="bo-card">
            <div class="bo-cardHeader">
                <div class="bo-cardTitle">⏱️ Règles d'Escalade</div>
            </div>

            <form class="bo-form">
                <div class="bo-field">
                    <label class="bo-label">Délai avant rappel (alertes non acquittées)</label>
                    <select class="bo-select">
                        <option>5 minutes</option>
                        <option selected>10 minutes</option>
                        <option>15 minutes</option>
                        <option>30 minutes</option>
                    </select>
                </div>

                <div class="bo-field">
                    <label class="bo-label">Escalade vers admin après</label>
                    <select class="bo-select">
                        <option>15 minutes</option>
                        <option selected>30 minutes</option>
                        <option>1 heure</option>
                    </select>
                </div>

                <div class="bo-field">
                    <label class="bo-label">Alertes critiques - Action immédiate</label>
                    <select class="bo-select">
                        <option selected>SMS + Email + Push</option>
                        <option>Email uniquement</option>
                        <option>SMS uniquement</option>
                    </select>
                </div>

                <div class="bo-field">
                    <label class="bo-label">Nombre max de rappels</label>
                    <input type="number" class="bo-input" value="3">
                </div>
            </form>
        </div>

        <!-- Types d'Alertes -->
        <div class="bo-card">
            <div class="bo-cardHeader">
                <div class="bo-cardTitle">📋 Types d'Alertes</div>
            </div>

            <div style="display: flex; flex-direction: column; gap: 12px;">
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 14px; border: 1px solid var(--bo-border); border-radius: 10px;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span style="font-size: 1.5rem;">🩺</span>
                        <div>
                            <div style="font-weight: 700;">Alertes Santé</div>
                            <div style="font-size: 13px; color: var(--bo-muted);">Tension, cœur, glycémie</div>
                        </div>
                    </div>
                    <span class="bo-pill success">Activé</span>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; padding: 14px; border: 1px solid var(--bo-border); border-radius: 10px;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span style="font-size: 1.5rem;">💊</span>
                        <div>
                            <div style="font-weight: 700;">Rappels Médicaments</div>
                            <div style="font-size: 13px; color: var(--bo-muted);">Prises manquées</div>
                        </div>
                    </div>
                    <span class="bo-pill success">Activé</span>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; padding: 14px; border: 1px solid var(--bo-border); border-radius: 10px;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span style="font-size: 1.5rem;">🚶</span>
                        <div>
                            <div style="font-weight: 700;">Alertes Activité</div>
                            <div style="font-size: 13px; color: var(--bo-muted);">Inactivité prolongée</div>
                        </div>
                    </div>
                    <span class="bo-pill success">Activé</span>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; padding: 14px; border: 1px solid var(--bo-border); border-radius: 10px;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span style="font-size: 1.5rem;">🆘</span>
                        <div>
                            <div style="font-weight: 700;">Alertes Urgence</div>
                            <div style="font-size: 13px; color: var(--bo-muted);">Chute, bouton SOS</div>
                        </div>
                    </div>
                    <span class="bo-pill success">Activé</span>
                </div>
            </div>
        </div>

        <!-- Horaires -->
        <div class="bo-card">
            <div class="bo-cardHeader">
                <div class="bo-cardTitle">🕐 Horaires de Notification</div>
            </div>

            <form class="bo-form">
                <div class="bo-field">
                    <label class="bo-label">Mode Ne Pas Déranger</label>
                    <div style="display: flex; gap: 12px;">
                        <input type="time" class="bo-input" value="22:00" style="flex: 1;">
                        <span style="align-self: center;">à</span>
                        <input type="time" class="bo-input" value="07:00" style="flex: 1;">
                    </div>
                    <small style="color: var(--bo-muted);">Les alertes non critiques seront retenues</small>
                </div>

                <div class="bo-field">
                    <label class="bo-label">Alertes critiques pendant NPD</label>
                    <select class="bo-select">
                        <option selected>Toujours notifier</option>
                        <option>Respecter NPD</option>
                    </select>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
