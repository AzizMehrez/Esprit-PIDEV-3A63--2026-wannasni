{% extends 'base.html.twig' %}

{% block title %}Gestion des Habitudes – AssistIQ Admin{% endblock %}

{% block body %}
{% include 'back/_nav.html.twig' %}

<div class="bo-shell">
    <div class="bo-header">
        <div>
            <h1 class="bo-title">🎯 Gestion des Habitudes</h1>
            <p class="bo-subtitle">Configurer les habitudes et recommandations intelligentes</p>
        </div>
        <div class="bo-actions">
            <a href="{{ path('app_admin_habits_templates') }}" class="bo-btn bo-btnSecondary">📋 Modèles</a>
            <a href="{{ path('app_admin_recommendations') }}" class="bo-btn bo-btnPrimary">🤖 Recommandations IA</a>
        </div>
    </div>

    <!-- Stats -->
    <div class="bo-stats">
        <div class="bo-stat">
            <div class="bo-statTop">
                <span class="bo-statLabel">Habitudes Actives</span>
                <div class="bo-statIcon primary">🎯</div>
            </div>
            <div class="bo-statValue">0</div>
            <div class="bo-statChange">En cours</div>
        </div>
        <div class="bo-stat">
            <div class="bo-statTop">
                <span class="bo-statLabel">Taux Completion Moy.</span>
                <div class="bo-statIcon success">✅</div>
            </div>
            <div class="bo-statValue">--%</div>
            <div class="bo-statChange">Aucune donnée</div>
        </div>
        <div class="bo-stat">
            <div class="bo-statTop">
                <span class="bo-statLabel">Séries en Cours</span>
                <div class="bo-statIcon warn">🔥</div>
            </div>
            <div class="bo-statValue">0</div>
            <div class="bo-statChange">Streaks actifs</div>
        </div>
        <div class="bo-stat">
            <div class="bo-statTop">
                <span class="bo-statLabel">Recommandations IA</span>
                <div class="bo-statIcon info">🤖</div>
            </div>
            <div class="bo-statValue">0</div>
            <div class="bo-statChange">Générées</div>
        </div>
    </div>

    <div class="bo-grid cols-2">
        <!-- Catégories d'Habitudes -->
        <div class="bo-card">
            <div class="bo-cardHeader">
                <div>
                    <div class="bo-cardTitle">📂 Catégories d'Habitudes</div>
                    <div class="bo-cardHint">Types d'habitudes disponibles</div>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;">
                <div style="padding: 20px; background: rgba(16,185,129,.08); border-radius: 12px; text-align: center;">
                    <div style="font-size: 2rem; margin-bottom: 8px;">💊</div>
                    <div style="font-weight: 700;">Médicaments</div>
                    <div style="font-size: 13px; color: var(--bo-muted);">0 actives</div>
                </div>
                <div style="padding: 20px; background: rgba(99,102,241,.08); border-radius: 12px; text-align: center;">
                    <div style="font-size: 2rem; margin-bottom: 8px;">🚶</div>
                    <div style="font-weight: 700;">Activité</div>
                    <div style="font-size: 13px; color: var(--bo-muted);">0 actives</div>
                </div>
                <div style="padding: 20px; background: rgba(245,158,11,.08); border-radius: 12px; text-align: center;">
                    <div style="font-size: 2rem; margin-bottom: 8px;">🍎</div>
                    <div style="font-weight: 700;">Nutrition</div>
                    <div style="font-size: 13px; color: var(--bo-muted);">0 actives</div>
                </div>
                <div style="padding: 20px; background: rgba(14,165,233,.08); border-radius: 12px; text-align: center;">
                    <div style="font-size: 2rem; margin-bottom: 8px;">😴</div>
                    <div style="font-weight: 700;">Sommeil</div>
                    <div style="font-size: 13px; color: var(--bo-muted);">0 actives</div>
                </div>
                <div style="padding: 20px; background: rgba(239,68,68,.08); border-radius: 12px; text-align: center;">
                    <div style="font-size: 2rem; margin-bottom: 8px;">💧</div>
                    <div style="font-weight: 700;">Hydratation</div>
                    <div style="font-size: 13px; color: var(--bo-muted);">0 actives</div>
                </div>
                <div style="padding: 20px; background: rgba(139,92,246,.08); border-radius: 12px; text-align: center;">
                    <div style="font-size: 2rem; margin-bottom: 8px;">🧠</div>
                    <div style="font-weight: 700;">Cognitif</div>
                    <div style="font-size: 13px; color: var(--bo-muted);">0 actives</div>
                </div>
            </div>
        </div>

        <!-- Habitudes Utilisateurs -->
        <div class="bo-card">
            <div class="bo-cardHeader">
                <div>
                    <div class="bo-cardTitle">📋 Habitudes Utilisateurs</div>
                    <div class="bo-cardHint">Habitudes suivies par les utilisateurs</div>
                </div>
            </div>

            <div class="bo-empty">
                <div class="bo-emptyIcon">🎯</div>
                <div class="bo-emptyTitle">Aucune Habitude</div>
                <div class="bo-emptyText">Les habitudes des utilisateurs apparaîtront ici</div>
            </div>
        </div>
    </div>

    <!-- Graphiques -->
    <div class="bo-grid cols-equal" style="margin-top: 24px;">
        <div class="bo-card">
            <div class="bo-cardHeader">
                <div class="bo-cardTitle">📈 Taux de Complétion (7 jours)</div>
            </div>
            <div class="bo-chart">
                📊 Graphique disponible avec des données
            </div>
        </div>

        <div class="bo-card">
            <div class="bo-cardHeader">
                <div class="bo-cardTitle">🔥 Distribution des Séries</div>
            </div>
            <div class="bo-chart">
                📊 Graphique disponible avec des données
            </div>
        </div>
    </div>
</div>
{% endblock %}
