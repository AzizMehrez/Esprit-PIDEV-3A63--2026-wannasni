    text-align: center;
    margin-bottom: 60px;
}

.section-badge {
    display: inline-block;
    background: rgba(102, 126, 234, 0.1);
    border: 1px solid rgba(102, 126, 234, 0.3);
    padding: 8px 20px;
    border-radius: 50px;
    font-size: 14px;
    margin-bottom: 20px;
}

