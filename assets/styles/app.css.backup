.about-card:hover {
    transform: translateY(-15px) scale(1.02);
    border-color: rgba(102, 126, 234, 0.6);
    box-shadow: 0 25px 70px rgba(102, 126, 234, 0.3);
}

.about-card:hover::before {
    opacity: 1;
}

.card-icon {
    font-size: 48px;
    margin-bottom: 20px;
    display: inline-block;
    animation: iconFloat 3s ease-in-out infinite;
    filter: drop-shadow(0 0 20px rgba(102, 126, 234, 0.5));
}

@keyframes iconFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(5deg); }
}

.about-card h3 {
    font-size: 24px;
    margin-bottom: 15px;
    background: linear-gradient(135deg, #ffffff 0%, #667eea 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.about-card p {
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
}

/* ========== FEATURES SECTION ========== */
.features-section {
    background: linear-gradient(180deg, #0a0a0a 0%, #1a0a2e 100%);
}

.features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
}

.feature-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 40px;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: translateY(50px) scale(0.9);
    position: relative;
    overflow: hidden;
}

.feature-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(102, 126, 234, 0.1) 0%, transparent 70%);
    opacity: 0;
    transition: all 0.8s;
    transform: scale(0);
}

.feature-card.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
}

.feature-card:hover {
    transform: translateY(-15px) scale(1.03);
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(102, 126, 234, 0.6);
    box-shadow: 0 20px 60px rgba(102, 126, 234, 0.3);
}

.feature-card:hover::before {
    opacity: 1;
    transform: scale(1) rotate(180deg);
}

.feature-icon {
    font-size: 48px;
    margin-bottom: 20px;
    display: inline-block;
    transition: all 0.5s;
    filter: drop-shadow(0 0 15px rgba(102, 126, 234, 0.4));
}

.feature-card:hover .feature-icon {
    transform: scale(1.2) rotate(360deg);
    filter: drop-shadow(0 0 25px rgba(102, 126, 234, 0.8));
}

.feature-card h3 {
    font-size: 22px;
    margin-bottom: 15px;
    transition: all 0.3s;
}

.feature-card:hover h3 {
    color: #667eea;
    text-shadow: 0 0 20px rgba(102, 126, 234, 0.5);
}

.feature-card p {
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
    transition: color 0.3s;
}

.feature-card:hover p {
    color: rgba(255, 255, 255, 0.9);
}

/* ========== SOLUTION SECTION ========== */
.solution-section {
    background: linear-gradient(180deg, #1a0a2e 0%, #0f0520 100%);
    position: relative;
    overflow: hidden;
}

.solution-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 20% 50%, rgba(102, 126, 234, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 50%, rgba(118, 75, 162, 0.1) 0%, transparent 50%);
    pointer-events: none;
}

.comparison-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 60px;
    max-width: 1400px;
    margin: 0 auto;
    align-items: stretch;
    position: relative;
    z-index: 1;
}

.comparison-side {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 30px;
    padding: 50px 40px;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
}

.comparison-side::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.5s;
}

.comparison-side:hover::before {
    opacity: 1;
}

.problem-side {
    border-color: rgba(255, 100, 100, 0.4);
}

.problem-side::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255, 50, 50, 0.05) 0%, transparent 100%);
    pointer-events: none;
}

.solution-side {
    border-color: rgba(100, 255, 180, 0.4);
}

.solution-side::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(50, 255, 150, 0.05) 0%, transparent 100%);
    pointer-events: none;
}

.comparison-side:hover {
    transform: translateY(-10px);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4);
}

.problem-side:hover {
    border-color: rgba(255, 100, 100, 0.6);
    box-shadow: 0 30px 80px rgba(255, 50, 50, 0.2);
}

.solution-side:hover {
    border-color: rgba(100, 255, 180, 0.6);
    box-shadow: 0 30px 80px rgba(50, 255, 150, 0.2);
}

.comparison-header {
    text-align: center;
    margin-bottom: 40px;
    position: relative;
    z-index: 1;
}

.comparison-icon {
    font-size: 64px;
    display: block;
    margin-bottom: 20px;
    animation: iconBounce 2s ease-in-out infinite;
    filter: drop-shadow(0 0 20px currentColor);
}

@keyframes iconBounce {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-10px) scale(1.1); }
}

.problem-side .comparison-icon {
    color: #ff6b6b;
}

.solution-side .comparison-icon {
    color: #51cf66;
}

.comparison-header h3 {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 10px;
    background: linear-gradient(135deg, #ffffff 0%, rgba(255, 255, 255, 0.7) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.problem-side .comparison-header h3 {
    color: #ff6b6b;
    text-shadow: 0 0 30px rgba(255, 107, 107, 0.3);
}

.solution-side .comparison-header h3 {
    color: #51cf66;
    text-shadow: 0 0 30px rgba(81, 207, 102, 0.3);
}

.comparison-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: relative;
    z-index: 1;
}

.comparison-item {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 24px 20px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: translateX(-30px);
    position: relative;
    overflow: hidden;
}

.comparison-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(180deg, transparent 0%, currentColor 50%, transparent 100%);
    opacity: 0;
    transition: opacity 0.5s;
}

.problem-side .comparison-item::before {
    color: #ff6b6b;
}

.solution-side .comparison-item::before {
    color: #51cf66;
}

.comparison-item:hover::before {
    opacity: 1;
}

.solution-side .comparison-item {
    transform: translateX(30px);
}

.comparison-item.visible {
    opacity: 1;
    transform: translateX(0);
}

.comparison-item:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateX(8px) scale(1.03);
    border-color: rgba(255, 255, 255, 0.2);
}

.problem-side .comparison-item:hover {
    box-shadow: 0 15px 40px rgba(255, 107, 107, 0.2), inset 0 0 20px rgba(255, 107, 107, 0.05);
    border-color: rgba(255, 107, 107, 0.3);
}

.solution-side .comparison-item:hover {
    transform: translateX(-8px) scale(1.03);
    box-shadow: 0 15px 40px rgba(81, 207, 102, 0.2), inset 0 0 20px rgba(81, 207, 102, 0.05);
    border-color: rgba(81, 207, 102, 0.3);
}

.item-icon {
    font-size: 40px;
    flex-shrink: 0;
    animation: iconPulse 2s ease-in-out infinite;
    filter: drop-shadow(0 0 10px currentColor);
    line-height: 1;
}

@keyframes iconPulse {
    0%, 100% { transform: scale(1); opacity: 0.9; }
    50% { transform: scale(1.15); opacity: 1; }
}

.item-content {
    flex: 1;
}

.item-content h4 {
    font-size: 20px;
    margin-bottom: 8px;
    font-weight: 600;
    transition: all 0.3s;
    color: #ffffff;
}

.comparison-item:hover .item-content h4 {
    color: #667eea;
    transform: translateX(5px);
}

.problem-side .comparison-item:hover .item-content h4 {
    color: #ff6b6b;
}

.solution-side .comparison-item:hover .item-content h4 {
    color: #51cf66;
}

.item-content p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 15px;
    line-height: 1.6;
    transition: color 0.3s;
}

.comparison-item:hover .item-content p {
    color: rgba(255, 255, 255, 0.95);
}

.comparison-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.divider-line {
    width: 2px;
    height: 100%;
    background: linear-gradient(180deg, transparent 0%, #667eea 50%, transparent 100%);
}

.divider-icon {
    font-size: 48px;
    color: #667eea;
    margin: 20px 0;
}

/* ========== HOW IT WORKS SECTION ========== */
.how-it-works-section {
    background: linear-gradient(180deg, #1a0a2e 0%, #0a0a0a 100%);
}

.steps-container {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 1200px;
    margin: 0 auto;
}

.step-card {
    flex: 1;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 40px;
    text-align: center;
    position: relative;
    transition: all 0.3s;
    opacity: 0;
    transform: scale(0.9);
}

.step-card.visible {
    opacity: 1;
    transform: scale(1);
}

.step-card:hover {
    transform: scale(1.05);
    border-color: rgba(102, 126, 234, 0.5);
}

.step-number {
    position: absolute;
    top: -20px;
    left: 20px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: bold;
}

.step-icon {
    font-size: 64px;
    margin-bottom: 20px;
}

.step-card h3 {
    font-size: 24px;
    margin-bottom: 15px;
}

.step-card p {
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
}

.step-connector {
    width: 80px;
    height: 2px;
    background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
    position: relative;
}

.step-connector::after {
    content: '→';
    position: absolute;
    right: -15px;
    top: 50%;
    transform: translateY(-50%);
    color: #667eea;
    font-size: 24px;
}

/* ========== BENEFITS SECTION ========== */
.benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
}

.benefit-item {
    text-align: center;
    padding: 40px 20px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    transition: all 0.3s;
    opacity: 0;
    transform: translateY(50px);
}

.benefit-item.visible {
    opacity: 1;
    transform: translateY(0);
}

.benefit-item:hover {
    transform: translateY(-10px);
    background: rgba(102, 126, 234, 0.1);
    border-color: rgba(102, 126, 234, 0.5);
}

.benefit-stat {
    font-size: 56px;
    font-weight: 800;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 10px;
}

.benefit-label {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 10px;
}

.benefit-item p {
    color: rgba(255, 255, 255, 0.6);
    font-size: 14px;
}

/* ========== CTA SECTION ========== */
.cta-section {
    padding: 100px 20px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    position: relative;
    overflow: hidden;
}

.cta-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg width="100" height="100" xmlns="http://www.w3.org/2000/svg"><circle cx="50" cy="50" r="40" fill="rgba(255,255,255,0.05)"/></svg>');
    opacity: 0.1;
}

.cta-container {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
}

.cta-content {
    text-align: center;
}

.cta-title {
    font-size: 48px;
    font-weight: 800;
    margin-bottom: 20px;
    color: white;
}

.cta-text {
    font-size: 20px;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 40px;
}

.cta-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
    margin-bottom: 20px;
}

.btn-cta-primary {
    background: white;
    color: #667eea;
    border: none;
    padding: 18px 40px;
    border-radius: 50px;
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.btn-cta-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
}

.btn-cta-secondary {
    background: transparent;
    color: white;
    border: 2px solid white;
    padding: 16px 40px;
    border-radius: 50px;
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
}

.btn-cta-secondary:hover {
    background: white;
    color: #667eea;
}

.cta-note {
    color: rgba(255, 255, 255, 0.8);
    font-size: 14px;
}

/* ========== FOOTER ========== */
.footer {
    background: #0a0a0a;
    padding: 60px 20px 20px;
}

.footer-container {
    max-width: 1200px;
    margin: 0 auto;
}

.footer-content {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 60px;
    margin-bottom: 40px;
}

.footer-brand {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 24px;
    font-weight: bold;
}

.footer-brain {
    font-size: 32px;
}

.footer-name {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.footer-tagline {
    color: rgba(255, 255, 255, 0.6);
    font-size: 14px;
}

.footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
}

.footer-column h4 {
    font-size: 16px;
    margin-bottom: 15px;
    color: white;
}

.footer-column ul {
    list-style: none;
}

.footer-column li {
    margin-bottom: 10px;
}

.footer-column a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.3s;
}

.footer-column a:hover {
    color: #667eea;
}

.footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 30px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.footer-bottom p {
    color: rgba(255, 255, 255, 0.5);
    font-size: 14px;
}

.footer-socials {
    display: flex;
    gap: 20px;
}

.social-link {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.3s;
}

.social-link:hover {
    color: #667eea;
}

/* ========== RESPONSIVE DESIGN ========== */
@media (max-width: 1024px) {
    .hero-title {
        font-size: 56px;
    }

    .about-content,
    .features-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .comparison-container {
        grid-template-columns: 1fr;
    }

    .comparison-divider {
        flex-direction: row;
        margin: 20px 0;
    }

    .divider-line {
        width: 100%;
        height: 2px;
    }

    .divider-icon {
        transform: rotate(90deg);
    }

    .steps-container {
        flex-direction: column;
    }

    .step-connector {
        width: 2px;
        height: 60px;
        margin: 20px 0;
    }

    .step-connector::after {
        content: '↓';
        right: auto;
        top: auto;
        bottom: -20px;
        left: 50%;
        transform: translateX(-50%);
    }
}

@media (max-width: 768px) {
    .nav-menu {
        display: none;
    }

    .hero-title {
        font-size: 42px;
    }

    .hero-buttons {
        flex-direction: column;
    }

    .hero-stats {
        flex-direction: column;
        gap: 30px;
    }

    .about-content,
    .features-grid,
    .benefits-grid {
        grid-template-columns: 1fr;
    }

    .section-title {
        font-size: 36px;
    }

    .footer-content {
        grid-template-columns: 1fr;
    }

    .footer-links {
        grid-template-columns: 1fr;
    }

    .footer-bottom {
        flex-direction: column;
        gap: 20px;
    }
}

/* ========== SECTION STYLES ========== */
.about-section,
.features-section,
.solution-section,
.how-it-works-section,
.benefits-section {
    padding: 100px 20px;
    position: relative;
}

.section-header {
    text-align: center;
    margin-bottom: 60px;
}

.section-badge {
    display: inline-block;
    background: rgba(102, 126, 234, 0.1);
    border: 1px solid rgba(102, 126, 234, 0.3);
    padding: 8px 20px;
    border-radius: 50px;
    font-size: 14px;
    margin-bottom: 20px;
}

.section-title {
    font-size: 48px;
    font-weight: 800;
    margin-bottom: 15px;
    background: linear-gradient(135deg, #ffffff 0%, #667eea 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.section-subtitle {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.6);
}

/* ========== ABOUT SECTION ========== */
.about-content {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
}

.about-card {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 40px;
    text-align: center;
    transition: all 0.3s;
    opacity: 0;
    transform: translateY(50px);
}

.about-card.visible {
    opacity: 1;
    transform: translateY(0);
}

.about-card:hover {
    transform: translateY(-10px);
    border-color: rgba(102, 126, 234, 0.5);
    box-shadow: 0 20px 60px rgba(102, 126, 234, 0.2);
}

.card-icon {
    font-size: 48px;
    margin-bottom: 20px;
}

.about-card h3 {
    font-size: 24px;
    margin-bottom: 15px;
}

.about-card p {
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
}

/* ========== FEATURES SECTION ========== */
.features-section {
    background: linear-gradient(180deg, #0a0a0a 0%, #1a0a2e 100%);
}

.features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
}

.feature-card {
    background: rgba(255, 255, 255, 0.05);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 40px;
    transition: all 0.3s;
    opacity: 0;
    transform: translateY(50px);
}

.feature-card.visible {
    opacity: 1;
    transform: translateY(0);
}

.feature-card:hover {
    transform: translateY(-10px);
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(102, 126, 234, 0.5);
}

.feature-icon {
    font-size: 48px;
    margin-bottom: 20px;
}

.feature-card h3 {
    font-size: 22px;
    margin-bottom: 15px;
}

.feature-card p {
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
}

/* ========== SOLUTION SECTION ========== */
.comparison-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
    align-items: center;
}

.comparison-side {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 40px;
    transition: all 0.3s;
}

.problem-side {
    border-color: rgba(255, 100, 100, 0.3);
}

.solution-side {
    border-color: rgba(100, 255, 100, 0.3);
}

.comparison-header {
    text-align: center;
    margin-bottom: 30px;
}

.comparison-icon {
    font-size: 48px;
    display: block;
    margin-bottom: 15px;
}

.comparison-header h3 {
    font-size: 28px;
}

.comparison-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.comparison-item {
    display: flex;
    align-items: flex-start;
    gap: 15px;
    padding: 15px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 10px;
    transition: all 0.3s;
}

.comparison-item:hover {
    background: rgba(255, 255, 255, 0.05);
    transform: translateX(5px);
}

.item-icon {
    font-size: 32px;
    flex-shrink: 0;
}

.item-content h4 {
    font-size: 18px;
    margin-bottom: 5px;
}

.item-content p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 15px;
    line-height: 1.6;
    transition: color 0.3s;
}

.comparison-item:hover .item-content p {
    color: rgba(255, 255, 255, 0.95);
}

.comparison-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 20px 0;
}

.divider-line {
    width: 3px;
    height: 100%;
    background: linear-gradient(180deg, 
        transparent 0%, 
        rgba(102, 126, 234, 0.3) 20%,
        rgba(118, 75, 162, 0.6) 50%,
        rgba(102, 126, 234, 0.3) 80%,
        transparent 100%);
    position: relative;
    animation: lineGlow 3s ease-in-out infinite;
}

@keyframes lineGlow {
    0%, 100% { 
        opacity: 0.6;
        box-shadow: 0 0 10px rgba(102, 126, 234, 0.3);
    }
    50% { 
        opacity: 1;
        box-shadow: 0 0 30px rgba(102, 126, 234, 0.8), 0 0 60px rgba(118, 75, 162, 0.4);
    }
}

.divider-icon {
    font-size: 56px;
    color: #667eea;
    margin: 20px 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: arrowPulse 2s ease-in-out infinite;
    filter: drop-shadow(0 0 20px rgba(102, 126, 234, 0.8));
    position: relative;
    z-index: 2;
}

@keyframes arrowPulse {
    0%, 100% { 
        transform: translateX(0) scale(1);
        filter: drop-shadow(0 0 10px rgba(102, 126, 234, 0.5));
    }
    50% { 
        transform: translateX(10px) scale(1.2);
        filter: drop-shadow(0 0 30px rgba(102, 126, 234, 1));
    }
}

.divider-icon::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    background: radial-gradient(circle, rgba(102, 126, 234, 0.2) 0%, transparent 70%);
    border-radius: 50%;
    animation: ripple 2s ease-in-out infinite;
}

@keyframes ripple {
    0%, 100% {
        width: 60px;
        height: 60px;
        opacity: 0.4;
    }
    50% {
        width: 100px;
        height: 100px;
        opacity: 0.8;
    }
}

/* ========== HOW IT WORKS SECTION ========== */
.how-it-works-section {
    background: linear-gradient(180deg, #1a0a2e 0%, #0a0a0a 100%);
}

.steps-container {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 1200px;
    margin: 0 auto;
}

.step-card {
    flex: 1;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 40px;
    text-align: center;
    position: relative;
    transition: all 0.3s;
    opacity: 0;
    transform: scale(0.9);
}

.step-card.visible {
    opacity: 1;
    transform: scale(1);
}

.step-card:hover {
    transform: scale(1.05);
    border-color: rgba(102, 126, 234, 0.5);
}

.step-number {
    position: absolute;
    top: -20px;
    left: 20px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: bold;
}

.step-icon {
    font-size: 64px;
    margin-bottom: 20px;
}

.step-card h3 {
    font-size: 24px;
    margin-bottom: 15px;
}

.step-card p {
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
}

.step-connector {
    width: 80px;
    height: 2px;
    background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
    position: relative;
}

.step-connector::after {
    content: '→';
    position: absolute;
    right: -15px;
    top: 50%;
    transform: translateY(-50%);
    color: #667eea;
    font-size: 24px;
}

/* ========== BENEFITS SECTION ========== */
.benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
}

.benefit-item {
    text-align: center;
    padding: 40px 20px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    transition: all 0.3s;
    opacity: 0;
    transform: translateY(50px);
}

.benefit-item.visible {
    opacity: 1;
    transform: translateY(0);
}

.benefit-item:hover {
    transform: translateY(-10px);
    background: rgba(102, 126, 234, 0.1);
    border-color: rgba(102, 126, 234, 0.5);
}

.benefit-stat {
    font-size: 56px;
    font-weight: 800;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 10px;
}

.benefit-label {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 10px;
}

.benefit-item p {
    color: rgba(255, 255, 255, 0.6);
    font-size: 14px;
}

/* ========== CTA SECTION ========== */
.cta-section {
    padding: 100px 20px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    position: relative;
    overflow: hidden;
}

.cta-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg width="100" height="100" xmlns="http://www.w3.org/2000/svg"><circle cx="50" cy="50" r="40" fill="rgba(255,255,255,0.05)"/></svg>');
    opacity: 0.1;
}

.cta-container {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
}

.cta-content {
    text-align: center;
}

.cta-title {
    font-size: 48px;
    font-weight: 800;
    margin-bottom: 20px;
    color: white;
}

.cta-text {
    font-size: 20px;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 40px;
}

.cta-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
    margin-bottom: 20px;
}

.btn-cta-primary {
    background: white;
    color: #667eea;
    border: none;
    padding: 18px 40px;
    border-radius: 50px;
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.btn-cta-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
}

.btn-cta-secondary {
    background: transparent;
    color: white;
    border: 2px solid white;
    padding: 16px 40px;
    border-radius: 50px;
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
}

.btn-cta-secondary:hover {
    background: white;
    color: #667eea;
}

.cta-note {
    color: rgba(255, 255, 255, 0.8);
    font-size: 14px;
}

/* ========== FOOTER ========== */
.footer {
    background: #0a0a0a;
    padding: 60px 20px 20px;
}

.footer-container {
    max-width: 1200px;
    margin: 0 auto;
}

.footer-content {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 60px;
    margin-bottom: 40px;
}

.footer-brand {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 24px;
    font-weight: bold;
}

.footer-brain {
    font-size: 32px;
}

.footer-name {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.footer-tagline {
    color: rgba(255, 255, 255, 0.6);
    font-size: 14px;
}

.footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
}

.footer-column h4 {
    font-size: 16px;
    margin-bottom: 15px;
    color: white;
}

.footer-column ul {
    list-style: none;
}

.footer-column li {
    margin-bottom: 10px;
}

.footer-column a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.3s;
}

.footer-column a:hover {
    color: #667eea;
}

.footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 30px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.footer-bottom p {
    color: rgba(255, 255, 255, 0.5);
    font-size: 14px;
}

.footer-socials {
    display: flex;
    gap: 20px;
}

.social-link {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.3s;
}

.social-link:hover {
    color: #667eea;
}

/* ========== RESPONSIVE DESIGN ========== */
@media (max-width: 1024px) {
    .hero-title {
        font-size: 56px;
    }

    .about-content,
    .features-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .comparison-container {
        grid-template-columns: 1fr;
    }

    .comparison-divider {
        flex-direction: row;
        margin: 20px 0;
    }

    .divider-line {
        width: 100%;
        height: 2px;
    }

    .divider-icon {
        transform: rotate(90deg);
    }

    .steps-container {
        flex-direction: column;
    }

    .step-connector {
        width: 2px;
        height: 60px;
        margin: 20px 0;
    }

    .step-connector::after {
        content: '↓';
        right: auto;
        top: auto;
        bottom: -20px;
        left: 50%;
        transform: translateX(-50%);
    }
}

@media (max-width: 768px) {
    .nav-menu {
        display: none;
    }

    .hero-title {
        font-size: 42px;
    }

    .hero-buttons {
        flex-direction: column;
    }

    .hero-stats {
        flex-direction: column;
        gap: 30px;
    }

    .about-content,
    .features-grid,
    .benefits-grid {
        grid-template-columns: 1fr;
    }

    .section-title {
        font-size: 36px;
    }

    .footer-content {
        grid-template-columns: 1fr;
    }

    .footer-links {
        grid-template-columns: 1fr;
    }

    .footer-bottom {
        flex-direction: column;
        gap: 20px;
    }
}

/* ========== ADVANCED ANIMATIONS & EFFECTS ========== */

/* Animated background patterns for sections */
.features-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 20% 30%, rgba(102, 126, 234, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 80% 70%, rgba(118, 75, 162, 0.08) 0%, transparent 50%);
    animation: bgPulse 20s ease-in-out infinite;
    pointer-events: none;
}

.solution-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.03) 0%, transparent 50%),
                linear-gradient(-45deg, rgba(118, 75, 162, 0.03) 0%, transparent 50%);
    animation: gradientRotate 15s linear infinite;
    pointer-events: none;
}

.benefits-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: repeating-linear-gradient(45deg, rgba(102, 126, 234, 0.02) 0px, rgba(102, 126, 234, 0.02) 2px, transparent 2px, transparent 10px),
                      repeating-linear-gradient(-45deg, rgba(118, 75, 162, 0.02) 0px, rgba(118, 75, 162, 0.02) 2px, transparent 2px, transparent 10px);
    animation: patternSlide 30s linear infinite;
    pointer-events: none;
}

@keyframes bgPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.15); }
}

@keyframes gradientRotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

@keyframes patternSlide {
    0% { background-position: 0 0; }
    100% { background-position: 50px 50px; }
}

/* Enhanced feature cards with gradient border */
.feature-card::after {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: 22px;
    background: linear-gradient(135deg, #667eea, #764ba2, #f093fb);
    opacity: 0;
    z-index: -1;
    transition: opacity 0.5s;
    background-size: 300% 300%;
    animation: gradientFlow 5s ease-in-out infinite;
}

.feature-card:hover::after {
    opacity: 0.3;
}

@keyframes gradientFlow {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
}

/* Parallax hover effect for steps */
.step-card:hover .step-number {
    transform: scale(1.3) rotate(360deg);
    box-shadow: 0 20px 60px rgba(102, 126, 234, 0.5);
}

.step-card:hover .step-content h3 {
    transform: translateX(15px);
    color: #667eea;
    transition: all 0.5s ease;
}

.step-card:hover .step-content p {
    transform: translateX(20px);
    transition: all 0.5s ease 0.1s;
}

/* Floating particles */
.section-header::before {
    content: "";
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 6px;
    height: 6px;
    background: #667eea;
    border-radius: 50%;
    box-shadow: 0 0 20px rgba(102, 126, 234, 0.5), 0 0 40px rgba(102, 126, 234, 0.3), 0 0 60px rgba(102, 126, 234, 0.1);
    animation: particleFloat 4s ease-in-out infinite;
}

.section-header::after {
    content: "";
    position: absolute;
    top: -30px;
    right: 30%;
    width: 4px;
    height: 4px;
    background: #764ba2;
    border-radius: 50%;
    box-shadow: 0 0 15px rgba(118, 75, 162, 0.5);
    animation: particleFloat 5s ease-in-out infinite 1s;
}

@keyframes particleFloat {
    0%, 100% {
        transform: translateY(0) translateX(0);
        opacity: 0.5;
    }
    50% {
        transform: translateY(-20px) translateX(10px);
        opacity: 1;
    }
}

/* Glowing text effect */
.benefit-item:hover .benefit-stat {
    animation: textGlow 1.5s ease-in-out infinite;
    transform: scale(1.1);
}

@keyframes textGlow {
    0%, 100% {
        text-shadow: 0 0 10px rgba(102, 126, 234, 0.5), 0 0 20px rgba(102, 126, 234, 0.3);
    }
    50% {
        text-shadow: 0 0 20px rgba(102, 126, 234, 0.8), 0 0 40px rgba(102, 126, 234, 0.5), 0 0 60px rgba(102, 126, 234, 0.3);
    }
}

/* Ripple effect */
.comparison-item::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(102, 126, 234, 0.3) 0%, transparent 70%);
    transform: translate(-50%, -50%);
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
}

.comparison-item:hover::before {
    width: 300px;
    height: 300px;
}

/* Staggered reveal */
.feature-card:nth-child(1) { animation: revealCard 0.8s ease-out 0.1s backwards; }
.feature-card:nth-child(2) { animation: revealCard 0.8s ease-out 0.2s backwards; }
.feature-card:nth-child(3) { animation: revealCard 0.8s ease-out 0.3s backwards; }
.feature-card:nth-child(4) { animation: revealCard 0.8s ease-out 0.4s backwards; }
.feature-card:nth-child(5) { animation: revealCard 0.8s ease-out 0.5s backwards; }
.feature-card:nth-child(6) { animation: revealCard 0.8s ease-out 0.6s backwards; }

@keyframes revealCard {
    from {
        opacity: 0;
        transform: translateY(50px) rotateX(-20deg) scale(0.9);
    }
    to {
        opacity: 1;
        transform: translateY(0) rotateX(0) scale(1);
    }
}

/* Advanced button border animation */
.btn-cta-primary::after {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 54px;
    background: linear-gradient(45deg, #667eea, #764ba2, #f093fb, #667eea);
    background-size: 300% 300%;
    z-index: -1;
    opacity: 0;
    animation: borderRotate 4s linear infinite;
    transition: opacity 0.3s;
}

.btn-cta-primary:hover::after {
    opacity: 1;
}

@keyframes borderRotate {
    0% { background-position: 0% 50%; }
    100% { background-position: 300% 50%; }
}

.btn-cta-secondary::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50px;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.2), rgba(118, 75, 162, 0.2));
    opacity: 0;
    transition: all 0.4s;
}

.btn-cta-secondary:hover::before {
    opacity: 1;
    transform: scale(1.05);
}

/* Magnetic cursor effect */
.feature-card:hover {
    transform: translateY(-12px) scale(1.03);
}

.about-card:hover .card-icon {
    transform: translateY(-15px) rotate(360deg) scale(1.2);
    transition: all 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* Enhanced sparkle */
@keyframes sparkleEnhanced {
    0%, 100% {
        opacity: 0;
        transform: scale(0) rotate(0deg);
    }
    50% {
        opacity: 1;
        transform: scale(1) rotate(180deg);
    }
}

/* 3D flip effect */
@keyframes cardFlip {
    0% { transform: rotateY(0) translateY(0); }
    50% { transform: rotateY(5deg) translateY(-15px); }
    100% { transform: rotateY(0) translateY(-12px); }
}

/* Wave footer */
.footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 100px;
    background: linear-gradient(135deg, transparent 0%, rgba(102, 126, 234, 0.05) 50%, transparent 100%);
    animation: waveMove 5s ease-in-out infinite;
}

@keyframes waveMove {
    0%, 100% { transform: translateX(-10%) scaleX(1); }
    50% { transform: translateX(10%) scaleX(1.05); }
}

/* CTA pulse */
.cta-content {
    animation: contentPulse 4s ease-in-out infinite;
}

@keyframes contentPulse {
    0%, 100% {
        box-shadow: 0 0 30px rgba(102, 126, 234, 0);
    }
    50% {
        box-shadow: 0 0 60px rgba(102, 126, 234, 0.15);
    }
}
